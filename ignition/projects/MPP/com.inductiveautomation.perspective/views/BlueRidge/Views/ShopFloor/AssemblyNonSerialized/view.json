                                  "config": {
                                    "expression": "if({view.custom.container.ClosureMethod} = \"ByCount\", \"By Count\", if({view.custom.container.ClosureMethod} = \"ByWeight\", \"By Weight\", if({view.custom.container.ClosureMethod} = \"ByVision\", \"By Vision\", if(isNull({view.custom.container.ClosureMethod}), \"-\", {view.custom.container.ClosureMethod}))))"
                                  },
                                  "type": "expr"
