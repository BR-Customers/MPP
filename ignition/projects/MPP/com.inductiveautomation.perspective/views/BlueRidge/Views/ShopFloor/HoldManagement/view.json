                    "onActionPerformed": {
                      "type": "script",
                      "scope": "G",
                      "config": {
                        "script": "\td = self.view.custom.placeDraft\n\tlotName = (d.get(\"lotName\") or \"\").strip()\n\tcontainerId = BlueRidge.Common.Util.toIntOrNone(d.get(\"containerId\"))\n\tholdTypeCodeId = d.get(\"holdTypeCodeId\")\n\treason = (d.get(\"reason\") or \"\").strip() or None\n\tif holdTypeCodeId is None:\n\t\tBlueRidge.Common.Ui.notifyResult({\"Status\": False, \"Message\": \"Select a hold type.\"}, \"Place Hold\")\n\t\treturn\n\tif not lotName and containerId is None:\n\t\tBlueRidge.Common.Ui.notifyResult({\"Status\": False, \"Message\": \"Enter a LOT name or a Container Id.\"}, \"Place Hold\")\n\t\treturn\n\tif lotName and containerId is not None:\n\t\tBlueRidge.Common.Ui.notifyResult({\"Status\": False, \"Message\": \"Enter only one of LOT name or Container Id, not both.\"}, \"Place Hold\")\n\t\treturn\n\tlotId = None\n\tif lotName:\n\t\tlot = BlueRidge.Lots.Lot.getByName(lotName)\n\t\tif not lot or lot.get(\"Id\") is None:\n\t\t\tBlueRidge.Common.Ui.notifyResult({\"Status\": False, \"Message\": \"No LOT found named '\" + lotName + \"'.\"}, \"Place Hold\")\n\t\t\treturn\n\t\tlotId = lot.get(\"Id\")\n\tresult = BlueRidge.Quality.Hold.place(holdTypeCodeId, lotId=lotId, containerId=containerId, reason=reason)\n\tBlueRidge.Common.Ui.notifyResult(result, \"Hold placed\")\n\tif result and result.get(\"Status\"):\n\t\tself.view.custom.placeDraft = {\"lotName\": \"\", \"containerId\": \"\", \"holdTypeCodeId\": None, \"reason\": \"\"}\n\t\tself.view.custom.refreshToken = (self.view.custom.refreshToken or 0) + 1"
