                      "config": {
                        "script": "\td \u003d self.view.custom.placeDraft\n\tlotName \u003d (d.get(\"lotName\") or \"\").strip()\n\tcontainerId \u003d BlueRidge.Common.Util.toIntOrNone(d.get(\"containerId\"))\n\tholdTypeCodeId \u003d d.get(\"holdTypeCodeId\")\n\treason \u003d (d.get(\"reason\") or \"\").strip() or None\n\tif holdTypeCodeId is None:\n\t\tBlueRidge.Common.Ui.notifyResult({\"Status\": False, \"Message\": \"Select a hold type.\"}, \"Place Hold\")\n\t\treturn\n\tif not lotName and containerId is None:\n\t\tBlueRidge.Common.Ui.notifyResult({\"Status\": False, \"Message\": \"Enter a LOT name or a Container Id.\"}, \"Place Hold\")\n\t\treturn\n\tif lotName and containerId is not None:\n\t\tBlueRidge.Common.Ui.notifyResult({\"Status\": False, \"Message\": \"Enter only one of LOT name or Container Id, not both.\"}, \"Place Hold\")\n\t\treturn\n\tlotId \u003d None\n\tif lotName:\n\t\tlot \u003d BlueRidge.Lots.Lot.getByName(lotName)\n\t\tif not lot or lot.get(\"Id\") is None:\n\t\t\tBlueRidge.Common.Ui.notifyResult({\"Status\": False, \"Message\": \"No LOT found named \u0027\" + lotName + \"\u0027.\"}, \"Place Hold\")\n\t\t\treturn\n\t\tlotId \u003d lot.get(\"Id\")\n\tresult \u003d BlueRidge.Quality.Hold.place(holdTypeCodeId, lotId\u003dlotId, containerId\u003dcontainerId, reason\u003dreason)\n\tBlueRidge.Common.Ui.notifyResult(result, \"Hold placed\")\n\tif result and result.get(\"Status\"):\n\t\tself.view.custom.placeDraft \u003d {\"lotName\": \"\", \"containerId\": \"\", \"holdTypeCodeId\": None, \"reason\": \"\"}\n\t\tself.view.custom.refreshToken \u003d (self.view.custom.refreshToken or 0) + 1"
