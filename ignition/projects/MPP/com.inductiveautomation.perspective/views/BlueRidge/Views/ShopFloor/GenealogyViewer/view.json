{
  "custom": {
    "ancestors": [],
    "descendants": [],
    "direction": "Both",
    "nodes": [],
    "query": "",
    "rootLot": {
      "Id": null,
      "LotName": "",
      "ItemId": null,
      "ItemCode": "",
      "CurrentQty": null,
      "LotStatus": ""
    }
  },
  "params": {},
  "propConfig": {},
  "props": {
    "defaultSize": {
      "height": 800,
      "width": 1280
    }
  },
  "root": {
    "type": "ia.container.flex",
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "classes": "canvas",
        "padding": "0"
      }
    },
    "scripts": {
      "customMethods": [
        {
          "name": "walk",
          "params": [],
          "script": "\tq = self.view.custom.query\n\tif not q:\n\t\treturn\n\troot = BlueRidge.Lots.Lot.get(lotName=q)\n\tif not root:\n\t\tBlueRidge.Common.Notify.toast(\"No LOT found\", \"No LOT named %s\" % q, \"warning\")\n\t\treturn\n\tnodes = BlueRidge.Lots.Lot.getGenealogyTree(root[\"Id\"], self.view.custom.direction)\n\tself.view.custom.rootLot = root\n\tself.view.custom.nodes = nodes\n\tself.view.custom.ancestors = [n for n in nodes if n.get(\"Direction\") == \"Ancestor\"]\n\tself.view.custom.descendants = [n for n in nodes if n.get(\"Direction\") == \"Descendant\"]"
        }
      ],
      "messageHandlers": null,
      "extensionFunctions": null
    },
    "children": [
      {
        "type": "ia.container.flex",
        "meta": {
          "name": "PageHeader"
        },
        "position": {
          "basis": "auto",
          "shrink": 0
        },
        "props": {
          "alignItems": "center",
          "style": {
            "background": "var(--mpp-surface-card)",
            "borderBottom": "1px solid var(--mpp-border-subtle)",
            "gap": "0",
            "padding": "16px 24px 12px 24px"
          },
          "direction": "column"
        },
        "children": [
          {
            "type": "ia.display.label",
            "meta": {
              "name": "PageTitle"
            },
            "position": {
              "basis": "auto",
              "shrink": 0
            },
            "props": {
              "text": "Genealogy Lookup",
              "style": {
                "color": "var(--mpp-text-primary)",
                "fontSize": "22px",
                "fontWeight": "600",
                "marginBottom": "4px"
              }
            }
          },
          {
            "type": "ia.display.label",
            "meta": {
              "name": "ElevatedBadge"
            },
            "position": {
              "basis": "auto",
              "shrink": 0
            },
            "props": {
              "text": "Elevated · Honda audit query surface",
              "style": {
                "color": "var(--mpp-text-secondary)",
                "fontSize": "13px"
              }
            }
          }
        ]
      },
      {
        "type": "ia.container.flex",
        "meta": {
          "name": "SearchBar"
        },
        "position": {
          "basis": "auto",
          "shrink": 0
        },
        "props": {
          "alignItems": "flex-end",
          "style": {
            "background": "var(--mpp-surface-card)",
            "borderBottom": "1px solid var(--mpp-border-subtle)",
            "gap": "12px",
            "padding": "12px 24px"
          }
        },
        "children": [
          {
            "type": "ia.container.flex",
            "meta": {
              "name": "QueryFieldWrap"
            },
            "position": {
              "grow": 1
            },
            "props": {
              "direction": "column",
              "style": {
                "gap": "4px"
              }
            },
            "children": [
              {
                "type": "ia.display.label",
                "meta": {
                  "name": "QueryLabel"
                },
                "props": {
                  "text": "LotName",
                  "style": {
                    "color": "var(--mpp-text-secondary)",
                    "fontSize": "11px",
                    "fontWeight": "600",
                    "letterSpacing": "0.05em",
                    "textTransform": "uppercase"
                  }
                }
              },
              {
                "type": "ia.input.text-field",
                "meta": {
                  "name": "QueryField"
                },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "type": "property",
                      "config": {
                        "bidirectional": true,
                        "path": "view.custom.query"
                      }
                    }
                  }
                },
                "props": {
                  "placeholder": "MESL1710935…",
                  "style": {
                    "classes": "pf-field-input pf-field-input-mono",
                    "width": "100%"
                  }
                },
                "events": {
                  "dom": {
                    "onBlur": {
                      "type": "script",
                      "scope": "G",
                      "config": {
                        "script": "\tself.view.rootContainer.walk()"
                      }
                    }
                  }
                }
              }
            ]
          },
          {
            "type": "ia.container.flex",
            "meta": {
              "name": "DirectionFieldWrap"
            },
            "position": {
              "basis": "220px",
              "shrink": 0
            },
            "props": {
              "direction": "column",
              "style": {
                "gap": "4px"
              }
            },
            "children": [
              {
                "type": "ia.display.label",
                "meta": {
                  "name": "DirectionLabel"
                },
                "props": {
                  "text": "Direction",
                  "style": {
                    "color": "var(--mpp-text-secondary)",
                    "fontSize": "11px",
                    "fontWeight": "600",
                    "letterSpacing": "0.05em",
                    "textTransform": "uppercase"
                  }
                }
              },
              {
                "type": "ia.input.dropdown",
                "meta": {
                  "name": "DirectionDropdown"
                },
                "propConfig": {
                  "props.value": {
                    "binding": {
                      "type": "property",
                      "config": {
                        "bidirectional": true,
                        "path": "view.custom.direction"
                      }
                    }
                  }
                },
                "props": {
                  "options": [
                    {
                      "label": "Both (ancestors + descendants)",
                      "value": "Both"
                    },
                    {
                      "label": "Ancestors only",
                      "value": "Ancestors"
                    },
                    {
                      "label": "Descendants only",
                      "value": "Descendants"
                    }
                  ],
                  "style": {
                    "width": "100%"
                  }
                }
              }
            ]
          },
          {
            "type": "ia.input.button",
            "meta": {
              "name": "WalkButton"
            },
            "position": {
              "basis": "auto",
              "shrink": 0
            },
            "props": {
              "text": "Walk Tree",
              "style": {
                "classes": "pf-btn pf-btn-primary",
                "height": "38px",
                "minWidth": "110px"
              }
            },
            "events": {
              "component": {
                "onActionPerformed": {
                  "type": "script",
                  "scope": "G",
                  "config": {
                    "script": "\tself.view.rootContainer.walk()"
                  }
                }
              }
            }
          }
        ]
      },
      {
        "type": "ia.container.flex",
        "meta": {
          "name": "ContentArea"
        },
        "position": {
          "grow": 1
        },
        "props": {
          "direction": "column",
          "style": {
            "overflowY": "auto",
            "padding": "16px 24px"
          }
        },
        "children": [
          {
            "type": "ia.container.flex",
            "meta": {
              "name": "ResultHeader"
            },
            "position": {
              "basis": "auto",
              "shrink": 0
            },
            "propConfig": {
              "position.display": {
                "binding": {
                  "type": "expr",
                  "config": {
                    "expression": "len({view.custom.nodes}) > 0"
                  }
                }
              }
            },
            "props": {
              "alignItems": "center",
              "style": {
                "background": "var(--mpp-surface-card)",
                "borderBottom": "1px solid var(--mpp-border-subtle)",
                "borderRadius": "6px 6px 0 0",
                "gap": "8px",
                "justifyContent": "space-between",
                "padding": "10px 14px"
              }
            },
            "children": [
              {
                "type": "ia.display.label",
                "meta": {
                  "name": "TreeHeaderLabel"
                },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "type": "expr",
                      "config": {
                        "expression": "\"Tree for \" + if(isNull({view.custom.rootLot.LotName}), \"\", {view.custom.rootLot.LotName}) + \" · \" + toStr(len({view.custom.nodes})) + \" nodes\""
                      }
                    }
                  }
                },
                "props": {
                  "style": {
                    "color": "var(--mpp-text-primary)",
                    "fontSize": "15px",
                    "fontWeight": "600"
                  }
                }
              },
              {
                "type": "ia.display.label",
                "meta": {
                  "name": "AncestorCount"
                },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "type": "expr",
                      "config": {
                        "expression": "toStr(len({view.custom.ancestors})) + \" ancestors · \" + toStr(len({view.custom.descendants})) + \" descendants\""
                      }
                    }
                  }
                },
                "props": {
                  "style": {
                    "color": "var(--mpp-text-secondary)",
                    "fontSize": "13px"
                  }
                }
              }
            ]
          },
          {
            "type": "ia.container.flex",
            "meta": {
              "name": "TreePanel"
            },
            "position": {
              "basis": "auto",
              "shrink": 0
            },
            "propConfig": {
              "position.display": {
                "binding": {
                  "type": "expr",
                  "config": {
                    "expression": "len({view.custom.nodes}) > 0"
                  }
                }
              }
            },
            "props": {
              "direction": "column",
              "style": {
                "background": "var(--mpp-surface-card)",
                "border": "1px solid var(--mpp-border-subtle)",
                "borderRadius": "0 0 6px 6px",
                "gap": "0",
                "marginBottom": "16px",
                "overflow": "hidden"
              }
            },
            "children": [
              {
                "type": "ia.display.label",
                "meta": {
                  "name": "AncestorsSectionLabel"
                },
                "position": {
                  "basis": "auto",
                  "shrink": 0
                },
                "propConfig": {
                  "position.display": {
                    "binding": {
                      "type": "expr",
                      "config": {
                        "expression": "len({view.custom.ancestors}) > 0"
                      }
                    }
                  }
                },
                "props": {
                  "text": "Ancestors",
                  "style": {
                    "background": "var(--mpp-surface-alt)",
                    "borderBottom": "1px solid var(--mpp-border-subtle)",
                    "color": "var(--mpp-text-secondary)",
                    "fontSize": "11px",
                    "fontWeight": "600",
                    "letterSpacing": "0.05em",
                    "padding": "6px 12px",
                    "textTransform": "uppercase"
                  }
                }
              },
              {
                "type": "ia.display.flex-repeater",
                "meta": {
                  "name": "AncestorsRepeater"
                },
                "position": {
                  "basis": "auto",
                  "shrink": 0
                },
                "propConfig": {
                  "props.instances": {
                    "binding": {
                      "type": "property",
                      "config": {
                        "path": "view.custom.ancestors"
                      },
                      "transforms": [
                        {
                          "type": "script",
                          "code": "\treturn [\n\t\t{\n\t\t\t\"LotId\":    r.get(\"LotId\"),\n\t\t\t\"LotName\":  r.get(\"LotName\") or \"\",\n\t\t\t\"ItemCode\": r.get(\"ItemCode\") or \"\",\n\t\t\t\"Depth\":    r.get(\"Depth\") or 0,\n\t\t\t\"Direction\": r.get(\"Direction\") or \"\"\n\t\t}\n\t\tfor r in (value or [])\n\t]"
                        }
                      ]
                    }
                  },
                  "position.display": {
                    "binding": {
                      "type": "expr",
                      "config": {
                        "expression": "len({view.custom.ancestors}) > 0"
                      }
                    }
                  }
                },
                "props": {
                  "direction": "column",
                  "elementPosition": {
                    "basis": "auto",
                    "shrink": 0
                  },
                  "path": "BlueRidge/Views/ShopFloor/GenealogyViewer/_NodeRow",
                  "style": {
                    "gap": "0"
                  },
                  "useDefaultViewHeight": false,
                  "useDefaultViewWidth": false
                }
              },
              {
                "type": "ia.container.flex",
                "meta": {
                  "name": "RootRow"
                },
                "position": {
                  "basis": "auto",
                  "shrink": 0
                },
                "props": {
                  "alignItems": "center",
                  "style": {
                    "background": "var(--mpp-surface-selected)",
                    "borderBottom": "1px solid var(--mpp-border-subtle)",
                    "borderTop": "1px solid var(--mpp-border-subtle)",
                    "gap": "12px",
                    "padding": "10px 12px"
                  }
                },
                "children": [
                  {
                    "type": "ia.display.label",
                    "meta": {
                      "name": "RootIcon"
                    },
                    "position": {
                      "basis": "auto",
                      "shrink": 0
                    },
                    "props": {
                      "text": "⊙",
                      "style": {
                        "background": "var(--mpp-accent)",
                        "borderRadius": "50%",
                        "color": "var(--mpp-text-on-accent)",
                        "fontSize": "13px",
                        "fontWeight": "700",
                        "height": "30px",
                        "lineHeight": "30px",
                        "textAlign": "center",
                        "width": "30px"
                      }
                    }
                  },
                  {
                    "type": "ia.display.label",
                    "meta": {
                      "name": "RootLotName"
                    },
                    "position": {
                      "grow": 1
                    },
                    "propConfig": {
                      "props.text": {
                        "binding": {
                          "type": "expr",
                          "config": {
                            "expression": "if(isNull({view.custom.rootLot.LotName}), \"\", {view.custom.rootLot.LotName}) + if(isNull({view.custom.rootLot.ItemCode}), \"\", \" · \" + {view.custom.rootLot.ItemCode}) + \" · search root\""
                          }
                        }
                      }
                    },
                    "props": {
                      "style": {
                        "color": "var(--mpp-text-primary)",
                        "fontFamily": "monospace",
