                    "borderTop": "1px solid var(--mpp-border-subtle)",
                    "color": "var(--mpp-text-secondary)",
                    "fontSize": "11px",
                    "fontWeight": "600",
                    "letterSpacing": "0.05em",
                    "padding": "6px 12px",
                    "textTransform": "uppercase"
                  }
                }
              },
              {
                "type": "ia.display.flex-repeater",
                "meta": {
                  "name": "DescendantsRepeater"
                },
                "position": {
                  "basis": "auto",
                  "shrink": 0
                },
                "propConfig": {
                  "props.instances": {
                    "binding": {
                      "type": "property",
                      "config": {
                        "path": "view.custom.descendants"
