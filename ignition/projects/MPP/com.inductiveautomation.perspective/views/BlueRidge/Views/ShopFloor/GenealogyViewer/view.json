            "props": {
              "alignItems": "center",
              "direction": "column",
              "justify": "center",
              "style": {
                "gap": "8px",
                "padding": "48px 24px"
              }
            },
            "children": [
              {
                "type": "ia.display.label",
                "meta": {
                  "name": "EmptyIcon"
                },
                "props": {
                  "text": "⊙",
                  "style": {
                    "color": "var(--mpp-text-secondary)",
                    "fontSize": "36px",
                    "opacity": "0.4"
                  }
