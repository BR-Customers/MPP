      "ToolTypeCode": "",
      "CellLocationId": null,
      "AssignedAt": null,
      "AssignedByUserId": null,
      "Notes": null
    },
    "cavityOptions": [],
    "itemOptions": [],
    "shiftTally": [],
    "activeLotId": null,
    "editDraft": {
      "cavityNote": null,
      "itemId": null,
      "pieceCount": null,
      "scannedLtt": "",
      "toolCavityId": null,
      "weight": null,
      "weightUomId": null
    },
    "peersThisSession": [],
    "selectedLotId": null,
    "tallyCavityId": null
  },
  "params": {
    "areaId": null
  },
  "propConfig": {
    "custom.activeTool": {
      "binding": {
        "config": {
          "expression": "runScript(\"BlueRidge.Parts.Tool.getMountedToolForCellOrEmpty\", 0, {session.custom.cell.locationId})"
        },
        "type": "expr"
      }
    },
    "custom.cavityOptions": {
      "binding": {
        "config": {
          "expression": "runScript(\"BlueRidge.Parts.Tool.getCavitiesForDropdown\", 0, {view.custom.activeTool.ToolId})"
        },
        "type": "expr"
      }
    },
    "custom.itemOptions": {
      "binding": {
        "config": {
          "expression": "runScript(\"BlueRidge.Parts.Item.getEligibleForLocationDropdown\", 0, {session.custom.cell.locationId})"
        },
        "type": "expr"
      }
    },
    "custom.manufacturedOriginId": {
      "binding": {
        "config": {
          "expression": "runScript(\"BlueRidge.Lots.Lot.getOriginTypeIdByCode\", 0, \"Manufactured\")"
        },
        "type": "expr"
      }
    },
    "custom.shiftTally": {
      "binding": {
        "config": {
          "expression": "runScript(\"BlueRidge.Lots.Lot.getShiftCavityTally\", 0, {view.custom.activeTool.ToolId})"
        },
        "type": "expr"
      },
      "onChange": {
        "enabled": true,
        "script": "\trows = BlueRidge.Common.Util.extractQualifiedValues(self.view.custom.shiftTally) or []\n\tids = [r.get(\"ToolCavityId\") for r in rows]\n\tcur = self.view.custom.tallyCavityId\n\tif cur is None or cur not in ids:\n\t\tself.view.custom.tallyCavityId = BlueRidge.Lots.Lot.defaultShiftCavityId(rows)"
      }
    }
  },
  "props": {
    "defaultSize": {
      "width": 1280
    }
  },
