{
  "custom": {
    "cells": [],
    "selectedCellId": null
  },
  "params": {},
  "propConfig": {
    "custom.cells": {
      "binding": {
        "config": {
          "expression": "runScript(\"BlueRidge.Location.Terminal.getContextCellsForDropdown\", 0, {session.custom.terminal.terminalLocationId}, \"Trim Press\")"
        },
        "type": "expr"
      }
    }
  },
  "props": {},
  "root": {
    "type": "ia.container.flex",
    "meta": {
      "name": "root"
    },
    "props": {
      "style": {
        "classes": "canvas"
      },
      "direction": "column"
    },
    "children": [
      {
        "type": "ia.container.flex",
        "meta": {
          "name": "PickerBar"
        },
        "position": {
          "shrink": 0
        },
        "props": {
          "direction": "row",
          "alignItems": "center",
          "style": {
            "classes": "pf-terminal-cell-context",
            "gap": "12px"
          }
        },
        "children": [
          {
            "type": "ia.display.label",
            "meta": {
              "name": "PickerLabel"
            },
            "props": {
              "text": "Select press",
              "style": {
                "classes": "pf-cell-context-label"
              }
            }
          },
          {
            "events": {
              "component": {
                "onActionPerformed": {
                  "config": {
                    "script": "\tself.view.rootContainer.applyCell(self.props.value)"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "CellDropdown"
            },
            "position": {
              "basis": "320px"
            },
            "propConfig": {
              "props.options": {
                "binding": {
                  "config": {
                    "path": "view.custom.cells"
                  },
                  "transforms": [
                    {
                      "code": "\tcells = BlueRidge.Common.Util.extractQualifiedValues(value) or []\n\treturn [{\"label\": c.get(\"label\"), \"value\": c.get(\"value\")} for c in cells]",
                      "type": "script"
                    }
                  ],
                  "type": "property"
                }
              },
              "props.value": {
                "binding": {
                  "config": {
                    "bidirectional": true,
                    "path": "view.custom.selectedCellId"
                  },
                  "type": "property"
                }
              }
            },
            "props": {
              "placeholder": {
                "text": "Scan or pick a cell"
              }
            },
            "type": "ia.input.dropdown"
          }
        ]
      },
      {
        "type": "ia.display.view",
        "meta": {
          "name": "BodyEmbed"
        },
        "position": {
          "grow": 1,
          "basis": "0"
        },
        "props": {
          "path": "BlueRidge/Views/ShopFloor/TrimBody"
        }
      }
    ],
    "scripts": {
      "customMethods": [
        {
          "name": "applyCell",
          "params": [
            "cellId"
          ],
          "script": "\tcellId = BlueRidge.Common.Util.extractQualifiedValues(cellId)\n\trow = BlueRidge.Location.Location.findCellById(self.view.custom.cells, cellId)\n\tif row is None:\n\t\treturn\n\tself.view.custom.selectedCellId = row.get(\"value\")\n\tself.session.custom.cell = {\"locationId\": row.get(\"value\"), \"code\": row.get(\"code\") or \"\", \"name\": row.get(\"name\") or \"\"}"
        },
        {
          "name": "seedSelectedCell",
          "params": [],
          "script": "\tc = self.session.custom.cell\n\tif c and c.get(\"locationId\"):\n\t\tself.view.custom.selectedCellId = c.get(\"locationId\")"
        }
      ],
      "messageHandlers": [],
      "extensionFunctions": null
    },
    "events": {
      "system": {
        "onStartup": {
          "type": "script",
          "scope": "G",
          "config": {
            "script": "\ttry:\n\t\tself.session.custom.presence.policy = \"strict\"\n\texcept:\n\t\tself.session.custom.presence = {\"policy\": \"strict\"}\n\tself.seedSelectedCell()"
          }
        }
      }
    }
  }
}
