{
  "custom": {},
  "params": {},
  "propConfig": {},
  "props": {},
  "root": {
    "type": "ia.container.flex",
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "classes": "canvas",
        "height": "100%"
      }
    },
    "children": [
      {
        "type": "ia.container.tab",
        "meta": {
          "name": "TabContainer"
        },
        "position": {
          "grow": 1,
          "basis": "0"
        },
        "props": {
          "currentTabIndex": 0,
          "menuType": "modern",
          "tabs": [
            {
              "text": "Check In",
              "runWhileHidden": true,
              "disabled": false
            },
            {
              "text": "Inspect",
              "runWhileHidden": true,
              "disabled": false
            },
            {
              "text": "Check Out",
              "runWhileHidden": true,
              "disabled": false
            }
          ],
          "menuStyle": {
            "classes": "tab-strip"
          },
          "contentStyle": {
            "classes": "tab-content-fill"
          },
          "tabStyle": {
            "active": {
              "classes": "tab-item tab-item-active"
            },
            "inactive": {
              "classes": "tab-item"
            },
            "disabled": {
              "classes": "tab-item"
            }
          }
        },
        "children": [
          {
            "type": "ia.display.view",
            "meta": {
              "name": "CheckInTab"
            },
            "position": {
              "grow": 1
            },
            "props": {
              "path": "BlueRidge/Views/ShopFloor/ReceivingDock",
              "useDefaultViewHeight": false,
              "useDefaultViewWidth": false
            }
          },
          {
            "type": "ia.container.flex",
            "meta": {
              "name": "InspectTab"
            },
            "position": {
              "grow": 1
            },
            "props": {
              "direction": "column",
              "alignItems": "stretch",
              "style": {
                "gap": "12px",
                "padding": "24px",
                "overflowY": "auto"
              }
            },
            "children": [
              {
                "type": "ia.display.label",
                "meta": {
                  "name": "InspectHeader"
                },
                "props": {
                  "text": "Inspect - received LOTs awaiting inspection. Record a QualitySample per LOT; a PASS enables Check Out.",
                  "style": {
                    "fontWeight": 600,
                    "fontSize": "16px"
                  }
                }
              },
              {
                "type": "ia.display.label",
                "meta": {
                  "name": "InspectQueue"
                },
                "props": {
                  "text": "(loading...)",
                  "style": {
                    "whiteSpace": "pre-line",
                    "fontFamily": "monospace",
                    "fontSize": "13px"
                  }
                },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "type": "expr",
                      "config": {
                        "expression": "if(!isNull({session.custom.cell.locationId}), runScript(\"BlueRidge.Lots.Lot.getInspectionQueue\", 0, {session.custom.cell.locationId}, false), \"\")"
                      },
                      "transforms": [
                        {
                          "type": "script",
                          "code": "\trows = value or []\n\tif not rows:\n\t\treturn \"(no LOTs awaiting inspection at this station)\"\n\tlines = []\n\tfor r in rows:\n\t\tres = r.get(\"LatestInspectionResult\") or \"not inspected\"\n\t\tlines.append(\"%s  -  %s, %s pcs  -  vendor %s  [%s]\" % (r.get(\"LotName\") or \"?\", r.get(\"ItemPartNumber\") or \"?\", r.get(\"PieceCount\") or 0, r.get(\"VendorLotNumber\") or \"-\", res))\n\treturn \"\n\".join(lines)"
                        }
                      ]
                    }
                  }
                }
              }
            ]
          },
          {
            "type": "ia.display.view",
            "meta": {
              "name": "CheckOutTab"
            },
            "position": {
              "grow": 1
            },
            "props": {
              "path": "BlueRidge/Views/ShopFloor/AssemblyNonSerialized",
              "useDefaultViewHeight": false,
              "useDefaultViewWidth": false
            }
          }
        ]
      }
    ]
  }
}