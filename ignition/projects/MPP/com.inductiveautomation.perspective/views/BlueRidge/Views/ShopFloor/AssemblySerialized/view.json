{
  "custom": {
    "container": {
      "Id": null,
      "ItemPartNumber": "",
      "ItemDescription": "",
      "AccumulatedParts": 0,
      "TargetParts": 0,
      "ClosedTrays": 0,
      "TraysPerContainer": 0,
      "PartsPerTray": 0,
      "IsSerialized": false
    },
    "refreshToken": 0
  },
  "params": {},
  "propConfig": {
    "custom.container": {
      "binding": {
        "config": {
          "expression": "if({view.custom.refreshToken} >= 0 && !isNull({session.custom.cell.locationId}), runScript(\"BlueRidge.Lots.Container.getOpenByCell\", 0, {session.custom.cell.locationId}, {view.custom.refreshToken}), \"\")"
        },
        "transforms": [
          {
            "code": "\trows = value or []\n\tr = rows[0] if rows else {}\n\treturn {\"Id\": r.get(\"Id\"), \"ItemPartNumber\": r.get(\"ItemPartNumber\") or \"\", \"ItemDescription\": r.get(\"ItemDescription\") or \"\", \"AccumulatedParts\": r.get(\"AccumulatedParts\") or 0, \"TargetParts\": r.get(\"TargetParts\") or 0, \"ClosedTrays\": r.get(\"ClosedTrays\") or 0, \"TraysPerContainer\": r.get(\"TraysPerContainer\") or 0, \"PartsPerTray\": r.get(\"PartsPerTray\") or 0, \"IsSerialized\": r.get(\"IsSerialized\") or False}",
            "type": "script"
          }
        ],
        "type": "expr"
      }
    }
  },
  "props": {
    "defaultSize": {
      "height": 800,
      "width": 1280
    }
  },
  "root": {
    "type": "ia.container.flex",
    "meta": {
