            "type": "ia.input.button",
            "meta": {
              "name": "BtnSetCrt"
            },
            "position": {
              "basis": "auto",
              "shrink": 0
            },
            "propConfig": {
              "position.display": {
                "binding": {
                  "type": "expr",
                  "config": {
                    "expression": "!isNull({view.custom.lot.Id}) && !coalesce({view.custom.lot.CrtActive}, false)"
                  }
                }
              }
            },
            "props": {
              "text": "Set CRT",
              "style": {
                "classes": "pf-btn pf-btn-elevated"
              },
              "toolTipText": "Place this LOT on a Controlled Run Tag (200% downstream inspection prompt)."
            },
            "events": {
              "component": {
                "onActionPerformed": {
                  "type": "script",
                  "scope": "G",
                  "config": {
                    "script": "\tterm = self.session.custom.terminal\n\tresult = BlueRidge.Quality.Crt.setCrt(self.view.params.lotId, self.session.custom.appUserId, term.terminalLocationId if term else None)\n\tBlueRidge.Common.Ui.notifyResult(result, \"CRT\", result.get(\"Message\"))\n\tself.view.rootContainer.load()"
                  }
                }
              }
            }
          },
