              "component": {
                "onActionPerformed": {
                  "type": "script",
                  "scope": "G",
                  "config": {
                    "script": "\tsystem.perspective.navigate(\"/\")"
                  }
                }
              }
            }
          },
          {
            "type": "ia.input.button",
            "meta": {
              "name": "BtnLotSearch"
            },
            "position": {
              "basis": "auto",
              "shrink": 0
            },
            "props": {
              "text": "LOT Search",
              "style": {
                "classes": "pf-btn pf-btn-secondary"
              },
              "toolTipText": "Return to LOT Search to look up another LOT."
            },
            "events": {
              "component": {
                "onActionPerformed": {
                  "type": "script",
                  "scope": "G",
                  "config": {
                    "script": "\tsystem.perspective.navigate(\"/shop-floor/lot-search\")"
                  }
                }
              }
            }
          },
          {
            "type": "ia.input.button",
            "meta": {
              "name": "BtnReprint"
            },
            "position": {
              "basis": "auto",
              "shrink": 0
            },
            "props": {
              "text": "Reprint LTT",
              "style": {
                "classes": "pf-btn pf-btn-secondary"
              },
              "toolTipText": "Reprint the LTT label for this LOT (e.g. if it was damaged or did not print)."
            },
            "events": {
              "component": {
                "onActionPerformed": {
                  "type": "script",
                  "scope": "G",
                  "config": {
                    "script": "\tself.view.rootContainer.reprintLabel()"
                  }
                }
              }
            }
          },
          {
            "type": "ia.input.button",
            "meta": {
              "name": "BtnInspections"
            },
            "position": {
              "basis": "auto",
              "shrink": 0
            },
            "props": {
              "text": "Inspections",
              "style": {
                "classes": "pf-btn pf-btn-secondary"
              },
              "toolTipText": "Open the Inspection terminal to record a quality sample against a LOT."
            },
            "events": {
              "component": {
                "onActionPerformed": {
                  "type": "script",
                  "scope": "G",
                  "config": {
                    "script": "\tsystem.perspective.navigate(\"/shop-floor/inspection\")"
                  }
                }
              }
            }
          },
