                  "scope": "G",
                  "config": {
                    "script": "\tterm = self.session.custom.terminal\n\tresult = BlueRidge.Quality.Crt.clearCrt(self.view.params.lotId, self.session.custom.appUserId, term.terminalLocationId if term else None)\n\tBlueRidge.Common.Ui.notifyResult(result, \"CRT\", result.get(\"Message\"))\n\tself.view.rootContainer.load()"
                  }
                }
              }
            }
