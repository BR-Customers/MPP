{
  "custom": {
    "dialogOpen": false,
    "error": "",
    "initials": ""
  },
  "params": {
    "returnTo": ""
  },
  "propConfig": {},
  "props": {
    "defaultSize": {
      "height": 800,
      "width": 1280
    }
  },
  "root": {
    "type": "ia.container.flex",
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "alignItems": "center",
      "justify": "center",
      "style": {
        "classes": "canvas",
        "gap": "20px",
        "padding": "32px"
      }
    },
    "scripts": {
      "customMethods": [
        {
          "name": "appendKey",
          "params": [
            "ch"
          ],
          "script": "\tself.view.custom.error = \"\"\n\tself.view.custom.initials = (self.view.custom.initials or \"\") + ch"
        },
        {
          "name": "clearKeys",
          "params": [],
          "script": "\tself.view.custom.error = \"\"\n\tself.view.custom.initials = \"\""
        },
        {
          "name": "backspaceKey",
          "params": [],
          "script": "\tself.view.custom.error = \"\"\n\tself.view.custom.initials = (self.view.custom.initials or \"\")[:-1]"
        },
        {
          "name": "loginAs",
          "params": [
            "appUserId",
            "initials",
            "displayName",
            "ignitionRole"
          ],
          "script": "\tself.session.custom.user = {\"appUserId\": appUserId, \"initials\": initials, \"displayName\": displayName, \"ignitionRole\": ignitionRole}\n\tself.session.custom.appUserId = appUserId\n\tdest = self.view.params.returnTo or self.session.custom.terminal.defaultScreen or \"/\"\n\tsystem.perspective.navigate(dest)"
        },
        {
          "name": "submitInitials",
          "params": [],
          "script": "\tif self.view.custom.dialogOpen:\n\t\treturn\n\ttext = (self.view.custom.initials or \"\").strip().upper()\n\tif not text:\n\t\tself.view.custom.error = \"\"\n\t\treturn\n\tu = BlueRidge.Location.AppUser.getByInitials(text)\n\tif u is None:\n\t\tself.view.custom.dialogOpen = True\n\t\tsystem.perspective.openPopup(id=\"mpp-unknown-initials\", view=\"BlueRidge/Components/Popups/UnknownInitials\", params={\"initials\": text, \"replyMessage\": \"unknownInitialsResult\", \"popupId\": \"mpp-unknown-initials\"}, modal=True, showCloseIcon=False)\n\t\treturn\n\tself.loginAs(u[\"Id\"], u[\"Initials\"], u[\"DisplayName\"], u.get(\"IgnitionRole\"))"
        }
      ],
      "messageHandlers": [
        {
          "messageType": "initialsKeyPressed",
          "pageScope": true,
          "sessionScope": false,
          "viewScope": false,
          "script": "\ta = payload.get(\"action\") if payload else None\n\tif a == \"key\":\n\t\tself.appendKey(payload.get(\"key\"))\n\telif a == \"space\":\n\t\tself.appendKey(\" \")\n\telif a == \"backspace\":\n\t\tself.backspaceKey()\n\telif a == \"clear\":\n\t\tself.clearKeys()\n\telif a == \"enter\":\n\t\tself.submitInitials()"
        },
        {
          "messageType": "unknownInitialsResult",
          "pageScope": true,
          "sessionScope": false,
          "viewScope": false,
          "script": "\taction = payload.get(\"action\") if payload else None\n\tif action == \"register\":\n\t\tsystem.perspective.openPopup(id=\"mpp-register-operator\", view=\"BlueRidge/Components/Popups/RegisterOperator\", params={\"initials\": (self.view.custom.initials or \"\").strip().upper(), \"replyMessage\": \"registerOperatorResult\", \"popupId\": \"mpp-register-operator\"}, modal=True, showCloseIcon=False)\n\telif action == \"dismiss\":\n\t\tself.view.custom.dialogOpen = False\n\t\tself.clearKeys()"
        },
        {
          "messageType": "registerOperatorResult",
          "pageScope": true,
          "sessionScope": false,
          "viewScope": false,
          "script": "\taction = payload.get(\"action\") if payload else None\n\tself.view.custom.dialogOpen = False\n\tif action == \"registered\":\n\t\tself.loginAs(payload.get(\"appUserId\"), payload.get(\"initials\"), payload.get(\"displayName\"), None)"
        }
      ]
    },
    "children": [
      {
        "type": "ia.display.label",
        "meta": {
          "name": "Heading"
        },
        "position": {
          "basis": "auto",
          "shrink": 0
        },
        "props": {
          "text": "Enter your initials",
          "style": {
            "color": "var(--mpp-text-primary)",
            "fontSize": "34px",
            "fontWeight": "600"
          }
        }
      },
      {
        "type": "ia.display.label",
        "meta": {
          "name": "TerminalName"
        },
        "position": {
          "basis": "auto",
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "type": "property",
              "config": {
                "path": "session.custom.terminal.terminalName"
              }
            }
          }
        },
        "props": {
          "style": {
            "color": "var(--mpp-text-secondary)",
            "fontSize": "16px"
          }
        }
      },
      {
        "type": "ia.display.label",
        "meta": {
          "name": "InitialsEcho"
        },
        "position": {
          "basis": "auto",
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "type": "expr",
              "config": {
                "expression": "if({view.custom.initials} = \"\", \"- - -\", {view.custom.initials})"
              }
            }
          }
        },
        "props": {
          "style": {
            "color": "var(--mpp-text-accent)",
            "fontSize": "56px",
            "fontFamily": "monospace",
            "letterSpacing": "0.15em",
            "marginTop": "8px",
            "marginBottom": "8px"
          }
        }
      },
      {
        "type": "ia.input.text-field",
        "meta": {
          "name": "ScannerInput"
        },
        "position": {
          "basis": "auto",
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "type": "property",
              "config": {
                "bidirectional": true,
                "path": "view.custom.initials"
              }
            }
          }
        },
        "props": {
          "placeholder": "Scan or type initials",
          "style": {
            "classes": "pf-field-input-mono",
            "textTransform": "uppercase",
            "width": "320px",
            "textAlign": "center"
          }
        },
        "events": {
          "dom": {
            "onBlur": {
              "type": "script",
              "scope": "G",
              "config": {
                "script": "\tself.view.rootContainer.submitInitials()"
              }
            }
          }
        }
      },
      {
        "type": "ia.display.view",
        "meta": {
          "name": "Keyboard"
        },
        "position": {
          "basis": "300px",
          "shrink": 0
        },
        "props": {
          "params": {
            "messageName": "initialsKeyPressed"
          },
          "path": "BlueRidge/Components/PlantFloor/Keyboard",
          "style": {
            "marginTop": "8px",
            "width": "800px"
          },
          "useDefaultViewHeight": false,
          "useDefaultViewWidth": false
        }
      },
      {
        "type": "ia.display.label",
        "meta": {
          "name": "ErrorLabel"
        },
        "position": {
          "basis": "auto",
          "shrink": 0
        },
        "propConfig": {
          "position.display": {
            "binding": {
              "type": "expr",
              "config": {
                "expression": "{view.custom.error} != \"\""
              }
            }
          },
          "props.text": {
            "binding": {
              "type": "property",
              "config": {
                "path": "view.custom.error"
              }
            }
          }
        },
        "props": {
          "style": {
            "color": "var(--mpp-state-bad-fg)",
            "fontSize": "15px",
            "marginTop": "8px"
          }
        }
      }
    ]
  }
}
