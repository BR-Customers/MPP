                "classes": "pf-btn pf-btn-large pf-btn-secondary",
                "fontSize": "18px",
                "height": "62px",
                "minWidth": "130px"
              }
            },
            "events": {
              "component": {
                "onActionPerformed": {
                  "type": "script",
                  "scope": "G",
                  "config": {
                    "script": "\tself.view.rootContainer.clearKeys()"
                  }
                }
              }
            }
          },
          {
            "type": "ia.input.button",
            "meta": {
              "name": "Key_Enter"
            },
            "position": {
              "basis": "130px",
              "grow": 0,
              "shrink": 0
            },
            "props": {
              "text": "Enter",
              "style": {
                "classes": "pf-btn pf-btn-large pf-btn-primary",
                "fontSize": "18px",
                "height": "62px",
                "minWidth": "130px"
              }
            },
            "events": {
              "component": {
                "onActionPerformed": {
                  "type": "script",
                  "scope": "G",
                  "config": {
                    "script": "\tself.view.rootContainer.submitInitials()"
                  }
                }
              }
            }
          }
        ]
      },
      {
        "type": "ia.display.label",
        "meta": {
          "name": "ErrorLabel"
        },
        "position": {
          "basis": "auto",
          "shrink": 0
        },
        "propConfig": {
          "position.display": {
            "binding": {
              "type": "expr",
              "config": {
                "expression": "{view.custom.error} != \"\""
              }
            }
          },
          "props.text": {
            "binding": {
