{
  "custom": {
    "error": "",
    "initials": ""
  },
  "params": {},
  "props": {
    "defaultSize": {
      "width": 1280
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "Heading"
        },
        "position": {
          "shrink": 0
        },
        "props": {
          "style": {
            "color": "var(--mpp-text-primary)",
            "fontSize": "34px",
            "fontWeight": "600"
          },
          "text": "Enter your initials"
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "TerminalName"
        },
        "position": {
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "path": "session.custom.terminal.terminalName"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "color": "var(--mpp-text-secondary)",
            "fontSize": "16px"
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "InitialsEcho"
        },
        "position": {
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "expression": "if({view.custom.initials} \u003d \"\", \"- - -\", {view.custom.initials})"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "style": {
            "color": "var(--mpp-text-accent)",
            "fontFamily": "monospace",
            "fontSize": "56px",
            "letterSpacing": "0.15em",
            "marginBottom": "8px",
            "marginTop": "8px"
          }
        },
        "type": "ia.display.label"
      },
      {
        "events": {
          "dom": {
            "onBlur": {
              "config": {
                "script": "\tself.view.rootContainer.submitInitials()"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "ScannerInput"
        },
        "position": {
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "bidirectional": true,
                "path": "view.custom.initials"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "placeholder": "Scan or type initials",
          "style": {
            "classes": "pf-field-input-mono",
            "textAlign": "center",
            "textTransform": "uppercase",
            "width": "320px"
          }
        },
        "type": "ia.input.text-field"
      },
      {
        "meta": {
          "name": "Keyboard"
        },
        "position": {
          "basis": "240px",
          "shrink": 0
        },
        "props": {
          "params": {
            "messageName": "initialsKeyPressed"
          },
          "path": "BlueRidge/Components/PlantFloor/Keyboard",
          "style": {
            "marginTop": "8px",
            "width": "800px"
          }
        },
        "type": "ia.display.view"
      },
      {
        "meta": {
          "name": "ErrorLabel"
        },
        "position": {
          "shrink": 0
        },
        "propConfig": {
          "position.display": {
            "binding": {
              "config": {
                "expression": "{view.custom.error} !\u003d \"\""
              },
              "type": "expr"
            }
          },
          "props.text": {
            "binding": {
              "config": {
                "path": "view.custom.error"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "color": "var(--mpp-state-bad-fg)",
            "fontSize": "15px",
            "marginTop": "8px"
          }
        },
        "type": "ia.display.label"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "alignItems": "center",
      "direction": "column",
      "justify": "center",
      "style": {
        "classes": "canvas",
        "gap": "20px",
        "padding": "32px"
      }
    },
    "scripts": {
      "customMethods": [
        {
          "name": "appendKey",
          "params": [
            "ch"
          ],
          "script": "\tself.view.custom.error \u003d \"\"\n\tself.view.custom.initials \u003d (self.view.custom.initials or \"\") + ch"
        },
        {
          "name": "clearKeys",
          "params": [],
          "script": "\tself.view.custom.error \u003d \"\"\n\tself.view.custom.initials \u003d \"\""
        },
        {
          "name": "submitInitials",
          "params": [],
          "script": "\tu \u003d BlueRidge.Location.AppUser.getByInitials((self.view.custom.initials or \"\").strip().upper())\n\tif u is None:\n\t\tself.view.custom.error \u003d \"Initials not recognised - ask Admin to add this operator\"\n\t\treturn\n\tself.session.custom.user \u003d {\"appUserId\": u[\"Id\"], \"initials\": u[\"Initials\"], \"displayName\": u[\"DisplayName\"], \"ignitionRole\": u.get(\"IgnitionRole\")}\n\tself.session.custom.appUserId \u003d u[\"Id\"]\n\tsystem.perspective.navigate(self.session.custom.terminal.defaultScreen or \"/\")"
        }
      ],
      "extensionFunctions": null,
      "messageHandlers": [
        {
          "messageType": "initialsKeyPressed",
          "pageScope": true,
          "script": "\ta \u003d payload.get(\"action\") if payload else None\n\tif a \u003d\u003d \"key\":\n\t\tself.appendKey(payload.get(\"key\"))\n\telif a \u003d\u003d \"clear\":\n\t\tself.clearKeys()\n\telif a \u003d\u003d \"enter\":\n\t\tself.submitInitials()",
          "sessionScope": false,
          "viewScope": false
        }
      ]
    },
    "type": "ia.container.flex"
  }
}