                    "binding": {
                      "config": {
                        "expression": "{view.custom.lot.ItemPartNumber} + \"  ·  \" + toStr({view.custom.lot.PieceCount}) + \" pcs  ·  \" + {view.custom.lot.LotOriginTypeCode} + \"  ·  at \" + {view.custom.lot.CurrentLocationName}"
