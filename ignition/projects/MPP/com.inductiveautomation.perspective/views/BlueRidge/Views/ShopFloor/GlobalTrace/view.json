                  "props.text": {
                    "binding": {
                      "config": {
                        "expression": "\"Total Scrap: \" + toStr(coalesce({view.custom.scrap.TotalScrap}, 0)) + \"  (rejected \" + toStr(coalesce({view.custom.scrap.RejectedTotal}, 0)) + \" + counter scrap \" + toStr(coalesce({view.custom.scrap.CounterScrap}, 0)) + \")\""
                      },
