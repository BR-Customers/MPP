                  "position.display": {
                    "binding": {
                      "config": {
                        "expression": "len({view.custom.genealogy}) > 0"
                      },
                      "type": "expr"
                    }
                  },
                  "props.data": {
                    "binding": {
                      "config": {
                        "path": "view.custom.genealogy"
                      },
                      "transforms": [
                        {
                          "code": "\treturn value or []",
                          "type": "script"
                        }
                      ],
                      "type": "property"
                    }
                  }
                },
                "props": {
                  "columns": [
                    {
                      "field": "Relation",
                      "header": {
                        "title": "Relation"
                      }
                    },
                    {
                      "field": "LotName",
                      "header": {
                        "title": "LOT"
                      }
                    },
                    {
                      "field": "Item",
                      "header": {
                        "title": "Item"
                      }
                    },
                    {
                      "field": "Depth",
                      "header": {
                        "title": "Depth"
                      }
                    }
                  ]
                },
                "type": "ia.display.table"
              }
            ],
            "meta": {
              "name": "GenealogyPanel"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "direction": "column",
              "style": {
                "classes": "pf-panel",
                "gap": "12px",
                "padding": "14px 16px"
              }
            },
            "type": "ia.container.flex"
          }
        ],
        "meta": {
          "name": "TraceBody"
        },
        "position": {
          "basis": "auto",
          "shrink": 0
        },
        "propConfig": {
          "position.display": {
            "binding": {
              "config": {
                "expression": "!isNull({view.custom.selectedLotId})"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "direction": "column",
          "style": {
            "gap": "16px"
          }
        },
        "type": "ia.container.flex"
      }
    ],
    "events": {
      "system": {
        "onStartup": {
          "config": {
            "script": "\tif not self.session.custom.appUserId:\n\t\tsystem.perspective.openPopup(\"mpp-initials\", \"BlueRidge/Components/Popups/InitialsEntry\", params={\"popupId\": \"mpp-initials\"}, modal=True, showCloseIcon=False, overlayDismiss=False)"
          },
          "scope": "G",
          "type": "script"
        }
      }
    },
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "classes": "canvas",
        "gap": "16px",
        "overflowY": "auto",
        "padding": "24px"
      }
    },
    "scripts": {
      "customMethods": [
        {
          "name": "search",
          "params": [
            "text"
          ],
          "script": "\tself.view.custom.searchText = (text or \"\").strip()\n\tself.view.custom.refreshToken = (self.view.custom.refreshToken or 0) + 1"
        },
        {
          "name": "loadTrace",
          "params": [
            "lotId"
          ],
          "script": "\tif not lotId:\n\t\treturn\n\tself.view.custom.selectedLotId = lotId\n\tself.view.custom.lot = BlueRidge.Lots.Lot.getOrEmpty(lotId=lotId)\n\tself.view.custom.history = BlueRidge.Lots.Lot.getHistory(lotId)\n\tself.view.custom.scrap = BlueRidge.Lots.Lot.getScrapSummaryOrEmpty(lotId)\n\tself.view.custom.events = BlueRidge.Lots.GlobalTrace.productionEventRows(lotId)\n\tself.view.custom.genealogy = BlueRidge.Lots.GlobalTrace.genealogyRows(lotId)"
        }
      ],
      "extensionFunctions": null,
      "messageHandlers": [
        {
          "messageType": "traceCandidatePicked",
          "pageScope": true,
          "script": "\tself.view.rootContainer.loadTrace(payload.get(\"lotId\"))",
          "sessionScope": false,
          "viewScope": false
        }
      ]
    },
    "type": "ia.container.flex"
  }
}
