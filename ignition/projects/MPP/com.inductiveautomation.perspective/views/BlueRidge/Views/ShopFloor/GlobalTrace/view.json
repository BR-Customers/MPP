{
  "custom": {
    "candidates": [],
    "events": [],
    "genealogy": [],
    "history": [],
    "lot": {
      "CrtActive": null,
      "CurrentLocationId": null,
      "CurrentLocationName": "",
      "Id": null,
      "InventoryAvailable": 0,
      "ItemId": null,
      "ItemPartNumber": "",
      "LotName": "",
      "LotOriginTypeCode": "",
      "LotStatusCode": "",
      "LotStatusName": "",
      "PieceCount": 0
    },
    "refreshToken": 0,
    "scrap": {
      "CounterScrap": 0,
      "RejectedTotal": 0,
      "TotalScrap": 0
    },
    "searchInput": "",
    "searchText": "",
    "selectedLotId": null
  },
  "params": {},
  "propConfig": {
    "custom.candidates": {
      "binding": {
        "config": {
          "expression": "if({view.custom.refreshToken} >= 0, runScript(\"BlueRidge.Lots.GlobalTrace.resolveForTable\", 0, {view.custom.searchText}, {view.custom.refreshToken}), \"\")"
        },
        "transforms": [
          {
            "code": "\treturn value or []",
            "type": "script"
          }
        ],
        "type": "expr"
      }
    }
  },
  "props": {
    "defaultSize": {
      "width": 1280
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "children": [
              {
                "meta": {
                  "name": "Title"
                },
                "props": {
                  "style": {
                    "fontSize": "22px",
                    "fontWeight": 700
                  },
                  "text": "Track & Trace"
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "Subtitle"
                },
                "props": {
                  "style": {
                    "classes": "pf-kpi-sub"
                  },
                  "text": "Global trace - scan or type any LOT name, serial number, container id, or AIM shipper id - read-only"
                },
                "type": "ia.display.label"
              }
            ],
            "meta": {
              "name": "TitleBlock"
            },
            "position": {
              "grow": 1
            },
            "props": {
              "direction": "column"
            },
            "type": "ia.container.flex"
          },
          {
            "events": {
              "dom": {
                "onClick": {
                  "config": {
                    "script": "\tsystem.perspective.openPopup(\"mpp-initials\", \"BlueRidge/Components/Popups/InitialsEntry\", params={\"popupId\": \"mpp-initials\"}, modal=True, showCloseIcon=True, overlayDismiss=True)"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "OperatorLabel"
            },
            "position": {
              "shrink": 0
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "expression": "\"Operator: \" + if(isNull({session.custom.user.displayName}) || {session.custom.user.displayName} = \"\", if(isNull({session.custom.user.initials}), \"-\", {session.custom.user.initials}), {session.custom.user.displayName})"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "classes": "pf-kpi-sub",
                "cursor": "pointer"
              }
            },
            "type": "ia.display.label"
          },
          {
            "events": {
              "component": {
                "onActionPerformed": {
                  "config": {
                    "script": "\tself.view.custom.refreshToken = (self.view.custom.refreshToken or 0) + 1\n\tif self.view.custom.selectedLotId:\n\t\tself.view.rootContainer.loadTrace(self.view.custom.selectedLotId)"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "RefreshButton",
              "tooltip": {
                "text": "Refresh"
              }
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "style": {
                "classes": "pf-btn pf-btn-secondary"
              },
              "text": "Refresh"
            },
            "type": "ia.input.button"
          },
          {
            "events": {
              "component": {
                "onActionPerformed": {
                  "config": {
                    "script": "\tsystem.perspective.navigate(\"/\")"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "CloseButton"
            },
            "props": {
              "style": {
                "classes": "pf-btn pf-btn-secondary"
              },
              "text": "Close"
            },
            "type": "ia.input.button"
          }
        ],
        "meta": {
          "name": "Header"
        },
        "position": {
          "shrink": 0
        },
        "props": {
          "alignItems": "center",
          "style": {
            "gap": "16px",
            "overflow": "hidden"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "children": [
              {
                "meta": {
                  "name": "SearchLabel"
                },
                "position": {
                  "shrink": 0
                },
                "props": {
                  "style": {
                    "classes": "pf-field-label"
                  },
                  "text": "Identifier"
                },
                "type": "ia.display.label"
              },
              {
                "events": {
                  "dom": {
                    "onBlur": {
                      "config": {
                        "script": "\tself.view.rootContainer.search(self.props.text)"
                      },
                      "scope": "G",
                      "type": "script"
                    }
                  }
                },
                "meta": {
                  "name": "SearchInput"
                },
                "position": {
                  "grow": 1
                },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "config": {
                        "bidirectional": true,
                        "path": "view.custom.searchInput"
                      },
                      "type": "property"
                    }
                  }
                },
                "props": {
                  "placeholder": "Scan or type LOT / serial / container / shipper id",
                  "style": {
                    "classes": "pf-field-input"
                  }
                },
                "type": "ia.input.text-field"
              },
              {
                "events": {
                  "component": {
                    "onActionPerformed": {
                      "config": {
                        "script": "\tself.view.rootContainer.search(self.view.custom.searchInput)"
                      },
                      "scope": "G",
                      "type": "script"
                    }
                  }
                },
                "meta": {
                  "name": "SearchButton"
                },
                "position": {
                  "shrink": 0
                },
                "props": {
                  "style": {
                    "classes": "pf-btn pf-btn-primary"
                  },
                  "text": "Search"
                },
                "type": "ia.input.button"
              }
            ],
            "meta": {
              "name": "SearchRow"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "alignItems": "center",
              "style": {
                "classes": "pf-field",
                "gap": "12px",
                "overflow": "hidden"
              }
            },
            "type": "ia.container.flex"
          },
          {
            "meta": {
              "name": "NoMatchHint"
            },
            "position": {
              "shrink": 0
            },
            "propConfig": {
              "position.display": {
                "binding": {
                  "config": {
                    "expression": "{view.custom.searchText} != \"\" && len({view.custom.candidates}) = 0"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "classes": "pf-kpi-sub"
              },
              "text": "No match - nothing resolves to that identifier."
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "CandidateHint"
            },
            "position": {
              "shrink": 0
            },
            "propConfig": {
              "position.display": {
                "binding": {
                  "config": {
                    "expression": "len({view.custom.candidates}) > 0"
                  },
                  "type": "expr"
                }
              },
              "props.text": {
                "binding": {
                  "config": {
                    "expression": "toStr(len({view.custom.candidates})) + ' candidate LOT(s) - tap one to open its trace'"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "classes": "pf-kpi-sub"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "CandidateRepeater"
            },
            "position": {
              "basis": "auto",
              "shrink": 0
            },
            "propConfig": {
              "position.display": {
                "binding": {
                  "config": {
                    "expression": "len({view.custom.candidates}) > 0"
                  },
                  "type": "expr"
                }
              },
              "props.instances": {
                "binding": {
                  "config": {
                    "path": "view.custom.candidates"
                  },
                  "transforms": [
                    {
                      "code": "\treturn value or []",
                      "type": "script"
                    }
                  ],
                  "type": "property"
                }
              }
            },
            "props": {
              "direction": "column",
              "elementPosition": {
                "basis": "56px",
                "shrink": 0
              },
              "path": "BlueRidge/Components/PlantFloor/Trace/CandidateRow",
              "style": {
                "gap": "8px",
                "maxHeight": "244px",
                "overflowY": "auto"
              },
              "useDefaultViewHeight": true,
              "useDefaultViewWidth": false
            },
            "type": "ia.display.flex-repeater"
          }
        ],
        "meta": {
          "name": "SearchPanel"
        },
        "position": {
          "shrink": 0
        },
        "props": {
          "direction": "column",
          "style": {
            "classes": "pf-panel",
            "gap": "12px",
            "padding": "14px 16px"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "meta": {
          "name": "NoSelectionHint"
        },
        "position": {
          "shrink": 0
