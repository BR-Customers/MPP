{
  "custom": {
    "scanCode": ""
  },
  "params": {},
  "propConfig": {
    "custom.terminals": {
      "binding": {
        "config": {
          "expression": "runScript(\"BlueRidge.Location.Terminal.listAll\", 0)"
        },
        "type": "expr"
      }
    }
  },
  "props": {
    "defaultSize": {
      "width": 1280,
      "height": 800
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "Heading"
        },
        "position": {
          "shrink": 0
        },
        "props": {
          "style": {
            "color": "var(--mpp-text-primary)",
            "fontSize": "34px",
            "fontWeight": "600"
          },
          "text": "Select your terminal"
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "Subheading"
        },
        "position": {
          "shrink": 0
        },
        "props": {
          "style": {
            "color": "var(--mpp-text-secondary)",
            "fontSize": "15px"
          },
          "text": "Scan a terminal barcode or tap your terminal in the tree below."
        },
        "type": "ia.display.label"
      },
      {
        "children": [
          {
            "meta": {
              "name": "ScanIcon"
            },
            "position": {
              "basis": "26px",
              "shrink": 0
            },
            "props": {
              "path": "mpp/qr_code_scanner",
              "style": {
                "color": "var(--mpp-text-secondary)",
                "height": "26px",
                "width": "26px"
              }
            },
            "type": "ia.display.icon"
          },
          {
            "events": {
              "dom": {
                "onBlur": {
                  "config": {
                    "script": "\tself.view.rootContainer.selectByScan()"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "ScannerInput"
            },
            "position": {
              "shrink": 0
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "bidirectional": true,
                    "path": "view.custom.scanCode"
                  },
                  "type": "property"
                }
              }
            },
            "props": {
              "placeholder": "Scan terminal barcode",
              "style": {
                "classes": "pf-field-input-mono",
                "textAlign": "center",
                "textTransform": "uppercase",
                "width": "360px"
              }
            },
            "type": "ia.input.text-field"
          },
          {
            "children": [],
            "meta": {
              "name": "ScanSpacer"
            },
            "position": {
              "basis": "26px",
              "shrink": 0
            },
            "props": {},
            "type": "ia.container.flex"
          }
        ],
        "meta": {
          "name": "ScanField"
        },
        "position": {
          "shrink": 0
        },
        "props": {
          "alignItems": "center",
          "justify": "center",
          "style": {
            "gap": "10px",
            "marginTop": "4px",
            "overflow": "hidden"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "meta": {
          "name": "NavTree"
        },
        "position": {
          "basis": "0",
          "grow": 1
        },
        "props": {
          "path": "BlueRidge/Components/PlantFloor/NavigationTree",
          "style": {
            "maxWidth": "900px",
            "width": "100%"
          },
          "useDefaultViewHeight": false,
          "useDefaultViewWidth": false
        },
        "type": "ia.display.view"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "alignItems": "center",
      "direction": "column",
      "style": {
        "classes": "canvas",
        "gap": "20px",
        "padding": "40px"
      }
    },
    "scripts": {
      "customMethods": [
        {
          "name": "selectTerminal",
          "params": [
            "row"
          ],
          "script": "\trow = BlueRidge.Common.Util.extractQualifiedValues(row) or {}\n\ttid = row.get(\"TerminalId\")\n\tif not tid:\n\t\treturn\n\tfull = BlueRidge.Location.Terminal.findById(self.view.custom.terminals, tid) or row\n\tself.session.custom.terminal = {\"terminalLocationId\": full.get(\"TerminalId\"), \"terminalCode\": full.get(\"TerminalCode\"), \"terminalName\": full.get(\"TerminalName\"), \"zoneLocationId\": full.get(\"ZoneId\"), \"zoneName\": full.get(\"ZoneName\"), \"defaultScreen\": full.get(\"DefaultScreen\") or \"\", \"isFallback\": bool(full.get(\"IsFallback\"))}\n\tsystem.perspective.navigate(full.get(\"DefaultScreen\") or \"/\")"
        },
        {
          "name": "selectByScan",
          "params": [],
          "script": "\tcode = (self.view.custom.scanCode or \"\").strip().upper()\n\tif not code:\n\t\treturn\n\tmatch = BlueRidge.Location.Terminal.findByCode(self.view.custom.terminals, code)\n\tif match is None:\n\t\treturn\n\tself.selectTerminal(match)"
        }
      ],
      "extensionFunctions": null,
      "messageHandlers": null
    },
    "type": "ia.container.flex"
  }
}
