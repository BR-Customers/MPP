    "scripts": {
      "customMethods": [
        {
          "name": "selectTerminal",
          "params": [
            "row"
          ],
          "script": "\trow \u003d BlueRidge.Common.Util.extractQualifiedValues(row) or {}\n\ttid \u003d row.get(\"TerminalId\")\n\tif not tid:\n\t\treturn\n\tfull \u003d BlueRidge.Location.Terminal.findById(self.view.custom.terminals, tid) or row\n\tself.session.custom.terminal \u003d {\"terminalLocationId\": full.get(\"TerminalId\"), \"terminalCode\": full.get(\"TerminalCode\"), \"terminalName\": full.get(\"TerminalName\"), \"zoneLocationId\": full.get(\"ZoneId\"), \"zoneName\": full.get(\"ZoneName\"), \"defaultScreen\": full.get(\"DefaultScreen\") or \"\", \"isFallback\": bool(full.get(\"IsFallback\"))}\n\tsystem.perspective.navigate(full.get(\"DefaultScreen\") or \"/\")"
        },
        {
          "name": "selectByScan",
          "params": [],
          "script": "\tcode \u003d (self.view.custom.scanCode or \"\").strip().upper()\n\tif not code:\n\t\treturn\n\tmatch \u003d BlueRidge.Location.Terminal.findByCode(self.view.custom.terminals, code)\n\tif match is None:\n\t\treturn\n\tself.selectTerminal(match)"
        }
      ],
      "extensionFunctions": null,
      "messageHandlers": null
    },
