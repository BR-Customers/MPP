    "events": {
      "system": {
        "onStartup": {
          "config": {
            "script": "\tif not self.session.custom.appUserId:\n\t\tsystem.perspective.openPopup(\"mpp-initials\", \"BlueRidge/Components/Popups/InitialsEntry\", params={\"popupId\": \"mpp-initials\"}, modal=True, showCloseIcon=False, overlayDismiss=False)"
          },
          "scope": "G",
          "type": "script"
        }
      }
    },
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "classes": "canvas",
        "gap": "16px",
        "overflowY": "auto",
        "padding": "24px"
      }
    },
    "scripts": {
      "customMethods": [
        {
          "name": "resolveLot",
          "params": [
            "lotName"
          ],
          "script": "\tquery = (lotName or \"\").strip()\n\tself.view.custom.lotQuery = query\n\tself.view.custom.lot = BlueRidge.Lots.Lot.getOrEmpty(lotName=query)\n\tself.view.custom.entries = {}\n\tself.view.custom.triggerCodeId = None\n\tself.view.custom.refreshToken = (self.view.custom.refreshToken or 0) + 1"
        },
        {
          "name": "record",
          "params": [],
          "script": "\tterm = self.session.custom.terminal\n\tterminalId = term.terminalLocationId if term else None\n\tresult = BlueRidge.Quality.QualitySample.recordFromEntries(self.view.custom.lot, self.view.custom.spec, self.view.custom.entries, self.view.custom.triggerCodeId, self.session.custom.appUserId, terminalId)\n\tBlueRidge.Common.Ui.notifyResult(result, \"Inspection\", result.get(\"Message\"))\n\tif result and result.get(\"Status\"):\n\t\tif \"Fail\" in (result.get(\"Message\") or \"\"):\n\t\t\tBlueRidge.Common.Notify.toast(\"Inspection FAILED - no hold placed automatically\", result.get(\"Message\") or \"\", \"warning\")\n\t\tself.view.custom.entries = {}\n\t\tself.view.custom.triggerCodeId = None\n\t\tself.view.custom.refreshToken = (self.view.custom.refreshToken or 0) + 1"
        }
      ],
      "extensionFunctions": null,
      "messageHandlers": [
        {
          "messageType": "inspectionValueChanged",
          "pageScope": true,
          "script": "\tentries = dict(self.view.custom.entries or {})\n\tentries[\"%s\" % payload.get(\"qualitySpecAttributeId\")] = payload.get(\"measuredValue\") or \"\"\n\tself.view.custom.entries = entries",
          "sessionScope": false,
          "viewScope": false
        }
      ]
    },
    "type": "ia.container.flex"
  }
}
