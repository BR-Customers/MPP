{
  "custom": {
    "entries": {},
    "lot": {
      "CrtActive": null,
      "CurrentLocationId": null,
      "CurrentLocationName": "",
      "Id": null,
      "InventoryAvailable": 0,
      "ItemId": null,
      "ItemPartNumber": "",
      "LotName": "",
      "LotStatusCode": "",
      "LotStatusName": "",
      "PieceCount": 0
    },
    "lotQuery": "",
    "refreshToken": 0,
    "samples": [],
    "spec": {
      "attributes": [],
      "specId": null,
      "specName": "",
      "versionId": null,
      "versionNumber": null
    },
    "triggerCodeId": null,
    "triggerOptions": []
  },
  "params": {},
  "propConfig": {
    "custom.samples": {
      "binding": {
        "config": {
          "expression": "if({view.custom.refreshToken} >= 0, runScript(\"BlueRidge.Quality.QualitySample.listByLotInstances\", 0, {view.custom.lot.Id}, {view.custom.refreshToken}), \"\")"
        },
        "transforms": [
          {
            "code": "\treturn value or []",
            "type": "script"
          }
        ],
        "type": "expr"
      }
    },
    "custom.spec": {
      "binding": {
        "config": {
          "expression": "if({view.custom.refreshToken} >= 0, runScript(\"BlueRidge.Quality.QualitySpec.getActiveVersionForItemOrEmpty\", 0, {view.custom.lot.ItemId}, {view.custom.refreshToken}), \"\")"
        },
        "transforms": [
          {
            "code": "\treturn value or {\"specId\": None, \"specName\": \"\", \"versionId\": None, \"versionNumber\": None, \"attributes\": []}",
            "type": "script"
          }
        ],
        "type": "expr"
      }
    },
    "custom.triggerOptions": {
      "binding": {
        "config": {
          "expression": "runScript(\"BlueRidge.Quality.QualitySample.getTriggerOptions\", 0, {view.custom.refreshToken})"
        },
        "transforms": [
          {
            "code": "\treturn value or []",
            "type": "script"
          }
        ],
        "type": "expr"
      }
    }
  },
  "props": {
    "defaultSize": {
      "width": 1280
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "children": [
              {
                "meta": {
                  "name": "Title"
                },
                "props": {
                  "style": {
                    "fontSize": "22px",
                    "fontWeight": 700
                  },
                  "text": "Inspection"
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "Subtitle"
                },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "config": {
                        "expression": "if(isNull({session.custom.terminal.terminalName}) || {session.custom.terminal.terminalName} = \"\", \"Shared terminal\", {session.custom.terminal.terminalName}) + \"  ·  Quality capture - measurements record against the part's active spec - a Fail does NOT auto-hold\""
                      },
                      "type": "expr"
                    }
                  }
                },
                "props": {
                  "style": {
                    "classes": "pf-kpi-sub"
                  }
                },
                "type": "ia.display.label"
              }
            ],
            "meta": {
              "name": "TitleBlock"
            },
            "position": {
              "grow": 1
            },
            "props": {
              "direction": "column"
            },
            "type": "ia.container.flex"
          },
          {
            "events": {
              "dom": {
                "onClick": {
                  "config": {
                    "script": "\tsystem.perspective.openPopup(\"mpp-initials\", \"BlueRidge/Components/Popups/InitialsEntry\", params={\"popupId\": \"mpp-initials\"}, modal=True, showCloseIcon=True, overlayDismiss=True)"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "OperatorLabel"
            },
            "position": {
              "shrink": 0
            },
