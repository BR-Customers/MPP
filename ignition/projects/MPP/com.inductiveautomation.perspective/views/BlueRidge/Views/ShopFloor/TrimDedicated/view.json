{
  "custom": {},
  "params": {},
  "propConfig": {},
  "props": {},
  "root": {
    "type": "ia.container.flex",
    "meta": {
      "name": "root"
    },
    "props": {
      "style": {
        "classes": "canvas"
      },
      "direction": "column"
    },
    "children": [
      {
        "type": "ia.display.view",
        "meta": {
          "name": "BodyEmbed"
        },
        "position": {
          "grow": 1,
          "basis": "0"
        },
        "props": {
          "path": "BlueRidge/Views/ShopFloor/TrimBody"
        }
      }
    ],
    "scripts": {
      "customMethods": [],
      "messageHandlers": [],
      "extensionFunctions": null
    },
    "events": {
      "system": {
        "onStartup": {
          "type": "script",
          "scope": "G",
          "config": {
            "script": "\tt = self.session.custom.terminal\n\tif t and t.get(\"zoneLocationId\"):\n\t\tself.session.custom.cell = {\"locationId\": t.get(\"zoneLocationId\"), \"code\": t.get(\"zoneName\") or \"\", \"name\": t.get(\"zoneName\") or \"\"}\n\ttry:\n\t\tself.session.custom.presence.policy = \"confirm\"\n\texcept:\n\t\tself.session.custom.presence = {\"policy\": \"confirm\"}"
          }
        }
      }
    }
  }
}
