          "script": "\tself.view.custom.selectedLotId = payload.get(\"lotId\")\n\tself.view.custom.draft = {\"qty\": \"\"}\n\tself.view.custom.refreshToken = (self.view.custom.refreshToken or 0) + 1",
          "sessionScope": false,
          "viewScope": false
        },
        {
