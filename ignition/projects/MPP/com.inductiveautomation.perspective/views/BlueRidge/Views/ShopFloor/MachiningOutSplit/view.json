                    "children": [
                      {
                        "events": {
                          "component": {
                            "onActionPerformed": {
                              "config": {
                                "script": "\t# Terminal-mint: consume the source casting to MINT a machined SubAssembly LOT\n\t# (line-resident, no destination). Produced part derived via BOM by the proc.\n\tsource = self.view.custom.parentLot\n\totId = self.view.custom.opTemplateId\n\tcellId = self.session.custom.cell.locationId\n\td = self.view.custom.draft\n\tif cellId is None or not source or source.get(\"Id\") is None:\n\t\tBlueRidge.Common.Ui.notifyResult({\"Status\": False, \"Message\": \"Select a cell that has a casting ready for Machining OUT.\"}, \"Machining OUT\")\n\t\treturn\n\tif otId is None:\n\t\tBlueRidge.Common.Ui.notifyResult({\"Status\": False, \"Message\": \"MachiningOut operation template not found.\"}, \"Machining OUT\")\n\t\treturn\n\tq = BlueRidge.Common.Util.toIntOrNone(d.get(\"qty\"))\n\tif q is None or q <= 0:\n\t\tBlueRidge.Common.Ui.notifyResult({\"Status\": False, \"Message\": \"Enter a positive quantity to mint.\"}, \"Machining OUT\")\n\t\treturn\n\tresult = BlueRidge.Workorder.Machining.mint(source.get(\"Id\"), otId, q, None, self.session.custom.appUserId, cellId)\n\tavail = result.get(\"Available\") if result else None\n\tif result and (not result.get(\"Status\")) and avail and avail > 0 and avail < q:\n\t\tsystem.perspective.openPopup(\"mo-partial\", \"BlueRidge/Components/Popups/ConfirmDestructive\", params={\"title\": \"Not enough in the queue\", \"message\": \"Only %s available in the FIFO queue. Mint %s instead?\" % (avail, avail), \"confirmLabel\": \"Mint %s\" % avail, \"cancelLabel\": \"Cancel\", \"confirmClass\": \"pf-btn pf-btn-primary pf-btn-large\", \"replyMessage\": \"moPartialConfirmed\", \"popupId\": \"mo-partial\"}, modal=True, showCloseIcon=False)\n\t\treturn\n\tBlueRidge.Common.Ui.notifyResult(result, \"Machining OUT - Mint\")\n\tif result and result.get(\"Status\"):\n\t\tself.view.custom.draft = {\"qty\": \"\"}\n\t\tself.view.custom.refreshToken = (self.view.custom.refreshToken or 0) + 1"
                              },
                              "scope": "G",
                              "type": "script"
                            }
                          }
