{
  "custom": {
    "parentLot": {
      "Id": null,
      "LotName": "",
      "PieceCount": 0,
      "ItemPartNumber": ""
    },
    "draft": {
      "qty": ""
    },
    "refreshToken": 0
  },
  "params": {},
  "propConfig": {
    "custom.opTemplateId": {
      "binding": {
        "config": {
          "expression": "runScript(\"BlueRidge.Parts.OperationTemplate.getActiveTemplateIdForLot\", 0, {view.custom.parentLot.Id}, \"MachiningOut\")"
        },
        "type": "expr"
      }
    },
    "custom.parentLot": {
      "binding": {
        "config": {
          "expression": "if({view.custom.refreshToken} >= 0 && !isNull({session.custom.cell.locationId}), runScript(\"BlueRidge.Lots.Lot.getWipQueueByLocation\", 0, {session.custom.cell.locationId}, true, {view.custom.refreshToken}, \"MachiningOut\"), \"\")"
        },
        "transforms": [
          {
            "code": "\t# Terminal-mint: the source is the casting whose next route step is MachiningOut (the read is role-filtered).\n\tsources = value or []\n\tr = sources[-1] if sources else {}\n\treturn {\"Id\": r.get(\"Id\"), \"LotName\": r.get(\"LotName\") or \"\", \"PieceCount\": r.get(\"PieceCount\") or 0, \"ItemPartNumber\": r.get(\"ItemPartNumber\") or \"\"}",
            "type": "script"
          }
        ],
        "type": "expr"
      }
    }
  },
  "props": {
    "defaultSize": {
      "width": 1280
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "children": [
              {
                "meta": {
                  "name": "Title"
                },
                "props": {
                  "style": {
                    "fontSize": "22px",
                    "fontWeight": 700
                  },
                  "text": "Machining OUT - Sub-LOT Split"
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "Subtitle"
                },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "config": {
                        "expression": "if(isNull({session.custom.cell.name}) || {session.custom.cell.name} = \"\", \"No cell bound\", {session.custom.cell.name}) + \"  ·  Sublotting line (RequiresSubLotSplit = ON) - dedicated Machining OUT terminal\""
                      },
                      "type": "expr"
                    }
                  }
                },
                "props": {
                  "style": {
                    "classes": "pf-kpi-sub"
                  }
                },
                "type": "ia.display.label"
              }
            ],
            "meta": {
              "name": "TitleBlock"
            },
            "position": {
              "grow": 1
            },
            "props": {
              "direction": "column"
            },
            "type": "ia.container.flex"
          },
          {
            "events": {
              "dom": {
                "onClick": {
                  "config": {
                    "script": "\tsystem.perspective.openPopup(\"mpp-initials\", \"BlueRidge/Components/Popups/InitialsEntry\", params={\"popupId\": \"mpp-initials\"}, modal=True, showCloseIcon=True, overlayDismiss=True)"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "OperatorLabel"
            },
            "position": {
              "shrink": 0
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "expression": "\"Operator: \" + if(isNull({session.custom.user.displayName}) || {session.custom.user.displayName} = \"\", if(isNull({session.custom.user.initials}), \"-\", {session.custom.user.initials}), {session.custom.user.displayName})"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "classes": "pf-kpi-sub",
                "cursor": "pointer"
              }
            },
            "type": "ia.display.label"
          },
          {
            "children": [
              {
                "meta": {
                  "name": "PausedLabel"
                },
                "props": {
                  "style": {
                    "fontSize": "13px",
                    "fontWeight": "500"
                  },
                  "text": "Paused"
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "PausedCount"
                },
                "props": {
                  "style": {
                    "classes": "pf-paused-indicator-count"
                  },
                  "text": "0"
                },
                "type": "ia.display.label"
              }
            ],
            "meta": {
              "name": "PausedIndicator"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "alignItems": "center",
              "style": {
                "classes": "pf-paused-indicator",
                "gap": "8px",
                "padding": "8px 14px"
              }
            },
            "type": "ia.container.flex"
          },
          {
            "events": {
              "component": {
                "onActionPerformed": {
                  "config": {
                    "script": "\tself.view.custom.refreshToken = (self.view.custom.refreshToken or 0) + 1"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "RefreshButton",
              "tooltip": {
                "text": "Refresh"
              }
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "style": {
                "classes": "pf-btn pf-btn-secondary"
              },
              "text": "Refresh"
            },
            "type": "ia.input.button"
          },
          {
            "events": {
              "component": {
                "onActionPerformed": {
                  "config": {
                    "script": "\tsystem.perspective.openPopup(\"mpp-inventory\", \"BlueRidge/Components/PlantFloor/InventoryManager\", params={\"locationId\": self.session.custom.cell.locationId}, title=\"Line Inventory\", modal=False, showCloseIcon=True, draggable=True, resizable=True)"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "InventoryButton",
              "tooltip": {
                "text": "Check component / pass-through inventory in to this line"
              }
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "style": {
                "classes": "pf-btn pf-btn-secondary"
              },
              "text": "Inventory"
            },
            "type": "ia.input.button"
          },
          {
            "events": {
              "component": {
                "onActionPerformed": {
                  "config": {
                    "script": "\tsystem.perspective.navigate(\"/\")"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "CloseButton"
            },
            "props": {
              "style": {
                "classes": "pf-btn pf-btn-secondary"
              },
              "text": "Close"
            },
            "type": "ia.input.button"
          }
        ],
        "meta": {
          "name": "Header"
        },
        "props": {
          "alignItems": "center",
          "style": {
            "gap": "16px",
            "overflow": "hidden"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "children": [
              {
                "meta": {
                  "name": "ParentTitle"
                },
                "props": {
                  "style": {
                    "color": "var(--mpp-text-secondary)",
                    "fontSize": "14px",
                    "fontWeight": "600",
                    "letterSpacing": "0.06em",
                    "textTransform": "uppercase"
                  },
                  "text": "Active Machined LOT"
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "ParentSub"
                },
                "props": {
                  "style": {
                    "classes": "pf-kpi-sub"
                  },
                  "text": "Cumulative counters captured at the cell; the operation closes before the split."
                },
                "type": "ia.display.label"
              }
            ],
            "meta": {
              "name": "ParentHeader"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "direction": "column",
              "style": {
                "alignItems": "flex-start",
                "classes": "pf-panel-header",
                "gap": "4px"
              }
            },
            "type": "ia.container.flex"
          },
          {
            "meta": {
              "name": "ParentLot"
            },
            "position": {
              "shrink": 0
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "expression": "if(isNull({view.custom.parentLot.Id}), 'No machined LOT at this cell.', 'Parent LOT: ' + {view.custom.parentLot.LotName} + '  (' + {view.custom.parentLot.ItemPartNumber} + ')  -  ' + toStr({view.custom.parentLot.PieceCount}) + ' pcs')"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "color": "var(--mpp-accent-60)",
                "fontSize": "16px",
                "fontWeight": "600"
              }
            },
            "type": "ia.display.label"
          }
        ],
        "meta": {
          "name": "ParentPanel"
        },
        "position": {
          "shrink": 0
        },
        "props": {
          "direction": "column",
          "style": {
            "classes": "pf-panel",
            "gap": "12px",
            "padding": "14px 16px"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "children": [
              {
                "meta": {
                  "name": "SplitTitle"
                },
                "props": {
                  "style": {
                    "color": "var(--mpp-text-secondary)",
                    "fontSize": "14px",
                    "fontWeight": "600",
                    "letterSpacing": "0.06em",
                    "textTransform": "uppercase"
                  },
                  "text": "Extract Sub-LOT"
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "AllocHint"
                },
                "position": {
                  "shrink": 0
                },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "config": {
                        "expression": "'Extract: ' + toStr(toInt({view.custom.draft.qty}, 0)) + ' / ' + toStr({view.custom.parentLot.PieceCount}) + ' pcs remaining'"
                      },
                      "type": "expr"
                    }
                  }
                },
                "props": {
                  "style": {
                    "classes": "pf-kpi-sub"
                  }
                },
                "type": "ia.display.label"
              }
            ],
            "meta": {
              "name": "SplitHeader"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "alignItems": "center",
              "justify": "space-between",
              "style": {
                "classes": "pf-panel-header",
                "gap": "8px"
              },
              "wrap": "wrap"
            },
            "type": "ia.container.flex"
          },
          {
            "meta": {
              "name": "SplitNote"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "style": {
                "classes": "pf-kpi-sub"
              },
              "text": "Extract one machining-origin sub-LOT from the parent. Enter a piece count up to the parent's remaining count and a destination. The parent stays open with its reduced count and can be extracted again until it reaches zero. LTT labels print showing child + parent LotName."
            },
            "type": "ia.display.label"
          },
          {
            "children": [
              {
                "children": [
                  {
                    "children": [
                      {
                        "meta": {
                          "name": "L"
                        },
                        "props": {
                          "style": {
                            "classes": "pf-field-label"
                          },
                          "text": "Pieces"
                        },
                        "type": "ia.display.label"
                      },
                      {
                        "meta": {
                          "name": "Qty"
                        },
                        "propConfig": {
                          "props.text": {
                            "binding": {
                              "config": {
                                "bidirectional": true,
                                "path": "view.custom.draft.qty"
                              },
                              "type": "property"
                            }
                          }
                        },
                        "props": {
                          "style": {
                            "classes": "pf-field-input"
                          }
                        },
                        "type": "ia.input.text-field"
                      }
                    ],
                    "meta": {
                      "name": "QtyField"
                    },
                    "position": {
                      "basis": "160px",
                      "shrink": 0
                    },
                    "props": {
                      "direction": "column",
                      "style": {
                        "classes": "pf-field",
                        "gap": "6px"
                      }
                    },
                    "type": "ia.container.flex"
                  }
                ],
                "meta": {
                  "name": "ExtractRow"
                },
                "position": {
                  "shrink": 0
                },
                "props": {
                  "alignItems": "flex-end",
                  "style": {
                    "classes": "pf-repeater-entity",
                    "gap": "14px",
                    "padding": "12px 16px"
                  },
                  "wrap": "wrap"
                },
                "type": "ia.container.flex"
              }
            ],
            "meta": {
              "name": "Repeater"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "direction": "column",
              "style": {
                "classes": "pf-repeater",
                "gap": "8px"
              }
            },
            "type": "ia.container.flex"
          },
          {
            "children": [
              {
                "events": {
                  "component": {
                    "onActionPerformed": {
                      "config": {
                        "script": "\t# Terminal-mint: consume the source casting to MINT a machined SubAssembly LOT\n\t# (line-resident, no destination). Produced part derived via BOM by the proc.\n\tsource = self.view.custom.parentLot\n\totId = self.view.custom.opTemplateId\n\tcellId = self.session.custom.cell.locationId\n\td = self.view.custom.draft\n\tif cellId is None or not source or source.get(\"Id\") is None:\n\t\tBlueRidge.Common.Ui.notifyResult({\"Status\": False, \"Message\": \"Select a cell that has a casting ready for Machining OUT.\"}, \"Machining OUT\")\n\t\treturn\n\tif otId is None:\n\t\tBlueRidge.Common.Ui.notifyResult({\"Status\": False, \"Message\": \"MachiningOut operation template not found.\"}, \"Machining OUT\")\n\t\treturn\n\tq = BlueRidge.Common.Util.toIntOrNone(d.get(\"qty\"))\n\tif q is None or q <= 0:\n\t\tBlueRidge.Common.Ui.notifyResult({\"Status\": False, \"Message\": \"Enter a positive quantity to mint.\"}, \"Machining OUT\")\n\t\treturn\n\tresult = BlueRidge.Workorder.Machining.mint(source.get(\"Id\"), otId, q, None, self.session.custom.appUserId, cellId)\n\tBlueRidge.Common.Ui.notifyResult(result, \"Machining OUT - Mint\")\n\tif result and result.get(\"Status\"):\n\t\tself.view.custom.draft = {\"qty\": \"\"}\n\t\tself.view.custom.refreshToken = (self.view.custom.refreshToken or 0) + 1"
                      },
                      "scope": "G",
                      "type": "script"
                    }
                  }
                },
                "meta": {
                  "name": "SubmitButton"
                },
                "position": {
                  "shrink": 0
                },
                "props": {
                  "style": {
                    "classes": "pf-btn pf-btn-primary pf-btn-large"
                  },
                  "text": "Submit - MachiningOut + Extract + Route"
                },
                "type": "ia.input.button"
              },
              {
                "meta": {
                  "name": "ActionsSpacer"
                },
                "position": {
                  "basis": "0",
                  "grow": 1
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "ActionsHint"
                },
                "props": {
                  "style": {
                    "classes": "pf-kpi-sub"
                  },
                  "text": "Non-sublotting lines auto-move whole to the coupled Assembly Cell - no screen."
                },
                "type": "ia.display.label"
              }
            ],
            "meta": {
              "name": "Actions"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "alignItems": "center",
              "style": {
                "classes": "pf-actions",
                "gap": "12px",
                "marginTop": "12px",
                "paddingTop": "12px"
              },
              "wrap": "wrap"
            },
            "type": "ia.container.flex"
          }
        ],
        "meta": {
          "name": "SplitPanel"
        },
        "position": {
          "basis": "0",
          "grow": 1
        },
        "props": {
          "direction": "column",
          "style": {
            "classes": "pf-panel",
            "gap": "12px",
            "padding": "14px 16px"
          }
        },
        "type": "ia.container.flex"
      }
    ],
    "events": {
      "system": {
        "onStartup": {
          "type": "script",
          "scope": "G",
          "config": {
            "script": "\t# Dedicated-flavor context (FDS-02-010): bind the cell to the terminal's parent line.\n\tt = self.session.custom.terminal\n\tif t and t.get(\"zoneLocationId\"):\n\t\tself.session.custom.cell = {\"locationId\": t.get(\"zoneLocationId\"), \"code\": t.get(\"zoneName\") or \"\", \"name\": t.get(\"zoneName\") or \"\"}\n\ttry:\n\t\tself.session.custom.presence.policy = \"confirm\"\n\texcept:\n\t\tself.session.custom.presence = {\"policy\": \"confirm\"}\n\tif not self.session.custom.appUserId:\n\t\tsystem.perspective.openPopup(\"mpp-initials\", \"BlueRidge/Components/Popups/InitialsEntry\", params={\"popupId\": \"mpp-initials\"}, modal=True, showCloseIcon=False, overlayDismiss=False)"
          }
        }
      }
    },
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "classes": "canvas",
        "gap": "16px",
        "overflowY": "auto",
        "padding": "24px"
      }
    },
    "scripts": {
      "customMethods": [],
      "extensionFunctions": null,
      "messageHandlers": [
        {
          "messageType": "inventoryChanged",
          "pageScope": true,
          "script": "\tself.view.custom.refreshToken = (self.view.custom.refreshToken or 0) + 1",
          "sessionScope": false,
          "viewScope": false
        }
      ]
    },
    "type": "ia.container.flex"
  }
}
