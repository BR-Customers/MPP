{
  "custom": {
    "parentLot": {
      "Id": null,
      "LotName": "",
      "PieceCount": 0,
      "ItemPartNumber": ""
    },
    "draft": {
      "qty": ""
    },
    "refreshToken": 0,
    "selectedLotId": null,
    "queue": []
  },
  "params": {},
  "propConfig": {
    "custom.opTemplateId": {
      "binding": {
        "config": {
          "expression": "runScript(\"BlueRidge.Parts.OperationTemplate.getActiveTemplateIdForLot\", 0, {view.custom.parentLot.Id}, \"MachiningOut\")"
        },
        "type": "expr"
      }
    },
    "custom.parentLot": {
      "binding": {
        "config": {
          "path": "view.custom.queue"
        },
        "transforms": [
          {
            "code": "\tsel = [r for r in (value or []) if r.get(\"isSelected\")]\n\tr = sel[0] if sel else {}\n\treturn {\"Id\": r.get(\"lotId\"), \"LotName\": r.get(\"lotName\") or \"\", \"PieceCount\": r.get(\"pieceCount\") or 0, \"ItemPartNumber\": r.get(\"item\") or \"\"}",
            "type": "script"
          }
        ],
        "type": "property"
      }
    },
    "custom.queue": {
      "binding": {
        "config": {
          "expression": "if({view.custom.refreshToken} >= 0 && !isNull({session.custom.cell.locationId}), runScript(\"BlueRidge.Lots.Lot.getWipQueueByLocation\", 0, {session.custom.cell.locationId}, true, {view.custom.refreshToken}, \"MachiningOut\"), \"\")"
        },
        "transforms": [
          {
            "code": "\treturn BlueRidge.Lots.Lot.mapMachiningOutQueue(value, self.view.custom.selectedLotId)",
            "type": "script"
          }
        ],
        "type": "expr"
      }
    }
  },
