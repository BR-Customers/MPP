{
  "custom": {
    "draft": {
      "qty": ""
    },
    "refreshToken": 0,
    "selectedLotId": null
  },
  "params": {},
  "propConfig": {
    "custom.opTemplateId": {
      "binding": {
        "config": {
          "expression": "runScript(\"BlueRidge.Parts.OperationTemplate.getActiveTemplateIdForLot\", 0, {view.custom.parentLot.Id}, \"MachiningOut\")"
        },
        "type": "expr"
      }
    },
    "custom.parentLot": {
      "binding": {
        "config": {
          "path": "view.custom.queue"
        },
        "transforms": [
          {
            "code": "\tsel \u003d [r for r in (value or []) if r.get(\"isSelected\")]\n\tr \u003d sel[0] if sel else {}\n\treturn {\"Id\": r.get(\"lotId\"), \"LotName\": r.get(\"lotName\") or \"\", \"PieceCount\": r.get(\"pieceCount\") or 0, \"ItemPartNumber\": r.get(\"item\") or \"\"}",
            "type": "script"
          }
        ],
        "type": "property"
      }
    },
    "custom.queue": {
      "binding": {
        "config": {
          "expression": "if({view.custom.refreshToken} \u003e\u003d 0 \u0026\u0026 !isNull({session.custom.cell.locationId}), runScript(\"BlueRidge.Lots.Lot.getWipQueueByLocation\", 0, {session.custom.cell.locationId}, true, {view.custom.refreshToken}, \"MachiningOut\"), \"\")"
        },
        "transforms": [
          {
            "code": "\treturn BlueRidge.Lots.Lot.mapMachiningOutQueue(value, self.view.custom.selectedLotId)",
            "type": "script"
          }
        ],
        "type": "expr"
      }
    }
  },
  "props": {
    "defaultSize": {
      "width": 1280
    }
  },
