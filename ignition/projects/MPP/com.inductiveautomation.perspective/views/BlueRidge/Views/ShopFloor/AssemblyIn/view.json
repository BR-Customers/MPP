{
  "custom": {
    "refreshToken": 0,
    "scanInput": ""
  },
  "params": {},
  "propConfig": {
    "custom.queue": {
      "binding": {
        "config": {
          "expression": "if({view.custom.refreshToken} \u003e\u003d 0 \u0026\u0026 !isNull({session.custom.cell.locationId}), runScript(\"BlueRidge.Lots.Lot.getWipQueueByLocation\", 0, {session.custom.cell.locationId}, true, {view.custom.refreshToken}), \"\")"
        },
        "transforms": [
          {
            "code": "\treturn [{\"sourceLotId\": r.get(\"Id\"), \"lotName\": r.get(\"LotName\") or \"\", \"sourceItem\": r.get(\"ItemPartNumber\") or \"\", \"pieceCount\": r.get(\"PieceCount\") or 0, \"arrival\": str(r.get(\"LastMovementAt\") or \"\"), \"position\": i + 1, \"lotStatusCode\": r.get(\"LotStatusCode\") or \"\"} for i, r in enumerate(value or [])]",
            "type": "script"
          }
        ],
        "type": "expr"
      }
    },
    "custom.queueByPartText": {
      "binding": {
        "config": {
          "path": "view.custom.queue"
        },
        "transforms": [
          {
            "code": "\ttotals \u003d {}\n\torder \u003d []\n\tfor r in (value or []):\n\t\tk \u003d r.get(\"sourceItem\") or \"?\"\n\t\tif k not in totals:\n\t\t\ttotals[k] \u003d 0\n\t\t\torder.append(k)\n\t\ttotals[k] \u003d totals[k] + (r.get(\"pieceCount\") or 0)\n\treturn \"   |   \".join([\"%s: %d pcs\" % (k, totals[k]) for k in order])",
            "type": "script"
          }
        ],
        "type": "property"
      }
    }
  },
  "props": {},
  "root": {
    "children": [
      {
        "children": [
          {
