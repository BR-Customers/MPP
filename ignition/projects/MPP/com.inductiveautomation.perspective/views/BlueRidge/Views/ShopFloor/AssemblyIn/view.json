        "classes": "canvas",
        "gap": "16px",
        "overflowY": "auto",
        "padding": "24px"
      }
    },
    "scripts": {
      "customMethods": [],
      "extensionFunctions": null,
      "messageHandlers": [
        {
          "messageType": "inventoryChanged",
          "pageScope": true,
          "script": "\tself.view.custom.refreshToken \u003d (self.view.custom.refreshToken or 0) + 1",
          "sessionScope": false,
          "viewScope": false
