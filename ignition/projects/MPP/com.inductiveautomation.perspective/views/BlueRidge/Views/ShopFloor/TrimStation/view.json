{
  "custom": {
    "activeLotId": null,
    "outScan": "",
    "destCells": [],
    "destValue": null,
    "shotCount": 0,
    "scrapCount": 0
  },
  "params": {},
  "propConfig": {
    "custom.destCells": {
      "binding": {
        "type": "expr",
        "config": {
          "expression": "runScript(\"BlueRidge.Location.Location.getCellsForDropdown\", 0)"
        }
      }
    }
  },
  "props": {
    "defaultSize": {
      "height": 900,
      "width": 1280
    }
  },
  "root": {
    "type": "ia.container.flex",
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "alignItems": "stretch",
      "style": {
        "classes": "canvas",
        "gap": "0px",
        "padding": "0px",
        "overflowY": "auto"
      }
    },
    "scripts": {
      "customMethods": [
        {
          "name": "resolveOutScan",
          "params": [],
          "script": "\tcode = self.view.custom.outScan\n\tif not code:\n\t\treturn\n\tr = BlueRidge.Lots.Lot.getByName(code)\n\tif r:\n\t\tself.view.custom.activeLotId = r.get(\"Id\")\n\telse:\n\t\tBlueRidge.Common.Notify.toast(\"LOT not found\", \"No LOT matches '%s'.\" % code, \"warning\")"
        },
        {
          "name": "submitTrimOut",
          "params": [],
          "script": "\tlotId = self.view.custom.activeLotId\n\tif lotId is None:\n\t\tBlueRidge.Common.Notify.toast(\"No LOT\", \"Scan or select a LOT before recording Trim OUT.\", \"warning\")\n\t\treturn\n\t# TrimOut OperationTemplate resolved by code (active version) - no business logic in view.\n\toperationTemplateId = BlueRidge.Parts.OperationTemplate.getActiveTemplateIdByCode(\"TrimOut\")\n\tif operationTemplateId is None:\n\t\tBlueRidge.Common.Notify.toast(\"Template missing\", \"No active 'TrimOut' operation template is published.\", \"error\")\n\t\treturn\n\tdest = self.view.custom.destValue\n\tif dest is None or dest == \"\":\n\t\tBlueRidge.Common.Notify.toast(\"No destination\", \"Scan or pick a Machining destination.\", \"warning\")\n\t\treturn\n\tdata = {\n\t\t\"parentLotId\": lotId,\n\t\t\"operationTemplateId\": operationTemplateId,\n\t\t\"shotCount\": self.view.custom.shotCount,\n\t\t\"scrapCount\": self.view.custom.scrapCount,\n\t\t\"destinationCellLocationId\": dest,\n\t}\n\tres = BlueRidge.Workorder.TrimOut.record(data)\n\tBlueRidge.Common.Ui.notifyResult(res, \"Trim OUT recorded\")\n\tif res.get(\"Status\"):\n\t\tsystem.perspective.navigate(\"/shop-floor/lot-detail/\" + str(lotId))"
        }
      ],
      "messageHandlers": [
        {
          "messageType": "trimInMoved",
          "pageScope": true,
          "sessionScope": false,
          "viewScope": false,
          "script": "\tself.view.custom.activeLotId = payload.get(\"lotId\")\n\t# TODO(phase4): record the TrimIn checkpoint via ProductionEvent_Record here.\n\t# Per spec 6.2 the IN tab should fire ProductionEvent.record (TrimIn template,\n\t# carried-forward cumulative counters). The cumulative shot/scrap counter inputs\n\t# are not yet collected on this tab, so the checkpoint call is deferred rather than\n\t# invented. Wire BlueRidge.Workorder.ProductionEvent.record({lotId, operationTemplateId\n\t# (TrimIn active version), shotCount, scrapCount, ...}) once those inputs exist."
        }
      ],
      "extensionFunctions": null
    },
    "children": [
      {
        "type": "ia.container.flex",
        "meta": {
          "name": "Header"
        },
        "position": {
          "basis": "auto",
          "shrink": 0
        },
        "props": {
          "direction": "row",
          "alignItems": "center",
          "style": {
            "classes": "pf-terminal-header",
            "gap": "16px",
            "padding": "20px 24px",
            "flexShrink": 0
          }
        },
        "children": [
          {
            "type": "ia.display.label",
            "meta": {
              "name": "Title"
            },
            "position": {
              "grow": 1,
              "basis": "0"
            },
            "props": {
              "text": "Trim Station",
              "style": {
                "color": "var(--mpp-text-primary)",
                "fontSize": "28px",
                "fontWeight": "600"
              }
            }
          },
          {
            "type": "ia.display.view",
            "meta": {
              "name": "InitialsField"
            },
            "position": {
              "basis": "auto",
              "shrink": 0
            },
            "props": {
              "path": "BlueRidge/Components/PlantFloor/InitialsField"
            }
          },
          {
            "type": "ia.display.view",
            "meta": {
              "name": "PausedLotIndicator"
            },
            "position": {
              "basis": "auto",
              "shrink": 0
            },
            "propConfig": {
              "props.params.locationId": {
                "binding": {
                  "type": "property",
                  "config": {
                    "path": "session.custom.terminal.zoneLocationId"
                  }
                }
              }
            },
            "props": {
              "path": "BlueRidge/Components/PlantFloor/PausedLotIndicator",
              "params": {
                "locationId": null
              }
            }
          }
        ]
      },
      {
        "type": "ia.container.flex",
        "meta": {
          "name": "ContentPanel"
        },
        "position": {
          "grow": 1,
          "basis": "0"
        },
        "props": {
          "direction": "column",
          "alignItems": "stretch",
          "style": {
            "classes": "pf-panel",
            "margin": "16px 24px",
            "padding": "0px",
            "gap": "0px",
            "overflow": "hidden"
          }
        },
        "children": [
          {
            "type": "ia.container.tab",
            "meta": {
              "name": "TabContainer"
            },
            "position": {
              "grow": 1,
              "basis": "0"
            },
            "props": {
              "currentTabIndex": 0,
              "menuType": "modern",
              "tabs": [
                {
                  "text": "IN",
                  "runWhileHidden": true,
                  "disabled": false
                },
                {
                  "text": "OUT",
                  "runWhileHidden": true,
                  "disabled": false
                }
              ],
              "menuStyle": {
                "classes": "tab-strip"
              },
              "contentStyle": {
                "classes": "tab-content-fill"
              },
              "tabStyle": {
                "active": {
                  "classes": "tab-item tab-item-active"
                },
                "inactive": {
                  "classes": "tab-item"
                },
                "disabled": {
                  "classes": "tab-item"
                }
              }
            },
            "children": [
              {
                "type": "ia.container.flex",
                "meta": {
                  "name": "PanelIn"
                },
                "position": {
                  "tabIndex": 0
                },
                "props": {
                  "direction": "column",
                  "alignItems": "stretch",
                  "style": {
                    "gap": "16px",
                    "padding": "20px 24px",
                    "overflowY": "auto"
                  }
                },
                "children": [
                  {
                    "type": "ia.display.label",
                    "meta": {
                      "name": "InHeading"
                    },
                    "position": {
                      "basis": "auto",
                      "shrink": 0
                    },
                    "props": {
                      "text": "Receive into Trim",
                      "style": {
                        "color": "var(--mpp-text-muted)",
                        "fontSize": "11px",
                        "fontWeight": "600",
                        "textTransform": "uppercase",
                        "letterSpacing": "0.08em"
                      }
                    }
                  },
                  {
                    "type": "ia.display.view",
                    "meta": {
                      "name": "MovementScan"
                    },
                    "position": {
                      "basis": "auto",
                      "shrink": 0
                    },
                    "propConfig": {
                      "props.params.destinationLocationId": {
                        "binding": {
                          "type": "property",
                          "config": {
                            "path": "session.custom.terminal.zoneLocationId"
                          }
                        }
                      }
                    },
                    "props": {
                      "path": "BlueRidge/Components/PlantFloor/MovementScan",
                      "params": {
                        "replyMessage": "trimInMoved",
                        "destinationLocationId": null
                      }
                    }
                  },
                  {
                    "type": "ia.container.flex",
                    "meta": {
                      "name": "InActions"
                    },
                    "position": {
                      "basis": "auto",
                      "shrink": 0
                    },
                    "props": {
                      "direction": "row",
                      "alignItems": "center",
                      "style": {
                        "gap": "12px"
                      }
                    },
                    "children": [
                      {
                        "type": "ia.input.button",
                        "meta": {
                          "name": "BtnRecordScrap"
                        },
                        "position": {
                          "basis": "auto",
                          "shrink": 0
                        },
                        "props": {
                          "text": "Record scrap",
                          "enabled": false,
                          "style": {
                            "classes": "pf-btn pf-btn-elevated",
                            "minHeight": "44px"
                          },
                          "toolTipText": "TODO(phase4): wire RejectEvent.record (scrap / yield loss) once scrap-source + count inputs are added to the IN tab."
                        }
                      },
                      {
                        "type": "ia.input.button",
                        "meta": {
                          "name": "BtnCorrectCount"
                        },
                        "position": {
                          "basis": "auto",
                          "shrink": 0
                        },
                        "props": {
                          "text": "Correct piece count",
                          "enabled": false,
                          "style": {
                            "classes": "pf-btn pf-btn-elevated",
                            "minHeight": "44px"
                          },
                          "toolTipText": "TODO(phase4): wire Lot.update (weight-based piece correction, FRS 2.2.3) once the weight/count inputs are added to the IN tab."
                        }
                      }
                    ]
                  }
                ]
              },
              {
                "type": "ia.container.flex",
                "meta": {
                  "name": "PanelOut"
                },
                "position": {
                  "tabIndex": 1
                },
                "props": {
                  "direction": "column",
                  "alignItems": "stretch",
                  "style": {
                    "gap": "16px",
                    "padding": "20px 24px",
                    "overflowY": "auto"
                  }
                },
                "children": [
                  {
                    "type": "ia.display.label",
                    "meta": {
                      "name": "OutHeading"
                    },
                    "position": {
                      "basis": "auto",
                      "shrink": 0
                    },
                    "props": {
                      "text": "Trim OUT - whole-LOT move to Machining",
                      "style": {
                        "color": "var(--mpp-text-muted)",
                        "fontSize": "11px",
                        "fontWeight": "600",
                        "textTransform": "uppercase",
                        "letterSpacing": "0.08em"
                      }
                    }
                  },
                  {
                    "type": "ia.container.flex",
                    "meta": {
                      "name": "OutScanRow"
                    },
                    "position": {
                      "basis": "auto",
                      "shrink": 0
                    },
                    "props": {
                      "direction": "row",
                      "alignItems": "center",
                      "style": {
                        "classes": "pf-field-row",
                        "gap": "10px"
                      }
                    },
                    "children": [
                      {
                        "type": "ia.display.label",
                        "meta": {
                          "name": "ScanLabel"
                        },
                        "position": {
                          "basis": "120px",
                          "shrink": 0
                        },
                        "props": {
                          "text": "Scan LTT",
                          "style": {
                            "classes": "pf-field-label",
                            "marginBottom": "0px"
                          }
                        }
                      },
                      {
                        "type": "ia.input.text-field",
                        "meta": {
                          "name": "OutScanInput"
                        },
                        "position": {
                          "basis": "260px",
                          "shrink": 0
                        },
                        "propConfig": {
                          "props.text": {
                            "binding": {
                              "type": "property",
                              "config": {
                                "bidirectional": true,
                                "path": "view.custom.outScan"
                              }
                            }
                          }
                        },
                        "props": {
                          "placeholder": "Scan LOT ticket",
                          "style": {
                            "classes": "pf-field-input-mono",
                            "textTransform": "uppercase",
                            "minHeight": "44px"
                          }
                        },
                        "events": {
                          "dom": {
                            "onBlur": {
                              "type": "script",
                              "scope": "G",
                              "config": {
                                "script": "\tself.view.rootContainer.resolveOutScan()"
                              }
                            }
                          }
                        }
                      },
                      {
                        "type": "ia.display.label",
                        "meta": {
                          "name": "ActiveLotLabel"
                        },
                        "position": {
                          "basis": "auto",
                          "grow": 1,
                          "shrink": 1
                        },
                        "propConfig": {
                          "props.text": {
                            "binding": {
                              "type": "expr",
                              "config": {
                                "expression": "if(isNull({view.custom.activeLotId}), \"No LOT selected\", \"LOT #\" + toStr({view.custom.activeLotId}))"
                              }
                            }
                          }
                        },
                        "props": {
                          "style": {
                            "color": "var(--mpp-text-secondary)",
                            "fontSize": "14px",
                            "marginLeft": "4px"
                          }
                        }
                      }
                    ]
                  },
                  {
                    "type": "ia.container.flex",
                    "meta": {
                      "name": "DestRow"
                    },
                    "position": {
                      "basis": "auto",
                      "shrink": 0
                    },
                    "props": {
                      "direction": "row",
                      "alignItems": "center",
                      "style": {
                        "classes": "pf-field-row",
                        "gap": "10px"
                      }
                    },
                    "children": [
                      {
                        "type": "ia.display.label",
                        "meta": {
                          "name": "DestLabel"
                        },
                        "position": {
                          "basis": "120px",
                          "shrink": 0
                        },
                        "props": {
                          "text": "Destination",
                          "style": {
                            "classes": "pf-field-label",
                            "marginBottom": "0px"
                          }
                        }
                      },
                      {
                        "type": "ia.input.dropdown",
                        "meta": {
                          "name": "DestDropdown"
                        },
                        "position": {
                          "basis": "320px",
                          "shrink": 0
                        },
                        "propConfig": {
                          "props.options": {
                            "binding": {
                              "type": "property",
                              "config": {
                                "path": "view.custom.destCells"
                              }
                            }
                          },
                          "props.value": {
                            "binding": {
                              "type": "property",
                              "config": {
                                "bidirectional": true,
                                "path": "view.custom.destValue"
                              }
                            }
                          }
                        },
                        "props": {
                          "placeholder": "Scan or pick a Machining cell",
                          "allowCustomOptions": true,
                          "search": {
                            "enabled": true
                          },
                          "style": {
                            "classes": "pf-field-select",
                            "minHeight": "44px"
                          }
                        }
                      }
                    ]
                  },
                  {
                    "type": "ia.container.flex",
                    "meta": {
                      "name": "CountsRow"
                    },
                    "position": {
                      "basis": "auto",
                      "shrink": 0
                    },
                    "props": {
                      "direction": "row",
                      "alignItems": "center",
                      "style": {
                        "classes": "pf-field-row",
                        "gap": "10px"
                      }
                    },
                    "children": [
                      {
                        "type": "ia.display.label",
                        "meta": {
                          "name": "ShotLabel"
                        },
                        "position": {
                          "basis": "120px",
                          "shrink": 0
                        },
                        "props": {
                          "text": "Shot count",
                          "style": {
                            "classes": "pf-field-label",
                            "marginBottom": "0px"
                          }
                        }
                      },
                      {
                        "type": "ia.input.numeric-entry-field",
                        "meta": {
                          "name": "ShotCountInput"
                        },
                        "position": {
                          "basis": "140px",
                          "shrink": 0
                        },
                        "propConfig": {
                          "props.value": {
                            "binding": {
                              "type": "property",
                              "config": {
                                "bidirectional": true,
                                "path": "view.custom.shotCount"
                              }
                            }
                          }
                        },
                        "props": {
                          "style": {
                            "classes": "pf-field-input",
                            "minHeight": "44px"
                          }
                        }
                      },
                      {
                        "type": "ia.display.label",
                        "meta": {
                          "name": "ScrapLabel"
                        },
                        "position": {
                          "basis": "120px",
                          "shrink": 0
                        },
                        "props": {
                          "text": "Scrap count",
                          "style": {
                            "classes": "pf-field-label",
                            "marginBottom": "0px",
                            "marginLeft": "16px"
                          }
                        }
                      },
                      {
                        "type": "ia.input.numeric-entry-field",
                        "meta": {
                          "name": "ScrapCountInput"
                        },
                        "position": {
                          "basis": "140px",
                          "shrink": 0
                        },
                        "propConfig": {
                          "props.value": {
                            "binding": {
                              "type": "property",
                              "config": {
                                "bidirectional": true,
                                "path": "view.custom.scrapCount"
                              }
                            }
                          }
                        },
                        "props": {
                          "style": {
                            "classes": "pf-field-input",
                            "minHeight": "44px"
                          }
                        }
                      }
                    ]
                  },
                  {
                    "type": "ia.container.flex",
                    "meta": {
                      "name": "OutActions"
                    },
                    "position": {
                      "basis": "auto",
                      "shrink": 0
                    },
                    "props": {
                      "direction": "row",
                      "alignItems": "center",
                      "style": {
                        "gap": "12px",
                        "marginTop": "8px"
                      }
                    },
                    "children": [
                      {
                        "type": "ia.input.button",
                        "meta": {
                          "name": "BtnTrimOut"
                        },
                        "position": {
                          "basis": "auto",
                          "shrink": 0
                        },
                        "props": {
                          "text": "Trim OUT",
                          "style": {
                            "classes": "pf-btn pf-btn-primary",
                            "minHeight": "44px",
                            "minWidth": "160px"
                          }
                        },
                        "events": {
                          "component": {
                            "onActionPerformed": {
                              "type": "script",
                              "scope": "G",
                              "config": {
                                "script": "\tself.view.rootContainer.submitTrimOut()"
                              }
                            }
                          }
                        }
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
