{
  "custom": {
    "activeLotId": null,
    "outScan": "",
    "inScan": "",
    "destCells": [],
    "destValue": null,
    "shotCount": 0,
    "scrapCount": 0,
    "trimState": "out"
  },
  "params": {},
  "propConfig": {
    "custom.destCells": {
      "binding": {
        "type": "expr",
        "config": {
          "expression": "runScript(\"BlueRidge.Location.Location.getCellsForDropdown\", 0)"
        }
      }
    }
  },
  "props": {
    "defaultSize": {
      "width": 1920,
      "height": 1080
    }
  },
  "root": {
    "type": "ia.container.flex",
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "classes": "canvas",
        "gap": "16px",
        "padding": "24px"
      }
    },
    "children": [
      {
        "type": "ia.container.flex",
        "meta": {
          "name": "Header"
        },
        "props": {
          "direction": "row",
          "alignItems": "center",
          "style": {
            "gap": "16px"
          }
        },
        "children": [
          {
            "type": "ia.container.flex",
            "meta": {
              "name": "TitleBlock"
            },
            "props": {
              "direction": "column"
            },
            "children": [
              {
                "type": "ia.display.label",
                "meta": {
                  "name": "Title"
                },
                "props": {
                  "text": "Trim Station",
                  "style": {
                    "fontSize": "22px",
                    "fontWeight": 700
                  }
                }
              },
              {
                "type": "ia.display.label",
                "meta": {
                  "name": "Subtitle"
                },
                "props": {
                  "text": "Shared Terminal - Trim Shop Area",
                  "style": {
                    "classes": "pf-kpi-sub"
                  }
                }
              }
            ],
            "position": {
              "grow": 1
            }
          },
          {
            "type": "ia.display.view",
            "meta": {
              "name": "InitialsField"
            },
            "props": {
              "path": "BlueRidge/Components/PlantFloor/InitialsField"
            },
            "position": {
              "basis": "auto",
              "shrink": 0
            }
          },
          {
            "type": "ia.display.view",
            "meta": {
              "name": "PausedLotIndicator"
            },
            "props": {
              "path": "BlueRidge/Components/PlantFloor/PausedLotIndicator",
              "params": {}
            },
            "position": {
              "basis": "auto",
              "shrink": 0
            },
            "propConfig": {
              "props.params.locationId": {
                "binding": {
                  "type": "property",
                  "config": {
                    "path": "session.custom.terminal.zoneLocationId"
                  }
                }
              }
            }
          }
        ]
      },
      {
        "type": "ia.container.flex",
        "meta": {
          "name": "ContextBar"
        },
        "props": {
          "direction": "row",
          "alignItems": "center",
          "style": {
            "classes": "pf-terminal-cell-context",
            "gap": "12px"
          }
        },
        "children": [
          {
            "type": "ia.display.label",
            "meta": {
              "name": "ActiveCellLabel"
            },
            "props": {
              "text": "Active Cell",
              "style": {
                "classes": "pf-cell-context-label"
              }
            }
          },
          {
            "type": "ia.display.label",
            "meta": {
              "name": "ActiveCellValue"
            },
            "props": {
              "text": "",
              "style": {
                "classes": "pf-cell-context-value"
              }
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "type": "expr",
                  "config": {
                    "expression": "if(isNull({session.custom.cell.name}) || {session.custom.cell.name} = \"\", \"No cell selected\", {session.custom.cell.name})"
                  }
                }
              }
            }
          },
          {
            "type": "ia.display.label",
            "meta": {
              "name": "Spacer"
            },
            "props": {
              "text": "",
              "style": {}
            },
            "position": {
              "grow": 1
            }
          },
          {
            "type": "ia.display.label",
            "meta": {
              "name": "TrimNote"
            },
            "props": {
              "text": "Trim is yield loss only - LOT keeps its cast-part identity through Trim OUT.",
              "style": {
                "classes": "pf-kpi-sub"
              }
            }
          }
        ]
      },
      {
        "type": "ia.container.flex",
        "meta": {
          "name": "StateToggle"
        },
        "props": {
          "direction": "row",
          "style": {
            "gap": "8px"
          }
        },
        "children": [
          {
            "type": "ia.input.button",
            "meta": {
              "name": "BtnStateIn"
            },
            "props": {
              "text": "Check IN",
              "style": {
                "minHeight": "40px",
                "minWidth": "150px"
              }
            },
            "propConfig": {
              "props.style.classes": {
                "binding": {
                  "type": "expr",
                  "config": {
                    "expression": "if({view.custom.trimState} = \"in\", \"pf-btn pf-btn-primary\", \"pf-btn pf-btn-secondary\")"
                  }
                }
              }
            },
            "events": {
              "component": {
                "onActionPerformed": {
                  "type": "script",
                  "scope": "G",
                  "config": {
                    "script": "\tself.view.custom.trimState = \"in\""
                  }
                }
              }
            }
          },
          {
            "type": "ia.input.button",
            "meta": {
              "name": "BtnStateOut"
            },
            "props": {
              "text": "Trim OUT",
              "style": {
                "minHeight": "40px",
                "minWidth": "150px"
              }
            },
            "propConfig": {
              "props.style.classes": {
                "binding": {
                  "type": "expr",
                  "config": {
                    "expression": "if({view.custom.trimState} = \"out\", \"pf-btn pf-btn-primary\", \"pf-btn pf-btn-secondary\")"
                  }
                }
              }
            },
            "events": {
              "component": {
                "onActionPerformed": {
                  "type": "script",
                  "scope": "G",
                  "config": {
                    "script": "\tself.view.custom.trimState = \"out\""
                  }
                }
              }
            }
          }
        ]
      },
      {
        "type": "ia.container.flex",
        "meta": {
          "name": "InPanel"
        },
        "props": {
          "direction": "column",
          "style": {
            "classes": "pf-panel",
            "gap": "12px"
          }
        },
        "children": [
          {
            "type": "ia.display.label",
            "meta": {
              "name": "InHeader"
            },
            "props": {
              "text": "Movement Scan - Receive at Trim Cell",
              "style": {
                "classes": "pf-panel-header"
              }
            }
          },
          {
            "type": "ia.display.label",
            "meta": {
              "name": "InSub"
            },
            "props": {
              "text": "Validates eligibility (v_EffectiveItemLocation) + MaxParts cap on scan-in.",
              "style": {
                "classes": "pf-kpi-sub"
              }
            }
          },
          {
            "type": "ia.display.view",
            "meta": {
              "name": "MovementScan"
            },
            "props": {
              "path": "BlueRidge/Components/PlantFloor/MovementScan",
              "params": {}
            },
            "position": {
              "basis": "auto",
              "shrink": 0
            },
            "propConfig": {
              "props.params.destinationLocationId": {
                "binding": {
                  "type": "property",
                  "config": {
                    "path": "session.custom.terminal.zoneLocationId"
                  }
                }
              }
            }
          },
          {
            "type": "ia.display.label",
            "meta": {
              "name": "InNote"
            },
            "props": {
              "text": "On scan-in the LOT moves to this Cell. Closing counters are captured on the OUT step.",
              "style": {
                "classes": "pf-field-help"
              }
            }
          }
        ],
        "propConfig": {
          "position.display": {
            "binding": {
              "type": "expr",
              "config": {
                "expression": "{view.custom.trimState} = \"in\""
              }
            }
          }
        }
      },
      {
        "type": "ia.container.flex",
        "meta": {
          "name": "OutPanel"
        },
        "props": {
          "direction": "column",
          "style": {
            "classes": "pf-panel",
            "gap": "12px"
          }
        },
        "children": [
          {
            "type": "ia.display.label",
            "meta": {
              "name": "OutHeader"
            },
            "props": {
              "text": "Trim OUT - close + route",
              "style": {
                "classes": "pf-panel-header"
              }
            }
          },
          {
            "type": "ia.display.label",
            "meta": {
              "name": "OutSub"
            },
            "props": {
              "text": "Trim is yield loss - no shot delta. Scan the LOT, pick the Machining destination, record rejects.",
              "style": {
                "classes": "pf-kpi-sub"
              }
            }
          },
          {
            "type": "ia.container.flex",
            "meta": {
              "name": "OutScanField"
            },
            "props": {
              "direction": "column",
              "style": {
                "classes": "pf-field"
              }
            },
            "children": [
              {
                "type": "ia.display.label",
                "meta": {
                  "name": "OutScanLabel"
                },
                "props": {
                  "text": "Scan LTT Barcode",
                  "style": {
                    "classes": "pf-field-label"
                  }
                }
              },
              {
                "type": "ia.input.text-field",
                "meta": {
                  "name": "OutScanInput"
                },
                "props": {
                  "placeholder": "Scan LOT ticket",
                  "style": {
                    "classes": "pf-field-input-mono",
                    "textTransform": "uppercase",
                    "minHeight": "44px"
                  }
                },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "type": "property",
                      "config": {
                        "bidirectional": true,
                        "path": "view.custom.outScan"
                      }
                    }
                  }
                },
                "events": {
                  "dom": {
                    "onBlur": {
                      "type": "script",
                      "scope": "G",
                      "config": {
                        "script": "\tself.view.rootContainer.resolveOutScan()"
                      }
                    }
                  }
                }
              },
              {
                "type": "ia.display.label",
                "meta": {
                  "name": "ActiveLotLabel"
                },
                "props": {
                  "text": "",
                  "style": {
                    "classes": "pf-field-help"
                  }
                },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "type": "expr",
                      "config": {
                        "expression": "if(isNull({view.custom.activeLotId}), \"No LOT selected\", \"LOT #\" + toStr({view.custom.activeLotId}))"
                      }
                    }
                  }
                }
              }
            ]
          },
          {
            "type": "ia.container.flex",
            "meta": {
              "name": "DestField"
            },
            "props": {
              "direction": "column",
              "style": {
                "classes": "pf-field"
              }
            },
            "children": [
              {
                "type": "ia.display.label",
                "meta": {
                  "name": "DestLabel"
                },
                "props": {
                  "text": "Destination (Machining)",
                  "style": {
                    "classes": "pf-field-label"
                  }
                }
              },
              {
                "type": "ia.input.dropdown",
                "meta": {
                  "name": "DestDropdown"
                },
                "props": {
                  "placeholder": "Select destination cell",
                  "style": {
                    "minHeight": "44px"
                  }
                },
                "propConfig": {
                  "props.options": {
                    "binding": {
                      "type": "property",
                      "config": {
                        "path": "view.custom.destCells"
                      }
                    }
                  },
                  "props.value": {
                    "binding": {
                      "type": "property",
                      "config": {
                        "bidirectional": true,
                        "path": "view.custom.destValue"
                      }
                    }
                  }
                }
              }
            ]
          },
          {
            "type": "ia.container.flex",
            "meta": {
              "name": "CountsRow"
            },
            "props": {
              "direction": "row",
              "style": {
                "gap": "12px"
              }
            },
            "children": [
              {
                "type": "ia.container.flex",
                "meta": {
                  "name": "ShotField"
                },
                "props": {
                  "direction": "column",
                  "style": {
                    "classes": "pf-field"
                  }
                },
                "children": [
                  {
                    "type": "ia.display.label",
                    "meta": {
                      "name": "ShotLabel"
                    },
                    "props": {
                      "text": "Shot count",
                      "style": {
                        "classes": "pf-field-label"
                      }
                    }
                  },
                  {
                    "type": "ia.input.numeric-entry-field",
                    "meta": {
                      "name": "ShotCountInput"
                    },
                    "props": {
                      "style": {
                        "classes": "pf-field-input",
                        "minHeight": "44px"
                      }
                    },
                    "propConfig": {
                      "props.value": {
                        "binding": {
                          "type": "property",
                          "config": {
                            "bidirectional": true,
                            "path": "view.custom.shotCount"
                          }
                        }
                      }
                    }
                  }
                ],
                "position": {
                  "grow": 1
                }
              },
              {
                "type": "ia.container.flex",
                "meta": {
                  "name": "ScrapField"
                },
                "props": {
                  "direction": "column",
                  "style": {
                    "classes": "pf-field"
                  }
                },
                "children": [
                  {
                    "type": "ia.display.label",
                    "meta": {
                      "name": "ScrapLabel"
                    },
                    "props": {
                      "text": "Scrap count",
                      "style": {
                        "classes": "pf-field-label"
                      }
                    }
                  },
                  {
                    "type": "ia.input.numeric-entry-field",
                    "meta": {
                      "name": "ScrapCountInput"
                    },
                    "props": {
                      "style": {
                        "classes": "pf-field-input",
                        "minHeight": "44px"
                      }
                    },
                    "propConfig": {
                      "props.value": {
                        "binding": {
                          "type": "property",
                          "config": {
                            "bidirectional": true,
                            "path": "view.custom.scrapCount"
                          }
                        }
                      }
                    }
                  }
                ],
                "position": {
                  "grow": 1
                }
              }
            ]
          },
          {
            "type": "ia.container.flex",
            "meta": {
              "name": "OutActions"
            },
            "props": {
              "direction": "row",
              "alignItems": "center",
              "style": {
                "classes": "pf-actions",
                "gap": "8px"
              }
            },
            "children": [
              {
                "type": "ia.input.button",
                "meta": {
                  "name": "BtnTrimOut"
                },
                "props": {
                  "text": "Trim OUT",
                  "style": {
                    "classes": "pf-btn pf-btn-primary pf-btn-large",
                    "minHeight": "44px",
                    "minWidth": "160px"
                  }
                },
                "events": {
                  "component": {
                    "onActionPerformed": {
                      "type": "script",
                      "scope": "G",
                      "config": {
                        "script": "\tself.view.rootContainer.submitTrimOut()"
                      }
                    }
                  }
                }
              },
              {
                "type": "ia.display.label",
                "meta": {
                  "name": "OutActionsSpacer"
                },
                "props": {
                  "text": "",
                  "style": {}
                },
                "position": {
                  "grow": 1
                }
              },
              {
                "type": "ia.display.label",
                "meta": {
                  "name": "OutActionsNote"
                },
                "props": {
                  "text": "Whole-LOT move - no split at Trim (sub-LOT split is at Machining OUT).",
                  "style": {
                    "classes": "pf-kpi-sub"
                  }
                }
              }
            ]
          }
        ],
        "propConfig": {
          "position.display": {
            "binding": {
              "type": "expr",
              "config": {
                "expression": "{view.custom.trimState} = \"out\""
              }
            }
          }
        }
      }
    ],
    "scripts": {
      "customMethods": [
        {
          "name": "resolveOutScan",
          "params": [],
          "script": "\tcode = self.view.custom.outScan\n\tif not code:\n\t\treturn\n\tr = BlueRidge.Lots.Lot.getByName(code)\n\tif r:\n\t\tself.view.custom.activeLotId = r.get(\"Id\")\n\telse:\n\t\tBlueRidge.Common.Notify.toast(\"LOT not found\", \"No LOT matches '%s'.\" % code, \"warning\")"
        },
        {
          "name": "submitTrimOut",
          "params": [],
          "script": "\tlotId = self.view.custom.activeLotId\n\tif lotId is None:\n\t\tBlueRidge.Common.Notify.toast(\"No LOT\", \"Scan or select a LOT before recording Trim OUT.\", \"warning\")\n\t\treturn\n\toperationTemplateId = BlueRidge.Parts.OperationTemplate.getActiveTemplateIdByCode(\"TrimOut\")\n\tif operationTemplateId is None:\n\t\tBlueRidge.Common.Notify.toast(\"Template missing\", \"No active 'TrimOut' operation template is published.\", \"error\")\n\t\treturn\n\tdest = self.view.custom.destValue\n\tif dest is None or dest == \"\":\n\t\tBlueRidge.Common.Notify.toast(\"No destination\", \"Scan or pick a Machining destination.\", \"warning\")\n\t\treturn\n\tdata = {\n\t\t\"parentLotId\": lotId,\n\t\t\"operationTemplateId\": operationTemplateId,\n\t\t\"shotCount\": self.view.custom.shotCount,\n\t\t\"scrapCount\": self.view.custom.scrapCount,\n\t\t\"destinationCellLocationId\": dest,\n\t}\n\tres = BlueRidge.Workorder.TrimOut.record(data)\n\tBlueRidge.Common.Ui.notifyResult(res, \"Trim OUT recorded\")\n\tif res.get(\"Status\"):\n\t\tsystem.perspective.navigate(\"/shop-floor/lot-detail/\" + str(lotId))"
        }
      ],
      "messageHandlers": [
        {
          "messageType": "trimInMoved",
          "pageScope": true,
          "sessionScope": false,
          "viewScope": false,
          "script": "\tself.view.custom.activeLotId = payload.get(\"lotId\")\n\tself.view.custom.trimState = \"out\"\n\t# TODO(phase4): record the TrimIn checkpoint via ProductionEvent.record once cumulative inputs exist."
        }
      ],
      "extensionFunctions": null
    }
  }
}
