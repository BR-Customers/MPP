{
  "custom": {
    "activeLotId": "",
    "activeLotName": null,
    "destValue": null,
    "inScan": "",
    "outScan": "",
    "refreshToken": 0,
    "scrapCount": null,
    "shotCount": null,
    "lotPieceCount": null,
    "trimState": "in"
  },
  "params": {
    "areaId": 37,
    "cellPickerEnabled": false
  },
  "propConfig": {
    "custom.cells": {
      "binding": {
        "config": {
          "expression": "runScript(\"BlueRidge.Location.Terminal.getContextCellsForDropdown\", 0, {session.custom.terminal.terminalLocationId}, \"Trim Press\")"
        },
        "type": "expr"
      }
    },
    "custom.destCells": {
      "binding": {
        "config": {
          "expression": "runScript(\"BlueRidge.Location.Location.getMachiningDestinationsForDropdown\", 0, {view.custom.activeLotId}, {view.custom.refreshToken})"
        },
        "type": "expr"
      }
    },
    "custom.trimInventory": {
      "binding": {
        "config": {
          "expression": "if(isNull({session.custom.terminal.zoneLocationId}), \"\", runScript(\"BlueRidge.Lots.Lot.getWipQueueByLocation\", 0, {session.custom.terminal.zoneLocationId}, true, {view.custom.refreshToken}))"
        },
        "type": "expr"
      }
    },
    "custom.scrapCount": {
      "onChange": {
        "enabled": true,
        "script": "\tlp = self.view.custom.lotPieceCount\n\tif lp is None:\n\t\treturn\n\ts = currentValue.value\n\ttry:\n\t\ts = int(s) if s not in (None, \"\") else 0\n\texcept (ValueError, TypeError):\n\t\ts = 0\n\tself.view.custom.shotCount = max(0, int(lp) - s)"
      }
    },
    "params.cellPickerEnabled": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "width": 1280
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "children": [
