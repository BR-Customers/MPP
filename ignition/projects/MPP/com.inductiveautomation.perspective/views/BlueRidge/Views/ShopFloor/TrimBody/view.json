    "children": [
      {
        "children": [
          {
            "children": [
              {
                "meta": {
                  "name": "Title"
                },
                "props": {
                  "style": {
                    "fontSize": "22px",
                    "fontWeight": 700
                  },
                  "text": "Trim Station"
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "Subtitle"
                },
                "props": {
                  "style": {
                    "classes": "pf-kpi-sub"
