{
  "custom": {
    "activeLotId": null,
    "destValue": null,
    "inScan": "",
    "outScan": "",
    "refreshToken": 0,
    "scrapCount": null,
    "shotCount": null,
    "trimInventory": [],
    "trimState": "in"
  },
  "params": {
    "areaId": null
  },
  "propConfig": {
    "custom.destCells": {
      "binding": {
        "config": {
          "expression": "runScript(\"BlueRidge.Location.Location.getMachiningDestinationsForDropdown\", 0)"
        },
        "type": "expr"
      }
    },
    "custom.trimInventory": {
      "binding": {
        "config": {
          "expression": "runScript(\"BlueRidge.Lots.Lot.getWipQueueByLocation\", 0, {session.custom.terminal.zoneLocationId}, false, {view.custom.refreshToken})"
        },
        "type": "expr"
      }
    }
  },
  "props": {
    "defaultSize": {
      "width": 1280
    }
  },
