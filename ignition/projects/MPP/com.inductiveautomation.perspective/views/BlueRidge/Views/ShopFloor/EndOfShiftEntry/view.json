{
  "custom": {
    "filter": { "cellLocationId": null },
    "selectedBreaks": [],
    "breakFilter": { "areaLocationId": null, "downtimeReasonTypeId": null, "includeDeprecated": false, "searchText": "" }
  },
  "params": {},
  "propConfig": {
    "custom.shift": {
      "binding": { "config": { "expression": "runScript(\"BlueRidge.Oee.Shift.getOpen\", 0)" }, "type": "expr" }
    },
    "custom.cellOptions": {
      "binding": {
        "config": { "expression": "runScript(\"BlueRidge.Location.Location.listByTier\", 0, \"Cell\")" },
        "transforms": [
          { "code": "\treturn [{\"value\": r.get(\"Id\"), \"label\": (r.get(\"Code\") or \"\") + \" - \" + (r.get(\"Name\") or \"\")} for r in (value or [])]", "type": "script" }
        ],
        "type": "expr"
      }
    },
    "custom.breakItems": {
      "binding": {
        "config": { "expression": "runScript(\"BlueRidge.Oee.DowntimeReasonCode.search\", 0, {view.custom.breakFilter})" },
        "transforms": [
          { "code": "\treturn [{\"breakId\": r.get(\"Id\"), \"label\": r.get(\"Code\")} for r in (value or []) if r.get(\"ReasonTypeName\") == \"Break\"]", "type": "script" }
        ],
        "type": "expr"
      }
    }
  },
  "props": {
    "defaultSize": { "height": 1080, "width": 1920 }
  },
  "root": {
    "children": [
      {
        "meta": { "name": "Header" },
        "position": { "shrink": 0 },
        "props": { "text": "End of Shift", "style": { "fontSize": "22px", "fontWeight": "700", "padding": "16px", "borderBottom": "1px solid var(--mpp-border-subtle)" } },
        "type": "ia.display.label"
      },
      {
        "children": [
          {
            "meta": { "name": "ShiftStatus" },
            "position": { "shrink": 0 },
            "propConfig": {
              "props.text": { "binding": { "config": { "expression": "if(isNull({view.custom.shift}), 'No active shift — start a shift first', 'Active shift #' + toStr({view.custom.shift.Id}))" }, "type": "expr" } },
              "props.style.color": { "binding": { "config": { "expression": "if(isNull({view.custom.shift}), 'var(--pf-status-warn-fg)', 'var(--mpp-text-primary)')" }, "type": "expr" } }
            },
            "props": { "style": { "fontWeight": "600" } },
            "type": "ia.display.label"
          },
          {
            "children": [
              { "meta": { "name": "MachineLabel" }, "props": { "text": "Cell", "style": { "classes": "pf-field-label" } }, "type": "ia.display.label" },
              {
                "meta": { "name": "CellSelect" },
                "propConfig": {
                  "props.options": { "binding": { "config": { "path": "view.custom.cellOptions" }, "type": "property" } },
                  "props.value": { "binding": { "config": { "path": "view.custom.filter.cellLocationId", "bidirectional": true }, "type": "property" } }
                },
                "props": { "placeholder": "Select cell", "style": { "classes": "pf-field-input" } },
                "type": "ia.input.dropdown"
              }
            ],
            "meta": { "name": "MachineField" },
            "position": { "basis": "320px", "shrink": 0 },
            "props": { "direction": "column", "style": { "classes": "pf-field", "gap": "4px" } },
            "type": "ia.container.flex"
          },
          { "meta": { "name": "BreaksLabel" }, "position": { "shrink": 0 }, "props": { "text": "Breaks taken (tap each break you took):", "style": { "classes": "pf-field-label" } }, "type": "ia.display.label" },
          {
            "meta": { "name": "BreakToggles" },
            "position": { "shrink": 0 },
            "propConfig": {
              "props.instances": { "binding": { "config": { "path": "view.custom.breakItems" }, "type": "property" } }
            },
            "props": {
              "direction": "row",
              "wrap": "wrap",
              "elementPosition": { "basis": "180px", "shrink": 0 },
              "path": "BlueRidge/Components/PlantFloor/EndOfShift/BreakToggle",
              "style": { "gap": "12px" },
              "useDefaultViewHeight": false,
              "useDefaultViewWidth": false
            },
            "type": "ia.display.flex-repeater"
          },
          {
            "events": {
              "component": {
                "onActionPerformed": {
                  "type": "script",
                  "scope": "G",
                  "config": {
                    "script": "\tshift = self.view.custom.shift\n\tcellId = self.view.custom.filter.cellLocationId\n\tif not shift:\n\t\tBlueRidge.Common.Ui.notifyResult({\"Status\": False, \"Message\": \"No active shift to submit against.\"}, \"End of shift\")\n\t\treturn\n\tif cellId is None:\n\t\tBlueRidge.Common.Ui.notifyResult({\"Status\": False, \"Message\": \"Select a cell first.\"}, \"End of shift\")\n\t\treturn\n\tresult = BlueRidge.Oee.DowntimeEvent.submitEndOfShift(shift[\"Id\"], cellId, system.util.jsonEncode(self.view.custom.selectedBreaks or []))\n\tBlueRidge.Common.Ui.notifyResult(result, \"End-of-shift submitted\")\n\tif result and result.get(\"Status\"):\n\t\tself.view.custom.selectedBreaks = []\n\t\tsystem.perspective.sendMessage(\"breakReset\", scope=\"page\")"
                  }
                }
              }
            },
            "meta": { "name": "SubmitButton" },
            "position": { "shrink": 0 },
            "props": { "style": { "classes": "pf-btn pf-btn-primary pf-btn-large" }, "text": "Submit Shift Time Entry" },
            "type": "ia.input.button"
          }
        ],
        "meta": { "name": "Body" },
        "position": { "grow": 1 },
        "props": { "direction": "column", "style": { "classes": "pf-panel", "gap": "16px", "margin": "16px", "padding": "16px" } },
        "type": "ia.container.flex"
      }
    ],
    "meta": { "name": "root" },
    "props": { "direction": "column", "style": { "classes": "canvas" } },
    "scripts": {
      "customMethods": [],
      "extensionFunctions": null,
      "messageHandlers": [
        {
          "messageType": "breakToggled",
          "pageScope": true,
          "script": "\tbid = payload[\"breakId\"]\n\ton = payload[\"on\"]\n\tsel = list(self.view.custom.selectedBreaks or [])\n\tif on and bid not in sel:\n\t\tsel.append(bid)\n\telif (not on) and bid in sel:\n\t\tsel.remove(bid)\n\tself.view.custom.selectedBreaks = sel",
          "sessionScope": false,
          "viewScope": false
        }
      ]
    },
    "type": "ia.container.flex"
  }
}
