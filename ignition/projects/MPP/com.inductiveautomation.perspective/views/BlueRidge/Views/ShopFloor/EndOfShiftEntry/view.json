{
  "custom": {
    "breakFilter": {
      "areaLocationId": null,
      "downtimeReasonTypeId": null,
      "includeDeprecated": false,
      "searchText": ""
    },
    "filter": {
      "cellLocationId": null
    },
    "selectedBreaks": []
  },
  "params": {},
  "propConfig": {
    "custom.breakItems": {
      "binding": {
        "config": {
          "expression": "runScript(\"BlueRidge.Oee.DowntimeReasonCode.search\", 0, {view.custom.breakFilter})"
        },
        "transforms": [
          {
            "code": "\treturn [{\"breakId\": r.get(\"Id\"), \"label\": r.get(\"Code\")} for r in (value or []) if r.get(\"ReasonTypeName\") \u003d\u003d \"Break\"]",
            "type": "script"
          }
        ],
        "type": "expr"
      }
    },
    "custom.cellOptions": {
      "binding": {
        "config": {
          "expression": "runScript(\"BlueRidge.Location.Location.listByTier\", 0, \"Cell\")"
        },
        "transforms": [
          {
            "code": "\treturn [{\"value\": r.get(\"Id\"), \"label\": (r.get(\"Code\") or \"\") + \" - \" + (r.get(\"Name\") or \"\")} for r in (value or [])]",
            "type": "script"
          }
        ],
        "type": "expr"
      }
    },
    "custom.shift": {
      "binding": {
        "config": {
          "expression": "runScript(\"BlueRidge.Oee.Shift.getOpenOrEmpty\", 0)"
        },
        "type": "expr"
      }
    }
  },
  "props": {
    "defaultSize": {
      "width": 1280
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "Header"
        },
        "position": {
          "shrink": 0
        },
        "props": {
          "style": {
            "borderBottom": "1px solid var(--mpp-border-subtle)",
            "fontSize": "22px",
            "fontWeight": "700",
            "padding": "16px"
          },
          "text": "End of Shift"
        },
        "type": "ia.display.label"
      },
      {
        "children": [
          {
            "meta": {
              "name": "ShiftStatus"
            },
            "position": {
              "shrink": 0
            },
            "propConfig": {
              "props.style.color": {
                "binding": {
                  "config": {
                    "expression": "if(isNull({view.custom.shift.Id}), \u0027var(--pf-status-warn-fg)\u0027, \u0027var(--mpp-text-primary)\u0027)"
                  },
                  "type": "expr"
                }
              },
              "props.text": {
                "binding": {
                  "config": {
                    "expression": "if(isNull({view.custom.shift.Id}), \u0027No active shift — start a shift first\u0027, \u0027Active shift #\u0027 + toStr({view.custom.shift.Id}))"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "fontWeight": "600"
              }
            },
            "type": "ia.display.label"
          },
          {
            "children": [
              {
                "meta": {
                  "name": "MachineLabel"
                },
                "props": {
                  "style": {
                    "classes": "pf-field-label"
                  },
                  "text": "Cell"
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "CellSelect"
                },
                "propConfig": {
                  "props.options": {
                    "binding": {
                      "config": {
                        "path": "view.custom.cellOptions"
                      },
                      "type": "property"
                    }
                  },
                  "props.value": {
                    "binding": {
                      "config": {
                        "bidirectional": true,
                        "path": "view.custom.filter.cellLocationId"
                      },
                      "type": "property"
                    }
                  }
                },
                "props": {
                  "placeholder": "Select cell",
                  "style": {
                    "classes": "pf-field-input"
                  }
                },
                "type": "ia.input.dropdown"
              }
            ],
            "meta": {
              "name": "MachineField"
            },
            "position": {
              "basis": "320px",
              "shrink": 0
            },
            "props": {
              "direction": "column",
              "style": {
                "classes": "pf-field",
                "gap": "4px",
                "overflow": "visible"
              }
            },
            "type": "ia.container.flex"
          },
          {
            "meta": {
              "name": "BreaksLabel"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "style": {
                "classes": "pf-field-label"
              },
              "text": "Breaks taken (tap each break you took):"
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "BreakToggles"
            },
            "position": {
              "shrink": 0
            },
            "propConfig": {
              "props.instances": {
                "binding": {
                  "config": {
                    "path": "view.custom.breakItems"
                  },
                  "type": "property"
                }
              }
            },
            "props": {
              "elementPosition": {
                "basis": "180px",
                "shrink": 0
              },
              "path": "BlueRidge/Components/PlantFloor/EndOfShift/BreakToggle",
              "style": {
                "gap": "12px"
              },
              "useDefaultViewHeight": false,
              "useDefaultViewWidth": false,
              "wrap": "wrap"
            },
            "type": "ia.display.flex-repeater"
          },
          {
            "events": {
              "component": {
                "onActionPerformed": {
                  "config": {
                    "script": "\tshift \u003d self.view.custom.shift\n\tcellId \u003d self.view.custom.filter.cellLocationId\n\tif not shift or shift.get(\"Id\") is None:\n\t\tBlueRidge.Common.Ui.notifyResult({\"Status\": False, \"Message\": \"No active shift to submit against.\"}, \"End of shift\")\n\t\treturn\n\tif cellId is None:\n\t\tBlueRidge.Common.Ui.notifyResult({\"Status\": False, \"Message\": \"Select a cell first.\"}, \"End of shift\")\n\t\treturn\n\tresult \u003d BlueRidge.Oee.DowntimeEvent.submitEndOfShift(shift[\"Id\"], cellId, system.util.jsonEncode(self.view.custom.selectedBreaks or []))\n\tBlueRidge.Common.Ui.notifyResult(result, \"End-of-shift submitted\")\n\tif result and result.get(\"Status\"):\n\t\tself.view.custom.selectedBreaks \u003d []\n\t\tsystem.perspective.sendMessage(\"breakReset\", scope\u003d\"page\")"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "SubmitButton"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "style": {
                "classes": "pf-btn pf-btn-primary pf-btn-large"
              },
              "text": "Submit Shift Time Entry"
            },
            "type": "ia.input.button"
          }
        ],
        "meta": {
          "name": "Body"
        },
        "position": {
          "grow": 1
        },
        "props": {
          "direction": "column",
          "style": {
            "classes": "pf-panel",
            "gap": "16px",
            "margin": "16px",
            "padding": "16px"
          }
        },
        "type": "ia.container.flex"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "classes": "canvas"
      }
    },
    "scripts": {
      "customMethods": [],
      "extensionFunctions": null,
      "messageHandlers": [
        {
          "messageType": "breakToggled",
          "pageScope": true,
          "script": "\tbid \u003d payload[\"breakId\"]\n\ton \u003d payload[\"on\"]\n\tsel \u003d list(self.view.custom.selectedBreaks or [])\n\tif on and bid not in sel:\n\t\tsel.append(bid)\n\telif (not on) and bid in sel:\n\t\tsel.remove(bid)\n\tself.view.custom.selectedBreaks \u003d sel",
          "sessionScope": false,
          "viewScope": false
        }
      ]
    },
    "type": "ia.container.flex"
  }
}