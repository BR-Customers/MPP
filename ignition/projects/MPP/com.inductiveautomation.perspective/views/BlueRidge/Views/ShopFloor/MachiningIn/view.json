                "propConfig": {
                  "props.text": {
                    "binding": {
                      "config": {
                        "expression": "if(isNull({view.custom.activeMachined.lotName}) || {view.custom.activeMachined.lotName} \u003d \"\", \"(machined LOT)\", {view.custom.activeMachined.lotName})"
                      },
