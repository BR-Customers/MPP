                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "QueueSub"
                },
                "props": {
                  "style": {
                    "classes": "pf-kpi-sub"
                  },
                  "text": "Whole cast/trim LOTs moved here at Trim OUT (1:1). No scan-to-receive - pick from queue; BOM-driven rename fires on pick."
                },
                "type": "ia.display.label"
              }
            ],
            "meta": {
              "name": "QueueHeader"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "direction": "column",
              "style": {
                "alignItems": "flex-start",
                "classes": "pf-panel-header",
                "gap": "4px"
              }
            },
            "type": "ia.container.flex"
          },
          {
            "meta": {
              "name": "EmptyHint"
            },
            "position": {
              "shrink": 0
            },
            "propConfig": {
              "position.display": {
                "binding": {
                  "config": {
                    "expression": "len({view.custom.queue}) = 0"
                  },
                  "type": "expr"
                }
              },
              "props.text": {
                "binding": {
                  "config": {
                    "expression": "if(isNull({session.custom.cell.locationId}), 'No cell is bound to this terminal.', 'This cell has no LOTs queued.')"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "classes": "pf-kpi-sub"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "QueueRepeater"
            },
            "position": {
              "basis": "0",
              "grow": 1
            },
            "propConfig": {
              "props.instances": {
                "binding": {
                  "config": {
                    "path": "view.custom.queue"
                  },
                  "type": "property"
                }
              }
            },
            "props": {
              "direction": "column",
              "elementPosition": {
                "basis": "92px",
                "shrink": 0
              },
              "path": "BlueRidge/Components/PlantFloor/Machining/QueueRow",
              "style": {
                "gap": "8px",
                "overflowY": "auto"
              },
              "useDefaultViewWidth": false
            },
            "type": "ia.display.flex-repeater"
          },
          {
            "meta": {
              "name": "QueueFootnote"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "style": {
                "classes": "pf-kpi-sub"
              },
              "text": "Override-FIFO selection prompts for an optional reason (recorded). Held LOTs cannot be picked until the hold is released."
            },
            "type": "ia.display.label"
          }
        ],
        "meta": {
          "name": "QueuePanel"
        },
        "position": {
          "basis": "0",
          "grow": 1
        },
        "props": {
          "direction": "column",
          "style": {
            "classes": "pf-panel",
            "gap": "12px",
            "overflow": "hidden",
            "padding": "14px 16px"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "children": [
              {
                "meta": {
                  "name": "ActiveTitle"
                },
                "props": {
                  "style": {
                    "color": "var(--mpp-text-secondary)",
                    "fontSize": "14px",
                    "fontWeight": "600",
                    "letterSpacing": "0.06em",
                    "textTransform": "uppercase"
                  },
                  "text": "Active machined LOT (after pick)"
                },
