                  },
                  "type": "expr"
                }
              },
              "props.text": {
                "binding": {
                  "config": {
                    "expression": "if(isNull({session.custom.cell.locationId}), \u0027No cell is bound to this terminal.\u0027, \u0027This cell has no LOTs queued.\u0027)"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "classes": "pf-kpi-sub"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "QueueRepeater"
            },
            "position": {
              "basis": "0",
              "grow": 1
            },
