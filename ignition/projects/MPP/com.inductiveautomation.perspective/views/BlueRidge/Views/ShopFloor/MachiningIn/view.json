{
  "custom": {
    "pending": {
      "lotName": "",
      "sourceItem": "",
      "sourceLotId": null
    },
    "refreshToken": 0
  },
  "params": {},
  "propConfig": {
    "custom.activeMachined": {
      "binding": {
        "config": {
          "expression": "if({view.custom.refreshToken} \u003e\u003d 0 \u0026\u0026 !isNull({session.custom.cell.locationId}), runScript(\"BlueRidge.Lots.Lot.getWipQueueByLocation\", 0, {session.custom.cell.locationId}, true, {view.custom.refreshToken}, \"MachiningOut\"), \"\")"
        },
        "transforms": [
          {
            "code": "\tmachined \u003d value or []\n\tr \u003d machined[-1] if machined else {}\n\treturn {\"Id\": r.get(\"Id\"), \"lotName\": r.get(\"LotName\") or \"\", \"itemPartNumber\": r.get(\"ItemPartNumber\") or \"\", \"pieceCount\": r.get(\"PieceCount\") or 0}",
            "type": "script"
          }
        ],
        "type": "expr"
      }
    },
    "custom.holdCount": {
      "binding": {
        "config": {
          "path": "view.custom.queue"
        },
        "transforms": [
          {
            "code": "\treturn len([r for r in (value or []) if (r.get(\"lotStatusCode\") or \"\") !\u003d \"Good\"])",
            "type": "script"
          }
        ],
        "type": "property"
      }
    },
    "custom.queue": {
      "binding": {
        "config": {
          "expression": "if({view.custom.refreshToken} \u003e\u003d 0, runScript(\"BlueRidge.Lots.Lot.getWipQueueByLocation\", 0, 4, true, {view.custom.refreshToken}, \"MachiningIn\"), \"\")"
        },
        "transforms": [
          {
            "code": "\treturn value\n\t#rows \u003d value or []\n\t#return [{\"sourceLotId\": r.get(\"Id\"), \"lotName\": r.get(\"LotName\") or \"\", \"sourceItem\": r.get(\"ItemPartNumber\") or \"\", \"pieceCount\": r.get(\"PieceCount\") or 0, \"arrival\": str(r.get(\"LastMovementAt\") or \"\"), \"position\": i + 1, \"lotStatusCode\": r.get(\"LotStatusCode\") or \"\"} for i, r in enumerate(rows)]",
            "type": "script"
          }
        ],
        "type": "expr"
      }
    }
  },
  "props": {
    "defaultSize": {
      "width": 1280
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "children": [
