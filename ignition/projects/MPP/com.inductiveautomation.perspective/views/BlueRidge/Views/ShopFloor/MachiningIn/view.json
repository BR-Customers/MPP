              }
            ],
            "meta": {
              "name": "ActiveHeader"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "style": {
                "classes": "pf-panel-header"
              }
            },
            "type": "ia.container.flex"
          },
          {
            "children": [
              {
                "meta": {
                  "name": "ActiveEmptyText"
