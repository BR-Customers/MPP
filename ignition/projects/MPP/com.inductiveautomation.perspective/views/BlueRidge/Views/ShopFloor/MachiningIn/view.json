        },
        "position": {
          "basis": "0",
          "grow": 1
        },
        "props": {
          "direction": "column",
          "style": {
            "classes": "pf-panel",
            "gap": "12px",
            "overflow": "hidden",
            "padding": "14px 16px"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
