              "style": {
                "classes": "pf-kpi-sub"
              },
              "text": "Dedicated terminal - cell fixed by terminal binding."
            },
            "type": "ia.display.label"
          }
        ],
        "meta": {
          "name": "CellContext"
        },
        "props": {
          "alignItems": "center",
          "style": {
            "classes": "pf-terminal-cell-context",
            "gap": "12px"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "children": [
