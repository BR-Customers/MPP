              }
            ],
            "meta": {
              "name": "ActiveHeader"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "style": {
                "classes": "pf-panel-header"
              }
            },
            "type": "ia.container.flex"
          },
          {
            "children": [
              {
                "meta": {
                  "name": "ActiveEmptyText"
                },
                "props": {
                  "style": {
                    "fontSize": "13px",
                    "maxWidth": "480px",
                    "textAlign": "center"
                  },
                  "text": "No LOT picked yet. Pick a LOT above to fire the BOM-Driven Rename Confirmation. On confirm, a new machined LOT is created from this whole LOT."
                },
                "type": "ia.display.label"
              }
            ],
            "meta": {
              "name": "ActiveEmpty"
            },
            "position": {
              "shrink": 0
            },
            "propConfig": {
              "position.display": {
                "binding": {
                  "config": {
                    "expression": "isNull({view.custom.activeMachined.Id})"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "alignItems": "center",
              "direction": "column",
              "justify": "center",
              "style": {
                "classes": "pf-empty-state",
                "gap": "8px",
                "padding": "32px 24px"
              }
            },
            "type": "ia.container.flex"
          },
          {
            "children": [
              {
                "meta": {
                  "name": "ActiveCardName"
                },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "config": {
                        "expression": "if(isNull({view.custom.activeMachined.lotName}) || {view.custom.activeMachined.lotName} = \"\", \"(machined LOT)\", {view.custom.activeMachined.lotName})"
                      },
                      "type": "expr"
                    }
                  }
                },
                "props": {
                  "style": {
                    "classes": "pf-kpi-value",
                    "fontSize": "18px"
                  }
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "ActiveCardSub"
                },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "config": {
                        "expression": "{view.custom.activeMachined.itemPartNumber} + \"  |  \" + toStr({view.custom.activeMachined.pieceCount}) + \" pcs  |  machined LOT #\" + toStr({view.custom.activeMachined.Id})"
                      },
                      "type": "expr"
                    }
                  }
                },
                "props": {
                  "style": {
                    "classes": "pf-kpi-sub"
                  }
                },
                "type": "ia.display.label"
              }
            ],
            "meta": {
              "name": "ActiveCard"
            },
            "position": {
              "shrink": 0
            },
            "propConfig": {
              "position.display": {
                "binding": {
                  "config": {
                    "expression": "!isNull({view.custom.activeMachined.Id})"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "direction": "column",
              "style": {
                "backgroundColor": "var(--mpp-surface-raised)",
                "border": "1px solid var(--mpp-border-default)",
                "borderRadius": "8px",
                "gap": "6px",
                "padding": "16px"
              }
            },
            "type": "ia.container.flex"
          }
        ],
        "meta": {
          "name": "ActiveLotPanel"
        },
        "position": {
          "shrink": 0
        },
        "props": {
          "direction": "column",
          "style": {
            "classes": "pf-panel",
            "gap": "12px",
            "padding": "14px 16px"
          }
        },
        "type": "ia.container.flex"
      }
    ],
    "events": {
      "system": {
        "onStartup": {
          "type": "script",
          "scope": "G",
          "config": {
            "script": "\t# Dedicated-flavor context (FDS-02-010): bind the cell to the terminal's parent line.\n\tt = self.session.custom.terminal\n\tif t and t.get(\"zoneLocationId\"):\n\t\tself.session.custom.cell = {\"locationId\": t.get(\"zoneLocationId\"), \"code\": t.get(\"zoneName\") or \"\", \"name\": t.get(\"zoneName\") or \"\"}\n\ttry:\n\t\tself.session.custom.presence.policy = \"confirm\"\n\texcept:\n\t\tself.session.custom.presence = {\"policy\": \"confirm\"}\n\tif not self.session.custom.appUserId:\n\t\tsystem.perspective.openPopup(\"mpp-initials\", \"BlueRidge/Components/Popups/InitialsEntry\", params={\"popupId\": \"mpp-initials\"}, modal=True, showCloseIcon=False, overlayDismiss=False)"
          }
        }
      }
    },
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "classes": "pf-terminal canvas",
        "gap": "16px",
        "overflowY": "auto",
        "padding": "16px"
      }
    },
    "scripts": {
      "customMethods": [],
      "extensionFunctions": null,
      "messageHandlers": [
        {
          "messageType": "machiningPick",
          "pageScope": true,
          "script": "\tself.view.custom.pending = {\"sourceLotId\": payload.get(\"sourceLotId\"), \"lotName\": payload.get(\"lotName\") or \"\", \"sourceItem\": payload.get(\"sourceItem\") or \"\"}\n\tmsg = \"Pick LOT \" + (payload.get(\"lotName\") or \"\") + \" (\" + (payload.get(\"sourceItem\") or \"\") + \") and rename via its machining BOM?\"\n\tsystem.perspective.openPopup(\"mpp-bom-rename\", \"BlueRidge/Components/Popups/BomRenameConfirm\", params={\"title\": \"Machining IN - Pick & Rename\", \"message\": msg, \"replyMessage\": \"bomRenameResult\", \"popupId\": \"mpp-bom-rename\"}, modal=True)",
          "sessionScope": false,
          "viewScope": false
        },
        {
          "messageType": "bomRenameResult",
          "pageScope": true,
          "script": "\tif payload.get(\"action\") != \"confirm\":\n\t\treturn\n\tp = self.view.custom.pending\n\tcellId = self.session.custom.cell.locationId\n\tif not p or p.get(\"sourceLotId\") is None or cellId is None:\n\t\treturn\n\tresult = BlueRidge.Workorder.Machining.pickAndConsume(p.get(\"sourceLotId\"), cellId, None, self.session.custom.appUserId)\n\tBlueRidge.Common.Ui.notifyResult(result, \"Machining IN\")\n\tif result and result.get(\"Status\"):\n\t\tself.view.custom.pending = {\"sourceLotId\": None, \"lotName\": \"\", \"sourceItem\": \"\"}\n\t\tself.view.custom.refreshToken = (self.view.custom.refreshToken or 0) + 1",
          "sessionScope": false,
          "viewScope": false
        }
      ]
    },
    "type": "ia.container.flex"
  }
}
