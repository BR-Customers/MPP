                    "binding": {
                      "config": {
                        "expression": "if(isNull({session.custom.cell.name}) || {session.custom.cell.name} \u003d \"\", \"No cell bound\", {session.custom.cell.name}) + \"  ·  5G0 Machining WC - dedicated terminal - whole-LOT FIFO pick\""
                      },
                      "type": "expr"
                    }
                  }
                },
                "props": {
                  "style": {
                    "classes": "pf-kpi-sub"
                  }
