{
  "custom": {
    "pending": {
      "lotName": "",
      "sourceItem": "",
      "sourceLotId": null
    },
    "refreshToken": 0
  },
  "params": {},
  "propConfig": {
    "custom.activeMachined": {
      "binding": {
        "config": {
          "expression": "if({view.custom.refreshToken} >= 0 && !isNull({session.custom.cell.locationId}), runScript(\"BlueRidge.Lots.Lot.getWipQueueByLocation\", 0, {session.custom.cell.locationId}, false, {view.custom.refreshToken}), \"\")"
        },
        "transforms": [
          {
            "code": "\tmachined = [r for r in (value or []) if not r.get(\"HasRenameBom\")]\n\tr = machined[-1] if machined else {}\n\treturn {\"Id\": r.get(\"Id\"), \"lotName\": r.get(\"LotName\") or \"\", \"itemPartNumber\": r.get(\"ItemPartNumber\") or \"\", \"pieceCount\": r.get(\"PieceCount\") or 0}",
            "type": "script"
          }
        ],
        "type": "expr"
      }
    },
    "custom.holdCount": {
      "binding": {
        "config": {
          "path": "view.custom.queue"
        },
        "transforms": [
          {
            "code": "\treturn len([r for r in (value or []) if (r.get(\"lotStatusCode\") or \"\") != \"Good\"])",
            "type": "script"
          }
        ],
        "type": "property"
      }
    },
    "custom.queue": {
      "binding": {
        "config": {
          "expression": "if({view.custom.refreshToken} >= 0 && !isNull({session.custom.cell.locationId}), runScript(\"BlueRidge.Lots.Lot.getWipQueueByLocation\", 0, {session.custom.cell.locationId}, false, {view.custom.refreshToken}), \"\")"
        },
        "transforms": [
          {
            "code": "\trows = [r for r in (value or []) if r.get(\"HasRenameBom\")]\n\treturn [{\"sourceLotId\": r.get(\"Id\"), \"lotName\": r.get(\"LotName\") or \"\", \"sourceItem\": r.get(\"ItemPartNumber\") or \"\", \"pieceCount\": r.get(\"PieceCount\") or 0, \"arrival\": str(r.get(\"LastMovementAt\") or \"\"), \"position\": i + 1, \"lotStatusCode\": r.get(\"LotStatusCode\") or \"\"} for i, r in enumerate(rows)]",
            "type": "script"
          }
        ],
        "type": "expr"
      }
    }
  },
  "props": {
    "defaultSize": {
      "width": 1280
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "children": [
              {
                "meta": {
                  "name": "TitleText"
                },
                "props": {
                  "style": {
                    "classes": "pf-terminal-title",
                    "fontSize": "24px",
                    "fontWeight": "600"
                  },
                  "text": "Machining IN"
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "TitleMeta"
                },
                "props": {
                  "style": {
                    "classes": "pf-terminal-title-meta"
                  },
                  "text": "5G0 Machining WC - dedicated terminal - whole-LOT FIFO pick"
                },
                "type": "ia.display.label"
              }
            ],
            "meta": {
              "name": "Title"
            },
            "position": {
              "basis": "0",
              "grow": 1
            },
            "props": {
              "direction": "column",
              "style": {
                "classes": "pf-terminal-title",
                "gap": "4px"
              }
            },
            "type": "ia.container.flex"
          },
          {
            "events": {
              "dom": {
                "onClick": {
                  "config": {
                    "script": "\tsystem.perspective.openPopup(\"mpp-initials\", \"BlueRidge/Components/Popups/InitialsEntry\", params={\"popupId\": \"mpp-initials\"}, modal=True, showCloseIcon=True, overlayDismiss=True)"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "OperatorLabel"
            },
            "position": {
              "shrink": 0
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "expression": "\"Operator: \" + if(isNull({session.custom.user.displayName}) || {session.custom.user.displayName} = \"\", if(isNull({session.custom.user.initials}), \"-\", {session.custom.user.initials}), {session.custom.user.displayName})"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "classes": "pf-kpi-sub",
                "cursor": "pointer"
              }
            },
            "type": "ia.display.label"
          },
          {
            "children": [
              {
                "meta": {
                  "name": "PausedLabel"
                },
                "props": {
                  "style": {
                    "fontSize": "13px",
                    "fontWeight": "500"
                  },
                  "text": "On Hold"
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "PausedCount"
                },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "config": {
                        "expression": "toStr({view.custom.holdCount})"
                      },
                      "type": "expr"
                    }
                  }
                },
                "props": {
                  "style": {
                    "classes": "pf-paused-indicator-count"
                  }
                },
                "type": "ia.display.label"
              }
            ],
            "meta": {
              "name": "PausedIndicator"
            },
            "position": {
              "shrink": 0
            },
            "propConfig": {
              "position.display": {
                "binding": {
                  "config": {
                    "expression": "{view.custom.holdCount} > 0"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "alignItems": "center",
              "style": {
                "classes": "pf-paused-indicator",
                "gap": "8px",
                "padding": "8px 14px"
              }
            },
            "type": "ia.container.flex"
          }
        ],
        "meta": {
          "name": "Header"
        },
        "position": {
          "shrink": 0
        },
        "props": {
          "alignItems": "flex-end",
          "justify": "space-between",
          "style": {
            "classes": "pf-terminal-header",
            "gap": "12px",
            "paddingBottom": "16px"
          },
          "wrap": "wrap"
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "meta": {
              "name": "CtxLabel"
