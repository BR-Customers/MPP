      "customMethods": [
        {
          "name": "load",
          "params": [],
          "script": "\tself.view.custom.statusOptions = BlueRidge.Lots.Lot.getStatusOptions()\n\tself.view.custom.originOptions = BlueRidge.Lots.Lot.getOriginOptions()\n\tself.search()"
        },
        {
          "name": "search",
          "params": [],
          "script": "\tself.view.custom.results = BlueRidge.Lots.Lot.search(\n\t\tself.view.custom.query or None,\n\t\tself.view.custom.statusId,\n\t\tself.view.custom.originId,\n\t\t200)"
        }
      ],
      "extensionFunctions": null,
      "messageHandlers": null
    },
