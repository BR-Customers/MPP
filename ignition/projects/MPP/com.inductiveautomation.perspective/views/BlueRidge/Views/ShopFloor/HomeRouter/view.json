{
  "custom": {},
  "params": {},
  "propConfig": {},
  "props": {
    "defaultSize": {
      "height": 800,
      "width": 1280
    }
  },
  "root": {
    "type": "ia.container.flex",
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "alignItems": "center",
      "justify": "center",
      "style": {
        "classes": "canvas",
        "padding": "40px",
        "gap": "16px"
      }
    },
    "scripts": {
      "customMethods": [
        {
          "name": "route",
          "params": [],
          "script": "\tt = self.session.custom.terminal\n\tif (not t.terminalLocationId) or t.isFallback:\n\t\tsystem.perspective.navigate(\"/shop-floor/terminal-selector\")\n\t\treturn\n\tif t.defaultScreen:\n\t\tsystem.perspective.navigate(t.defaultScreen)\n\t\treturn"
        }
      ]
    },
    "events": {
      "component": {
        "onStartup": {
          "type": "script",
          "scope": "G",
          "config": {
            "script": "\tself.route()"
          }
        }
      }
    },
    "children": [
      {
        "type": "ia.container.flex",
        "meta": {
          "name": "FallbackCard"
        },
        "position": {
          "basis": "auto",
          "shrink": 0
        },
        "props": {
          "direction": "column",
          "alignItems": "center",
          "justify": "center",
          "style": {
            "classes": "surface-card",
            "gap": "14px",
            "maxWidth": "640px",
            "padding": "40px"
          }
        },
        "children": [
          {
            "type": "ia.display.label",
            "meta": {
              "name": "Heading"
            },
            "position": {
              "basis": "auto",
              "shrink": 0
            },
            "props": {
              "text": "MPP MES",
              "style": {
                "color": "var(--mpp-text-primary)",
                "fontSize": "40px",
                "fontWeight": "600"
              }
            }
          },
          {
            "type": "ia.display.label",
            "meta": {
              "name": "TerminalName"
            },
            "position": {
              "basis": "auto",
              "shrink": 0
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "type": "expr",
                  "config": {
                    "expression": "if(isNull({session.custom.terminal.terminalName}), \"\", {session.custom.terminal.terminalName} + if(isNull({session.custom.terminal.zoneName}), \"\", \"  -  \" + {session.custom.terminal.zoneName}))"
                  }
                }
              }
            },
            "props": {
              "style": {
                "color": "var(--mpp-text-secondary)",
                "fontSize": "18px"
              }
            }
          },
          {
            "type": "ia.display.label",
            "meta": {
              "name": "Message"
            },
            "position": {
              "basis": "auto",
              "shrink": 0
            },
            "props": {
              "text": "No default screen configured for this terminal - contact Engineering.",
              "style": {
                "color": "var(--mpp-text-secondary)",
                "fontSize": "15px",
                "textAlign": "center",
                "marginTop": "4px"
              }
            }
          },
          {
            "type": "ia.container.flex",
            "meta": {
              "name": "NavTiles"
            },
            "position": {
              "basis": "auto",
              "shrink": 0
            },
            "props": {
              "direction": "row",
              "wrap": "wrap",
              "justify": "center",
              "alignItems": "center",
              "style": {
                "gap": "12px",
                "marginTop": "12px"
              }
            },
            "children": [
              {
                "type": "ia.input.button",
                "meta": {
                  "name": "TileTerminalSelector"
                },
                "position": {
                  "basis": "auto",
                  "grow": 0,
                  "shrink": 0
                },
                "props": {
                  "text": "Select Terminal",
                  "style": {
                    "classes": "pf-btn pf-btn-large pf-btn-secondary",
                    "fontSize": "18px",
                    "height": "62px",
                    "minWidth": "220px"
                  }
                },
                "events": {
                  "component": {
                    "onActionPerformed": {
                      "type": "script",
                      "scope": "G",
                      "config": {
                        "script": "\tsystem.perspective.navigate(\"/shop-floor/terminal-selector\")"
                      }
                    }
                  }
                }
              },
              {
                "type": "ia.input.button",
                "meta": {
                  "name": "TileOperatorEntry"
                },
                "position": {
                  "basis": "auto",
                  "grow": 0,
                  "shrink": 0
                },
                "props": {
                  "text": "Operator Entry",
                  "style": {
                    "classes": "pf-btn pf-btn-large pf-btn-secondary",
                    "fontSize": "18px",
                    "height": "62px",
                    "minWidth": "220px"
                  }
                },
                "events": {
                  "component": {
                    "onActionPerformed": {
                      "type": "script",
                      "scope": "G",
                      "config": {
                        "script": "\tsystem.perspective.navigate(\"/shop-floor/initials\")"
                      }
                    }
                  }
                }
              }
            ]
          }
        ]
      }
    ]
  }
}
