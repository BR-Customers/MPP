{
  "custom": {},
  "params": {},
  "props": {
    "defaultSize": {
      "width": 1280
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "meta": {
              "name": "Heading"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "style": {
                "color": "var(--mpp-text-primary)",
                "fontSize": "40px",
                "fontWeight": "600"
              },
              "text": "MPP MES"
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "TerminalName"
            },
            "position": {
              "shrink": 0
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "expression": "if(isNull({session.custom.terminal.terminalName}), \"\", {session.custom.terminal.terminalName} + if(isNull({session.custom.terminal.zoneName}), \"\", \"  -  \" + {session.custom.terminal.zoneName}))"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "color": "var(--mpp-text-secondary)",
                "fontSize": "18px"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "Message"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "style": {
                "color": "var(--mpp-text-secondary)",
                "fontSize": "15px",
                "marginTop": "4px",
                "textAlign": "center"
              },
              "text": "No default screen configured for this terminal - contact Engineering."
            },
            "type": "ia.display.label"
          },
          {
            "children": [
              {
                "events": {
                  "component": {
                    "onActionPerformed": {
                      "config": {
                        "script": "\tsystem.perspective.navigate(\"/shop-floor/terminal-selector\")"
                      },
                      "scope": "G",
                      "type": "script"
                    }
                  }
                },
                "meta": {
                  "name": "TileTerminalSelector"
                },
                "position": {
                  "shrink": 0
                },
                "props": {
                  "style": {
                    "classes": "pf-btn pf-btn-large pf-btn-secondary",
                    "fontSize": "18px",
                    "height": "62px",
                    "minWidth": "220px"
                  },
                  "text": "Select Terminal"
                },
                "type": "ia.input.button"
              },
              {
                "events": {
                  "component": {
                    "onActionPerformed": {
                      "config": {
                        "script": "\tsystem.perspective.openPopup(\"mpp-initials\", \"BlueRidge/Components/Popups/InitialsEntry\", params\u003d{\"popupId\": \"mpp-initials\"}, modal\u003dTrue, showCloseIcon\u003dTrue, overlayDismiss\u003dTrue)"
                      },
                      "scope": "G",
                      "type": "script"
                    }
                  }
                },
                "meta": {
                  "name": "TileOperatorEntry"
                },
                "position": {
                  "shrink": 0
                },
                "props": {
                  "style": {
                    "classes": "pf-btn pf-btn-large pf-btn-secondary",
                    "fontSize": "18px",
                    "height": "62px",
                    "minWidth": "220px"
                  },
                  "text": "Operator Entry"
                },
                "type": "ia.input.button"
              },
              {
                "events": {
                  "component": {
                    "onActionPerformed": {
                      "config": {
                        "script": "\tsystem.perspective.navigate(\"/shop-floor/die-cast\")"
                      },
                      "scope": "G",
                      "type": "script"
                    }
                  }
                },
                "meta": {
                  "name": "TileDieCast"
                },
                "position": {
                  "shrink": 0
                },
                "props": {
                  "style": {
                    "classes": "pf-btn pf-btn-large pf-btn-secondary",
                    "fontSize": "18px",
                    "height": "62px",
                    "minWidth": "220px"
                  },
                  "text": "Die Cast Entry"
                },
                "type": "ia.input.button"
              },
              {
                "events": {
                  "component": {
                    "onActionPerformed": {
                      "config": {
                        "script": "\tsystem.perspective.navigate(\"/shop-floor/trace\")"
                      },
                      "scope": "G",
                      "type": "script"
                    }
                  }
                },
                "meta": {
                  "name": "TileTrack"
                },
                "position": {
                  "shrink": 0
                },
                "props": {
                  "style": {
                    "classes": "pf-btn pf-btn-large pf-btn-secondary",
                    "fontSize": "18px",
                    "height": "62px",
                    "minWidth": "220px"
                  },
                  "text": "Track \u0026 Trace"
                },
                "type": "ia.input.button"
              }
            ],
            "meta": {
              "name": "NavTiles"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "alignItems": "center",
              "justify": "center",
              "style": {
                "gap": "12px",
                "marginTop": "12px"
              },
              "wrap": "wrap"
            },
            "type": "ia.container.flex"
          }
        ],
        "meta": {
          "name": "FallbackCard"
        },
        "position": {
          "shrink": 0
        },
        "props": {
          "alignItems": "center",
          "direction": "column",
          "justify": "center",
          "style": {
            "classes": "surface-card",
            "gap": "14px",
            "maxWidth": "640px",
            "padding": "40px"
          }
        },
        "type": "ia.container.flex"
      }
    ],
    "events": {
      "system": {
        "onStartup": {
          "config": {
            "script": "\tself.route()"
          },
          "scope": "G",
          "type": "script"
        }
      }
    },
    "meta": {
      "name": "root"
    },
    "props": {
      "alignItems": "center",
      "direction": "column",
      "justify": "center",
      "style": {
        "classes": "canvas",
        "gap": "16px",
        "padding": "40px"
      }
    },
    "scripts": {
      "customMethods": [
        {
          "name": "route",
          "params": [],
          "script": "\tt \u003d self.session.custom.terminal\n\tif (not t.terminalLocationId) or t.isFallback:\n\t\tsystem.perspective.navigate(\"/shop-floor/terminal-selector\")\n\t\treturn\n\tif t.defaultScreen:\n\t\tsystem.perspective.navigate(t.defaultScreen)\n\t\treturn"
        }
      ],
      "extensionFunctions": null,
      "messageHandlers": null
    },
    "type": "ia.container.flex"
  }
}