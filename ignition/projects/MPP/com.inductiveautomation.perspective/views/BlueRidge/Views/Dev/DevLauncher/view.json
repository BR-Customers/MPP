{
  "custom": {
    "expanded": true,
    "selected": {
      "id": null,
      "isTerminal": false,
      "target": "",
      "terminal": {}
    }
  },
  "params": {},
  "propConfig": {
    "custom.tree": {
      "binding": {
        "config": {
          "expression": "runScript(\"BlueRidge.Location.Tree.buildLauncherTree\", 0, 1, 2)"
        },
        "type": "expr"
      }
    }
  },
  "props": {
    "defaultSize": {
      "width": 340
    }
  },
  "root": {
    "children": [
      {
        "events": {
          "component": {
            "onItemClicked": {
              "config": {
                "script": "\titems \u003d BlueRidge.Common.Util.extractQualifiedValues(self.view.custom.tree) or []\n\traw \u003d getattr(event, \"itemPath\", None)\n\tif raw is None:\n\t\tpath \u003d None\n\telif isinstance(raw, basestring):\n\t\tpath \u003d raw\n\telse:\n\t\tpath \u003d \"/\".join(str(i) for i in raw)\n\tdata \u003d BlueRidge.Location.Tree.getNodeData(items, path) if path else {}\n\tif not data:\n\t\tsel \u003d BlueRidge.Common.Util.extractQualifiedValues(self.props.selectionData) or []\n\t\tdata \u003d (sel[0].get(\"value\") if sel else {}) or {}\n\tif not data.get(\"isTerminal\"):\n\t\treturn\n\ttarget \u003d data.get(\"target\") or \"\"\n\tif not target:\n\t\treturn\n\tself.session.custom.terminal \u003d data.get(\"terminal\") or {}\n\tsystem.perspective.navigate(target)"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "Tree"
        },
        "position": {
          "basis": "0",
          "grow": 1
        },
        "propConfig": {
          "position.display": {
            "binding": {
              "config": {
                "path": "view.custom.expanded"
              },
              "type": "property"
            }
          },
          "props.items": {
            "binding": {
              "config": {
                "path": "view.custom.tree"
              },
              "type": "property"
            }
          },
          "props.selectionData[0].value": {
            "binding": {
              "config": {
                "bidirectional": true,
                "path": "view.custom.selected"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "appearance": {
            "defaultNodeIcons": {
              "collapsed": {
                "path": "material/account_tree"
              },
              "empty": {
                "path": "material/inventory"
              },
              "expanded": {
                "path": "material/account_tree"
              }
            },
            "expandIcons": {
              "collapsed": {
                "path": "material/chevron_right"
              },
              "expanded": {
                "path": "material/expand_more"
              }
            }
          },
          "selection": [
            ""
          ],
          "selectionData": [
            {
              "itemPath": ""
            }
          ],
          "style": {
            "overflow": "auto",
            "padding": "6px 4px"
          }
        },
        "type": "ia.display.tree"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "classes": "canvas",
        "gap": "0px",
        "height": "100%",
        "overflow": "hidden"
      }
    },
    "type": "ia.container.flex"
  }
}