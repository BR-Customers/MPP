          "text": "DEV NAV",
          "style": {
            "fontWeight": 700,
            "fontSize": "13px",
            "color": "#b91c1c",
            "padding": "0 6px",
            "whiteSpace": "nowrap"
          }
        }
      },
      {
        "type": "ia.display.label",
        "meta": {
          "name": "SimCell"
