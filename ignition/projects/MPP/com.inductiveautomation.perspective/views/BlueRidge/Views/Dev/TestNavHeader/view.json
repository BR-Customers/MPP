            "color": "#1f2937",
            "padding": "0 6px",
            "whiteSpace": "nowrap"
          }
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "type": "expr",
              "config": {
                "expression": "\"Cell: \" + if(isNull({session.custom.cell.name}) || {session.custom.cell.name} = \"\", \"(none)\", {session.custom.cell.name})"
              }
            }
          }
        }
