{
  "custom": {
    "value": null
  },
  "params": {
    "field": {
      "Id": null,
      "DataCollectionFieldId": null,
      "Code": "",
      "Name": "",
      "IsRequired": false,
      "DataTypeCode": "String"
    }
  },
  "propConfig": {
    "params.field": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 78,
      "width": 360
    }
  },
  "root": {
    "type": "ia.container.flex",
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "classes": "pf-field",
        "gap": "4px"
      }
    },
    "children": [
      {
        "type": "ia.display.label",
        "meta": {
          "name": "FieldLabel"
        },
        "props": {
          "style": {
            "classes": "pf-field-label"
          }
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "type": "expr",
              "config": {
                "expression": "{view.params.field.Name} + if({view.params.field.IsRequired}, ' *', '')"
              }
            }
          }
        }
      },
      {
        "type": "ia.input.text-field",
        "version": 0,
        "meta": {
          "name": "StringInput"
        },
        "props": {
          "style": {
            "classes": "pf-field-input"
          }
        },
        "position": {},
        "propConfig": {
          "position.display": {
            "binding": {
              "type": "expr",
              "config": {
                "expression": "{view.params.field.DataTypeCode} = \"String\" || isNull({view.params.field.DataTypeCode})"
              }
            }
          },
          "props.text": {
            "binding": {
              "type": "property",
              "config": {
                "path": "view.custom.value"
              },
              "bidirectional": true
            }
          }
        },
        "events": {
          "dom": {
            "onBlur": {
              "type": "script",
              "scope": "G",
              "config": {
                "script": "\tself.view.rootContainer.broadcastValue()"
              }
            }
          }
        }
      },
      {
        "type": "ia.input.numeric-entry-field",
        "version": 0,
        "meta": {
          "name": "NumericInput"
        },
        "props": {
          "style": {
            "classes": "pf-field-input"
          }
        },
        "position": {},
        "propConfig": {
          "position.display": {
            "binding": {
              "type": "expr",
              "config": {
                "expression": "{view.params.field.DataTypeCode} = \"Integer\" || {view.params.field.DataTypeCode} = \"Decimal\""
              }
            }
          },
          "props.value": {
            "binding": {
              "type": "property",
              "config": {
                "path": "view.custom.value"
              },
              "bidirectional": true
            }
          }
        },
        "events": {
          "dom": {
            "onBlur": {
              "type": "script",
              "scope": "G",
              "config": {
                "script": "\tself.view.rootContainer.broadcastValue()"
              }
            }
          }
        }
      },
      {
        "type": "ia.input.checkbox",
        "version": 0,
        "meta": {
          "name": "BooleanInput"
        },
        "props": {
          "text": ""
        },
        "position": {},
        "propConfig": {
          "position.display": {
            "binding": {
              "type": "expr",
              "config": {
                "expression": "{view.params.field.DataTypeCode} = \"Boolean\""
              }
            }
          },
          "props.selected": {
            "binding": {
              "type": "property",
              "config": {
                "path": "view.custom.value"
              },
              "bidirectional": true
            }
          }
        },
        "events": {
          "component": {
            "onActionPerformed": {
              "type": "script",
              "scope": "G",
              "config": {
                "script": "\tself.view.rootContainer.broadcastValue()"
              }
            }
          }
        }
      },
      {
        "type": "ia.input.date-time-picker",
        "version": 0,
        "meta": {
          "name": "DateInput"
        },
        "props": {},
        "position": {},
        "propConfig": {
          "position.display": {
            "binding": {
              "type": "expr",
              "config": {
                "expression": "{view.params.field.DataTypeCode} = \"Date\""
              }
            }
          },
          "props.value": {
            "binding": {
              "type": "property",
              "config": {
                "path": "view.custom.value"
              },
              "bidirectional": true
            }
          }
        },
        "events": {
          "component": {
            "onActionPerformed": {
              "type": "script",
              "scope": "G",
              "config": {
                "script": "\tself.view.rootContainer.broadcastValue()"
              }
            }
          }
        }
      }
    ],
    "scripts": {
      "customMethods": [
        {
          "name": "broadcastValue",
          "params": [],
          "script": "\t# Embed params are input-only; cross back to the CheckpointPanel parent with a\n\t# page-scoped message carrying this field's DataCollectionFieldId + value.\n\tfid = self.view.params.field.get(\"DataCollectionFieldId\") if self.view.params.field else None\n\tsystem.perspective.sendMessage(\"dcFieldChanged\", {\"fieldId\": fid, \"value\": self.view.custom.value}, scope=\"page\")"
        }
      ]
    }
  }
}
