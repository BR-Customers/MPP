{
  "custom": {
    "cells": [],
    "selectedCellId": null,
    "scanCode": ""
  },
  "params": {
    "replyMessage": "cellContextChanged"
  },
  "propConfig": {
    "params.replyMessage": {
      "paramDirection": "input",
      "persistent": true
    },
    "custom.cells": {
      "binding": {
        "type": "expr",
        "config": {
          "expression": "runScript(\"BlueRidge.Location.Location.getCellsForDropdown\", 0)"
        }
      }
    }
  },
  "props": {
    "defaultSize": {
      "height": 56,
      "width": 640
    }
  },
  "root": {
    "type": "ia.container.flex",
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "row",
      "alignItems": "center",
      "style": {
        "classes": "pf-field-row",
        "gap": "10px",
        "padding": "8px 12px"
      }
    },
    "scripts": {
      "customMethods": [
        {
          "name": "applyCell",
          "params": [
            "cellId"
          ],
          "script": "\tcellId = BlueRidge.Common.Util.extractQualifiedValues(cellId)\n\trow = BlueRidge.Location.Location.findCellById(self.view.custom.cells, cellId)\n\tif row is None:\n\t\treturn\n\tself.view.custom.selectedCellId = row.get(\"value\")\n\tself.session.custom.cell = {\"locationId\": row.get(\"value\"), \"code\": row.get(\"code\") or \"\", \"name\": row.get(\"name\") or \"\"}\n\tsystem.perspective.sendMessage(self.view.params.replyMessage, payload={\"locationId\": row.get(\"value\"), \"code\": row.get(\"code\") or \"\", \"name\": row.get(\"name\") or \"\"}, scope=\"page\")"
        },
        {
          "name": "applyByScan",
          "params": [],
          "script": "\tmatch = BlueRidge.Location.Location.findCellByCode(self.view.custom.cells, self.view.custom.scanCode)\n\tif match is None:\n\t\treturn\n\tself.view.custom.scanCode = \"\"\n\tself.applyCell(match.get(\"value\"))"
        }
      ]
    },
    "events": {
      "component": {
        "onStartup": {
          "type": "script",
          "scope": "G",
          "config": {
            "script": "\tc = self.session.custom.cell\n\tif c and c.get(\"locationId\"):\n\t\tself.view.custom.selectedCellId = c.get(\"locationId\")"
          }
        }
      }
    },
    "children": [
      {
        "type": "ia.display.label",
        "meta": {
          "name": "CellLabel"
        },
        "position": {
          "basis": "auto",
          "shrink": 0
        },
        "props": {
          "text": "Cell:",
          "style": {
            "classes": "pf-field-label",
            "marginBottom": "0px"
          }
        }
      },
      {
        "type": "ia.input.dropdown",
        "meta": {
          "name": "CellDropdown"
        },
        "position": {
          "basis": "260px",
          "shrink": 0
        },
        "propConfig": {
          "props.options": {
            "binding": {
              "type": "property",
              "config": {
                "path": "view.custom.cells"
              }
            }
          },
          "props.value": {
            "binding": {
              "type": "property",
              "config": {
                "bidirectional": true,
                "path": "view.custom.selectedCellId"
              }
            }
          }
        },
        "props": {
          "placeholder": "Select cell",
          "style": {
            "classes": "pf-field-select"
          }
        },
        "events": {
          "component": {
            "onActionPerformed": {
              "type": "script",
              "scope": "G",
              "config": {
                "script": "\tself.view.rootContainer.applyCell(self.props.value)"
              }
            }
          }
        }
      },
      {
        "type": "ia.display.icon",
        "meta": {
          "name": "ScanIcon"
        },
        "position": {
          "basis": "22px",
          "shrink": 0
        },
        "props": {
          "path": "mpp/qr_code_scanner",
          "style": {
            "width": "22px",
            "height": "22px",
            "color": "var(--mpp-text-secondary)"
          }
        }
      },
      {
        "type": "ia.input.text-field",
        "meta": {
          "name": "ScannerInput"
        },
        "position": {
          "basis": "180px",
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "type": "property",
              "config": {
                "bidirectional": true,
                "path": "view.custom.scanCode"
              }
            }
          }
        },
        "props": {
          "placeholder": "Scan cell",
          "style": {
            "classes": "pf-field-input-mono",
            "textTransform": "uppercase"
          }
        },
        "events": {
          "dom": {
            "onBlur": {
              "type": "script",
              "scope": "G",
              "config": {
                "script": "\tself.view.rootContainer.applyByScan()"
              }
            }
          }
        }
      },
      {
        "type": "ia.display.label",
        "meta": {
          "name": "SelectedCellName"
        },
        "position": {
          "basis": "auto",
          "grow": 1,
          "shrink": 1
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "type": "expr",
              "config": {
                "expression": "if({session.custom.cell.name} = \"\", \"No cell selected\", {session.custom.cell.name})"
              }
            }
          }
        },
        "props": {
          "style": {
            "color": "var(--mpp-text-secondary)",
            "fontSize": "14px",
            "marginLeft": "4px"
          }
        }
      }
    ]
  }
}
