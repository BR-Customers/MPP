{
  "custom": {
    "adAccount": "",
    "busy": false,
    "error": "",
    "password": ""
  },
  "params": {
    "actionCode": "",
    "actionLabel": "Protected Action",
    "popupId": "mpp-elevation-modal",
    "replyMessage": "elevationResult"
  },
  "propConfig": {
    "params.actionCode": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.actionLabel": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.popupId": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.replyMessage": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 360,
      "width": 480
    }
  },
  "root": {
    "type": "ia.container.flex",
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "classes": "modal"
      }
    },
    "children": [
      {
        "type": "ia.container.flex",
        "meta": {
          "name": "Header"
        },
        "position": {
          "basis": "auto",
          "shrink": 0
        },
        "props": {
          "alignItems": "center",
          "style": {
            "classes": "modal-header",
            "gap": "10px"
          }
        },
        "children": [
          {
            "type": "ia.display.icon",
            "meta": {
              "name": "LockIcon"
            },
            "position": {
              "basis": "22px",
              "shrink": 0
            },
            "props": {
              "path": "mpp/lock",
              "style": {
                "width": "22px",
                "height": "22px"
              }
            }
          },
          {
            "type": "ia.display.label",
            "meta": {
              "name": "HeaderTitle"
            },
            "position": {
              "basis": "auto",
              "grow": 1
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "type": "expr",
                  "config": {
                    "expression": "\"Authorize: \" + {view.params.actionLabel}"
                  }
                }
              }
            }
          }
        ]
      },
      {
        "type": "ia.container.flex",
        "meta": {
          "name": "Body"
        },
        "position": {
          "basis": "0",
          "grow": 1
        },
        "props": {
          "direction": "column",
          "style": {
            "classes": "modal-body"
          }
        },
        "children": [
          {
            "type": "ia.display.label",
            "meta": {
              "name": "Prompt"
            },
            "position": {
              "basis": "auto",
              "shrink": 0
            },
            "props": {
              "text": "Enter your Active Directory credentials to authorize this action.",
              "style": {
                "color": "var(--mpp-text-secondary)",
                "fontSize": "13px"
              }
            }
          },
          {
            "type": "ia.container.flex",
            "meta": {
              "name": "AccountField"
            },
            "position": {
              "basis": "auto",
              "shrink": 0
            },
            "props": {
              "direction": "column",
              "style": {
                "classes": "pf-field"
              }
            },
            "children": [
              {
                "type": "ia.display.label",
                "meta": {
                  "name": "AccountLabel"
                },
                "position": {
                  "basis": "auto",
                  "shrink": 0
                },
                "props": {
                  "text": "AD Username",
                  "style": {
                    "classes": "pf-field-label"
                  }
                }
              },
              {
                "type": "ia.input.text-field",
                "meta": {
                  "name": "AccountInput"
                },
                "position": {
                  "basis": "auto",
                  "shrink": 0
                },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "type": "property",
                      "config": {
                        "bidirectional": true,
                        "path": "view.custom.adAccount"
                      }
                    }
                  }
                },
                "props": {
                  "placeholder": "domain\\username",
                  "style": {
                    "classes": "pf-field-input"
                  }
                }
              }
            ]
          },
          {
            "type": "ia.container.flex",
            "meta": {
              "name": "PasswordField"
            },
            "position": {
              "basis": "auto",
              "shrink": 0
            },
            "props": {
              "direction": "column",
              "style": {
                "classes": "pf-field"
              }
            },
            "children": [
              {
                "type": "ia.display.label",
                "meta": {
                  "name": "PasswordLabel"
                },
                "position": {
                  "basis": "auto",
                  "shrink": 0
                },
                "props": {
                  "text": "Password",
                  "style": {
                    "classes": "pf-field-label"
                  }
                }
              },
              {
                "type": "ia.input.password-field",
                "meta": {
                  "name": "PasswordInput"
                },
                "position": {
                  "basis": "auto",
                  "shrink": 0
                },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "type": "property",
                      "config": {
                        "bidirectional": true,
                        "path": "view.custom.password"
                      }
                    }
                  }
                },
                "props": {
                  "placeholder": "Password",
                  "style": {
                    "classes": "pf-field-input"
                  }
                }
              }
            ]
          },
          {
            "type": "ia.display.label",
            "meta": {
              "name": "ErrorLabel"
            },
            "position": {
              "basis": "auto",
              "shrink": 0
            },
            "propConfig": {
              "position.display": {
                "binding": {
                  "type": "expr",
                  "config": {
                    "expression": "{view.custom.error} != \"\""
                  }
                }
              },
              "props.text": {
                "binding": {
                  "type": "property",
                  "config": {
                    "path": "view.custom.error"
                  }
                }
              }
            },
            "props": {
              "style": {
                "color": "var(--mpp-state-bad-fg)",
                "fontSize": "13px"
              }
            }
          }
        ]
      },
      {
        "type": "ia.container.flex",
        "meta": {
          "name": "Footer"
        },
        "position": {
          "basis": "auto",
          "shrink": 0
        },
        "props": {
          "alignItems": "center",
          "justify": "flex-end",
          "style": {
            "classes": "modal-footer",
            "gap": "10px"
          }
        },
        "children": [
          {
            "type": "ia.input.button",
            "meta": {
              "name": "CancelButton"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "text": "Cancel",
              "style": {
                "classes": "pf-btn pf-btn-secondary"
              }
            },
            "events": {
              "component": {
                "onActionPerformed": {
                  "type": "script",
                  "scope": "G",
                  "config": {
                    "script": "\tsystem.perspective.sendMessage(self.view.params.replyMessage, payload={\"success\": False, \"cancelled\": True}, scope=\"page\")\n\tsystem.perspective.closePopup(id=self.view.params.popupId)"
                  }
                }
              }
            }
          },
          {
            "type": "ia.input.button",
            "meta": {
              "name": "AuthenticateButton"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "text": "Authenticate",
              "style": {
                "classes": "pf-btn pf-btn-primary"
              }
            },
            "events": {
              "component": {
                "onActionPerformed": {
                  "type": "script",
                  "scope": "G",
                  "config": {
                    "script": "\tres = BlueRidge.Location.AppUser.elevate(self.view.custom.adAccount, self.view.custom.password, self.view.params.actionCode, self.session.custom.terminal.terminalLocationId)\n\tif res.get(\"success\"):\n\t\tsystem.perspective.sendMessage(self.view.params.replyMessage, res, scope=\"page\")\n\t\tsystem.perspective.closePopup(self.view.params.popupId)\n\telse:\n\t\tself.view.custom.error = res.get(\"message\") or \"Authentication failed\""
                  }
                }
              }
            }
          }
        ]
      }
    ]
  }
}
