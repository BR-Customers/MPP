{
  "custom": {},
  "params": {
    "downtimeEventId": null,
    "timeRange": "",
    "durationMinutes": null,
    "reasonLabel": "",
    "sourceCode": "",
    "initials": "",
    "isOpen": false,
    "isVoided": false
  },
  "propConfig": {
    "params.downtimeEventId": { "paramDirection": "input" },
    "params.timeRange": { "paramDirection": "input" },
    "params.durationMinutes": { "paramDirection": "input" },
    "params.reasonLabel": { "paramDirection": "input" },
    "params.sourceCode": { "paramDirection": "input" },
    "params.initials": { "paramDirection": "input" },
    "params.isOpen": { "paramDirection": "input" },
    "params.isVoided": { "paramDirection": "input" }
  },
  "props": {
    "defaultSize": { "height": 52 }
  },
  "root": {
    "children": [
      {
        "meta": { "name": "TimeRange" },
        "position": { "basis": "230px", "shrink": 0 },
        "propConfig": {
          "props.text": { "binding": { "config": { "path": "view.params.timeRange" }, "type": "property" } }
        },
        "props": { "style": { "fontWeight": "600", "whiteSpace": "nowrap" } },
        "type": "ia.display.label"
      },
      {
        "meta": { "name": "Duration" },
        "position": { "basis": "64px", "shrink": 0 },
        "propConfig": {
          "props.text": {
            "binding": { "config": { "expression": "if(isNull({view.params.durationMinutes}), \"—\", toStr({view.params.durationMinutes}) + \"m\")" }, "type": "expr" }
          }
        },
        "props": { "style": { "color": "var(--mpp-text-secondary)" } },
        "type": "ia.display.label"
      },
      {
        "meta": { "name": "Reason" },
        "position": { "basis": "0", "grow": 1 },
        "propConfig": {
          "props.text": {
            "binding": { "config": { "expression": "if({view.params.reasonLabel} = \"\", \"(no reason)\", {view.params.reasonLabel})" }, "type": "expr" }
          },
          "props.style.color": {
            "binding": { "config": { "expression": "if({view.params.reasonLabel} = \"\", 'var(--pf-status-warn-fg)', 'var(--mpp-text-primary)')" }, "type": "expr" }
          }
        },
        "props": { "style": { "whiteSpace": "nowrap", "overflow": "hidden", "textOverflow": "ellipsis" } },
        "type": "ia.display.label"
      },
      {
        "meta": { "name": "Source" },
        "position": { "basis": "80px", "shrink": 0 },
        "propConfig": {
          "props.text": { "binding": { "config": { "path": "view.params.sourceCode" }, "type": "property" } }
        },
        "props": { "style": { "color": "var(--mpp-text-secondary)", "fontSize": "12px" } },
        "type": "ia.display.label"
      },
      {
        "meta": { "name": "Initials" },
        "position": { "basis": "50px", "shrink": 0 },
        "propConfig": {
          "props.text": { "binding": { "config": { "path": "view.params.initials" }, "type": "property" } }
        },
        "props": { "style": { "color": "var(--mpp-text-secondary)", "fontSize": "12px" } },
        "type": "ia.display.label"
      },
      {
        "meta": { "name": "StatusChip" },
        "position": { "basis": "84px", "shrink": 0 },
        "propConfig": {
          "props.text": {
            "binding": { "config": { "expression": "if({view.params.isVoided}, \"VOIDED\", if({view.params.isOpen}, \"OPEN\", \"CLOSED\"))" }, "type": "expr" }
          },
          "props.style.classes": {
            "binding": { "config": { "expression": "if({view.params.isVoided}, \"badge badge-deprecated\", if({view.params.isOpen}, \"badge badge-warning\", \"badge badge-muted\"))" }, "type": "expr" }
          }
        },
        "type": "ia.display.label"
      },
      {
        "events": {
          "component": {
            "onActionPerformed": {
              "config": { "script": "\tsystem.perspective.sendMessage(\"dtEndRequested\", payload={\"downtimeEventId\": self.view.params.downtimeEventId}, scope=\"page\")" },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": { "name": "EndButton" },
        "position": { "basis": "62px", "shrink": 0 },
        "propConfig": {
          "meta.visible": { "binding": { "config": { "expression": "{view.params.isOpen} && !{view.params.isVoided}" }, "type": "expr" } }
        },
        "props": { "style": { "classes": "pf-btn pf-btn-primary" }, "text": "End" },
        "type": "ia.input.button"
      },
      {
        "events": {
          "component": {
            "onActionPerformed": {
              "config": { "script": "\tsystem.perspective.sendMessage(\"dtEditRequested\", payload={\"downtimeEventId\": self.view.params.downtimeEventId}, scope=\"page\")" },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": { "name": "EditButton" },
        "position": { "basis": "62px", "shrink": 0 },
        "propConfig": {
          "meta.visible": { "binding": { "config": { "expression": "!{view.params.isVoided}" }, "type": "expr" } }
        },
        "props": { "style": { "classes": "pf-btn pf-btn-secondary" }, "text": "Edit" },
        "type": "ia.input.button"
      },
      {
        "events": {
          "component": {
            "onActionPerformed": {
              "config": { "script": "\tsystem.perspective.sendMessage(\"dtVoidRequested\", payload={\"downtimeEventId\": self.view.params.downtimeEventId}, scope=\"page\")" },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": { "name": "VoidButton" },
        "position": { "basis": "62px", "shrink": 0 },
        "propConfig": {
          "meta.visible": { "binding": { "config": { "expression": "!{view.params.isVoided}" }, "type": "expr" } }
        },
        "props": { "style": { "classes": "pf-btn pf-btn-danger" }, "text": "Void" },
        "type": "ia.input.button"
      }
    ],
    "meta": { "name": "root" },
    "propConfig": {
      "props.style.opacity": {
        "binding": { "config": { "expression": "if({view.params.isVoided}, 0.5, 1)" }, "type": "expr" }
      }
    },
    "props": {
      "alignItems": "center",
      "style": {
        "classes": "surface-card",
        "gap": "12px",
        "padding": "0 12px",
        "borderBottom": "1px solid var(--mpp-border-subtle)"
      }
    },
    "type": "ia.container.flex"
  }
}
