{
  "custom": {},
  "params": {
    "arrival": "",
    "lotName": "",
    "lotStatusCode": "",
    "pieceCount": 0,
    "position": 0,
    "sourceItem": "",
    "sourceLotId": null
  },
  "propConfig": {
    "params.arrival": {
      "paramDirection": "input"
    },
    "params.lotName": {
      "paramDirection": "input"
    },
    "params.lotStatusCode": {
      "paramDirection": "input"
    },
    "params.pieceCount": {
      "paramDirection": "input"
    },
    "params.position": {
      "paramDirection": "input"
    },
    "params.sourceItem": {
      "paramDirection": "input"
    },
    "params.sourceLotId": {
      "paramDirection": "input"
    }
  },
  "props": {
    "defaultSize": {
      "height": 92,
      "width": 640
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "meta": {
              "name": "Position"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "expression": "if({view.params.position} \u003d 1, \u0027Position 1 - oldest\u0027, \u0027Position \u0027 + toStr({view.params.position}))"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "classes": "pf-queue-position"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "LotName"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "path": "view.params.lotName"
                  },
                  "type": "property"
                }
              }
            },
            "props": {
              "style": {
                "classes": "pf-queue-name"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "Detail"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "expression": "{view.params.sourceItem} + \u0027 | \u0027 + toStr({view.params.pieceCount}) + \u0027 pcs | whole LOT\u0027 + if({view.params.arrival} \u003d \u0027\u0027, \u0027\u0027, \u0027 | arrived \u0027 + {view.params.arrival})"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "classes": "pf-queue-detail"
              }
            },
            "type": "ia.display.label"
          }
        ],
        "meta": {
          "name": "Info"
        },
        "position": {
          "basis": "0",
          "grow": 1
        },
        "props": {
          "direction": "column",
          "style": {
            "gap": "2px"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "meta": {
          "name": "StatusPill"
        },
        "position": {
          "shrink": 0
        },
        "propConfig": {
          "props.style.classes": {
            "binding": {
              "config": {
                "expression": "if({view.params.lotStatusCode} \u003d \u0027Good\u0027, \u0027pf-pill pf-pill-good\u0027, \u0027pf-pill pf-pill-hold\u0027)"
              },
              "type": "expr"
            }
          },
          "props.text": {
            "binding": {
              "config": {
                "expression": "if({view.params.lotStatusCode} \u003d \u0027Good\u0027, \u0027Good\u0027, \u0027Hold\u0027)"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "style": {}
        },
        "type": "ia.display.label"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "alignItems": "center",
      "style": {
        "classes": "pf-queue-row",
        "gap": "16px",
        "padding": "12px 16px"
      }
    },
    "type": "ia.container.flex"
  }
}