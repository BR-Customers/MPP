{
  "custom": {
    "dcValues": {},
    "draft": {
      "scrapCount": null,
      "shotCount": null,
      "weightValue": null
    }
  },
  "params": {
    "lotId": null
  },
  "propConfig": {
    "custom.fields": {
      "binding": {
        "config": {
          "expression": "runScript(\"BlueRidge.Parts.OperationTemplate.getDieCastShotFields\", 0)"
        },
        "type": "expr"
      }
    },
    "custom.templateId": {
      "binding": {
        "config": {
          "expression": "runScript(\"BlueRidge.Parts.OperationTemplate.getActiveTemplateIdByCode\", 0, \"DieCastShot\")"
        },
        "type": "expr"
      }
    },
    "params.lotId": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 460,
      "width": 360
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "PanelHeader"
        },
        "props": {
          "style": {
            "classes": "pf-panel-header"
          },
          "text": "Record Checkpoint"
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "CumulativeHint"
        },
        "props": {
          "style": {
            "classes": "pf-field-help"
          },
          "text": "Enter the running CUMULATIVE cavity counters, not a delta."
        },
        "type": "ia.display.label"
      },
      {
        "children": [
          {
            "children": [
              {
                "meta": {
                  "name": "ShotLabel"
                },
                "props": {
                  "style": {
                    "classes": "pf-field-label"
                  },
                  "text": "Cumulative shots"
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "ShotInput"
                },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "config": {
                        "bidirectional": true,
                        "path": "view.custom.draft.shotCount"
                      },
                      "type": "property"
                    }
                  }
                },
                "props": {
                  "style": {
                    "classes": "pf-field-input"
                  }
                },
                "type": "ia.input.text-field"
              }
            ],
            "meta": {
              "name": "ShotField"
            },
            "props": {
              "direction": "column",
              "style": {
                "classes": "pf-field",
                "gap": "4px"
              }
            },
            "type": "ia.container.flex"
          },
          {
            "children": [
              {
                "meta": {
                  "name": "ScrapLabel"
                },
                "props": {
                  "style": {
                    "classes": "pf-field-label"
                  },
                  "text": "Cumulative scrap"
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "ScrapInput"
                },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "config": {
                        "bidirectional": true,
                        "path": "view.custom.draft.scrapCount"
                      },
                      "type": "property"
                    }
                  }
                },
                "props": {
                  "style": {
                    "classes": "pf-field-input"
                  }
                },
                "type": "ia.input.text-field"
              }
            ],
            "meta": {
              "name": "ScrapField"
            },
            "props": {
              "direction": "column",
              "style": {
                "classes": "pf-field",
                "gap": "4px"
              }
            },
            "type": "ia.container.flex"
          }
        ],
        "meta": {
          "name": "CumulativeRow"
        },
        "props": {
          "style": {
            "gap": "10px",
            "overflow": "visible"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "meta": {
          "name": "FieldsRepeater"
        },
        "position": {
          "basis": "0",
          "grow": 1
        },
        "propConfig": {
          "props.instances": {
            "binding": {
              "config": {
                "path": "view.custom.fields"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "direction": "column",
          "elementPosition": {
            "basis": "auto"
          },
          "path": "BlueRidge/Components/PlantFloor/DieCastEntry/FieldInputRow",
          "style": {
            "gap": "8px",
            "overflowY": "auto"
          },
          "useDefaultViewHeight": false,
          "useDefaultViewWidth": false
        },
        "type": "ia.display.flex-repeater"
      },
      {
        "events": {
          "component": {
            "onActionPerformed": {
              "config": {
                "script": "\tself.view.rootContainer.submitCheckpoint()"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "SubmitCheckpointButton"
        },
        "propConfig": {
          "props.enabled": {
            "binding": {
              "config": {
                "expression": "!isNull({view.params.lotId})"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "style": {
            "classes": "pf-btn pf-btn-primary"
          },
          "text": "Submit Checkpoint"
        },
        "type": "ia.input.button"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "classes": "pf-panel",
        "gap": "12px",
        "padding": "16px"
      }
    },
    "scripts": {
      "customMethods": [
        {
          "name": "submitCheckpoint",
          "params": [],
          "script": "\tlotId \u003d self.view.params.lotId\n\tif lotId is None:\n\t\treturn\n\tdraft \u003d BlueRidge.Common.Util.extractQualifiedValues(self.view.custom.draft) or {}\n\tdcValues \u003d BlueRidge.Common.Util.extractQualifiedValues(self.view.custom.dcValues) or {}\n\tdata \u003d {\n\t\t\"lotId\": lotId,\n\t\t\"operationTemplateId\": self.view.custom.templateId,\n\t\t\"shotCount\": BlueRidge.Common.Util.toIntOrNone(draft.get(\"shotCount\")),\n\t\t\"scrapCount\": BlueRidge.Common.Util.toIntOrNone(draft.get(\"scrapCount\")),\n\t\t\"weightValue\": BlueRidge.Common.Util.toDecimalOrNone(draft.get(\"weightValue\")),\n\t\t\"dcValues\": dcValues,\n\t}\n\tappUserId \u003d self.session.custom.appUserId\n\ttermId \u003d None\n\ttry:\n\t\ttermId \u003d self.session.custom.terminal.terminalLocationId\n\texcept:\n\t\ttermId \u003d None\n\tresult \u003d BlueRidge.Workorder.ProductionEvent.record(data, appUserId, termId)\n\tBlueRidge.Common.Ui.notifyResult(result, successTitle\u003d\"Checkpoint recorded\")\n\tif result and result.get(\"Status\"):\n\t\tself.view.custom.draft \u003d {\"shotCount\": None, \"scrapCount\": None, \"weightValue\": None}\n\t\tself.view.custom.dcValues \u003d {}\n\t\tsystem.perspective.sendMessage(\"checkpointRecorded\", {\"lotId\": lotId}, scope\u003d\"page\")"
        }
      ],
      "extensionFunctions": null,
      "messageHandlers": [
        {
          "messageType": "dcFieldChanged",
          "pageScope": true,
          "script": "\tp \u003d payload or {}\n\tfid \u003d p.get(\"fieldId\")\n\tif fid is None:\n\t\treturn\n\tdc \u003d BlueRidge.Common.Util.extractQualifiedValues(self.view.custom.dcValues) or {}\n\tdc[str(fid)] \u003d p.get(\"value\")\n\tself.view.custom.dcValues \u003d dc",
          "sessionScope": false,
          "viewScope": false
        }
      ]
    },
    "type": "ia.container.flex"
  }
}