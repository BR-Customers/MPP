{
  "custom": {},
  "params": {
    "value": ""
  },
  "propConfig": {
    "params.value": {
      "paramDirection": "input"
    }
  },
  "props": {
    "defaultSize": {
      "height": 40,
      "width": 120
    }
  },
  "root": {
    "type": "ia.container.flex",
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "row",
      "alignItems": "center",
      "justify": "center",
      "style": {
        "height": "100%",
        "width": "100%"
      }
    },
    "children": [
      {
        "type": "ia.display.label",
        "meta": {
          "name": "Pill"
        },
        "position": {
          "basis": "auto",
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "type": "property",
              "config": {
                "path": "view.params.value"
              }
            }
          },
          "props.style.classes": {
            "binding": {
              "type": "expr",
              "config": {
                "expression": "\"pf-pill \" + if({view.params.value} = \"Good\", \"pf-pill-good\", if({view.params.value} = \"Held\", \"pf-pill-hold\", if({view.params.value} = \"Scrapped\", \"pf-pill-bad\", if({view.params.value} = \"Rejected\", \"pf-pill-bad\", \"pf-pill\"))))"
              }
            }
          }
        },
        "props": {
          "text": "",
          "style": {
            "classes": "pf-pill",
            "fontSize": "12px",
            "fontWeight": "600",
            "padding": "3px 10px",
            "borderRadius": "999px"
          }
        }
      }
    ]
  }
}
