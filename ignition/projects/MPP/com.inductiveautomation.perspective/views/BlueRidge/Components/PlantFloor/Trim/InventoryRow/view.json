{
  "custom": {},
  "params": {
    "arrival": "",
    "isSelected": false,
    "item": "",
    "lotId": null,
    "lotName": "",
    "lotStatusCode": "",
    "pieceCount": 0,
    "position": 0,
    "selectable": false
  },
  "propConfig": {
    "params.arrival": {
      "paramDirection": "input"
    },
    "params.isSelected": {
      "paramDirection": "input"
    },
    "params.item": {
      "paramDirection": "input"
    },
    "params.lotId": {
      "paramDirection": "input"
    },
    "params.lotName": {
      "paramDirection": "input"
    },
    "params.lotStatusCode": {
      "paramDirection": "input"
    },
    "params.pieceCount": {
      "paramDirection": "input"
    },
    "params.position": {
      "paramDirection": "input"
    },
    "params.selectable": {
      "paramDirection": "input"
    }
  },
  "props": {
    "defaultSize": {
      "height": 92,
      "width": 640
    }
  },
  "root": {
    "children": [
      {
        "events": {
          "component": {
            "onActionPerformed": {
              "config": {
                "script": "\tsystem.perspective.sendMessage(\"trimLotSelected\", payload\u003d{\"lotId\": self.view.params.lotId, \"lotName\": self.view.params.lotName}, scope\u003d\"page\")"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "SelectButton"
        },
        "position": {
          "shrink": 0
        },
        "propConfig": {
          "meta.visible": {
            "binding": {
              "config": {
                "path": "view.params.selectable"
              },
              "type": "property"
            }
          },
          "props.enabled": {
            "binding": {
              "config": {
                "expression": "{view.params.lotStatusCode} \u003d \u0027Good\u0027"
              },
              "type": "expr"
            }
          },
          "props.style.classes": {
            "binding": {
              "config": {
                "expression": "if({view.params.isSelected}, \u0027pf-btn pf-btn-primary pf-btn-large\u0027, \u0027pf-btn pf-btn-secondary pf-btn-large\u0027)"
              },
              "type": "expr"
            }
          },
          "props.text": {
            "binding": {
              "config": {
                "expression": "if({view.params.isSelected}, \u0027Selected\u0027, \u0027Select\u0027)"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "style": {}
        },
        "type": "ia.input.button"
      },
      {
        "children": [
          {
            "meta": {
              "name": "Position"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "expression": "if({view.params.position} \u003d 1, \u0027Position 1 - oldest\u0027, \u0027Position \u0027 + toStr({view.params.position}))"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "classes": "pf-queue-position"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "LotName"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "path": "view.params.lotName"
                  },
                  "type": "property"
                }
              }
            },
            "props": {
              "style": {
                "classes": "pf-queue-name"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "Detail"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "expression": "{view.params.item} + \u0027 | \u0027 + toStr({view.params.pieceCount}) + \u0027 pcs\u0027 + if({view.params.arrival} \u003d \u0027\u0027, \u0027\u0027, \u0027 | arrived \u0027 + {view.params.arrival})"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "classes": "pf-queue-detail"
              }
            },
            "type": "ia.display.label"
          }
        ],
        "meta": {
          "name": "Info"
        },
        "position": {
          "basis": "0",
          "grow": 1
        },
        "props": {
          "direction": "column",
          "style": {
            "gap": "2px",
            "overflow": "hidden"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "meta": {
          "name": "StatusPill"
        },
        "position": {
          "shrink": 0
        },
        "propConfig": {
          "props.style.classes": {
            "binding": {
              "config": {
                "expression": "if({view.params.lotStatusCode} \u003d \u0027Good\u0027, \u0027pf-pill pf-pill-good\u0027, \u0027pf-pill pf-pill-hold\u0027)"
              },
              "type": "expr"
            }
          },
          "props.text": {
            "binding": {
              "config": {
                "expression": "if({view.params.lotStatusCode} \u003d \u0027Good\u0027, \u0027Good\u0027, \u0027Hold\u0027)"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "style": {}
        },
        "type": "ia.display.label"
      }
    ],
    "meta": {
      "name": "root"
    },
    "propConfig": {
      "props.style.borderLeft": {
        "binding": {
          "config": {
            "expression": "if({view.params.isSelected}, \"3px solid var(--mpp-accent-60)\", \"\")"
          },
          "type": "expr"
        }
      }
    },
    "props": {
      "alignItems": "center",
      "style": {
        "classes": "pf-inventory-row",
        "gap": "16px",
        "overflow": "hidden",
        "padding": "12px 16px"
      }
    },
    "type": "ia.container.flex"
  }
}