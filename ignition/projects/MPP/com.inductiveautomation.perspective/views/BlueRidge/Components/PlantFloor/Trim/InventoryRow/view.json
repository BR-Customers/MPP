{
  "custom": {},
  "params": {
    "arrival": "",
    "isSelected": false,
    "item": "",
    "lotId": null,
    "lotName": "",
    "lotStatusCode": "",
    "pieceCount": 0,
    "position": 0,
    "selectable": false
  },
  "propConfig": {
    "params.arrival": {
      "paramDirection": "input"
    },
    "params.isSelected": {
      "paramDirection": "input"
    },
    "params.item": {
      "paramDirection": "input"
    },
    "params.lotId": {
      "paramDirection": "input"
    },
    "params.lotName": {
      "paramDirection": "input"
    },
    "params.lotStatusCode": {
      "paramDirection": "input"
    },
    "params.pieceCount": {
      "paramDirection": "input"
    },
    "params.position": {
      "paramDirection": "input"
    },
    "params.selectable": {
      "paramDirection": "input"
    }
  },
  "props": {
    "defaultSize": {
      "height": 92,
      "width": 640
    }
  },
  "root": {
    "type": "ia.container.flex",
    "meta": {
      "name": "root"
    },
    "propConfig": {
      "props.style.borderLeft": {
        "binding": {
          "type": "expr",
          "config": {
            "expression": "if({view.params.isSelected}, \"3px solid var(--mpp-accent-60)\", \"\")"
          }
        }
      }
    },
    "props": {
      "direction": "row",
      "alignItems": "center",
      "style": {
        "classes": "pf-queue-row",
        "gap": "16px",
        "overflow": "hidden",
        "padding": "12px 16px"
      }
    },
    "children": [
      {
        "type": "ia.container.flex",
        "meta": {
          "name": "Info"
        },
        "position": {
          "grow": 1,
          "basis": "0"
        },
        "props": {
          "direction": "column",
          "style": {
            "gap": "2px",
            "overflow": "hidden"
          }
        },
        "children": [
          {
            "type": "ia.display.label",
            "meta": {
              "name": "Position"
            },
            "props": {
              "style": {
                "classes": "pf-queue-position"
              }
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "type": "expr",
                  "config": {
                    "expression": "if({view.params.position} = 1, 'Position 1 - oldest', 'Position ' + toStr({view.params.position}))"
                  }
                }
              }
            }
          },
          {
            "type": "ia.display.label",
            "meta": {
              "name": "LotName"
            },
            "props": {
              "style": {
                "classes": "pf-queue-name"
              }
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "type": "property",
                  "config": {
                    "path": "view.params.lotName"
                  }
                }
              }
            }
          },
          {
            "type": "ia.display.label",
            "meta": {
              "name": "Detail"
            },
            "props": {
              "style": {
                "classes": "pf-queue-detail"
              }
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "type": "expr",
                  "config": {
                    "expression": "{view.params.item} + ' | ' + toStr({view.params.pieceCount}) + ' pcs' + if({view.params.arrival} = '', '', ' | arrived ' + {view.params.arrival})"
                  }
                }
              }
            }
          }
        ]
      },
      {
        "type": "ia.display.label",
        "meta": {
          "name": "StatusPill"
        },
        "position": {
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "type": "expr",
              "config": {
                "expression": "if({view.params.lotStatusCode} = 'Good', 'Good', 'Hold')"
              }
            }
          },
          "props.style.classes": {
            "binding": {
              "type": "expr",
              "config": {
                "expression": "if({view.params.lotStatusCode} = 'Good', 'pf-pill pf-pill-good', 'pf-pill pf-pill-hold')"
              }
            }
          }
        },
        "props": {
          "style": {
            "classes": "pf-pill pf-pill-good"
          }
        }
      },
      {
        "type": "ia.input.button",
        "meta": {
          "name": "SelectButton"
        },
        "position": {
          "shrink": 0
        },
        "propConfig": {
          "position.display": {
            "binding": {
              "type": "property",
              "config": {
                "path": "view.params.selectable"
              }
            }
          },
          "props.enabled": {
            "binding": {
              "type": "expr",
              "config": {
                "expression": "{view.params.lotStatusCode} = 'Good'"
              }
            }
          },
          "props.text": {
            "binding": {
              "type": "expr",
              "config": {
                "expression": "if({view.params.isSelected}, 'Selected', 'Select')"
              }
            }
          },
          "props.style.classes": {
            "binding": {
              "type": "expr",
              "config": {
                "expression": "if({view.params.isSelected}, 'pf-btn pf-btn-primary pf-btn-large', 'pf-btn pf-btn-secondary pf-btn-large')"
              }
            }
          }
        },
        "props": {
          "text": "Select",
          "style": {
            "classes": "pf-btn pf-btn-secondary pf-btn-large"
          }
        },
        "events": {
          "component": {
            "onActionPerformed": {
              "type": "script",
              "scope": "G",
              "config": {
                "script": "\tsystem.perspective.sendMessage(\"trimLotSelected\", payload={\"lotId\": self.view.params.lotId, \"lotName\": self.view.params.lotName}, scope=\"page\")"
              }
            }
          }
        }
      }
    ]
  }
}
