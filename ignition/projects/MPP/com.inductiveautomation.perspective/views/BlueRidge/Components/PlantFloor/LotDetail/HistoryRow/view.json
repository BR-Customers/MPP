{
  "custom": {},
  "params": {
    "row": {
      "EventAt": "",
      "EventAtDisplay": "",
      "EventAgo": "",
      "EventKind": "",
      "Detail": "",
      "ByUserName": ""
    }
  },
  "propConfig": {
    "params.row": {
      "paramDirection": "input"
    }
  },
  "props": {
    "defaultSize": {
      "height": 44,
      "width": 800
    }
  },
  "root": {
    "type": "ia.container.flex",
    "meta": {
      "name": "root"
    },
    "props": {
      "alignItems": "center",
      "style": {
        "borderBottom": "1px solid var(--mpp-border-subtle)",
        "gap": "12px",
        "minHeight": "44px",
        "paddingLeft": "12px",
        "paddingRight": "12px",
        "paddingTop": "8px",
        "paddingBottom": "8px"
      }
    },
    "children": [
      {
        "type": "ia.display.icon",
        "meta": {
          "name": "KindIcon"
        },
        "position": {
          "basis": "auto",
          "shrink": 0
        },
        "propConfig": {
          "props.path": {
            "binding": {
              "type": "expr",
              "config": {
                "expression": "if({view.params.row.EventKind}=\"Movement\",\"mpp/arrow_right_alt\",if({view.params.row.EventKind}=\"Status\",\"mpp/verified\",if({view.params.row.EventKind}=\"Attribute\",\"mpp/edit\",if({view.params.row.EventKind}=\"Pause\",\"mpp/pause_circle\",if({view.params.row.EventKind}=\"Resume\",\"mpp/play_arrow\",if({view.params.row.EventKind}=\"Genealogy\",\"mpp/content_cut\",if({view.params.row.EventKind}=\"Label\",\"mpp/print\",if({view.params.row.EventKind}=\"Production\",\"mpp/handyman\",if({view.params.row.EventKind}=\"Reject\",\"mpp/warning\",\"mpp/pending_actions\")))))))))"
              }
            }
          },
          "props.style.color": {
            "binding": {
              "type": "expr",
              "config": {
                "expression": "if({view.params.row.EventKind}=\"Movement\",\"#5b8def\",if({view.params.row.EventKind}=\"Status\",\"#3fb950\",if({view.params.row.EventKind}=\"Attribute\",\"#d29922\",if({view.params.row.EventKind}=\"Pause\",\"#db8b3a\",if({view.params.row.EventKind}=\"Resume\",\"#2dd4bf\",if({view.params.row.EventKind}=\"Genealogy\",\"#a371f7\",if({view.params.row.EventKind}=\"Production\",\"#0d9488\",if({view.params.row.EventKind}=\"Reject\",\"#f85149\",\"#8b949e\"))))))))"
              }
            }
          }
        },
        "props": {
          "path": "mpp/pending_actions",
          "style": {
            "width": "18px",
            "height": "18px"
          }
        }
      },
      {
        "type": "ia.display.label",
        "meta": {
          "name": "EventKindBadge"
        },
        "position": {
          "basis": "auto",
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "type": "property",
              "config": {
                "path": "view.params.row.EventKind"
              }
            }
          },
          "props.style.color": {
            "binding": {
              "type": "expr",
              "config": {
                "expression": "if({view.params.row.EventKind}=\"Movement\",\"#5b8def\",if({view.params.row.EventKind}=\"Status\",\"#3fb950\",if({view.params.row.EventKind}=\"Attribute\",\"#d29922\",if({view.params.row.EventKind}=\"Pause\",\"#db8b3a\",if({view.params.row.EventKind}=\"Resume\",\"#2dd4bf\",if({view.params.row.EventKind}=\"Genealogy\",\"#a371f7\",if({view.params.row.EventKind}=\"Production\",\"#0d9488\",if({view.params.row.EventKind}=\"Reject\",\"#f85149\",\"#8b949e\"))))))))"
              }
            }
          }
        },
        "props": {
          "style": {
            "background": "var(--mpp-surface-alt)",
            "borderRadius": "4px",
            "color": "var(--mpp-text-secondary)",
            "fontSize": "11px",
            "fontWeight": "600",
            "letterSpacing": "0.05em",
            "padding": "2px 8px",
            "textTransform": "uppercase",
            "width": "80px"
          }
        }
      },
      {
        "type": "ia.display.label",
        "meta": {
          "name": "DetailLabel"
        },
        "position": {
          "grow": 1
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "type": "property",
              "config": {
                "path": "view.params.row.Detail"
              }
            }
          }
        },
        "props": {
          "style": {
            "color": "var(--mpp-text-primary)",
            "fontSize": "14px"
          }
        }
      },
      {
        "type": "ia.display.label",
        "meta": {
          "name": "MetaLabel"
        },
        "position": {
          "basis": "auto",
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "type": "expr",
              "config": {
                "expression": "coalesce({view.params.row.EventAgo}, \"\") + \"  ·  \" + toStr({view.params.row.ByUserName}) + \"  ·  \" + coalesce({view.params.row.EventAtDisplay}, \"\")"
              }
            }
          }
        },
        "props": {
          "style": {
            "color": "var(--mpp-text-secondary)",
            "fontSize": "12px"
          }
        }
      }
    ]
  }
}
