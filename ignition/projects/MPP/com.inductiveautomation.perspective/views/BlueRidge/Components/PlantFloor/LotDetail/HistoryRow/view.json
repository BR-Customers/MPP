{
  "custom": {},
  "params": {
    "row": {
      "ByUserName": "",
      "Detail": "",
      "EventAgo": "",
      "EventAt": "",
      "EventAtDisplay": "",
      "EventKind": ""
    }
  },
  "propConfig": {
    "params.row": {
      "paramDirection": "input"
    }
  },
  "props": {
    "defaultSize": {
      "height": 44
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "KindIcon"
        },
        "position": {
          "shrink": 0
        },
        "propConfig": {
          "props.color": {
            "binding": {
              "config": {
                "expression": "if({view.params.row.EventKind}\u003d\"Movement\",\"#5b8def\",if({view.params.row.EventKind}\u003d\"Status\",\"#3fb950\",if({view.params.row.EventKind}\u003d\"Attribute\",\"#d29922\",if({view.params.row.EventKind}\u003d\"Pause\",\"#db8b3a\",if({view.params.row.EventKind}\u003d\"Resume\",\"#2dd4bf\",if({view.params.row.EventKind}\u003d\"Genealogy\",\"#a371f7\",if({view.params.row.EventKind}\u003d\"Production\",\"#0d9488\",if({view.params.row.EventKind}\u003d\"Reject\",\"#f85149\",\"#8b949e\"))))))))"
              },
              "type": "expr"
            }
          },
          "props.path": {
            "binding": {
              "config": {
                "expression": "if({view.params.row.EventKind}\u003d\"Movement\",\"material/swap_horiz\",if({view.params.row.EventKind}\u003d\"Status\",\"material/flag\",if({view.params.row.EventKind}\u003d\"Attribute\",\"material/edit\",if({view.params.row.EventKind}\u003d\"Pause\",\"material/pause\",if({view.params.row.EventKind}\u003d\"Resume\",\"material/play_arrow\",if({view.params.row.EventKind}\u003d\"Genealogy\",\"material/call_split\",if({view.params.row.EventKind}\u003d\"Label\",\"material/label\",if({view.params.row.EventKind}\u003d\"Production\",\"material/build\",if({view.params.row.EventKind}\u003d\"Reject\",\"material/warning\",\"material/circle\")))))))))"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "style": {
            "height": "18px",
            "width": "18px"
          }
        },
        "type": "ia.display.icon"
      },
      {
        "meta": {
          "name": "EventKindBadge"
        },
        "position": {
          "shrink": 0
        },
        "propConfig": {
          "props.style.color": {
            "binding": {
              "config": {
                "expression": "if({view.params.row.EventKind}\u003d\"Movement\",\"#5b8def\",if({view.params.row.EventKind}\u003d\"Status\",\"#3fb950\",if({view.params.row.EventKind}\u003d\"Attribute\",\"#d29922\",if({view.params.row.EventKind}\u003d\"Pause\",\"#db8b3a\",if({view.params.row.EventKind}\u003d\"Resume\",\"#2dd4bf\",if({view.params.row.EventKind}\u003d\"Genealogy\",\"#a371f7\",if({view.params.row.EventKind}\u003d\"Production\",\"#0d9488\",if({view.params.row.EventKind}\u003d\"Reject\",\"#f85149\",\"#8b949e\"))))))))"
              },
              "type": "expr"
            }
          },
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.row.EventKind"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "background": "var(--mpp-surface-alt)",
            "borderRadius": "4px",
            "fontSize": "11px",
            "fontWeight": "600",
            "letterSpacing": "0.05em",
            "padding": "2px 8px",
            "textTransform": "uppercase",
            "width": "80px"
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "DetailLabel"
        },
        "position": {
          "grow": 1
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.row.Detail"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "color": "var(--mpp-text-primary)",
            "fontSize": "14px"
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "MetaLabel"
        },
        "position": {
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "expression": "coalesce({view.params.row.EventAgo}, \"\") + \"  ·  \" + toStr({view.params.row.ByUserName}) + \"  ·  \" + coalesce({view.params.row.EventAtDisplay}, \"\")"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "style": {
            "color": "var(--mpp-text-secondary)",
            "fontSize": "12px"
          }
        },
        "type": "ia.display.label"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "alignItems": "center",
      "style": {
        "borderBottom": "1px solid var(--mpp-border-subtle)",
        "gap": "12px",
        "minHeight": "44px",
        "paddingBottom": "8px",
        "paddingLeft": "12px",
        "paddingRight": "12px",
        "paddingTop": "8px"
      }
    },
    "type": "ia.container.flex"
  }
}