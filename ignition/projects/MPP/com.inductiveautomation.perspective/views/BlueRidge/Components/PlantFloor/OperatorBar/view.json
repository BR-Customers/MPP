{
  "custom": {},
  "params": {},
  "propConfig": {},
  "props": {
    "defaultSize": {
      "width": 1920,
      "height": 44
    }
  },
  "root": {
    "type": "ia.container.flex",
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "row",
      "alignItems": "center",
      "justify": "flex-end",
      "style": {
        "classes": "canvas",
        "gap": "12px",
        "padding": "6px 16px",
        "borderBottom": "1px solid var(--mpp-border-subtle)"
      }
    },
    "children": [
      {
        "type": "ia.display.label",
        "meta": {
          "name": "OperatorLabel"
        },
        "position": {
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "type": "expr",
              "config": {
                "expression": "\"Operator: \" + if(isNull({session.custom.user.displayName}) || {session.custom.user.displayName} = \"\", if(isNull({session.custom.user.initials}), \"-\", {session.custom.user.initials}), {session.custom.user.displayName})"
              }
            }
          }
        },
        "props": {
          "style": {
            "classes": "pf-kpi-sub"
          }
        }
      },
      {
        "type": "ia.input.button",
        "meta": {
          "name": "ChangeOperatorButton"
        },
        "position": {
          "shrink": 0
        },
        "props": {
          "text": "Change Operator",
          "style": {
            "classes": "pf-btn pf-btn-secondary"
          }
        },
        "events": {
          "component": {
            "onActionPerformed": {
              "type": "script",
              "scope": "G",
              "config": {
                "script": "\tsystem.perspective.openPopup(\"mpp-initials\", \"BlueRidge/Components/Popups/InitialsEntry\", params={\"popupId\": \"mpp-initials\"}, modal=True, showCloseIcon=True, overlayDismiss=True)"
              }
            }
          }
        }
      }
    ]
  }
}
