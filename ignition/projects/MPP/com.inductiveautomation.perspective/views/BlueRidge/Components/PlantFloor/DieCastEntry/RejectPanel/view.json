{
  "custom": {
    "draft": {
      "chargeToArea": null,
      "defectCodeId": null,
      "quantity": 0,
      "remarks": null
    }
  },
  "params": {
    "refreshToken": 0,
    "toolCavityId": null,
    "toolId": null
  },
  "propConfig": {
    "custom.defectOptions": {
      "binding": {
        "config": {
          "expression": "runScript(\"BlueRidge.Quality.DefectCode.getForDropdown\", 0)"
        },
        "type": "expr"
      }
    },
    "custom.targetLot": {
      "binding": {
        "config": {
          "expression": "runScript(\"BlueRidge.Lots.Lot.getLatestForToolCavityOrEmpty\", 0, {view.params.toolId}, {view.params.toolCavityId}, {view.params.refreshToken})"
        },
        "type": "expr"
      }
    },
    "params.refreshToken": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.toolCavityId": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.toolId": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 320,
      "width": 320
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "PanelHeader"
        },
        "props": {
          "style": {
            "classes": "pf-panel-header"
          },
          "text": "Reject Entry"
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "TargetLotLabel"
        },
        "propConfig": {
          "props.style.color": {
            "binding": {
              "config": {
                "expression": "if(isNull({view.custom.targetLot.Id}), \"var(--mpp-text-secondary, #757575)\", \"var(--mpp-warning, #b26a00)\")"
              },
              "type": "expr"
            }
          },
          "props.text": {
            "binding": {
              "config": {
                "expression": "if(isNull({view.params.toolCavityId}), \"Select a cavity above to target rejects.\", if(isNull({view.custom.targetLot.Id}), \"No open LOT on the selected cavity.\", \"Rejecting Cavity \" + toStr({view.custom.targetLot.CavityNumber}) + \" - charges newest open LOT \" + {view.custom.targetLot.LotName}))"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "style": {
            "classes": "pf-kpi-sub",
            "fontWeight": 600
          }
        },
        "type": "ia.display.label"
      },
      {
        "children": [
          {
            "meta": {
              "name": "DefectLabel"
            },
            "props": {
              "style": {
                "classes": "pf-field-label"
              },
              "text": "Defect Code"
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "DefectDropdown"
            },
            "propConfig": {
              "props.options": {
                "binding": {
                  "config": {
                    "path": "view.custom.defectOptions"
                  },
                  "type": "property"
                }
              },
              "props.value": {
                "binding": {
                  "config": {
                    "bidirectional": true,
                    "path": "view.custom.draft.defectCodeId"
                  },
                  "type": "property"
                }
              }
            },
            "props": {
              "placeholder": {
                "text": "Select a defect code"
              }
            },
            "type": "ia.input.dropdown"
          }
        ],
        "meta": {
          "name": "DefectField"
        },
        "props": {
          "direction": "column",
          "style": {
            "classes": "pf-field",
            "gap": "4px",
            "overflow": "visible"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "meta": {
              "name": "QuantityLabel"
            },
            "props": {
              "style": {
                "classes": "pf-field-label"
              },
              "text": "Quantity"
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "QuantityInput"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "bidirectional": true,
                    "path": "view.custom.draft.quantity"
                  },
                  "type": "property"
                }
              }
            },
            "props": {
              "style": {
                "classes": "pf-field-input"
              }
            },
            "type": "ia.input.text-field"
          }
        ],
        "meta": {
          "name": "QuantityField"
        },
        "props": {
          "direction": "column",
          "style": {
            "classes": "pf-field",
            "gap": "4px",
            "overflow": "visible"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "events": {
          "component": {
            "onActionPerformed": {
              "config": {
                "script": "\tself.view.rootContainer.submitReject()"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "AddRejectButton"
        },
        "propConfig": {
          "props.enabled": {
            "binding": {
              "config": {
                "expression": "!isNull({view.custom.targetLot.Id}) \u0026\u0026 !isNull({view.custom.draft.defectCodeId}) \u0026\u0026 {view.custom.draft.quantity} \u003e 0"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "style": {
            "classes": "pf-btn pf-btn-secondary"
          },
          "text": "Add RejectEvent"
        },
        "type": "ia.input.button"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "borderTop": "1px solid var(--mpp-border, #e0e0e0)",
        "gap": "12px",
        "overflow": "visible",
        "paddingTop": "12px"
      }
    },
    "scripts": {
      "customMethods": [
        {
          "name": "submitReject",
          "params": [],
          "script": "\t# Cavity-scoped reject (Jacques 2026-07-06): charge the newest open LOT on the selected cavity.\n\ttarget \u003d BlueRidge.Common.Util.extractQualifiedValues(self.view.custom.targetLot) or {}\n\tlotId \u003d target.get(\"Id\")\n\tif lotId is None:\n\t\tBlueRidge.Common.Notify.toast(\"No target LOT\", \"No open LOT on the selected cavity - nothing to reject against.\", \"warning\")\n\t\treturn\n\tdraft \u003d dict(self.view.custom.draft)\n\tdraft[\"lotId\"] \u003d lotId\n\tdraft[\"quantity\"] \u003d BlueRidge.Common.Util.toIntOrNone(draft.get(\"quantity\"))\n\tappUserId \u003d self.session.custom.appUserId\n\ttermId \u003d None\n\ttry:\n\t\ttermId \u003d self.session.custom.terminal.terminalLocationId\n\texcept:\n\t\ttermId \u003d None\n\tresult \u003d BlueRidge.Workorder.RejectEvent.record(draft, appUserId, termId)\n\tBlueRidge.Common.Ui.notifyResult(result, successTitle\u003d\"Reject recorded\")\n\tif result and result.get(\"Status\"):\n\t\tself.view.custom.draft \u003d {\"defectCodeId\": None, \"quantity\": 0, \"chargeToArea\": None, \"remarks\": None}\n\t\tsystem.perspective.sendMessage(\"rejectRecorded\", {\"lotId\": lotId}, scope\u003d\"page\")"
        }
      ],
      "extensionFunctions": null,
      "messageHandlers": null
    },
    "type": "ia.container.flex"
  }
}