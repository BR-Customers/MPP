{
  "custom": {
    "draft": {
      "defectCodeId": null,
      "quantity": 0,
      "chargeToArea": null,
      "remarks": null
    },
    "defectOptions": [],
    "targetLot": {
      "CavityNumber": null,
      "Id": null,
      "InventoryAvailable": 0,
      "LotName": "",
      "PieceCount": 0
    }
  },
  "params": {
    "refreshToken": 0,
    "toolCavityId": null,
    "toolId": null
  },
  "propConfig": {
    "params.refreshToken": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.toolCavityId": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.toolId": {
      "paramDirection": "input",
      "persistent": true
    },
    "custom.defectOptions": {
      "binding": {
        "type": "expr",
        "config": {
          "expression": "runScript(\"BlueRidge.Quality.DefectCode.getForDropdown\", 0)"
        }
      }
    },
    "custom.targetLot": {
      "binding": {
        "type": "expr",
        "config": {
          "expression": "runScript(\"BlueRidge.Lots.Lot.getLatestForToolCavityOrEmpty\", 0, {view.params.toolId}, {view.params.toolCavityId}, {view.params.refreshToken})"
        }
      }
    }
  },
  "props": {
    "defaultSize": {
      "height": 320,
      "width": 320
    }
  },
  "root": {
    "type": "ia.container.flex",
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "borderTop": "1px solid var(--mpp-border, #e0e0e0)",
        "gap": "12px",
        "paddingTop": "12px"
      }
    },
    "children": [
      {
        "type": "ia.display.label",
        "meta": {
          "name": "PanelHeader"
        },
        "props": {
          "text": "Reject Entry",
          "style": {
            "classes": "pf-panel-header"
          }
        }
      },
      {
        "type": "ia.display.label",
        "meta": {
          "name": "TargetLotLabel"
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "type": "expr",
              "config": {
                "expression": "if(isNull({view.params.toolCavityId}), \"Select a cavity above to target rejects.\", if(isNull({view.custom.targetLot.Id}), \"No open LOT on the selected cavity.\", \"Rejecting against \" + {view.custom.targetLot.LotName} + \" (Cavity \" + toStr({view.custom.targetLot.CavityNumber}) + \")\"))"
              }
            }
          },
          "props.style.color": {
            "binding": {
              "type": "expr",
              "config": {
                "expression": "if(isNull({view.custom.targetLot.Id}), \"var(--mpp-text-secondary, #757575)\", \"var(--mpp-warning, #b26a00)\")"
              }
            }
          }
        },
        "props": {
          "style": {
            "classes": "pf-kpi-sub",
            "fontWeight": 600
          }
        }
      },
      {
        "type": "ia.container.flex",
        "meta": {
          "name": "DefectField"
        },
        "props": {
          "direction": "column",
          "style": {
            "classes": "pf-field",
            "gap": "4px"
          }
        },
        "children": [
          {
            "type": "ia.display.label",
            "meta": {
              "name": "DefectLabel"
            },
            "props": {
              "text": "Defect Code",
              "style": {
                "classes": "pf-field-label"
              }
            }
          },
          {
            "type": "ia.input.dropdown",
            "version": 0,
            "meta": {
              "name": "DefectDropdown"
            },
            "props": {
              "placeholder": {
                "text": "Select a defect code"
              }
            },
            "propConfig": {
              "props.options": {
                "binding": {
                  "type": "property",
                  "config": {
                    "path": "view.custom.defectOptions"
                  }
                }
              },
              "props.value": {
                "binding": {
                  "type": "property",
                  "config": {
                    "path": "view.custom.draft.defectCodeId",
                    "bidirectional": true
                  }
                }
              }
            }
          }
        ]
      },
      {
        "type": "ia.container.flex",
        "meta": {
          "name": "QuantityField"
        },
        "props": {
          "direction": "column",
          "style": {
            "classes": "pf-field",
            "gap": "4px"
          }
        },
        "children": [
          {
            "type": "ia.display.label",
            "meta": {
              "name": "QuantityLabel"
            },
            "props": {
              "text": "Quantity",
              "style": {
                "classes": "pf-field-label"
              }
            }
          },
          {
            "type": "ia.input.text-field",
            "version": 0,
            "meta": {
              "name": "QuantityInput"
            },
            "props": {
              "style": {
                "classes": "pf-field-input"
              }
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "type": "property",
                  "config": {
                    "path": "view.custom.draft.quantity",
                    "bidirectional": true
                  }
                }
              }
            }
          }
        ]
      },
      {
        "type": "ia.input.button",
        "version": 0,
        "meta": {
          "name": "AddRejectButton"
        },
        "props": {
          "text": "Add RejectEvent",
          "style": {
            "classes": "pf-btn pf-btn-secondary"
          }
        },
        "propConfig": {
          "props.enabled": {
            "binding": {
              "type": "expr",
              "config": {
                "expression": "!isNull({view.custom.targetLot.Id}) && !isNull({view.custom.draft.defectCodeId}) && {view.custom.draft.quantity} > 0"
              }
            }
          }
        },
        "events": {
          "component": {
            "onActionPerformed": {
              "type": "script",
              "scope": "G",
              "config": {
                "script": "\tself.view.rootContainer.submitReject()"
              }
            }
          }
        }
      }
    ],
    "scripts": {
      "customMethods": [
        {
          "name": "submitReject",
          "params": [],
          "script": "\t# Cavity-scoped reject (Jacques 2026-07-06): charge the newest open LOT on the selected cavity.\n\ttarget = BlueRidge.Common.Util.extractQualifiedValues(self.view.custom.targetLot) or {}\n\tlotId = target.get(\"Id\")\n\tif lotId is None:\n\t\tBlueRidge.Common.Notify.toast(\"No target LOT\", \"No open LOT on the selected cavity - nothing to reject against.\", \"warning\")\n\t\treturn\n\tdraft = dict(self.view.custom.draft)\n\tdraft[\"lotId\"] = lotId\n\tdraft[\"quantity\"] = BlueRidge.Common.Util.toIntOrNone(draft.get(\"quantity\"))\n\tappUserId = self.session.custom.appUserId\n\ttermId = None\n\ttry:\n\t\ttermId = self.session.custom.terminal.terminalLocationId\n\texcept:\n\t\ttermId = None\n\tresult = BlueRidge.Workorder.RejectEvent.record(draft, appUserId, termId)\n\tBlueRidge.Common.Ui.notifyResult(result, successTitle=\"Reject recorded\")\n\tif result and result.get(\"Status\"):\n\t\tself.view.custom.draft = {\"defectCodeId\": None, \"quantity\": 0, \"chargeToArea\": None, \"remarks\": None}\n\t\tsystem.perspective.sendMessage(\"rejectRecorded\", {\"lotId\": lotId}, scope=\"page\")"
        }
      ]
    }
  }
}
