{
  "custom": {},
  "params": {
    "displayName": "",
    "initials": "",
    "popupId": "mpp-idle-reconfirm",
    "replyMessage": "idleReconfirmResult"
  },
  "propConfig": {
    "params.displayName": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.initials": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.popupId": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.replyMessage": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 240,
      "width": 460
    }
  },
  "root": {
    "type": "ia.container.flex",
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "classes": "modal"
      }
    },
    "children": [
      {
        "type": "ia.container.flex",
        "meta": {
          "name": "Header"
        },
        "position": {
          "basis": "auto",
          "shrink": 0
        },
        "props": {
          "alignItems": "center",
          "style": {
            "classes": "modal-header",
            "gap": "10px"
          }
        },
        "children": [
          {
            "type": "ia.display.icon",
            "meta": {
              "name": "TimerIcon"
            },
            "position": {
              "basis": "22px",
              "shrink": 0
            },
            "props": {
              "path": "mpp/pending_actions",
              "style": {
                "width": "22px",
                "height": "22px"
              }
            }
          },
          {
            "type": "ia.display.label",
            "meta": {
              "name": "HeaderTitle"
            },
            "position": {
              "basis": "auto",
              "grow": 1
            },
            "props": {
              "text": "Still there?"
            }
          }
        ]
      },
      {
        "type": "ia.container.flex",
        "meta": {
          "name": "Body"
        },
        "position": {
          "basis": "0",
          "grow": 1
        },
        "props": {
          "direction": "column",
          "style": {
            "classes": "modal-body"
          }
        },
        "children": [
          {
            "type": "ia.display.label",
            "meta": {
              "name": "Prompt"
            },
            "position": {
              "basis": "auto",
              "shrink": 0
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "type": "expr",
                  "config": {
                    "expression": "\"Operate as \" + {view.params.displayName} + \" (\" + {view.params.initials} + \")?\""
                  }
                }
              }
            },
            "props": {
              "style": {
                "color": "var(--mpp-text-primary)",
                "fontSize": "18px"
              }
            }
          }
        ]
      },
      {
        "type": "ia.container.flex",
        "meta": {
          "name": "Footer"
        },
        "position": {
          "basis": "auto",
          "shrink": 0
        },
        "props": {
          "alignItems": "center",
          "justify": "flex-end",
          "style": {
            "classes": "modal-footer",
            "gap": "10px"
          }
        },
        "children": [
          {
            "type": "ia.input.button",
            "meta": {
              "name": "ChangeOperatorButton"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "text": "No - change operator",
              "style": {
                "classes": "pf-btn pf-btn-secondary"
              }
            },
            "events": {
              "component": {
                "onActionPerformed": {
                  "type": "script",
                  "scope": "G",
                  "config": {
                    "script": "\tself.session.custom.user = {\"appUserId\": None, \"initials\": \"\", \"displayName\": \"\", \"ignitionRole\": \"\"}\n\tself.session.custom.appUserId = None\n\tsystem.perspective.closePopup(self.view.params.popupId)\n\tsystem.perspective.navigate(\"/shop-floor/initials\")"
                  }
                }
              }
            }
          },
          {
            "type": "ia.input.button",
            "meta": {
              "name": "ContinueButton"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "text": "Yes, continue",
              "style": {
                "classes": "pf-btn pf-btn-primary"
              }
            },
            "events": {
              "component": {
                "onActionPerformed": {
                  "type": "script",
                  "scope": "G",
                  "config": {
                    "script": "\tsystem.perspective.sendMessage(self.view.params.replyMessage, payload={\"action\": \"continue\"}, scope=\"page\")\n\tsystem.perspective.closePopup(self.view.params.popupId)"
                  }
                }
              }
            }
          }
        ]
      }
    ]
  }
}
