{
  "custom": {},
  "params": {
    "action": "key",
    "key": "",
    "label": "",
    "messageName": "keyboardKeyPressed",
    "variant": "default"
  },
  "propConfig": {
    "params.action": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.key": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.label": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.messageName": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.variant": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 62,
      "width": 62
    }
  },
  "root": {
    "children": [
      {
        "events": {
          "component": {
            "onActionPerformed": {
              "config": {
                "script": "\tsystem.perspective.sendMessage(self.view.params.messageName or \"keyboardKeyPressed\", {\"action\": self.view.params.action, \"key\": self.view.params.key}, scope\u003d\"page\")"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "KeyButton"
        },
        "position": {
          "grow": 1,
          "shrink": 0
        },
        "propConfig": {
          "props.style.classes": {
            "binding": {
              "config": {
                "expression": "\"pf-btn pf-btn-large\" + if({view.params.variant} \u003d \"primary\", \" pf-btn-primary\", if({view.params.variant} \u003d \"secondary\", \" pf-btn-secondary\", \"\"))"
              },
              "type": "expr"
            }
          },
          "props.style.fontSize": {
            "binding": {
              "config": {
                "expression": "if({view.params.action} \u003d \"key\", \"22px\", \"18px\")"
              },
              "type": "expr"
            }
          },
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.label"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "height": "62px"
          }
        },
        "type": "ia.input.button"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column"
    },
    "type": "ia.container.flex"
  }
}