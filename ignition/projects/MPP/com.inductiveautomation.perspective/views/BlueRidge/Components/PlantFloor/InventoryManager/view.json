{
  "custom": {
    "receiveDraft": {
      "partItemId": null,
      "qty": "",
      "vendorLotNumber": ""
    },
    "refreshToken": 0,
    "scanCode": ""
  },
  "params": {
    "locationId": null,
    "replyMessage": "inventoryChanged"
  },
  "propConfig": {
    "custom.partOptions": {
      "binding": {
        "config": {
          "expression": "runScript(\"BlueRidge.Parts.Item.getForDropdown\", 0)"
        },
        "type": "expr"
      }
    },
    "custom.receivedOriginId": {
      "binding": {
        "config": {
          "expression": "runScript(\"BlueRidge.Lots.Lot.getOriginTypeIdByCode\", 0, \"Received\")"
        },
        "type": "expr"
      }
    },
    "params.locationId": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.replyMessage": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 620,
      "width": 1040
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "ContextLine"
        },
        "position": {
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "expression": "if(isNull({session.custom.cell.name}) || {session.custom.cell.name} \u003d \"\", \"Line inventory\", {session.custom.cell.name})"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "style": {
            "fontSize": "18px",
            "fontWeight": 600,
            "overflow": "hidden"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "children": [
              {
                "children": [
                  {
                    "meta": {
                      "name": "CheckInHeader"
                    },
                    "props": {
                      "style": {
                        "classes": "pf-panel-header"
                      },
                      "text": "Check in LTT"
                    },
                    "type": "ia.display.label"
                  },
                  {
                    "meta": {
                      "name": "ScanLabel"
                    },
                    "position": {
                      "shrink": 0
                    },
                    "props": {
                      "style": {
                        "classes": "pf-field-label",
                        "marginBottom": "0px"
                      },
                      "text": "Scan an LTT to check it in to this line"
                    },
                    "type": "ia.display.label"
                  },
                  {
                    "events": {
                      "dom": {
                        "onBlur": {
                          "config": {
                            "script": "\tself.view.rootContainer.checkIn()"
                          },
                          "scope": "G",
                          "type": "script"
                        }
                      }
                    },
                    "meta": {
                      "name": "ScanInput"
                    },
                    "position": {
                      "shrink": 0
                    },
                    "propConfig": {
                      "props.text": {
                        "binding": {
                          "config": {
                            "bidirectional": true,
                            "path": "view.custom.scanCode"
                          },
                          "type": "property"
                        }
                      }
                    },
                    "props": {
                      "placeholder": "Scan LTT barcode",
                      "style": {
                        "classes": "pf-field-input-mono",
                        "fontSize": "18px",
                        "minHeight": "44px",
                        "textTransform": "uppercase"
                      }
                    },
                    "type": "ia.input.text-field"
                  }
                ],
                "meta": {
                  "name": "CheckInPanel"
                },
                "position": {
                  "shrink": 0
                },
                "props": {
                  "direction": "column",
                  "style": {
                    "classes": "pf-panel",
                    "gap": "8px",
                    "padding": "12px"
                  }
                },
                "type": "ia.container.flex"
              },
              {
                "children": [
                  {
                    "meta": {
                      "name": "ReceiveHeader"
                    },
                    "props": {
                      "style": {
                        "classes": "pf-panel-header"
                      },
                      "text": "Receive loose parts"
                    },
                    "type": "ia.display.label"
                  },
                  {
                    "meta": {
                      "name": "ReceiveHelp"
                    },
                    "props": {
                      "style": {
                        "classes": "pf-field-label",
                        "marginBottom": "0px"
                      },
                      "text": "Scan a part number and enter how many are in the box"
                    },
                    "type": "ia.display.label"
                  },
                  {
                    "children": [
                      {
                        "meta": {
                          "name": "PartLabel"
                        },
                        "props": {
                          "style": {
                            "classes": "pf-field-label"
                          },
                          "text": "Part Number (scan or pick)"
                        },
                        "type": "ia.display.label"
                      },
                      {
                        "meta": {
                          "name": "PartNumberDropdown"
                        },
                        "propConfig": {
                          "props.options": {
                            "binding": {
                              "config": {
                                "path": "view.custom.partOptions"
                              },
                              "type": "property"
                            }
                          },
                          "props.value": {
                            "binding": {
                              "config": {
                                "bidirectional": true,
                                "path": "view.custom.receiveDraft.partItemId"
                              },
                              "type": "property"
                            }
                          }
                        },
                        "props": {
                          "allowCustomOptions": true,
                          "placeholder": "Scan or select a part number",
                          "style": {
                            "minHeight": "44px"
                          }
                        },
                        "type": "ia.input.dropdown"
                      }
                    ],
                    "meta": {
                      "name": "PartField"
                    },
                    "props": {
                      "direction": "column",
                      "style": {
                        "classes": "pf-field",
                        "gap": "4px",
                        "overflow": "visible"
                      }
                    },
                    "type": "ia.container.flex"
                  },
                  {
                    "children": [
                      {
                        "meta": {
                          "name": "QtyLabel"
                        },
                        "props": {
                          "style": {
                            "classes": "pf-field-label"
                          },
                          "text": "Piece Count"
                        },
                        "type": "ia.display.label"
                      },
                      {
                        "meta": {
                          "name": "QtyInput"
                        },
                        "propConfig": {
                          "props.text": {
                            "binding": {
                              "config": {
                                "bidirectional": true,
                                "path": "view.custom.receiveDraft.qty"
                              },
                              "type": "property"
                            }
                          }
                        },
                        "props": {
                          "inputType": "tel",
                          "placeholder": "Enter piece count",
                          "style": {
                            "classes": "pf-field-input",
                            "minHeight": "44px"
                          }
                        },
                        "type": "ia.input.text-field"
                      }
                    ],
                    "meta": {
                      "name": "QtyField"
                    },
                    "props": {
                      "direction": "column",
                      "style": {
                        "classes": "pf-field",
                        "gap": "4px",
                        "overflow": "visible"
                      }
                    },
                    "type": "ia.container.flex"
                  },
                  {
                    "children": [
                      {
                        "meta": {
                          "name": "VendorLotLabel"
                        },
                        "props": {
                          "style": {
                            "classes": "pf-field-label"
                          },
                          "text": "Vendor LOT (optional)"
                        },
                        "type": "ia.display.label"
                      },
                      {
                        "meta": {
                          "name": "VendorLotInput"
                        },
                        "propConfig": {
                          "props.text": {
                            "binding": {
                              "config": {
                                "bidirectional": true,
                                "path": "view.custom.receiveDraft.vendorLotNumber"
                              },
                              "type": "property"
                            }
                          }
                        },
                        "props": {
                          "placeholder": "Scan or enter vendor LOT",
                          "style": {
                            "classes": "pf-field-input-mono",
                            "minHeight": "44px"
                          }
                        },
                        "type": "ia.input.text-field"
                      }
                    ],
                    "meta": {
                      "name": "VendorLotField"
                    },
                    "props": {
                      "direction": "column",
                      "style": {
                        "classes": "pf-field",
                        "gap": "4px",
                        "overflow": "visible"
                      }
                    },
                    "type": "ia.container.flex"
                  },
                  {
                    "events": {
                      "component": {
                        "onActionPerformed": {
                          "config": {
                            "script": "\tself.view.rootContainer.receiveLoose()"
                          },
                          "scope": "G",
                          "type": "script"
                        }
                      }
                    },
                    "meta": {
                      "name": "AddButton"
                    },
                    "position": {
                      "shrink": 0
                    },
                    "props": {
                      "style": {
                        "classes": "pf-btn pf-btn-primary"
                      },
                      "text": "Add to line"
                    },
                    "type": "ia.input.button"
                  }
                ],
                "meta": {
                  "name": "ReceivePanel"
                },
                "position": {
                  "shrink": 0
                },
                "props": {
                  "direction": "column",
                  "style": {
                    "classes": "pf-panel",
                    "gap": "10px",
                    "padding": "12px"
                  }
                },
                "type": "ia.container.flex"
              }
            ],
            "meta": {
              "name": "ActionsCol"
            },
            "position": {
              "basis": "420px",
              "shrink": 0
            },
            "props": {
              "direction": "column",
              "style": {
                "gap": "12px",
                "overflow": "hidden"
              }
            },
            "type": "ia.container.flex"
          },
          {
            "children": [
              {
                "meta": {
                  "name": "OnHandHeader"
                },
                "position": {
                  "shrink": 0
                },
                "props": {
                  "style": {
                    "classes": "pf-panel-header"
                  },
                  "text": "On hand (FIFO by arrival)"
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "OnHandRepeater"
                },
                "position": {
                  "basis": "0",
                  "grow": 1
                },
                "propConfig": {
                  "props.instances": {
                    "binding": {
                      "config": {
                        "expression": "runScript(\"BlueRidge.Lots.Lot.getLineInventoryCards\", 0, {view.params.locationId}, {view.custom.refreshToken})"
                      },
                      "type": "expr"
                    }
                  }
                },
                "props": {
                  "direction": "column",
                  "elementPosition": {
                    "basis": "92px",
                    "shrink": 0
                  },
                  "path": "BlueRidge/Components/PlantFloor/Trim/InventoryRow",
                  "style": {
                    "gap": "8px",
                    "overflowY": "auto"
                  },
                  "useDefaultViewWidth": false
                },
                "type": "ia.display.flex-repeater"
              }
            ],
            "meta": {
              "name": "OnHandCol"
            },
            "position": {
              "basis": "0",
              "grow": 1
            },
            "props": {
              "direction": "column",
              "style": {
                "classes": "pf-panel",
                "gap": "8px",
                "overflow": "hidden",
                "padding": "12px"
              }
            },
            "type": "ia.container.flex"
          }
        ],
        "meta": {
          "name": "BodyRow"
        },
        "position": {
          "basis": "0",
          "grow": 1
        },
        "props": {
          "style": {
            "gap": "16px",
            "overflow": "hidden"
          }
        },
        "type": "ia.container.flex"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "classes": "pf-field-col",
        "gap": "12px",
        "padding": "16px"
      }
    },
    "scripts": {
      "customMethods": [
        {
          "name": "checkIn",
          "params": [],
          "script": "\tcode \u003d self.view.custom.scanCode\n\tif not code:\n\t\treturn\n\tloc \u003d self.view.params.locationId\n\tif loc is None:\n\t\tBlueRidge.Common.Notify.toast(\"No line selected\", \"This inventory view has no location context.\", \"warning\")\n\t\treturn\n\tlot \u003d BlueRidge.Lots.Lot.getByName(code)\n\tif not lot:\n\t\tBlueRidge.Common.Notify.toast(\"LOT not found\", \"No LOT matches \u0027%s\u0027.\" % code, \"warning\")\n\t\treturn\n\tres \u003d BlueRidge.Lots.Lot.moveToValidated(lot.get(\"Id\"), loc)\n\tBlueRidge.Common.Ui.notifyResult(res, \"Checked in\")\n\tif res and res.get(\"Status\"):\n\t\tself.view.custom.scanCode \u003d \"\"\n\t\tself.view.custom.refreshToken \u003d (self.view.custom.refreshToken or 0) + 1\n\t\tsystem.perspective.sendMessage(self.view.params.replyMessage, payload\u003d{\"lotId\": lot.get(\"Id\")}, scope\u003d\"page\")"
        },
        {
          "name": "refresh",
          "params": [],
          "script": "\tself.view.custom.refreshToken \u003d (self.view.custom.refreshToken or 0) + 1"
        }
      ],
      "extensionFunctions": null,
      "messageHandlers": null
    },
    "type": "ia.container.flex"
  }
}