    "scripts": {
      "customMethods": [
        {
          "name": "checkIn",
          "params": [],
          "script": "\tcode \u003d self.view.custom.scanCode\n\tif not code:\n\t\treturn\n\tloc \u003d self.view.params.locationId\n\tif loc is None:\n\t\tBlueRidge.Common.Notify.toast(\"No line selected\", \"This inventory view has no location context.\", \"warning\")\n\t\treturn\n\tlot \u003d BlueRidge.Lots.Lot.getByName(code)\n\tif not lot:\n\t\tBlueRidge.Common.Notify.toast(\"LOT not found\", \"No LOT matches \u0027%s\u0027.\" % code, \"warning\")\n\t\treturn\n\tres \u003d BlueRidge.Lots.Lot.moveToValidated(lot.get(\"Id\"), loc)\n\tBlueRidge.Common.Ui.notifyResult(res, \"Checked in\")\n\tif res and res.get(\"Status\"):\n\t\tself.view.custom.scanCode \u003d \"\"\n\t\tself.view.custom.refreshToken \u003d (self.view.custom.refreshToken or 0) + 1\n\t\tsystem.perspective.sendMessage(self.view.params.replyMessage, payload\u003d{\"lotId\": lot.get(\"Id\")}, scope\u003d\"page\")"
        },
        {
          "name": "refresh",
          "params": [],
          "script": "\tself.view.custom.refreshToken \u003d (self.view.custom.refreshToken or 0) + 1"
        }
      ],
