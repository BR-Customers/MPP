{
  "custom": {},
  "params": {
    "isRoot": false
  },
  "propConfig": {
    "params.isRoot": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 64,
      "width": 256
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "Icon"
        },
        "position": {
          "basis": "64px"
        },
        "propConfig": {
          "meta.visible": {
            "binding": {
              "config": {
                "path": "view.params.isRoot"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "path": "material/arrow_forward_ios",
          "style": {
            "marginRight": 16
          }
        },
        "type": "ia.display.icon"
      },
      {
        "meta": {
          "name": "Label"
        },
        "position": {
          "basis": "50px",
          "grow": 1
        },
        "props": {
          "text": "Label"
        },
        "type": "ia.display.label"
      }
    ],
    "meta": {
      "name": "root"
    },
    "type": "ia.container.flex"
  }
}