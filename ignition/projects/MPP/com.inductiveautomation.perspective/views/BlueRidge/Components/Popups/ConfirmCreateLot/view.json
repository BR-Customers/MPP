{
  "custom": {},
  "params": {
    "title": "Create LOT",
    "message": "Create this LOT?",
    "replyMessage": "confirmCreateLotResult",
    "popupId": "mpp-confirm-create-lot"
  },
  "propConfig": {
    "params.title": { "paramDirection": "input", "persistent": true },
    "params.message": { "paramDirection": "input", "persistent": true },
    "params.replyMessage": { "paramDirection": "input", "persistent": true },
    "params.popupId": { "paramDirection": "input", "persistent": true }
  },
  "props": {
    "defaultSize": { "height": 220, "width": 640 }
  },
  "root": {
    "type": "ia.container.flex",
    "meta": { "name": "root" },
    "props": {
      "direction": "column",
      "style": { "classes": "surface-card", "gap": "16px", "padding": "24px" }
    },
    "children": [
      {
        "type": "ia.display.label",
        "meta": { "name": "Title" },
        "props": {
          "style": { "fontSize": "20px", "fontWeight": 700 }
        },
        "propConfig": {
          "props.text": {
            "binding": { "type": "property", "config": { "path": "view.params.title" } }
          }
        }
      },
      {
        "type": "ia.display.label",
        "meta": { "name": "Message" },
        "position": { "grow": 1 },
        "props": {
          "style": { "classes": "pf-kpi-sub" }
        },
        "propConfig": {
          "props.text": {
            "binding": { "type": "property", "config": { "path": "view.params.message" } }
          }
        }
      },
      {
        "type": "ia.container.flex",
        "meta": { "name": "ButtonRow" },
        "position": { "shrink": 0 },
        "props": {
          "direction": "row",
          "alignItems": "center",
          "wrap": "nowrap",
          "style": { "gap": "12px", "overflow": "hidden" }
        },
        "children": [
          {
            "type": "ia.input.button",
            "version": 0,
            "meta": { "name": "CancelButton" },
            "position": { "basis": "auto", "shrink": 0 },
            "props": { "text": "Cancel", "style": { "classes": "pf-btn pf-btn-secondary", "minHeight": "44px" } },
            "events": {
              "component": {
                "onActionPerformed": {
                  "type": "script", "scope": "G",
                  "config": { "script": "\tsystem.perspective.sendMessage(self.view.params.replyMessage, payload={\"action\": \"cancel\"}, scope=\"page\")\n\tsystem.perspective.closePopup(id=self.view.params.popupId)" }
                }
              }
            }
          },
          {
            "type": "ia.display.label",
            "meta": { "name": "Spacer" },
            "position": { "grow": 1 },
            "props": { "text": "" }
          },
          {
            "type": "ia.input.button",
            "version": 0,
            "meta": { "name": "ClearButton" },
            "position": { "basis": "auto", "shrink": 0 },
            "props": { "text": "Confirm & Clear", "style": { "classes": "pf-btn pf-btn-primary", "minHeight": "44px" } },
            "events": {
              "component": {
                "onActionPerformed": {
                  "type": "script", "scope": "G",
                  "config": { "script": "\tsystem.perspective.sendMessage(self.view.params.replyMessage, payload={\"action\": \"clear\"}, scope=\"page\")\n\tsystem.perspective.closePopup(id=self.view.params.popupId)" }
                }
              }
            }
          },
          {
            "type": "ia.input.button",
            "version": 0,
            "meta": { "name": "AnotherButton" },
            "position": { "basis": "auto", "shrink": 0 },
            "props": { "text": "Confirm & Submit Another", "style": { "classes": "pf-btn pf-btn-primary", "minHeight": "44px" } },
            "events": {
              "component": {
                "onActionPerformed": {
                  "type": "script", "scope": "G",
                  "config": { "script": "\tsystem.perspective.sendMessage(self.view.params.replyMessage, payload={\"action\": \"another\"}, scope=\"page\")\n\tsystem.perspective.closePopup(id=self.view.params.popupId)" }
                }
              }
            }
          }
        ]
      }
    ]
  }
}
