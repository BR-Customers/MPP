{
  "custom": {},
  "params": {
    "attributeOptions": [],
    "row": {
      "dataType": "String",
      "definitionLabel": "",
      "id": null,
      "rowIndex": 0,
      "toolAttributeDefinitionId": null,
      "value": ""
    }
  },
  "propConfig": {
    "params.attributeOptions": {
      "paramDirection": "input"
    },
    "params.row": {
      "paramDirection": "input"
    }
  },
  "props": {
    "defaultSize": {
      "height": 36,
      "width": 1200
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "IndexLabel"
        },
        "position": {
          "basis": "32px",
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "expression": "toStr({view.params.row.rowIndex} + 1)"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "style": {
            "color": "var(--mpp-text-secondary)",
            "fontSize": "12px",
            "textAlign": "right"
          }
        },
        "type": "ia.display.label"
      },
      {
        "events": {
          "component": {
            "onActionPerformed": {
              "config": {
                "script": "\tsystem.perspective.sendMessage(\"attrRowDefinitionChanged\", payload\u003d{\"rowIndex\": self.view.params.row.rowIndex, \"newDefId\": self.props.value}, scope\u003d\"page\")"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "DefinitionDropdown"
        },
        "position": {
          "basis": "0",
          "grow": 1
        },
        "propConfig": {
          "position.display": {
            "binding": {
              "config": {
                "expression": "isNull({view.params.row.id})"
              },
              "type": "expr"
            }
          },
          "props.options": {
            "binding": {
              "config": {
                "path": "view.params.attributeOptions"
              },
              "transforms": [
                {
                  "code": "\tout \u003d []\n\tfor it in (value or []):\n\t\tit \u003d it or {}\n\t\tout.append({\u0027label\u0027: it.get(\u0027label\u0027) or \u0027\u0027, \u0027value\u0027: it.get(\u0027value\u0027)})\n\treturn out",
                  "type": "script"
                }
              ],
              "type": "property"
            }
          },
          "props.value": {
            "binding": {
              "config": {
                "path": "view.params.row.toolAttributeDefinitionId"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "filterable": true,
          "noSelectionText": "Pick attribute...",
          "style": {
            "classes": "select",
            "height": "30px"
          }
        },
        "type": "ia.input.dropdown"
      },
      {
        "meta": {
          "name": "DefinitionLabel"
        },
        "position": {
          "basis": "0",
          "grow": 1
        },
        "propConfig": {
          "position.display": {
            "binding": {
              "config": {
                "expression": "!isNull({view.params.row.id})"
              },
              "type": "expr"
            }
          },
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.row.definitionLabel"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "fontSize": "12px"
          }
        },
        "type": "ia.display.label"
      },
      {
        "events": {
          "dom": {
            "onBlur": {
              "config": {
                "script": "\tsystem.perspective.sendMessage(\"attrRowValueChanged\", payload\u003d{\"rowIndex\": self.view.params.row.rowIndex, \"newValue\": self.props.text}, scope\u003d\"page\")"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "ValueText"
        },
        "position": {
          "basis": "260px",
          "shrink": 0
        },
        "propConfig": {
          "position.display": {
            "binding": {
              "config": {
                "expression": "{view.params.row.dataType} \u003d \"String\""
              },
              "type": "expr"
            }
          },
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.row.value"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "placeholder": "Value",
          "style": {
            "classes": "search-input",
            "height": "30px"
          }
        },
        "type": "ia.input.text-field"
      },
      {
        "events": {
          "dom": {
            "onBlur": {
              "config": {
                "script": "\tv \u003d self.props.value\n\tnewValue \u003d \"\" if v is None else str(v)\n\tsystem.perspective.sendMessage(\"attrRowValueChanged\", payload\u003d{\"rowIndex\": self.view.params.row.rowIndex, \"newValue\": newValue}, scope\u003d\"page\")"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "ValueNumeric"
        },
        "position": {
          "basis": "260px",
          "shrink": 0
        },
        "propConfig": {
          "position.display": {
            "binding": {
              "config": {
                "expression": "{view.params.row.dataType} \u003d \"Integer\" || {view.params.row.dataType} \u003d \"Decimal\""
              },
              "type": "expr"
            }
          },
          "props.value": {
            "binding": {
              "config": {
                "expression": "if(isNull({view.params.row.value}) || {view.params.row.value} \u003d \"\", null, toFloat({view.params.row.value}))"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "placeholder": "Value",
          "style": {
            "classes": "search-input",
            "height": "30px"
          }
        },
        "type": "ia.input.numeric-entry-field"
      },
      {
        "events": {
          "component": {
            "onActionPerformed": {
              "config": {
                "script": "\tnewValue \u003d \"true\" if self.props.selected else \"false\"\n\tsystem.perspective.sendMessage(\"attrRowValueChanged\", payload\u003d{\"rowIndex\": self.view.params.row.rowIndex, \"newValue\": newValue}, scope\u003d\"page\")"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "ValueCheckbox"
        },
        "position": {
          "basis": "260px",
          "shrink": 0
        },
        "propConfig": {
          "position.display": {
            "binding": {
              "config": {
                "expression": "{view.params.row.dataType} \u003d \"Boolean\""
              },
              "type": "expr"
            }
          },
          "props.selected": {
            "binding": {
              "config": {
                "expression": "{view.params.row.value} \u003d \"true\""
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "style": {
            "height": "30px"
          },
          "text": ""
        },
        "type": "ia.input.checkbox"
      },
      {
        "events": {
          "dom": {
            "onBlur": {
              "config": {
                "script": "\tv \u003d self.props.value\n\tnewValue \u003d \"\" if v is None else system.date.format(v, \"yyyy-MM-dd\")\n\tsystem.perspective.sendMessage(\"attrRowValueChanged\", payload\u003d{\"rowIndex\": self.view.params.row.rowIndex, \"newValue\": newValue}, scope\u003d\"page\")"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "ValueDate"
        },
        "position": {
          "basis": "260px",
          "shrink": 0
        },
        "propConfig": {
          "position.display": {
            "binding": {
              "config": {
                "expression": "{view.params.row.dataType} \u003d \"Date\""
              },
              "type": "expr"
            }
          },
          "props.value": {
            "binding": {
              "config": {
                "expression": "if(isNull({view.params.row.value}) || {view.params.row.value} \u003d \"\", null, parseDate({view.params.row.value}, \"yyyy-MM-dd\"))"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "format": "YYYY-MM-DD",
          "style": {
            "classes": "search-input",
            "height": "30px"
          }
        },
        "type": "ia.input.date-time-input"
      },
      {
        "events": {
          "component": {
            "onActionPerformed": {
              "config": {
                "script": "\tsystem.perspective.sendMessage(\"attrRowRemove\", payload\u003d{\"rowIndex\": self.view.params.row.rowIndex}, scope\u003d\"page\")"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "RemoveBtn"
        },
        "position": {
          "basis": "40px",
          "shrink": 0
        },
        "props": {
          "style": {
            "classes": "btn btn-sm",
            "height": "30px",
            "padding": "2px 6px"
          },
          "text": "×"
        },
        "type": "ia.input.button"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "alignItems": "center",
      "style": {
        "borderBottom": "1px solid var(--mpp-border-subtle)",
        "gap": "6px",
        "height": "100%",
        "padding": "2px 10px"
      }
    },
    "type": "ia.container.flex"
  }
}