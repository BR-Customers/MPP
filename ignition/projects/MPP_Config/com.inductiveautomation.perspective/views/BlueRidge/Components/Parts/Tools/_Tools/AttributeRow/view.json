{
  "custom": {},
  "params": {
    "row": {
      "rowIndex": 0,
      "id": null,
      "toolAttributeDefinitionId": null,
      "definitionLabel": "",
      "value": "",
      "dataType": "String"
    },
    "attributeOptions": []
  },
  "propConfig": {
    "params.row":              { "paramDirection": "input" },
    "params.attributeOptions": { "paramDirection": "input" }
  },
  "props": {
    "defaultSize": { "height": 36, "width": 1200 }
  },
  "root": {
    "type": "ia.container.flex",
    "meta": { "name": "root" },
    "props": {
      "direction": "row",
      "alignItems": "center",
      "style": {
        "borderBottom": "1px solid var(--mpp-border-subtle)",
        "gap": "6px",
        "padding": "2px 10px",
        "height": "100%"
      }
    },
    "children": [
      {
        "type": "ia.display.label",
        "meta": { "name": "IndexLabel" },
        "position": { "basis": "32px", "shrink": 0 },
        "propConfig": {
          "props.text": {
            "binding": {
              "type": "expr",
              "config": { "expression": "toStr({view.params.row.rowIndex} + 1)" }
            }
          }
        },
        "props": {
          "style": {
            "color": "var(--mpp-text-secondary)",
            "fontSize": "12px",
            "textAlign": "right"
          }
        }
      },
      {
        "type": "ia.input.dropdown",
        "meta": { "name": "DefinitionDropdown" },
        "position": { "grow": 1, "basis": "0" },
        "propConfig": {
          "position.display": {
            "binding": {
              "type": "expr",
              "config": { "expression": "isNull({view.params.row.id})" }
            }
          },
          "props.options": {
            "binding": {
              "type": "property",
              "config": { "path": "view.params.attributeOptions" },
              "transforms": [
                {
                  "type": "script",
                  "code": "\tout = []\n\tfor it in (value or []):\n\t\tit = it or {}\n\t\tout.append({'label': it.get('label') or '', 'value': it.get('value')})\n\treturn out"
                }
              ]
            }
          },
          "props.value": {
            "binding": {
              "type": "property",
              "config": { "path": "view.params.row.toolAttributeDefinitionId" }
            }
          }
        },
        "props": {
          "filterable": true,
          "noSelectionText": "Pick attribute...",
          "style": { "classes": "select", "height": "30px" }
        },
        "events": {
          "component": {
            "onActionPerformed": {
              "type": "script",
              "scope": "G",
              "config": {
                "script": "\tsystem.perspective.sendMessage(\"attrRowDefinitionChanged\", payload={\"rowIndex\": self.view.params.row.rowIndex, \"newDefId\": self.props.value}, scope=\"page\")"
              }
            }
          }
        }
      },
      {
        "type": "ia.display.label",
        "meta": { "name": "DefinitionLabel" },
        "position": { "grow": 1, "basis": "0" },
        "propConfig": {
          "position.display": {
            "binding": {
              "type": "expr",
              "config": { "expression": "!isNull({view.params.row.id})" }
            }
          },
          "props.text": {
            "binding": {
              "type": "property",
              "config": { "path": "view.params.row.definitionLabel" }
            }
          }
        },
        "props": {
          "text": "",
          "style": { "fontSize": "12px" }
        }
      },
      {
        "type": "ia.input.text-field",
        "meta": { "name": "ValueText" },
        "position": { "basis": "260px", "shrink": 0 },
        "propConfig": {
          "position.display": {
            "binding": {
              "type": "expr",
              "config": { "expression": "{view.params.row.dataType} = \"String\"" }
            }
          },
          "props.text": {
            "binding": {
              "type": "property",
              "config": { "path": "view.params.row.value" }
            }
          }
        },
        "props": {
          "placeholder": "Value",
          "style": { "classes": "search-input", "height": "30px" }
        },
        "events": {
          "dom": {
            "onBlur": {
              "type": "script",
              "scope": "G",
              "config": {
                "script": "\tsystem.perspective.sendMessage(\"attrRowValueChanged\", payload={\"rowIndex\": self.view.params.row.rowIndex, \"newValue\": self.props.text}, scope=\"page\")"
              }
            }
          }
        }
      },
      {
        "type": "ia.input.numeric-entry-field",
        "meta": { "name": "ValueNumeric" },
        "position": { "basis": "260px", "shrink": 0 },
        "propConfig": {
          "position.display": {
            "binding": {
              "type": "expr",
              "config": { "expression": "{view.params.row.dataType} = \"Integer\" || {view.params.row.dataType} = \"Decimal\"" }
            }
          },
          "props.value": {
            "binding": {
              "type": "expr",
              "config": { "expression": "if(isNull({view.params.row.value}) || {view.params.row.value} = \"\", null, toFloat({view.params.row.value}))" }
            }
          }
        },
        "props": {
          "placeholder": "Value",
          "style": { "classes": "search-input", "height": "30px" }
        },
        "events": {
          "component": {
            "onActionPerformed": {
              "type": "script",
              "scope": "G",
              "config": {
                "script": "\tv = self.props.value\n\tnewValue = \"\" if v is None else toStr(v)\n\tsystem.perspective.sendMessage(\"attrRowValueChanged\", payload={\"rowIndex\": self.view.params.row.rowIndex, \"newValue\": newValue}, scope=\"page\")"
              }
            }
          }
        }
      },
      {
        "type": "ia.input.checkbox",
        "meta": { "name": "ValueCheckbox" },
        "position": { "basis": "260px", "shrink": 0 },
        "propConfig": {
          "position.display": {
            "binding": {
              "type": "expr",
              "config": { "expression": "{view.params.row.dataType} = \"Boolean\"" }
            }
          },
          "props.selected": {
            "binding": {
              "type": "expr",
              "config": { "expression": "{view.params.row.value} = \"true\"" }
            }
          }
        },
        "props": {
          "text": "",
          "style": { "height": "30px" }
        },
        "events": {
          "component": {
            "onActionPerformed": {
              "type": "script",
              "scope": "G",
              "config": {
                "script": "\tnewValue = \"true\" if self.props.selected else \"false\"\n\tsystem.perspective.sendMessage(\"attrRowValueChanged\", payload={\"rowIndex\": self.view.params.row.rowIndex, \"newValue\": newValue}, scope=\"page\")"
              }
            }
          }
        }
      },
      {
        "type": "ia.input.date-time-input",
        "meta": { "name": "ValueDate" },
        "position": { "basis": "260px", "shrink": 0 },
        "propConfig": {
          "position.display": {
            "binding": {
              "type": "expr",
              "config": { "expression": "{view.params.row.dataType} = \"Date\"" }
            }
          },
          "props.value": {
            "binding": {
              "type": "expr",
              "config": { "expression": "if(isNull({view.params.row.value}) || {view.params.row.value} = \"\", null, parseDate({view.params.row.value}, \"yyyy-MM-dd\"))" }
            }
          }
        },
        "props": {
          "format": "YYYY-MM-DD",
          "style": { "classes": "search-input", "height": "30px" }
        },
        "events": {
          "component": {
            "onActionPerformed": {
              "type": "script",
              "scope": "G",
              "config": {
                "script": "\tv = self.props.value\n\tnewValue = \"\" if v is None else system.date.format(v, \"yyyy-MM-dd\")\n\tsystem.perspective.sendMessage(\"attrRowValueChanged\", payload={\"rowIndex\": self.view.params.row.rowIndex, \"newValue\": newValue}, scope=\"page\")"
              }
            }
          }
        }
      },
      {
        "type": "ia.input.button",
        "meta": { "name": "RemoveBtn" },
        "position": { "basis": "40px", "shrink": 0 },
        "props": {
          "text": "×",
          "style": { "classes": "btn btn-sm", "padding": "2px 6px", "height": "30px" }
        },
        "events": {
          "component": {
            "onActionPerformed": {
              "type": "script",
              "scope": "G",
              "config": {
                "script": "\tsystem.perspective.sendMessage(\"attrRowRemove\", payload={\"rowIndex\": self.view.params.row.rowIndex}, scope=\"page\")"
              }
            }
          }
        }
      }
    ]
  }
}
