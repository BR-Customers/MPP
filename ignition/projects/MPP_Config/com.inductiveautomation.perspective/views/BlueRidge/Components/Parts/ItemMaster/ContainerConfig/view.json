    "scripts": {
      "customMethods": [
        {
          "name": "load",
          "params": [],
          "script": "\titemId = self.view.params.value\n\tdef _s(v):\n\t\treturn \"\" if v is None else (v if isinstance(v, basestring) else unicode(v))\n\tif not itemId:\n\t\tempty = {\n\t\t\t\"Id\": None, \"ItemId\": None,\n\t\t\t\"TraysPerContainer\": \"\", \"PartsPerTray\": \"\",\n\t\t\t\"IsSerialized\": False,\n\t\t\t\"ClosureMethod\": None, \"TargetWeight\": \"\",\n\t\t\t\"DunnageCode\": \"\", \"CustomerCode\": \"\",\n\t\t}\n\t\tself.view.custom.selected  = dict(empty)\n\t\tself.view.custom.editDraft = dict(empty)\n\t\treturn\n\trow = BlueRidge.Parts.ContainerConfig.getByItem(itemId) or {}\n\tloaded = {\n\t\t\"Id\":                row.get(\"Id\"),\n\t\t\"ItemId\":            itemId,\n\t\t\"TraysPerContainer\": _s(row.get(\"TraysPerContainer\")),\n\t\t\"PartsPerTray\":      _s(row.get(\"PartsPerTray\")),\n\t\t\"IsSerialized\":      bool(row.get(\"IsSerialized\", False)),\n\t\t\"ClosureMethod\":     row.get(\"ClosureMethod\"),\n\t\t\"TargetWeight\":      _s(row.get(\"TargetWeight\")),\n\t\t\"DunnageCode\":       _s(row.get(\"DunnageCode\")),\n\t\t\"CustomerCode\":      _s(row.get(\"CustomerCode\")),\n\t}\n\tself.view.custom.selected  = dict(loaded)\n\tself.view.custom.editDraft = dict(loaded)"
        },
        {
          "name": "handleSave",
          "params": [],
          "script": "\tdraft = self.view.custom.editDraft or {}\n\titemId = self.view.params.value\n\tif not itemId:\n\t\tBlueRidge.Common.Notify.toast(\"No item selected\", \"Select an item before saving container configuration.\", \"warning\")\n\t\treturn\n\tdef _toNum(v):\n\t\tif v is None or v == \"\":\n\t\t\treturn None\n\t\ttry:\n\t\t\treturn int(v)\n\t\texcept (ValueError, TypeError):\n\t\t\ttry:\n\t\t\t\treturn float(v)\n\t\t\texcept (ValueError, TypeError):\n\t\t\t\treturn None\n\ttrays = _toNum(draft.get(\"TraysPerContainer\"))\n\tpartsPerTray = _toNum(draft.get(\"PartsPerTray\"))\n\tif trays is None or trays <= 0:\n\t\tBlueRidge.Common.Notify.toast(\"Trays per Container required\", \"Enter a positive number of trays per container.\", \"warning\")\n\t\treturn\n\tif partsPerTray is None or partsPerTray <= 0:\n\t\tBlueRidge.Common.Notify.toast(\"Parts per Tray required\", \"Enter a positive number of parts per tray.\", \"warning\")\n\t\treturn\n\ttargetWeight = None\n\tif draft.get(\"ClosureMethod\") == \"ByWeight\":\n\t\ttargetWeight = _toNum(draft.get(\"TargetWeight\"))\n\t\tif targetWeight is None or targetWeight <= 0:\n\t\t\tBlueRidge.Common.Notify.toast(\"Target Weight required\", \"ByWeight closure requires a positive target weight.\", \"warning\")\n\t\t\treturn\n\tpayload = dict(draft)\n\tpayload[\"ItemId\"] = itemId\n\tpayload[\"TraysPerContainer\"] = trays\n\tpayload[\"PartsPerTray\"] = partsPerTray\n\tpayload[\"TargetWeight\"] = targetWeight\n\tif payload.get(\"Id\"):\n\t\tresult = BlueRidge.Parts.ContainerConfig.update(payload)\n\t\tsuccessTitle = \"Container config updated\"\n\telse:\n\t\tresult = BlueRidge.Parts.ContainerConfig.add(payload)\n\t\tsuccessTitle = \"Container config saved\"\n\tBlueRidge.Common.Ui.notifyResult(result, successTitle)\n\tif result and result.get(\"Status\"):\n\t\tself.load()"
        },
        {
          "name": "handleDiscard",
          "params": [],
          "script": "\tself.view.custom.editDraft = dict(self.view.custom.selected)"
        }
      ],
      "messageHandlers": [
        {
          "messageType": "sectionSaveRequested",
          "pageScope": true,
          "script": "\tif payload and payload.get(\"section\") == \"containerConfig\":\n\t\tself.handleSave()",
          "sessionScope": false,
          "viewScope": false
        },
        {
          "messageType": "sectionDiscardRequested",
          "pageScope": true,
          "script": "\tif payload and payload.get(\"section\") == \"containerConfig\":\n\t\tself.handleDiscard()",
          "sessionScope": false,
          "viewScope": false
        }
      ]
    },
