{
  "custom": {},
  "params": {
    "selectedId": 0,
    "tool": {}
  },
  "propConfig": {
    "params.selectedId": {
      "paramDirection": "input"
    },
    "params.tool": {
      "paramDirection": "input"
    }
  },
  "props": {
    "defaultSize": {
      "height": 44,
      "width": 240
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "meta": {
              "name": "LabelCode"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "path": "view.params.tool.code"
                  },
                  "type": "property"
                }
              }
            },
            "props": {
              "style": {
                "fontSize": "12px",
                "fontWeight": "600"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "LabelName"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "path": "view.params.tool.name"
                  },
                  "type": "property"
                }
              }
            },
            "props": {
              "style": {
                "color": "var(--mpp-text-muted)",
                "fontSize": "11px",
                "overflow": "hidden",
                "textOverflow": "ellipsis",
                "whiteSpace": "nowrap"
              }
            },
            "type": "ia.display.label"
          }
        ],
        "meta": {
          "name": "RowText"
        },
        "position": {
          "basis": "0",
          "grow": 1
        },
        "props": {
          "direction": "column",
          "style": {
            "gap": "1px",
            "overflow": "hidden"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "meta": {
          "name": "BadgeRank"
        },
        "propConfig": {
          "position.display": {
            "binding": {
              "config": {
                "expression": "!isNull({view.params.tool.rank})"
              },
              "type": "expr"
            }
          },
          "props.style.classes": {
            "binding": {
              "config": {
                "expression": "if({view.params.tool.rank} \u003d \u0027A\u0027, \u0027badge badge-purple\u0027, \u0027badge badge-muted\u0027)"
              },
              "type": "expr"
            }
          },
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.tool.rank"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "fontSize": "10px",
            "padding": "1px 5px"
          }
        },
        "type": "ia.display.label"
      }
    ],
    "events": {
      "dom": {
        "onClick": {
          "config": {
            "script": "\tsystem.perspective.sendMessage(\u0027toolRowClicked\u0027, payload\u003d{\u0027id\u0027: self.view.params.tool.get(\u0027id\u0027)}, scope\u003d\u0027page\u0027)"
          },
          "scope": "G",
          "type": "script"
        }
      }
    },
    "meta": {
      "name": "root"
    },
    "propConfig": {
      "props.style.classes": {
        "binding": {
          "config": {
            "expression": "if({view.params.tool.id} \u003d {view.params.selectedId}, \u0027tree-item tree-item-selected\u0027, \u0027tree-item\u0027)"
          },
          "type": "expr"
        }
      },
      "props.style.opacity": {
        "binding": {
          "config": {
            "expression": "if({view.params.tool.deprecated}, 0.55, 1)"
          },
          "type": "expr"
        }
      }
    },
    "props": {
      "alignItems": "center",
      "justify": "space-between",
      "style": {
        "borderBottom": "1px solid var(--mpp-border-subtle)",
        "cursor": "pointer",
        "padding": "4px 10px"
      }
    },
    "type": "ia.container.flex"
  }
}