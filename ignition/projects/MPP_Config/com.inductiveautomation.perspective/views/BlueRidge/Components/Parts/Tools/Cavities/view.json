{
  "custom": {
    "state": {
      "editDraft": {
        "rows": []
      },
      "selected": {
        "rows": []
      }
    }
  },
  "params": {
    "deprecated": false,
    "value": null
  },
  "propConfig": {
    "custom.isDirty": {
      "binding": {
        "config": {
          "expression": "runScript(\"BlueRidge.Common.Util.convertWrapperObjectToJson\", 0, {view.custom.state.editDraft.rows}) !\u003d runScript(\"BlueRidge.Common.Util.convertWrapperObjectToJson\", 0, {view.custom.state.selected.rows})"
        },
        "type": "expr"
      },
      "onChange": {
        "enabled": true,
        "script": "\tsystem.perspective.sendMessage(\"sectionDirtyChanged\", payload\u003d{\"section\": \"cavities\", \"isDirty\": bool(currentValue.value)}, scope\u003d\"page\")"
      }
    },
    "params.deprecated": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.value": {
      "onChange": {
        "enabled": true,
        "script": "\tself.rootContainer.load()"
      },
      "paramDirection": "input"
    }
  },
  "props": {
    "defaultSize": {
      "height": 360,
      "width": 1200
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "meta": {
              "name": "PanelHeader"
            },
            "props": {
              "style": {
                "fontSize": "13px",
                "fontWeight": "600"
              },
              "text": "Cavities"
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "Spacer"
            },
            "position": {
              "grow": 1
            },
            "type": "ia.display.label"
          },
          {
            "events": {
              "component": {
                "onActionPerformed": {
                  "config": {
                    "script": "\tself.view.rootContainer.handleDiscard()"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "BtnDiscard"
            },
            "position": {
              "shrink": 0
            },
            "propConfig": {
              "meta.visible": {
                "binding": {
                  "config": {
                    "expression": "if(isNull({view.custom.isDirty}), false, {view.custom.isDirty})"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "classes": "btn btn-sm"
              },
              "text": "Discard"
            },
            "type": "ia.input.button"
          },
          {
            "events": {
              "component": {
                "onActionPerformed": {
                  "config": {
                    "script": "\tself.view.rootContainer.handleSave()"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "BtnSave"
            },
            "position": {
              "shrink": 0
            },
            "propConfig": {
              "props.enabled": {
                "binding": {
                  "config": {
                    "expression": "if(isNull({view.custom.isDirty}), false, {view.custom.isDirty})"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "classes": "btn btn-primary btn-sm"
              },
              "text": "Save"
            },
            "type": "ia.input.button"
          }
        ],
        "meta": {
          "name": "HeaderRow"
        },
        "props": {
          "alignItems": "center",
          "style": {
            "gap": "8px"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "meta": {
              "name": "ColHash"
            },
            "position": {
              "basis": "32px",
              "shrink": 0
            },
            "props": {
              "style": {
                "color": "var(--mpp-text-muted)",
                "fontSize": "11px",
                "textAlign": "right"
              },
              "text": "#"
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "ColNumber"
            },
            "position": {
              "basis": "120px",
              "shrink": 0
            },
            "props": {
              "style": {
                "color": "var(--mpp-text-muted)",
                "fontSize": "11px"
              },
              "text": "Number"
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "ColDescription"
            },
            "position": {
              "basis": "0",
              "grow": 1
            },
            "props": {
              "style": {
                "color": "var(--mpp-text-muted)",
                "fontSize": "11px"
              },
              "text": "Description"
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "ColStatus"
            },
            "position": {
              "basis": "160px",
              "shrink": 0
            },
            "props": {
              "style": {
                "color": "var(--mpp-text-muted)",
                "fontSize": "11px"
              },
              "text": "Status"
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "ColRm"
            },
            "position": {
              "basis": "40px",
              "shrink": 0
            },
            "type": "ia.display.label"
          }
        ],
        "meta": {
          "name": "ColumnHeader"
        },
        "props": {
          "alignItems": "center",
          "style": {
            "gap": "6px",
            "padding": "0 10px"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "meta": {
          "name": "RowsRepeater"
        },
        "position": {
          "basis": "0",
          "grow": 1
        },
        "propConfig": {
          "props.instances": {
            "binding": {
              "config": {
                "path": "view.custom.state.editDraft.rows"
              },
              "transforms": [
                {
                  "code": "\trows \u003d BlueRidge.Common.Util.extractQualifiedValues(value) or []\n\tout \u003d []\n\tif len(rows) \u003d\u003d 0:\n\t\treturn []\n\t\t\n\tfor i, r in enumerate(rows):\n\t\tr \u003d dict(r or {})\n\t\tr[\u0027rowIndex\u0027] \u003d i\n\t\tout.append({\u0027row\u0027: r})\n\treturn out",
                  "type": "script"
                }
              ],
              "type": "property"
            }
          }
        },
        "props": {
          "direction": "column",
          "elementPosition": {
            "basis": "auto"
          },
          "elementStyle": {
            "maxHeight": "44px"
          },
          "path": "BlueRidge/Components/Parts/Tools/_Tools/CavityRow",
          "style": {
            "overflow": "scroll",
            "overflowY": "auto"
          },
          "useDefaultViewWidth": false
        },
        "type": "ia.display.flex-repeater"
      },
      {
        "events": {
          "component": {
            "onActionPerformed": {
              "config": {
                "script": "\tself.view.rootContainer.addRow()"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "BtnAddRow"
        },
        "position": {
          "shrink": 0
        },
        "propConfig": {
          "props.enabled": {
            "binding": {
              "config": {
                "expression": "!{view.params.deprecated}"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "style": {
            "classes": "btn btn-sm"
          },
          "text": "+ Add cavity"
        },
        "type": "ia.input.button"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "classes": "detail-panel",
        "gap": "8px",
        "padding": "10px 14px"
      }
    },
    "scripts": {
      "customMethods": [
        {
          "name": "load",
          "params": [],
          "script": "\ttoolId \u003d self.view.params.value\n\tif not toolId:\n\t\tempty \u003d {\"rows\": []}\n\t\tself.view.custom.state \u003d {\"selected\": dict(empty), \"editDraft\": dict(empty)}\n\t\treturn\n\tinstances \u003d BlueRidge.Parts.Tool.getCavityInstancesForTool(toolId) or []\n\tloaded \u003d []\n\tfor inst in instances:\n\t\tcav \u003d (inst or {}).get(\"cavity\") or {}\n\t\tsc \u003d cav.get(\"StatusCode\") or \"Active\"\n\t\tloaded.append({\n\t\t\t\"id\":              cav.get(\"Id\"),\n\t\t\t\"cavityNumber\":    cav.get(\"Number\"),\n\t\t\t\"description\":     cav.get(\"Description\") if cav.get(\"Description\") is not None else \"\",\n\t\t\t\"statusCode\":      sc,\n\t\t\t\"isScrappedSaved\": (sc \u003d\u003d \"Scrapped\"),\n\t\t\t\"isDeprecated\":    self.view.params.deprecated\n\t\t})\n\tself.view.custom.state \u003d {\"selected\": {\"rows\": loaded}, \"editDraft\": {\"rows\": [dict(r) for r in loaded]}}"
        },
        {
          "name": "handleSave",
          "params": [],
          "script": "\ttoolId \u003d self.view.params.value\n\tif not toolId:\n\t\tBlueRidge.Common.Notify.toast(\"No tool selected\", \"Pick a tool before saving.\", \"warning\")\n\t\treturn\n\tdraft \u003d BlueRidge.Common.Util.extractQualifiedValues(self.view.custom.state.editDraft) or {}\n\trows \u003d draft.get(\"rows\") or []\n\tresult \u003d BlueRidge.Parts.Tool.saveCavitiesAll(toolId, rows)\n\tBlueRidge.Common.Ui.notifyResult(result, \"Cavities saved\")\n\tif result and result.get(\"Status\"):\n\t\tself.load()"
        },
        {
          "name": "handleDiscard",
          "params": [],
          "script": "\tselected \u003d BlueRidge.Common.Util.extractQualifiedValues(self.view.custom.state.selected) or {\"rows\": []}\n\tself.view.custom.state \u003d {\"selected\": selected, \"editDraft\": {\"rows\": [dict(r) for r in (selected.get(\"rows\") or [])]}}"
        },
        {
          "name": "addRow",
          "params": [],
          "script": "\tdraft \u003d dict(BlueRidge.Common.Util.extractQualifiedValues(self.view.custom.state.editDraft) or {\"rows\": []})\n\trows \u003d list(draft.get(\"rows\") or [])\n\trows.append({\n\t\t\"id\":              None,\n\t\t\"cavityNumber\":    None,\n\t\t\"description\":     \"\",\n\t\t\"statusCode\":      \"Active\",\n\t\t\"isScrappedSaved\": False,\n\t})\n\tdraft[\"rows\"] \u003d rows\n\tselected \u003d BlueRidge.Common.Util.extractQualifiedValues(self.view.custom.state.selected) or {\"rows\": []}\n\tself.view.custom.state \u003d {\"selected\": selected, \"editDraft\": draft}"
        },
        {
          "name": "_applyNumberChange",
          "params": [
            "idx",
            "newNumber"
          ],
          "script": "\tdraft \u003d dict(BlueRidge.Common.Util.extractQualifiedValues(self.view.custom.state.editDraft) or {\"rows\": []})\n\trows \u003d list(draft.get(\"rows\") or [])\n\tif idx \u003c 0 or idx \u003e\u003d len(rows):\n\t\treturn\n\trow \u003d dict(rows[idx])\n\trow[\"cavityNumber\"] \u003d None if newNumber is None else int(newNumber)\n\trows[idx] \u003d row\n\tdraft[\"rows\"] \u003d rows\n\tselected \u003d BlueRidge.Common.Util.extractQualifiedValues(self.view.custom.state.selected) or {\"rows\": []}\n\tself.view.custom.state \u003d {\"selected\": selected, \"editDraft\": draft}"
        },
        {
          "name": "_applyDescChange",
          "params": [
            "idx",
            "newDesc"
          ],
          "script": "\tdraft \u003d dict(BlueRidge.Common.Util.extractQualifiedValues(self.view.custom.state.editDraft) or {\"rows\": []})\n\trows \u003d list(draft.get(\"rows\") or [])\n\tif idx \u003c 0 or idx \u003e\u003d len(rows):\n\t\treturn\n\trow \u003d dict(rows[idx])\n\trow[\"description\"] \u003d \"\" if newDesc is None else unicode(newDesc)\n\trows[idx] \u003d row\n\tdraft[\"rows\"] \u003d rows\n\tselected \u003d BlueRidge.Common.Util.extractQualifiedValues(self.view.custom.state.selected) or {\"rows\": []}\n\tself.view.custom.state \u003d {\"selected\": selected, \"editDraft\": draft}"
        },
        {
          "name": "_applyStatusChange",
          "params": [
            "idx",
            "newStatus"
          ],
          "script": "\tdraft \u003d dict(BlueRidge.Common.Util.extractQualifiedValues(self.view.custom.state.editDraft) or {\"rows\": []})\n\trows \u003d list(draft.get(\"rows\") or [])\n\tif idx \u003c 0 or idx \u003e\u003d len(rows):\n\t\treturn\n\trow \u003d dict(rows[idx])\n\trow[\"statusCode\"] \u003d newStatus or \"Active\"\n\trows[idx] \u003d row\n\tdraft[\"rows\"] \u003d rows\n\tselected \u003d BlueRidge.Common.Util.extractQualifiedValues(self.view.custom.state.selected) or {\"rows\": []}\n\tself.view.custom.state \u003d {\"selected\": selected, \"editDraft\": draft}"
        },
        {
          "name": "_removeRow",
          "params": [
            "idx"
          ],
          "script": "\tdraft \u003d dict(BlueRidge.Common.Util.extractQualifiedValues(self.view.custom.state.editDraft) or {\"rows\": []})\n\trows \u003d list(draft.get(\"rows\") or [])\n\tif idx \u003c 0 or idx \u003e\u003d len(rows):\n\t\treturn\n\tdel rows[idx]\n\tdraft[\"rows\"] \u003d rows\n\tselected \u003d BlueRidge.Common.Util.extractQualifiedValues(self.view.custom.state.selected) or {\"rows\": []}\n\tself.view.custom.state \u003d {\"selected\": selected, \"editDraft\": draft}"
        }
      ],
      "extensionFunctions": null,
      "messageHandlers": [
        {
          "messageType": "sectionSaveRequested",
          "pageScope": true,
          "script": "\tif payload and payload.get(\"section\") \u003d\u003d \"cavities\":\n\t\tself.handleSave()",
          "sessionScope": false,
          "viewScope": false
        },
        {
          "messageType": "sectionDiscardRequested",
          "pageScope": true,
          "script": "\tif payload and payload.get(\"section\") \u003d\u003d \"cavities\":\n\t\tself.handleDiscard()",
          "sessionScope": false,
          "viewScope": false
        },
        {
          "messageType": "cavityRowNumberChanged",
          "pageScope": true,
          "script": "\tif not payload:\n\t\treturn\n\tidx \u003d int(payload.get(\"rowIndex\", -1))\n\tself._applyNumberChange(idx, payload.get(\"newNumber\"))",
          "sessionScope": false,
          "viewScope": false
        },
        {
          "messageType": "cavityRowDescChanged",
          "pageScope": true,
          "script": "\tif not payload:\n\t\treturn\n\tidx \u003d int(payload.get(\"rowIndex\", -1))\n\tself._applyDescChange(idx, payload.get(\"newDesc\"))",
          "sessionScope": false,
          "viewScope": false
        },
        {
          "messageType": "cavityRowStatusChanged",
          "pageScope": true,
          "script": "\tif not payload:\n\t\treturn\n\tidx \u003d int(payload.get(\"rowIndex\", -1))\n\tself._applyStatusChange(idx, payload.get(\"newStatus\"))",
          "sessionScope": false,
          "viewScope": false
        },
        {
          "messageType": "cavityRowRemove",
          "pageScope": true,
          "script": "\tif not payload:\n\t\treturn\n\tidx \u003d int(payload.get(\"rowIndex\", -1))\n\tself._removeRow(idx)",
          "sessionScope": false,
          "viewScope": false
        }
      ]
    },
    "type": "ia.container.flex"
  }
}