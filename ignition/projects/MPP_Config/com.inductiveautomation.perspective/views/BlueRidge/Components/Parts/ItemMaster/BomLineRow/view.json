{
  "custom": {},
  "params": {
    "availableItems": [],
    "line": {
      "childItemId": null,
      "componentName": "",
      "id": null,
      "partNumber": "",
      "qtyPer": 0,
      "uomCode": "",
      "uomId": null
    },
    "lineCount": 0,
    "mode": "published",
    "rowIndex": 0,
    "uoms": []
  },
  "propConfig": {
    "params.availableItems": {
      "paramDirection": "input"
    },
    "params.line": {
      "paramDirection": "input"
    },
    "params.lineCount": {
      "paramDirection": "input"
    },
    "params.mode": {
      "paramDirection": "input"
    },
    "params.rowIndex": {
      "paramDirection": "input"
    },
    "params.uoms": {
      "paramDirection": "input"
    }
  },
  "props": {
    "defaultSize": {
      "height": 36,
      "width": 1200
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "ColIndex"
        },
        "position": {
          "basis": "36px",
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "expression": "toStr({view.params.rowIndex} + 1)"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "style": {
            "color": "var(--mpp-text-secondary)",
            "fontSize": "12px",
            "textAlign": "right"
          }
        },
        "type": "ia.display.label"
      },
      {
        "children": [
          {
            "events": {
              "component": {
                "onActionPerformed": {
                  "config": {
                    "script": "\tsystem.perspective.sendMessage(\"bomLineMoveUp\", payload\u003d{\"rowIndex\": self.view.params.rowIndex}, scope\u003d\"page\")"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "UpArrow"
            },
            "position": {
              "shrink": 0
            },
            "propConfig": {
              "props.enabled": {
                "binding": {
                  "config": {
                    "expression": "{view.params.rowIndex} \u003e 0"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "classes": "btn btn-sm",
                "height": "30px",
                "padding": "2px 6px"
              },
              "text": "▲"
            },
            "type": "ia.input.button"
          },
          {
            "events": {
              "component": {
                "onActionPerformed": {
                  "config": {
                    "script": "\tsystem.perspective.sendMessage(\"bomLineMoveDown\", payload\u003d{\"rowIndex\": self.view.params.rowIndex}, scope\u003d\"page\")"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "DownArrow"
            },
            "position": {
              "shrink": 0
            },
            "propConfig": {
              "props.enabled": {
                "binding": {
                  "config": {
                    "expression": "{view.params.rowIndex} \u003c {view.params.lineCount} - 1"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "classes": "btn btn-sm",
                "height": "30px",
                "padding": "2px 6px"
              },
              "text": "▼"
            },
            "type": "ia.input.button"
          }
        ],
        "meta": {
          "name": "ColArrows"
        },
        "position": {
          "basis": "72px",
          "shrink": 0
        },
        "propConfig": {
          "position.display": {
            "binding": {
              "config": {
                "expression": "{view.params.mode} \u003d \"draft\""
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "alignItems": "center",
          "style": {
            "gap": "2px"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "events": {
          "component": {
            "onActionPerformed": {
              "config": {
                "script": "\tsystem.perspective.sendMessage(\"bomLineItemChanged\", payload\u003d{\"rowIndex\": self.view.params.rowIndex, \"newItemId\": self.props.value}, scope\u003d\"page\")"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "ItemPicker"
        },
        "position": {
          "basis": "0",
          "grow": 1
        },
        "propConfig": {
          "position.display": {
            "binding": {
              "config": {
                "expression": "{view.params.mode} \u003d \"draft\""
              },
              "type": "expr"
            }
          },
          "props.options": {
            "binding": {
              "config": {
                "path": "view.params.availableItems"
              },
              "transforms": [
                {
                  "code": "\tout \u003d []\n\tfor it in (value or []):\n\t\tit \u003d it or {}\n\t\tpart \u003d it.get(\u0027PartNumber\u0027) or \u0027\u0027\n\t\tdesc \u003d it.get(\u0027Description\u0027) or \u0027\u0027\n\t\tout.append({\u0027label\u0027: part + \u0027 — \u0027 + desc, \u0027value\u0027: it.get(\u0027Id\u0027)})\n\treturn out",
                  "type": "script"
                }
              ],
              "type": "property"
            }
          },
          "props.value": {
            "binding": {
              "config": {
                "path": "view.params.line.childItemId"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "filterable": true,
          "noSelectionText": "Pick component...",
          "style": {
            "classes": "select",
            "height": "30px"
          }
        },
        "type": "ia.input.dropdown"
      },
      {
        "meta": {
          "name": "ItemDisplay"
        },
        "position": {
          "basis": "0",
          "grow": 1
        },
        "propConfig": {
          "position.display": {
            "binding": {
              "config": {
                "expression": "{view.params.mode} !\u003d \"draft\""
              },
              "type": "expr"
            }
          },
          "props.text": {
            "binding": {
              "config": {
                "expression": "{view.params.line.partNumber} + \" — \" + {view.params.line.componentName}"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "style": {
            "fontSize": "12px"
          }
        },
        "type": "ia.display.label"
      },
      {
        "events": {
          "dom": {
            "onBlur": {
              "config": {
                "script": "\tsystem.perspective.sendMessage(\"bomLineQtyChanged\", payload\u003d{\"rowIndex\": self.view.params.rowIndex, \"newQty\": self.props.text}, scope\u003d\"page\")"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "QtyEdit"
        },
        "position": {
          "basis": "80px",
          "shrink": 0
        },
        "propConfig": {
          "position.display": {
            "binding": {
              "config": {
                "expression": "{view.params.mode} \u003d \"draft\""
              },
              "type": "expr"
            }
          },
          "props.text": {
            "binding": {
              "config": {
                "bidirectional": true,
                "path": "view.params.line.qtyPer"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "classes": "search-input",
            "height": "30px",
            "textAlign": "right"
          }
        },
        "type": "ia.input.text-field"
      },
      {
        "meta": {
          "name": "QtyDisplay"
        },
        "position": {
          "basis": "80px",
          "shrink": 0
        },
        "propConfig": {
          "position.display": {
            "binding": {
              "config": {
                "expression": "{view.params.mode} !\u003d \"draft\""
              },
              "type": "expr"
            }
          },
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.line.qtyPer"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "textAlign": "right"
          }
        },
        "type": "ia.display.label"
      },
      {
        "events": {
          "component": {
            "onActionPerformed": {
              "config": {
                "script": "\tsystem.perspective.sendMessage(\"bomLineUomChanged\", payload\u003d{\"rowIndex\": self.view.params.rowIndex, \"newUomId\": self.props.value}, scope\u003d\"page\")"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "UomEdit"
        },
        "position": {
          "basis": "90px",
          "shrink": 0
        },
        "propConfig": {
          "position.display": {
            "binding": {
              "config": {
                "expression": "{view.params.mode} \u003d \"draft\""
              },
              "type": "expr"
            }
          },
          "props.options": {
            "binding": {
              "config": {
                "path": "view.params.uoms"
              },
              "transforms": [
                {
                  "code": "\tout \u003d []\n\tfor it in (value or []):\n\t\tit \u003d it or {}\n\t\tcode \u003d it.get(\u0027Code\u0027) or \u0027\u0027\n\t\tout.append({\u0027label\u0027: code, \u0027value\u0027: it.get(\u0027Id\u0027)})\n\treturn out",
                  "type": "script"
                }
              ],
              "type": "property"
            }
          },
          "props.value": {
            "binding": {
              "config": {
                "bidirectional": true,
                "path": "view.params.line.uomId"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "classes": "select",
            "height": "30px"
          }
        },
        "type": "ia.input.dropdown"
      },
      {
        "meta": {
          "name": "UomDisplay"
        },
        "position": {
          "basis": "90px",
          "shrink": 0
        },
        "propConfig": {
          "position.display": {
            "binding": {
              "config": {
                "expression": "{view.params.mode} !\u003d \"draft\""
              },
              "type": "expr"
            }
          },
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.line.uomCode"
              },
              "type": "property"
            }
          }
        },
        "type": "ia.display.label"
      },
      {
        "events": {
          "component": {
            "onActionPerformed": {
              "config": {
                "script": "\tsystem.perspective.sendMessage(\"bomLineRemove\", payload\u003d{\"rowIndex\": self.view.params.rowIndex}, scope\u003d\"page\")"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "RemoveBtn"
        },
        "position": {
          "basis": "40px",
          "shrink": 0
        },
        "propConfig": {
          "position.display": {
            "binding": {
              "config": {
                "expression": "{view.params.mode} \u003d \"draft\""
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "style": {
            "classes": "btn btn-sm",
            "height": "30px",
            "padding": "2px 6px"
          },
          "text": "×"
        },
        "type": "ia.input.button"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "alignItems": "center",
      "style": {
        "borderBottom": "1px solid var(--mpp-border-subtle)",
        "gap": "6px",
        "height": "100%",
        "padding": "2px 10px"
      }
    },
    "type": "ia.container.flex"
  }
}