{
  "custom": {},
  "params": {
    "locationOptions": [],
    "row": {
      "defaultQuantity": null,
      "id": null,
      "isConsumptionPoint": false,
      "locationId": null,
      "locationLabel": "",
      "locationTierOrdinal": null,
      "maxQuantity": null,
      "minQuantity": null
    },
    "rowIndex": 0
  },
  "propConfig": {
    "params.locationOptions": {
      "paramDirection": "input"
    },
    "params.row": {
      "paramDirection": "input"
    },
    "params.rowIndex": {
      "paramDirection": "input"
    }
  },
  "props": {
    "defaultSize": {
      "height": 36,
      "width": 1200
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "ColIndex"
        },
        "position": {
          "basis": "36px",
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "expression": "toStr({view.params.rowIndex} + 1)"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "style": {
            "color": "var(--mpp-text-secondary)",
            "fontSize": "12px",
            "textAlign": "right"
          }
        },
        "type": "ia.display.label"
      },
      {
        "events": {
          "component": {
            "onActionPerformed": {
              "config": {
                "script": "\tsystem.perspective.sendMessage(\"eligibilityRowLocationChanged\", payload\u003d{\"rowIndex\": self.view.params.rowIndex, \"newLocationId\": self.props.value}, scope\u003d\"page\")"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "LocationPicker"
        },
        "position": {
          "basis": "0",
          "grow": 1
        },
        "propConfig": {
          "props.options": {
            "binding": {
              "config": {
                "path": "view.params.locationOptions"
              },
              "transforms": [
                {
                  "code": "\tout \u003d []\n\tfor it in (value or []):\n\t\tit \u003d it or {}\n\t\tlabel \u003d it.get(\u0027DisplayLabel\u0027) or \u0027\u0027\n\t\tout.append({\u0027label\u0027: label, \u0027value\u0027: it.get(\u0027Id\u0027)})\n\treturn out",
                  "type": "script"
                }
              ],
              "type": "property"
            }
          },
          "props.value": {
            "binding": {
              "config": {
                "path": "view.params.row.locationId"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "filterable": true,
          "noSelectionText": "Pick location...",
          "style": {
            "classes": "select",
            "height": "30px"
          }
        },
        "type": "ia.input.dropdown"
      },
      {
        "events": {
          "component": {
            "onActionPerformed": {
              "config": {
                "script": "\tsystem.perspective.sendMessage(\"eligibilityRowConsumptionChanged\", payload\u003d{\"rowIndex\": self.view.params.rowIndex, \"isConsumptionPoint\": bool(self.props.selected)}, scope\u003d\"page\")"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "ConsumptionCheckbox"
        },
        "position": {
          "basis": "60px",
          "shrink": 0
        },
        "propConfig": {
          "props.selected": {
            "binding": {
              "config": {
                "path": "view.params.row.isConsumptionPoint"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "height": "30px"
          },
          "text": ""
        },
        "type": "ia.input.checkbox"
      },
      {
        "events": {
          "dom": {
            "onBlur": {
              "config": {
                "script": "\tsystem.perspective.sendMessage(\"eligibilityRowQtyChanged\", payload\u003d{\"rowIndex\": self.view.params.rowIndex, \"field\": \"minQuantity\", \"newValue\": self.props.text}, scope\u003d\"page\")"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "MinField"
        },
        "position": {
          "basis": "80px",
          "shrink": 0
        },
        "propConfig": {
          "meta.visible": {
            "binding": {
              "config": {
                "expression": "{view.params.row.isConsumptionPoint} \u003d true"
              },
              "type": "expr"
            }
          },
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.row.minQuantity"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "placeholder": "Min",
          "style": {
            "classes": "search-input",
            "height": "30px",
            "textAlign": "right"
          }
        },
        "type": "ia.input.text-field"
      },
      {
        "events": {
          "dom": {
            "onBlur": {
              "config": {
                "script": "\tsystem.perspective.sendMessage(\"eligibilityRowQtyChanged\", payload\u003d{\"rowIndex\": self.view.params.rowIndex, \"field\": \"maxQuantity\", \"newValue\": self.props.text}, scope\u003d\"page\")"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "MaxField"
        },
        "position": {
          "basis": "80px",
          "shrink": 0
        },
        "propConfig": {
          "meta.visible": {
            "binding": {
              "config": {
                "expression": "{view.params.row.isConsumptionPoint} \u003d true"
              },
              "type": "expr"
            }
          },
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.row.maxQuantity"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "placeholder": "Max",
          "style": {
            "classes": "search-input",
            "height": "30px",
            "textAlign": "right"
          }
        },
        "type": "ia.input.text-field"
      },
      {
        "events": {
          "dom": {
            "onBlur": {
              "config": {
                "script": "\tsystem.perspective.sendMessage(\"eligibilityRowQtyChanged\", payload\u003d{\"rowIndex\": self.view.params.rowIndex, \"field\": \"defaultQuantity\", \"newValue\": self.props.text}, scope\u003d\"page\")"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "DefaultField"
        },
        "position": {
          "basis": "80px",
          "shrink": 0
        },
        "propConfig": {
          "meta.visible": {
            "binding": {
              "config": {
                "expression": "{view.params.row.isConsumptionPoint} \u003d true"
              },
              "type": "expr"
            }
          },
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.row.defaultQuantity"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "placeholder": "Default",
          "style": {
            "classes": "search-input",
            "height": "30px",
            "textAlign": "right"
          }
        },
        "type": "ia.input.text-field"
      },
      {
        "events": {
          "component": {
            "onActionPerformed": {
              "config": {
                "script": "\tsystem.perspective.sendMessage(\"eligibilityRowRemove\", payload\u003d{\"rowIndex\": self.view.params.rowIndex}, scope\u003d\"page\")"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "RemoveBtn"
        },
        "position": {
          "basis": "40px",
          "shrink": 0
        },
        "props": {
          "style": {
            "classes": "btn btn-sm",
            "height": "30px",
            "padding": "2px 6px"
          },
          "text": "×"
        },
        "type": "ia.input.button"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "alignItems": "center",
      "style": {
        "borderBottom": "1px solid var(--mpp-border-subtle)",
        "gap": "6px",
        "height": "100%",
        "padding": "2px 10px"
      }
    },
    "type": "ia.container.flex"
  }
}