{
  "custom": {
    "rows": [],
    "pendingRemoveDefId": null
  },
  "params": {
    "value": 0,
    "toolTypeId": 0
  },
  "propConfig": {
    "params.value":      { "paramDirection": "input" },
    "params.toolTypeId": { "paramDirection": "input" },
    "custom.rows": {
      "binding": {
        "type": "expr",
        "config": {
          "expression": "runScript(\"BlueRidge.Parts.Tool.getAttributeInstancesForTool\", 0, {view.params.value})"
        }
      }
    }
  },
  "props": {
    "defaultSize": { "height": 360, "width": 800 }
  },
  "root": {
    "type": "ia.container.flex",
    "meta": { "name": "root" },
    "scripts": {
      "customMethods": [
        {
          "name": "refresh",
          "params": [],
          "script": "\tself.view.custom.rows = BlueRidge.Parts.Tool.getAttributeInstancesForTool(self.view.params.value)"
        }
      ],
      "extensionFunctions": null,
      "messageHandlers": [
        {
          "messageType": "toolDataChanged",
          "pageScope": true,
          "sessionScope": false,
          "viewScope": false,
          "script": "\tsection = (payload or {}).get('section')\n\tif section and section != 'attributes':\n\t\treturn\n\tself.view.rootContainer.refresh()"
        },
        {
          "messageType": "attributeRemoveRequest",
          "pageScope": true,
          "sessionScope": false,
          "viewScope": false,
          "script": "\tdata = payload or {}\n\tdefId = data.get('defId')\n\tname  = data.get('name') or 'this attribute'\n\tif defId is None:\n\t\treturn\n\tself.view.custom.pendingRemoveDefId = defId\n\tsystem.perspective.openPopup(\n\t\tid='mpp-confirm-destructive',\n\t\tview='BlueRidge/Components/Popups/ConfirmDestructive',\n\t\tmodal=True,\n\t\tshowCloseIcon=False,\n\t\tparams={\n\t\t\t'title':        'Remove Attribute',\n\t\t\t'message':      'Remove ' + name + ' from this tool?',\n\t\t\t'confirmLabel': 'Remove',\n\t\t\t'replyMessage': 'attributeRemoveConfirmed'\n\t\t}\n\t)"
        },
        {
          "messageType": "attributeRemoveConfirmed",
          "pageScope": true,
          "sessionScope": false,
          "viewScope": false,
          "script": "\taction = (payload or {}).get('action')\n\tdefId = self.view.custom.pendingRemoveDefId\n\tself.view.custom.pendingRemoveDefId = None\n\tif action != 'confirm' or defId is None:\n\t\treturn\n\tresult = BlueRidge.Parts.Tool.removeAttribute(self.view.params.value, defId)\n\tBlueRidge.Common.Ui.notifyResult(result, 'Attribute removed')\n\tif result and result.get('Status'):\n\t\tself.view.rootContainer.refresh()"
        }
      ]
    },
    "props": {
      "direction": "column",
      "style": {
        "gap": "10px",
        "height": "100%"
      }
    },
    "children": [
      {
        "type": "ia.container.flex",
        "meta": { "name": "ActionRow" },
        "position": { "basis": "auto", "shrink": 0 },
        "props": {
          "direction": "row",
          "alignItems": "center",
          "style": { "gap": "8px" }
        },
        "children": [
          {
            "type": "ia.display.label",
            "meta": { "name": "HintText" },
            "position": { "grow": 1 },
            "props": {
              "text": "Shot counts are derived at runtime from production events - not stored on the tool record.",
              "style": {
                "fontSize": "11px",
                "color": "var(--mpp-text-muted)"
              }
            }
          },
          {
            "type": "ia.input.button",
            "meta": { "name": "BtnAddAttribute" },
            "events": {
              "component": {
                "onActionPerformed": {
                  "type": "script",
                  "scope": "G",
                  "config": {
                    "script": "\ttoolId = self.view.params.value\n\ttoolTypeId = self.view.params.toolTypeId\n\tif not toolId:\n\t\tBlueRidge.Common.Notify.toast('No tool selected', 'Pick a tool first.', 'warning')\n\t\treturn\n\tsystem.perspective.openPopup(\n\t\tid='mpp-add-attribute',\n\t\tview='BlueRidge/Components/Popups/AddAttribute',\n\t\tmodal=True,\n\t\tshowCloseIcon=False,\n\t\tparams={'toolId': toolId, 'toolTypeId': toolTypeId}\n\t)"
                  }
                }
              }
            },
            "props": {
              "text": "+ Add Attribute",
              "style": { "classes": "btn btn-primary btn-sm" }
            }
          }
        ]
      },
      {
        "type": "ia.container.flex",
        "meta": { "name": "DataPanel" },
        "position": { "grow": 1 },
        "props": {
          "direction": "column",
          "style": {
            "classes": "detail-panel",
            "overflow": "hidden",
            "padding": "0"
          }
        },
        "children": [
          {
            "type": "ia.container.flex",
            "meta": { "name": "TableHeader" },
            "position": { "basis": "auto", "shrink": 0 },
            "props": {
              "direction": "row",
              "alignItems": "center",
              "style": {
                "background": "var(--mpp-surface-card)",
                "borderBottom": "1px solid var(--mpp-border-subtle)",
                "color": "var(--mpp-text-secondary)",
                "fontSize": "11px",
                "fontWeight": "600",
                "textTransform": "uppercase",
                "letterSpacing": "0.05em",
                "padding": "8px 12px",
                "gap": "8px"
              }
            },
            "children": [
              { "type": "ia.display.label", "meta": { "name": "ColAttr" },   "position": { "basis": "0", "grow": 1 },        "props": { "text": "Attribute" } },
              { "type": "ia.display.label", "meta": { "name": "ColValue" },  "position": { "basis": "220px", "shrink": 0 }, "props": { "text": "Value" } },
              { "type": "ia.display.label", "meta": { "name": "ColRemove" }, "position": { "basis": "36px", "shrink": 0 },  "props": { "text": "" } }
            ]
          },
          {
            "type": "ia.display.flex-repeater",
            "meta": { "name": "Rows" },
            "position": { "basis": "0", "grow": 1 },
            "propConfig": {
              "props.instances": {
                "binding": {
                  "type": "property",
                  "config": { "path": "view.custom.rows" }
                }
              }
            },
            "props": {
              "direction": "column",
              "elementPosition": { "basis": "48px", "shrink": 0 },
              "path": "BlueRidge/Components/Parts/Tools/_Tools/AttributeRow",
              "style": { "overflowY": "auto" },
              "useDefaultViewHeight": true,
              "useDefaultViewWidth": false
            }
          }
        ]
      }
    ]
  }
}
