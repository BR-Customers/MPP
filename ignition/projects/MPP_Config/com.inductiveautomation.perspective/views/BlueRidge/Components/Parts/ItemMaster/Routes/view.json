          },
          {
            "type": "ia.display.label",
            "meta": {
              "name": "ReadOnlyCaption"
            },
            "position": {
              "basis": "auto",
              "shrink": 0
            },
            "props": {
              "style": {
                "color": "var(--mpp-text-muted)",
                "fontSize": "11px",
                "fontStyle": "italic",
                "padding": "8px 12px"
              },
              "text": "Read-only. Click New Version to create a draft copy for editing."
            }
          }
        ]
      },
      {
        "type": "ia.container.flex",
        "meta": {
          "name": "DraftPanel"
        },
        "position": {
          "grow": 1
        },
        "propConfig": {
          "position.display": {
            "binding": {
              "type": "expr",
              "config": {
                "expression": "{view.custom.mode} = 'draft'"
              }
            }
          }
        },
        "props": {
          "direction": "column",
          "style": {
            "classes": "detail-panel",
            "gap": "4px",
            "overflow": "auto"
          }
        },
        "children": [
          {
            "type": "ia.display.flex-repeater",
            "meta": {
              "name": "DraftStepRows"
            },
            "position": {
              "basis": "auto",
              "shrink": 0
            },
            "propConfig": {
              "props.instances": {
                "binding": {
                  "type": "property",
                  "config": {
                    "path": "view.custom.draftEditDraft.steps"
                  },
                  "transforms": [
                    {
                      "code": "\tsteps = value or []\n\tareas = self.view.custom.areas or []\n\topCache = self.view.custom.opTemplatesByArea or {}\n\tout = []\n\ttotal = len(steps)\n\tfor i, s in enumerate(steps):\n\t\ts = s or {}\n\t\tout.append({'rowIndex': i, 'step': dict(s), 'areas': areas, 'opTemplatesByArea': opCache, 'isFirst': (i == 0), 'isLast': (i == total - 1)})\n\treturn out",
                      "type": "script"
                    }
                  ]
                }
              }
            },
            "props": {
              "direction": "column",
              "path": "BlueRidge/Components/Parts/ItemMaster/Routes/DraftStepRow",
              "elementPosition": {
                "basis": "44px",
                "shrink": 0
              },
              "useDefaultViewHeight": false,
              "useDefaultViewWidth": false,
              "style": {
                "gap": "4px"
              }
            }
          },
          {
            "type": "ia.input.button",
            "meta": {
              "name": "BtnAddStep"
            },
            "position": {
              "basis": "auto",
              "shrink": 0
            },
            "props": {
              "text": "+ Add Step",
              "style": {
                "classes": "btn btn-sm",
                "marginTop": "8px",
                "width": "120px"
              }
            },
            "events": {
              "component": {
                "onActionPerformed": {
                  "type": "script",
                  "scope": "G",
                  "config": {
                    "script": "\tBlueRidge.Common.Util.log('BtnAddStep click')\n\tdraft = self.view.custom.draftEditDraft or {}\n\tsteps = list(draft.get('steps') or [])\n\tsteps.append({'Id': None, 'SequenceNumber': len(steps) + 1, 'OperationAreaLocationId': None, 'OperationAreaName': '', 'OperationTemplateId': None, 'OperationCode': '', 'OperationName': '', 'OperationVersionNumber': None, 'DataCollectionSummary': '', 'IsRequired': True, 'Description': None})\n\tnewDraft = {'Id': draft.get('Id'), 'Name': draft.get('Name'), 'EffectiveFrom': draft.get('EffectiveFrom'), 'steps': steps}\n\tself.view.custom.draftEditDraft = newDraft\n\tself.view.rootContainer.broadcastDirty(True)"
                  }
                }
              }
            }
          }
        ]
      }
    ],
    "messageHandlers": [
      {
        "messageType": "routeConfirmDiscard",
        "scopes": {
          "pageScope": true,
          "viewScope": false
        },
        "config": {
          "script": "\taction = payload.get('action') if payload else None\n\tif action != 'confirm':\n\t\treturn\n\tresult = BlueRidge.Parts.RouteTemplate.discardDraft(self.view.custom.draftId)\n\tBlueRidge.Common.Ui.notifyResult(result, 'Discard', 'Draft discarded.', 'Discard failed')\n\tif not result or not result.get('Status'):\n\t\treturn\n\tself.view.custom.draftId = 0\n\tself.view.custom.draftEditDraft = {'Id': 0, 'Name': '', 'EffectiveFrom': '', 'steps': []}\n\tself.view.custom.draftSelected = {'Id': 0, 'Name': '', 'EffectiveFrom': '', 'steps': []}\n\tself.view.custom.mode = 'view'\n\tself.rootContainer.reloadVersions()\n\tactive = None\n\tfor v in (self.view.custom.versions or []):\n\t\tif v.get('PublishedAt') and not v.get('DeprecatedAt'):\n\t\t\tactive = v\n\t\t\tbreak\n\tself.view.custom.selectedVersionId = active['Id'] if active else 0\n\tself.rootContainer.broadcastDirty(False)"
        }
      },
      {
        "messageType": "sectionSaveRequested",
        "scopes": {
          "pageScope": true,
          "viewScope": false
        },
        "config": {
          "script": "\tif not payload or payload.get('section') != 'routes':\n\t\treturn\n\tif self.view.custom.mode != 'draft':\n\t\treturn\n\tdraft = self.view.custom.draftEditDraft\n\tresult = BlueRidge.Parts.RouteTemplate.saveAll(self.view.custom.draftId, draft.get('Name'), draft.get('EffectiveFrom'), draft.get('steps') or [])\n\tBlueRidge.Common.Ui.notifyResult(result, 'Route saved', 'Route saved.', 'Save failed')\n\tif not result or not result.get('Status'):\n\t\treturn\n\tself.view.custom.draftSelected = {'Id': draft.get('Id'), 'Name': draft.get('Name'), 'EffectiveFrom': draft.get('EffectiveFrom'), 'steps': [dict(s) for s in (draft.get('steps') or [])]}\n\tself.rootContainer.reloadVersions()\n\tself.rootContainer.broadcastDirty(False)"
        }
      },
      {
        "messageType": "sectionDiscardRequested",
        "scopes": {
          "pageScope": true,
          "viewScope": false
        },
        "config": {
          "script": "\tif not payload or payload.get('section') != 'routes':\n\t\treturn\n\tif self.view.custom.mode != 'draft':\n\t\treturn\n\tsel = self.view.custom.draftSelected\n\tself.view.custom.draftEditDraft = {'Id': sel.get('Id'), 'Name': sel.get('Name'), 'EffectiveFrom': sel.get('EffectiveFrom'), 'steps': [dict(s) for s in (sel.get('steps') or [])]}\n\tself.rootContainer.broadcastDirty(False)"
        }
      },
      {
        "messageType": "routeStepChanged",
        "scopes": {
          "pageScope": true,
          "viewScope": false
        },
        "config": {
          "script": "\tif not payload:\n\t\treturn\n\tidx = payload.get('rowIndex')\n\tnewStep = payload.get('step')\n\tif idx is None or newStep is None:\n\t\treturn\n\tdraft = self.view.custom.draftEditDraft\n\tsteps = list(draft.get('steps') or [])\n\tif idx < 0 or idx >= len(steps):\n\t\treturn\n\tsteps[idx] = dict(newStep)\n\tnewDraft = {'Id': draft.get('Id'), 'Name': draft.get('Name'), 'EffectiveFrom': draft.get('EffectiveFrom'), 'steps': steps}\n\tself.view.custom.draftEditDraft = newDraft\n\tself.rootContainer.broadcastDirty(True)"
        }
      },
      {
        "messageType": "routeStepMoveUp",
        "scopes": {
          "pageScope": true,
          "viewScope": false
        },
        "config": {
          "script": "\tif not payload:\n\t\treturn\n\tidx = payload.get('rowIndex')\n\tif idx is None or idx <= 0:\n\t\treturn\n\tdraft = self.view.custom.draftEditDraft\n\tsteps = list(draft.get('steps') or [])\n\tif idx >= len(steps):\n\t\treturn\n\tsteps[idx-1], steps[idx] = steps[idx], steps[idx-1]\n\tnewDraft = {'Id': draft.get('Id'), 'Name': draft.get('Name'), 'EffectiveFrom': draft.get('EffectiveFrom'), 'steps': steps}\n\tself.view.custom.draftEditDraft = newDraft\n\tself.rootContainer.broadcastDirty(True)"
        }
      },
      {
        "messageType": "routeStepMoveDown",
        "scopes": {
          "pageScope": true,
          "viewScope": false
        },
        "config": {
          "script": "\tif not payload:\n\t\treturn\n\tidx = payload.get('rowIndex')\n\tdraft = self.view.custom.draftEditDraft\n\tsteps = list(draft.get('steps') or [])\n\tif idx is None or idx < 0 or idx >= len(steps) - 1:\n\t\treturn\n\tsteps[idx+1], steps[idx] = steps[idx], steps[idx+1]\n\tnewDraft = {'Id': draft.get('Id'), 'Name': draft.get('Name'), 'EffectiveFrom': draft.get('EffectiveFrom'), 'steps': steps}\n\tself.view.custom.draftEditDraft = newDraft\n\tself.rootContainer.broadcastDirty(True)"
        }
      },
      {
        "messageType": "routeStepRemove",
        "scopes": {
          "pageScope": true,
          "viewScope": false
        },
        "config": {
          "script": "\tif not payload:\n\t\treturn\n\tidx = payload.get('rowIndex')\n\tif idx is None:\n\t\treturn\n\tdraft = self.view.custom.draftEditDraft\n\tsteps = list(draft.get('steps') or [])\n\tif idx < 0 or idx >= len(steps):\n\t\treturn\n\tdel steps[idx]\n\tnewDraft = {'Id': draft.get('Id'), 'Name': draft.get('Name'), 'EffectiveFrom': draft.get('EffectiveFrom'), 'steps': steps}\n\tself.view.custom.draftEditDraft = newDraft\n\tself.rootContainer.broadcastDirty(True)"
        }
      }
    ]
  }
}
