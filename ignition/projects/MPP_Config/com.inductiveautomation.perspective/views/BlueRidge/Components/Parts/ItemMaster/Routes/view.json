{
  "custom": {
    "itemId": 0,
    "versions": [],
    "showDeprecated": false,
    "selectedVersionId": 0,
    "selectedHeader": {
      "Id": 0,
      "ItemId": 0,
      "PartNumber": "",
      "VersionNumber": 0,
      "Name": "",
      "EffectiveFrom": "",
      "PublishedAt": null,
      "DeprecatedAt": null,
      "CreatedByDisplayName": "",
      "CreatedAt": ""
    },
    "selectedSteps": [],
    "selectedStepsView": [],
    "mode": "view",
    "areas": [],
    "opTemplatesByArea": {},
    "draftId": 0,
    "draftEditDraft": {
      "Id": 0,
      "Name": "",
      "EffectiveFrom": "",
      "steps": []
    },
    "draftSelected": {
      "Id": 0,
      "Name": "",
      "EffectiveFrom": "",
      "steps": []
    }
  },
  "params": {
    "value": 0
  },
  "propConfig": {
    "params.value": {
      "paramDirection": "input"
    },
    "custom.itemId": {
      "binding": {
        "type": "property",
        "config": {
          "path": "view.params.value"
        }
      }
    },
    "custom.versions": {
      "binding": {
        "type": "expr",
        "config": {
          "expression": "runScript(\"BlueRidge.Parts.RouteTemplate.listVersions\", 0, {view.custom.itemId}, {view.custom.showDeprecated})"
        }
      },
      "onChange": {
        "enabled": true,
        "script": "\tdef _g(obj, key):\n\t\ttry:\n\t\t\treturn obj[key]\n\t\texcept Exception:\n\t\t\treturn None\n\tif self.view.custom.selectedVersionId and self.view.custom.selectedVersionId > 0:\n\t\treturn\n\tcurr = currentValue.value if currentValue is not None else None\n\tBlueRidge.Common.Util.log('versions.onChange count=%s' % (len(curr) if curr is not None else 'None'))\n\tif curr is None:\n\t\tself.view.custom.selectedVersionId = 0\n\t\treturn\n\tactive = None\n\tfor v in curr:\n\t\tpub = _g(v, 'PublishedAt')\n\t\tdep = _g(v, 'DeprecatedAt')\n\t\tif pub and not dep:\n\t\t\tactive = v\n\t\t\tbreak\n\tif active is not None:\n\t\tself.view.custom.selectedVersionId = _g(active, 'Id') or 0\n\telif len(curr) > 0:\n\t\tself.view.custom.selectedVersionId = _g(curr[0], 'Id') or 0\n\telse:\n\t\tself.view.custom.selectedVersionId = 0"
      }
    },
    "custom.selectedHeader": {
      "binding": {
        "type": "expr",
        "config": {
          "expression": "runScript(\"BlueRidge.Parts.RouteTemplate.getHeader\", 0, {view.custom.selectedVersionId})"
        }
      },
      "onChange": {
        "enabled": true,
        "script": "\tdef _g(obj, key):\n\t\ttry:\n\t\t\treturn obj[key]\n\t\texcept Exception:\n\t\t\treturn None\n\theader = currentValue.value if currentValue is not None else None\n\thdrId = _g(header, 'Id') if header is not None else None\n\tBlueRidge.Common.Util.log('selectedHeader.onChange hdrId=%s' % hdrId)\n\tif not hdrId or hdrId <= 0:\n\t\tif self.view.custom.mode == 'draft':\n\t\t\tself.view.custom.draftId = 0\n\t\t\tself.view.custom.draftEditDraft = {'Id': 0, 'Name': '', 'EffectiveFrom': '', 'steps': []}\n\t\t\tself.view.custom.draftSelected = {'Id': 0, 'Name': '', 'EffectiveFrom': '', 'steps': []}\n\t\t\tself.view.custom.mode = 'view'\n\t\t\tself.view.rootContainer.broadcastDirty(False)\n\t\treturn\n\tpublishedAt = _g(header, 'PublishedAt')\n\tdeprecatedAt = _g(header, 'DeprecatedAt')\n\tisDraft = (publishedAt is None) and (deprecatedAt is None)\n\tBlueRidge.Common.Util.log('selectedHeader.onChange isDraft=%s publishedAt=%s deprecatedAt=%s' % (isDraft, publishedAt, deprecatedAt))\n\tif isDraft:\n\t\tif self.view.custom.draftId == hdrId:\n\t\t\treturn\n\t\tname = _g(header, 'Name') or ''\n\t\teffRaw = _g(header, 'EffectiveFrom')\n\t\teffStr = str(effRaw or '')[:10]\n\t\tsteps = BlueRidge.Parts.RouteTemplate.getSteps(hdrId) or []\n\t\tstepsCopy = [dict(s) for s in steps]\n\t\tself.view.custom.draftId = hdrId\n\t\tself.view.custom.draftEditDraft = {'Id': hdrId, 'Name': name, 'EffectiveFrom': effStr, 'steps': stepsCopy}\n\t\tself.view.custom.draftSelected = {'Id': hdrId, 'Name': name, 'EffectiveFrom': effStr, 'steps': [dict(s) for s in steps]}\n\t\tself.view.custom.mode = 'draft'\n\t\tself.view.rootContainer.broadcastDirty(False)\n\telse:\n\t\tif self.view.custom.mode == 'draft':\n\t\t\tself.view.custom.draftId = 0\n\t\t\tself.view.custom.draftEditDraft = {'Id': 0, 'Name': '', 'EffectiveFrom': '', 'steps': []}\n\t\t\tself.view.custom.draftSelected = {'Id': 0, 'Name': '', 'EffectiveFrom': '', 'steps': []}\n\t\t\tself.view.custom.mode = 'view'\n\t\t\tself.view.rootContainer.broadcastDirty(False)"
      }
    },
    "custom.selectedSteps": {
      "binding": {
        "type": "expr",
        "config": {
          "expression": "runScript(\"BlueRidge.Parts.RouteTemplate.getSteps\", 0, {view.custom.selectedVersionId})"
        }
      }
    },
    "custom.selectedStepsView": {
      "binding": {
        "type": "property",
        "config": {
          "path": "view.custom.selectedSteps"
        },
        "transforms": [
          {
            "code": "\tout = []\n\tfor r in (value or []):\n\t\tr = r or {}\n\t\tout.append({'seq': r.get('SequenceNumber'), 'areaName': r.get('OperationAreaName') or '', 'opCode': r.get('OperationCode') or '', 'opName': r.get('OperationName') or '', 'isRequired': bool(r.get('IsRequired')), 'dataFields': r.get('DataCollectionSummary') or ''})\n\treturn out",
            "type": "script"
          }
        ]
      }
    },
    "custom.areas": {
      "binding": {
        "type": "expr",
        "config": {
          "expression": "runScript(\"BlueRidge.Location.Location.getAllAreas\", 0, false)"
        }
      }
    }
  },
  "props": {
    "defaultSize": {
      "height": 360,
      "width": 1100
    }
  },
  "root": {
    "type": "ia.container.flex",
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "classes": "detail-panel",
        "gap": "10px",
        "height": "100%"
      }
    },
    "scripts": {
      "customMethods": [
        {
          "name": "broadcastDirty",
          "params": ["isDirty"],
          "script": "\tsystem.perspective.sendMessage('sectionDirtyChanged', payload={'section': 'routes', 'isDirty': bool(isDirty)}, scope='page')"
        },
        {
          "name": "reloadVersions",
          "params": [],
          "script": "\tself.view.custom.versions = BlueRidge.Parts.RouteTemplate.listVersions(self.view.custom.itemId, self.view.custom.showDeprecated)"
        }
      ]
    },
    "children": [
      {
        "type": "ia.container.flex",
        "meta": {
          "name": "HeaderRow"
        },
        "position": {
          "basis": "auto",
          "shrink": 0
        },
        "props": {
          "alignItems": "center",
          "style": {
            "gap": "8px"
          }
        },
        "children": [
          {
            "type": "ia.input.dropdown",
            "meta": {
              "name": "VersionDropdown"
            },
            "position": {
              "basis": "360px",
              "shrink": 0
            },
            "propConfig": {
              "props.options": {
                "binding": {
                  "type": "property",
                  "config": {
                    "path": "view.custom.versions"
                  },
                  "transforms": [
                    {
                      "code": "\tout = []\n\tfor v in (value or []):\n\t\tvnum = v.get('VersionNumber', 0)\n\t\tname = v.get('Name') or ''\n\t\tif v.get('DeprecatedAt'):\n\t\t\tstate = 'Deprecated'\n\t\telif v.get('PublishedAt'):\n\t\t\tstate = 'Published'\n\t\telse:\n\t\t\tstate = 'Draft'\n\t\tlabel = 'v' + str(vnum) + ' -- ' + name + ' (' + state + ')'\n\t\tout.append({'label': label, 'value': v.get('Id')})\n\treturn out",
                      "type": "script"
                    }
                  ]
                }
              },
              "props.value": {
                "binding": {
                  "type": "property",
                  "config": {
                    "path": "view.custom.selectedVersionId",
                    "bidirectional": true
                  }
                }
              }
            },
            "props": {
              "style": {
                "classes": "select"
              }
            }
          },
          {
            "type": "ia.input.checkbox",
            "meta": {
              "name": "ShowDeprecatedCheckbox"
            },
            "position": {
              "shrink": 0
            },
            "propConfig": {
              "props.selected": {
                "binding": {
                  "type": "property",
                  "config": {
                    "path": "view.custom.showDeprecated",
                    "bidirectional": true
                  }
                }
              }
            },
            "props": {
              "text": "Show all versions",
              "style": {
                "fontSize": "12px"
              }
            }
          },
          {
            "type": "ia.display.label",
            "meta": {
              "name": "StateBadge"
            },
            "position": {
              "shrink": 0
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "type": "expr",
                  "config": {
                    "expression": "if({view.custom.selectedHeader.DeprecatedAt} != null, 'Deprecated', if({view.custom.selectedHeader.PublishedAt} != null, 'Published', if({view.custom.selectedHeader.Id} > 0, 'Draft', '')))"
                  }
                }
              },
              "props.style.classes": {
                "binding": {
                  "type": "expr",
                  "config": {
                    "expression": "if({view.custom.selectedHeader.DeprecatedAt} != null, 'badge badge-deprecated', if({view.custom.selectedHeader.PublishedAt} != null, 'badge badge-published', 'badge badge-draft'))"
                  }
                }
              }
            },
            "props": {
              "text": "",
              "style": {
                "classes": "badge"
              }
            }
          },
          {
            "type": "ia.display.label",
            "meta": {
              "name": "DraftDirtyIndicator"
            },
            "position": {
              "shrink": 0
            },
            "propConfig": {
              "position.display": {
                "binding": {
                  "type": "expr",
                  "config": {
                    "expression": "{view.custom.mode} = 'draft'"
                  }
                }
              }
            },
            "props": {
              "text": "Editing draft",
              "style": {
                "color": "var(--mpp-state-warn-fg)",
                "fontSize": "11px",
                "fontStyle": "italic"
              }
            }
          },
          {
            "type": "ia.input.text-field",
            "meta": {
              "name": "DraftEffectiveFromField"
            },
            "position": {
              "basis": "200px",
              "shrink": 0
            },
            "propConfig": {
              "position.display": {
                "binding": {
                  "type": "expr",
                  "config": {
                    "expression": "{view.custom.mode} = 'draft'"
                  }
                }
              },
              "props.text": {
                "binding": {
                  "type": "property",
                  "config": {
                    "path": "view.custom.draftEditDraft.EffectiveFrom",
                    "bidirectional": true
                  }
                }
              }
            },
            "props": {
              "placeholder": "EffectiveFrom (ISO)",
              "style": {
                "classes": "psc-search-input"
              }
            }
          },
          {
            "type": "ia.container.flex",
            "meta": {
              "name": "HeaderSpacer"
            },
            "position": {
              "grow": 1
            }
          },
          {
            "type": "ia.input.button",
            "meta": {
              "name": "BtnNewVersion"
            },
            "position": {
              "shrink": 0
            },
            "propConfig": {
              "position.display": {
                "binding": {
                  "type": "expr",
                  "config": {
                    "expression": "{view.custom.mode} = 'view'"
                  }
                }
              }
            },
            "props": {
              "text": "New Version",
              "style": {
                "classes": "btn btn-primary btn-sm"
              }
            },
            "events": {
              "component": {
                "onActionPerformed": {
                  "type": "script",
                  "scope": "G",
                  "config": {
                    "script": "\tparentId = self.view.custom.selectedVersionId\n\tBlueRidge.Common.Util.log('BtnNewVersion click; parentId=%s' % parentId)\n\tif not parentId or parentId <= 0:\n\t\tBlueRidge.Common.Notify.toast('Cannot create version', 'No source version selected.', 'warn', 5)\n\t\treturn\n\tresult = BlueRidge.Parts.RouteTemplate.createNewVersion(parentId, None)\n\tBlueRidge.Common.Ui.notifyResult(result, 'New version', 'Draft created.', 'Create failed')\n\tif not result or not result.get('Status'):\n\t\treturn\n\tnewDraftId = result['NewId']\n\tself.view.custom.draftId = newDraftId\n\theader = BlueRidge.Parts.RouteTemplate.getHeader(newDraftId) or {}\n\tsteps = BlueRidge.Parts.RouteTemplate.getSteps(newDraftId) or []\n\teffStr = str(header.get('EffectiveFrom') or '')[:10]\n\tdraft = {'Id': newDraftId, 'Name': header.get('Name', ''), 'EffectiveFrom': effStr, 'steps': [dict(s) for s in steps]}\n\tself.view.custom.draftEditDraft = dict(draft)\n\tself.view.custom.draftSelected = {'Id': newDraftId, 'Name': header.get('Name', ''), 'EffectiveFrom': effStr, 'steps': [dict(s) for s in steps]}\n\tself.view.custom.mode = 'draft'\n\tself.view.custom.selectedVersionId = newDraftId\n\tself.view.rootContainer.reloadVersions()\n\tself.view.rootContainer.broadcastDirty(False)"
                  }
                }
              }
            }
          },
          {
            "type": "ia.input.button",
            "meta": {
              "name": "BtnSaveDraft"
            },
            "position": {
              "shrink": 0
            },
            "propConfig": {
              "position.display": {
                "binding": {
                  "type": "expr",
                  "config": {
                    "expression": "{view.custom.mode} = 'draft'"
                  }
                }
              }
            },
            "props": {
              "text": "Save",
              "style": {
                "classes": "btn btn-sm"
              }
            },
            "events": {
              "component": {
                "onActionPerformed": {
                  "type": "script",
                  "scope": "G",
                  "config": {
                    "script": "\tdraft = self.view.custom.draftEditDraft\n\tresult = BlueRidge.Parts.RouteTemplate.saveAll(self.view.custom.draftId, draft.get('Name'), draft.get('EffectiveFrom'), draft.get('steps') or [])\n\tBlueRidge.Common.Ui.notifyResult(result, 'Route saved', 'Route saved.', 'Save failed')\n\tif not result or not result.get('Status'):\n\t\treturn\n\tself.view.custom.draftSelected = {'Id': draft.get('Id'), 'Name': draft.get('Name'), 'EffectiveFrom': draft.get('EffectiveFrom'), 'steps': [dict(s) for s in (draft.get('steps') or [])]}\n\tself.view.rootContainer.reloadVersions()\n\tself.view.rootContainer.broadcastDirty(False)"
                  }
                }
              }
            }
          },
          {
            "type": "ia.input.button",
            "meta": {
              "name": "BtnPublish"
            },
            "position": {
              "shrink": 0
            },
            "propConfig": {
              "position.display": {
                "binding": {
                  "type": "expr",
                  "config": {
                    "expression": "{view.custom.mode} = 'draft'"
                  }
                }
              }
            },
            "props": {
              "text": "Publish",
              "style": {
                "classes": "btn btn-primary btn-sm"
              }
            },
            "events": {
              "component": {
                "onActionPerformed": {
                  "type": "script",
                  "scope": "G",
                  "config": {
                    "script": "\tdraft = self.view.custom.draftEditDraft\n\tresult = BlueRidge.Parts.RouteTemplate.publishWithSave(self.view.custom.draftId, draft.get('Name'), draft.get('EffectiveFrom'), draft.get('steps') or [])\n\tBlueRidge.Common.Ui.notifyResult(result, 'Publish', 'Route published.', 'Publish failed')\n\tif not result or not result.get('Status'):\n\t\treturn\n\tpublishedId = self.view.custom.draftId\n\tself.view.custom.draftId = 0\n\tself.view.custom.draftEditDraft = {'Id': 0, 'Name': '', 'EffectiveFrom': '', 'steps': []}\n\tself.view.custom.draftSelected = {'Id': 0, 'Name': '', 'EffectiveFrom': '', 'steps': []}\n\tself.view.custom.mode = 'view'\n\tself.view.rootContainer.reloadVersions()\n\tself.view.custom.selectedVersionId = publishedId\n\tself.view.rootContainer.broadcastDirty(False)"
                  }
                }
              }
            }
          },
          {
            "type": "ia.input.button",
            "meta": {
              "name": "BtnDiscardDraft"
            },
            "position": {
              "shrink": 0
            },
            "propConfig": {
              "position.display": {
                "binding": {
                  "type": "expr",
                  "config": {
                    "expression": "{view.custom.mode} = 'draft'"
                  }
                }
              }
            },
            "props": {
              "text": "Discard Draft",
              "style": {
                "classes": "btn btn-danger btn-sm"
              }
            },
            "events": {
              "component": {
                "onActionPerformed": {
                  "type": "script",
                  "scope": "G",
                  "config": {
                    "script": "\tsystem.perspective.openPopup(id='mpp-confirm-destructive', view='BlueRidge/Components/Popups/ConfirmDestructive', modal=True, showCloseIcon=False, params={'title': 'Discard Draft?', 'message': 'This deletes the unpublished draft entirely. It cannot be undone.', 'confirmLabel': 'Discard Draft', 'replyMessage': 'routeConfirmDiscard'})"
                  }
                }
              }
            }
          }
        ]
      },
      {
        "type": "ia.container.flex",
        "meta": {
          "name": "PublishedPanel"
        },
        "position": {
          "grow": 1
        },
        "propConfig": {
          "position.display": {
            "binding": {
              "type": "expr",
              "config": {
                "expression": "{view.custom.mode} = 'view'"
              }
            }
          }
        },
        "props": {
          "direction": "column",
          "style": {
            "classes": "detail-panel",
            "overflow": "hidden"
          }
        },
        "children": [
          {
            "type": "ia.display.table",
            "meta": {
              "name": "RouteStepsTable"
            },
            "position": {
              "grow": 1
            },
            "propConfig": {
              "props.data": {
                "binding": {
                  "type": "expr",
                  "config": {
                    "expression": "runScript(\"BlueRidge.Parts.RouteTemplate.getSteps\", 0, {view.custom.selectedVersionId})"
                  },
                  "transforms": [
                    {
                      "code": "\tout = []\n\tfor r in (value or []):\n\t\tr = r or {}\n\t\tout.append({'seq': r.get('SequenceNumber'), 'areaName': r.get('OperationAreaName') or '', 'opCode': r.get('OperationCode') or '', 'opName': r.get('OperationName') or '', 'isRequired': bool(r.get('IsRequired')), 'dataFields': r.get('DataCollectionSummary') or ''})\n\treturn out",
                      "type": "script"
                    }
                  ]
                }
              }
            },
            "props": {
              "columns": [
                {
                  "field": "seq",
                  "visible": true,
                  "editable": false,
                  "render": "auto",
                  "justify": "auto",
                  "align": "center",
                  "resizable": false,
                  "sortable": false,
                  "sort": "none",
                  "filter": {"enabled": false, "visible": "on-hover", "string": {"condition": "", "value": ""}, "number": {"condition": "", "value": ""}, "boolean": {"condition": ""}, "date": {"condition": "", "value": ""}},
                  "viewPath": "",
                  "viewParams": {},
                  "boolean": "checkbox",
                  "number": "value",
                  "progressBar": {"max": 100, "min": 0, "bar": {"color": "", "style": {"classes": ""}}, "track": {"color": "", "style": {"classes": ""}}, "value": {"enabled": true, "format": "0,0.##", "justify": "center", "style": {"classes": ""}}},
                  "toggleSwitch": {"color": {"selected": "", "unselected": ""}},
                  "nullFormat": {"includeNullStrings": false, "strict": false, "nullFormatValue": ""},
                  "numberFormat": "0,0.##",
                  "dateFormat": "MM/DD/YYYY",
                  "width": 50,
                  "strictWidth": false,
                  "style": {"classes": ""},
                  "header": {"title": "#", "justify": "center", "align": "center", "style": {"classes": ""}},
                  "footer": {"title": "", "justify": "left", "align": "center", "style": {"classes": ""}}
                },
                {
                  "field": "areaName",
                  "visible": true,
                  "editable": false,
                  "render": "auto",
                  "justify": "auto",
                  "align": "center",
                  "resizable": true,
                  "sortable": false,
                  "sort": "none",
                  "filter": {"enabled": false, "visible": "on-hover", "string": {"condition": "", "value": ""}, "number": {"condition": "", "value": ""}, "boolean": {"condition": ""}, "date": {"condition": "", "value": ""}},
                  "viewPath": "",
                  "viewParams": {},
                  "boolean": "checkbox",
                  "number": "value",
                  "progressBar": {"max": 100, "min": 0, "bar": {"color": "", "style": {"classes": ""}}, "track": {"color": "", "style": {"classes": ""}}, "value": {"enabled": true, "format": "0,0.##", "justify": "center", "style": {"classes": ""}}},
                  "toggleSwitch": {"color": {"selected": "", "unselected": ""}},
                  "nullFormat": {"includeNullStrings": false, "strict": false, "nullFormatValue": ""},
                  "numberFormat": "0,0.##",
                  "dateFormat": "MM/DD/YYYY",
                  "width": 140,
                  "strictWidth": false,
                  "style": {"classes": ""},
                  "header": {"title": "Area", "justify": "left", "align": "center", "style": {"classes": ""}},
                  "footer": {"title": "", "justify": "left", "align": "center", "style": {"classes": ""}}
                },
                {
                  "field": "opCode",
                  "visible": true,
                  "editable": false,
                  "render": "auto",
                  "justify": "auto",
                  "align": "center",
                  "resizable": true,
                  "sortable": false,
                  "sort": "none",
                  "filter": {"enabled": false, "visible": "on-hover", "string": {"condition": "", "value": ""}, "number": {"condition": "", "value": ""}, "boolean": {"condition": ""}, "date": {"condition": "", "value": ""}},
                  "viewPath": "",
                  "viewParams": {},
                  "boolean": "checkbox",
                  "number": "value",
                  "progressBar": {"max": 100, "min": 0, "bar": {"color": "", "style": {"classes": ""}}, "track": {"color": "", "style": {"classes": ""}}, "value": {"enabled": true, "format": "0,0.##", "justify": "center", "style": {"classes": ""}}},
                  "toggleSwitch": {"color": {"selected": "", "unselected": ""}},
                  "nullFormat": {"includeNullStrings": false, "strict": false, "nullFormatValue": ""},
                  "numberFormat": "0,0.##",
                  "dateFormat": "MM/DD/YYYY",
                  "width": 140,
                  "strictWidth": false,
                  "style": {"classes": ""},
                  "header": {"title": "Operation Code", "justify": "left", "align": "center", "style": {"classes": ""}},
                  "footer": {"title": "", "justify": "left", "align": "center", "style": {"classes": ""}}
                },
                {
                  "field": "opName",
                  "visible": true,
                  "editable": false,
                  "render": "auto",
                  "justify": "auto",
                  "align": "center",
                  "resizable": true,
                  "sortable": false,
                  "sort": "none",
                  "filter": {"enabled": false, "visible": "on-hover", "string": {"condition": "", "value": ""}, "number": {"condition": "", "value": ""}, "boolean": {"condition": ""}, "date": {"condition": "", "value": ""}},
                  "viewPath": "",
                  "viewParams": {},
