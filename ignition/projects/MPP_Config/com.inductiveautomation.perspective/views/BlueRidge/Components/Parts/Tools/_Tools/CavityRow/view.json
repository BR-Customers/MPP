{
  "custom": {},
  "params": {
    "row": {
      "cavityNumber": null,
      "description": "",
      "id": null,
      "isDeprecated": null,
      "isScrappedSaved": false,
      "rowIndex": 0,
      "statusCode": "Active"
    }
  },
  "propConfig": {
    "params.row": {
      "paramDirection": "input"
    }
  },
  "props": {
    "defaultSize": {
      "height": 36,
      "width": 1200
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "IndexLabel"
        },
        "position": {
          "basis": "32px",
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "expression": "toStr({view.params.row.rowIndex} + 1)"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "style": {
            "color": "var(--mpp-text-secondary)",
            "fontSize": "12px",
            "textAlign": "right"
          }
        },
        "type": "ia.display.label"
      },
      {
        "events": {
          "dom": {
            "onBlur": {
              "config": {
                "script": "\tv \u003d self.props.value\n\tnewNumber \u003d None if v is None else int(v)\n\tsystem.perspective.sendMessage(\"cavityRowNumberChanged\", payload\u003d{\"rowIndex\": self.view.params.row.rowIndex, \"newNumber\": newNumber}, scope\u003d\"page\")"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "NumberInput"
        },
        "position": {
          "basis": "120px",
          "shrink": 0
        },
        "propConfig": {
          "position.display": {
            "binding": {
              "config": {
                "expression": "isNull({view.params.row.id})"
              },
              "type": "expr"
            }
          },
          "props.value": {
            "binding": {
              "config": {
                "path": "view.params.row.cavityNumber"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "placeholder": "No.",
          "style": {
            "classes": "search-input",
            "height": "30px"
          }
        },
        "type": "ia.input.numeric-entry-field"
      },
      {
        "meta": {
          "name": "NumberLabel"
        },
        "position": {
          "basis": "120px",
          "shrink": 0
        },
        "propConfig": {
          "position.display": {
            "binding": {
              "config": {
                "expression": "!isNull({view.params.row.id})"
              },
              "type": "expr"
            }
          },
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.row.cavityNumber"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "fontSize": "12px"
          }
        },
        "type": "ia.display.label"
      },
      {
        "events": {
          "dom": {
            "onBlur": {
              "config": {
                "script": "\tsystem.perspective.sendMessage(\"cavityRowDescChanged\", payload\u003d{\"rowIndex\": self.view.params.row.rowIndex, \"newDesc\": self.props.text}, scope\u003d\"page\")"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "DescInput"
        },
        "position": {
          "basis": "0",
          "grow": 1
        },
        "propConfig": {
          "props.enabled": {
            "binding": {
              "config": {
                "expression": "!{view.params.row.isScrappedSaved} \u0026\u0026 !{view.params.row.isDeprecated}"
              },
              "type": "expr"
            }
          },
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.row.description"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "placeholder": "Description",
          "style": {
            "classes": "search-input",
            "height": "30px"
          }
        },
        "type": "ia.input.text-field"
      },
      {
        "events": {
          "component": {
            "onActionPerformed": {
              "config": {
                "script": "\tsystem.perspective.sendMessage(\"cavityRowStatusChanged\", payload\u003d{\"rowIndex\": self.view.params.row.rowIndex, \"newStatus\": self.props.value}, scope\u003d\"page\")"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "StatusDropdown"
        },
        "position": {
          "basis": "160px",
          "shrink": 0
        },
        "propConfig": {
          "props.enabled": {
            "binding": {
              "config": {
                "expression": "!{view.params.row.isScrappedSaved} \u0026\u0026 !{view.params.row.isDeprecated}"
              },
              "type": "expr"
            }
          },
          "props.value": {
            "binding": {
              "config": {
                "path": "view.params.row.statusCode"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "options": [
            {
              "label": "Active",
              "value": "Active"
            },
            {
              "label": "Closed",
              "value": "Closed"
            },
            {
              "label": "Scrapped",
              "value": "Scrapped"
            }
          ],
          "style": {
            "classes": "select",
            "height": "30px"
          }
        },
        "type": "ia.input.dropdown"
      },
      {
        "events": {
          "component": {
            "onActionPerformed": {
              "config": {
                "script": "\tsystem.perspective.sendMessage(\"cavityRowRemove\", payload\u003d{\"rowIndex\": self.view.params.row.rowIndex}, scope\u003d\"page\")"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "RemoveBtn"
        },
        "position": {
          "basis": "40px",
          "shrink": 0
        },
        "propConfig": {
          "position.display": {
            "binding": {
              "config": {
                "expression": "isNull({view.params.row.id})"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "style": {
            "classes": "btn btn-sm",
            "height": "30px",
            "padding": "2px 6px"
          },
          "text": "×"
        },
        "type": "ia.input.button"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "alignItems": "center",
      "style": {
        "borderBottom": "1px solid var(--mpp-border-subtle)",
        "gap": "6px",
        "height": "100%",
        "padding": "2px 10px"
      }
    },
    "type": "ia.container.flex"
  }
}