{
  "custom": {},
  "params": {
    "row": {
      "rowIndex": 0,
      "id": null,
      "cavityNumber": null,
      "description": "",
      "statusCode": "Active",
      "isScrappedSaved": false
    }
  },
  "propConfig": {
    "params.row": { "paramDirection": "input" }
  },
  "props": {
    "defaultSize": { "height": 36, "width": 1200 }
  },
  "root": {
    "type": "ia.container.flex",
    "meta": { "name": "root" },
    "props": {
      "direction": "row",
      "alignItems": "center",
      "style": {
        "borderBottom": "1px solid var(--mpp-border-subtle)",
        "gap": "6px",
        "padding": "2px 10px",
        "height": "100%"
      }
    },
    "children": [
      {
        "type": "ia.display.label",
        "meta": { "name": "IndexLabel" },
        "position": { "basis": "32px", "shrink": 0 },
        "propConfig": {
          "props.text": {
            "binding": {
              "type": "expr",
              "config": { "expression": "toStr({view.params.row.rowIndex} + 1)" }
            }
          }
        },
        "props": {
          "style": {
            "color": "var(--mpp-text-secondary)",
            "fontSize": "12px",
            "textAlign": "right"
          }
        }
      },
      {
        "type": "ia.input.numeric-entry-field",
        "meta": { "name": "NumberInput" },
        "position": { "basis": "120px", "shrink": 0 },
        "propConfig": {
          "position.display": {
            "binding": {
              "type": "expr",
              "config": { "expression": "isNull({view.params.row.id})" }
            }
          },
          "props.value": {
            "binding": {
              "type": "property",
              "config": { "path": "view.params.row.cavityNumber" }
            }
          }
        },
        "props": {
          "placeholder": "No.",
          "style": { "classes": "search-input", "height": "30px" }
        },
        "events": {
          "dom": {
            "onBlur": {
              "type": "script",
              "scope": "G",
              "config": {
                "script": "\tv = self.props.value\n\tnewNumber = None if v is None else int(v)\n\tsystem.perspective.sendMessage(\"cavityRowNumberChanged\", payload={\"rowIndex\": self.view.params.row.rowIndex, \"newNumber\": newNumber}, scope=\"page\")"
              }
            }
          }
        }
      },
      {
        "type": "ia.display.label",
        "meta": { "name": "NumberLabel" },
        "position": { "basis": "120px", "shrink": 0 },
        "propConfig": {
          "position.display": {
            "binding": {
              "type": "expr",
              "config": { "expression": "!isNull({view.params.row.id})" }
            }
          },
          "props.text": {
            "binding": {
              "type": "property",
              "config": { "path": "view.params.row.cavityNumber" }
            }
          }
        },
        "props": {
          "text": "",
          "style": { "fontSize": "12px" }
        }
      },
      {
        "type": "ia.input.text-field",
        "meta": { "name": "DescInput" },
        "position": { "grow": 1, "basis": "0" },
        "propConfig": {
          "props.text": {
            "binding": {
              "type": "property",
              "config": { "path": "view.params.row.description" }
            }
          },
          "props.enabled": {
            "binding": {
              "type": "expr",
              "config": { "expression": "!{view.params.row.isScrappedSaved}" }
            }
          }
        },
        "props": {
          "placeholder": "Description",
          "style": { "classes": "search-input", "height": "30px" }
        },
        "events": {
          "dom": {
            "onBlur": {
              "type": "script",
              "scope": "G",
              "config": {
                "script": "\tsystem.perspective.sendMessage(\"cavityRowDescChanged\", payload={\"rowIndex\": self.view.params.row.rowIndex, \"newDesc\": self.props.text}, scope=\"page\")"
              }
            }
          }
        }
      },
      {
        "type": "ia.input.dropdown",
        "meta": { "name": "StatusDropdown" },
        "position": { "basis": "160px", "shrink": 0 },
        "propConfig": {
          "props.value": {
            "binding": {
              "type": "property",
              "config": { "path": "view.params.row.statusCode" }
            }
          },
          "props.enabled": {
            "binding": {
              "type": "expr",
              "config": { "expression": "!{view.params.row.isScrappedSaved}" }
            }
          }
        },
        "props": {
          "options": [
            { "label": "Active", "value": "Active" },
            { "label": "Closed", "value": "Closed" },
            { "label": "Scrapped", "value": "Scrapped" }
          ],
          "style": { "classes": "select", "height": "30px" }
        },
        "events": {
          "component": {
            "onActionPerformed": {
              "type": "script",
              "scope": "G",
              "config": {
                "script": "\tsystem.perspective.sendMessage(\"cavityRowStatusChanged\", payload={\"rowIndex\": self.view.params.row.rowIndex, \"newStatus\": self.props.value}, scope=\"page\")"
              }
            }
          }
        }
      },
      {
        "type": "ia.input.button",
        "meta": { "name": "RemoveBtn" },
        "position": { "basis": "40px", "shrink": 0 },
        "propConfig": {
          "position.display": {
            "binding": {
              "type": "expr",
              "config": { "expression": "isNull({view.params.row.id})" }
            }
          }
        },
        "props": {
          "text": "×",
          "style": { "classes": "btn btn-sm", "padding": "2px 6px", "height": "30px" }
        },
        "events": {
          "component": {
            "onActionPerformed": {
              "type": "script",
              "scope": "G",
              "config": {
                "script": "\tsystem.perspective.sendMessage(\"cavityRowRemove\", payload={\"rowIndex\": self.view.params.row.rowIndex}, scope=\"page\")"
              }
            }
          }
        }
      }
    ]
  }
}
