{
  "custom": {
    "data": {}
  },
  "params": {
    "value": 0
  },
  "propConfig": {
    "params.value": {
      "paramDirection": "input"
    },
    "custom.data": {
      "binding": {
        "type": "expr",
        "config": {
          "expression": "runScript(\"BlueRidge.Parts.Bom.getActiveForItem\", 0, {view.params.value})"
        }
      }
    }
  },
  "props": {
    "defaultSize": {
      "height": 280
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "meta": {
              "name": "DropdownVersion"
            },
            "propConfig": {
              "props.options": {
                "binding": {
                  "config": {
                    "expression": "[{\u0027label\u0027: \u0027v\u0027 + toStr({view.custom.data.publishedVersion}) + \u0027 — Effective \u0027 + {view.custom.data.effectiveFrom} + \u0027 (Published)\u0027, \u0027value\u0027: {view.custom.data.publishedVersion}}]"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "classes": "select",
                "minWidth": "320px"
              }
            },
            "type": "ia.input.dropdown"
          },
          {
            "meta": {
              "name": "BadgePublished"
            },
            "props": {
              "style": {
                "classes": "badge badge-published"
              },
              "text": "Published"
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "HeaderSpacer"
            },
            "position": {
              "grow": 1
            },
            "type": "ia.container.flex"
          },
          {
            "events": {
              "component": {
                "onActionPerformed": {
                  "config": {
                    "script": "BlueRidge.Common.Notify.toast(\u0027Not wired yet\u0027, \u0027BOMs versioning workflow lands in Phase 6.\u0027, \u0027info\u0027, 5)"
                  },
                  "scope": "C",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "BtnNewVersion"
            },
            "props": {
              "style": {
                "classes": "btn btn-sm"
              },
              "text": "New Version"
            },
            "type": "ia.input.button"
          }
        ],
        "meta": {
          "name": "HeaderRow"
        },
        "props": {
          "alignItems": "center",
          "style": {
            "gap": "8px"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "meta": {
              "name": "BomLinesTable"
            },
            "propConfig": {
              "props.data": {
                "binding": {
                  "config": {
                    "path": "view.custom.data.lines"
                  },
                  "type": "property"
                }
              }
            },
            "props": {
              "columns": [
                {
                  "editable": false,
                  "field": "seq",
                  "header": "#",
                  "width": 50
                },
                {
                  "editable": false,
                  "field": "componentName",
                  "header": "Component"
                },
                {
                  "editable": false,
                  "field": "partNumber",
                  "header": "Part Number"
                },
                {
                  "editable": false,
                  "field": "qtyPer",
                  "header": "Qty",
                  "width": 80
                },
                {
                  "editable": false,
                  "field": "uom",
                  "header": "UOM",
                  "width": 80
                }
              ],
              "rows": {
                "height": 32
              },
              "style": {
                "classes": "data-table"
              }
            },
            "type": "ia.display.table"
          },
          {
            "meta": {
              "name": "ReadOnlyCaption"
            },
            "props": {
              "style": {
                "color": "var(--mpp-text-muted)",
                "fontSize": "11px",
                "fontStyle": "italic",
                "padding": "8px 12px"
              },
              "text": "Published — read-only. Click New Version to create a draft copy for editing."
            },
            "type": "ia.display.label"
          }
        ],
        "meta": {
          "name": "PublishedPanel"
        },
        "props": {
          "direction": "column",
          "style": {
            "classes": "detail-panel",
            "overflow": "hidden"
          }
        },
        "type": "ia.container.flex"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "gap": "10px"
      }
    },
    "type": "ia.container.flex"
  }
}