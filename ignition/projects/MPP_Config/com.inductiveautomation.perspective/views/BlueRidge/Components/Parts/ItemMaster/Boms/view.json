          "script": "\tif not payload:\n\t\treturn\n\tif payload.get(\"action\") != \"confirm\":\n\t\treturn\n\tsel = self.view.custom.state.selected or {}\n\tbomId = sel.get(\"id\")\n\tif not bomId:\n\t\treturn\n\tresult = BlueRidge.Parts.Bom.handleDeprecate(bomId)\n\tBlueRidge.Common.Ui.notifyResult(result, \"BOM deprecated\")\n\tif result and result.get(\"Status\"):\n\t\tself.refreshVersionList()\n\t\tself.loadActiveVersion()"
        },
        {
          "messageType": "bomConfirmDiscardResult",
          "pageScope": true,
          "sessionScope": false,
          "viewScope": false,
          "script": "\tif not payload:\n\t\treturn\n\tif payload.get(\"action\") != \"confirm\":\n\t\treturn\n\tdraft = self.view.custom.state.editDraft or {}\n\tbomId = draft.get(\"id\")\n\tif not bomId:\n\t\treturn\n\tresult = BlueRidge.Parts.Bom.handleDiscardDraft(bomId)\n\tBlueRidge.Common.Ui.notifyResult(result, \"Draft discarded\")\n\tif result and result.get(\"Status\"):\n\t\tself.view.custom.activeVersionId = None\n\t\tself.refreshVersionList()\n\t\tvers = self.view.custom.versions or []\n\t\tif vers:\n\t\t\tself.view.custom.activeVersionId = vers[0].get(\"Id\")"
        }
