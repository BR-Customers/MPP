{
  "custom": {},
  "params": {
    "item": {},
    "selectedId": 0
  },
  "propConfig": {
    "params.item": {
      "paramDirection": "input"
    },
    "params.selectedId": {
      "paramDirection": "input"
    }
  },
  "props": {
    "defaultSize": {
      "height": 36,
      "width": 240
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "meta": {
              "name": "LabelPartNumber"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "path": "view.params.item.partNumber"
                  },
                  "type": "property"
                }
              }
            },
            "props": {
              "style": {
                "fontSize": "12px",
                "fontWeight": "600"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "LabelDescription"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "path": "view.params.item.description"
                  },
                  "type": "property"
                }
              }
            },
            "props": {
              "style": {
                "color": "var(--mpp-text-muted)",
                "fontSize": "11px",
                "overflow": "hidden",
                "textOverflow": "ellipsis",
                "whiteSpace": "nowrap"
              }
            },
            "type": "ia.display.label"
          }
        ],
        "meta": {
          "name": "RowText"
        },
        "position": {
          "basis": "0",
          "grow": 1
        },
        "props": {
          "direction": "column",
          "style": {
            "gap": "1px",
            "overflow": "hidden"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "meta": {
          "name": "BadgeType"
        },
        "propConfig": {
          "props.style.classes": {
            "binding": {
              "config": {
                "expression": "if({view.params.item.isDraft} \u003d true, \u0027badge badge-draft\u0027, \u0027badge badge-purple\u0027)"
              },
              "type": "expr"
            }
          },
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.item.typeBadge"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "fontSize": "10px",
            "padding": "1px 5px"
          }
        },
        "type": "ia.display.label"
      }
    ],
    "events": {
      "dom": {
        "onClick": {
          "config": {
            "script": "\tsystem.perspective.sendMessage(\u0027itemRowClicked\u0027, payload\u003d{\u0027id\u0027: self.view.params.item.get(\u0027id\u0027)}, scope\u003d\u0027page\u0027)"
          },
          "scope": "G",
          "type": "script"
        }
      }
    },
    "meta": {
      "name": "root"
    },
    "propConfig": {
      "props.style.classes": {
        "binding": {
          "config": {
            "expression": "if({view.params.item.id} \u003d {view.params.selectedId}, \u0027tree-item tree-item-selected\u0027, \u0027tree-item\u0027)"
          },
          "type": "expr"
        }
      }
    },
    "props": {
      "alignItems": "center",
      "justify": "space-between",
      "style": {
        "borderBottom": "1px solid var(--mpp-border-subtle)",
        "cursor": "pointer",
        "padding": "6px 10px"
      }
    },
    "type": "ia.container.flex"
  }
}