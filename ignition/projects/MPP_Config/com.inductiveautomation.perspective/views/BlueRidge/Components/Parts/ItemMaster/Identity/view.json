    "custom.isDirty": {
      "binding": {
        "config": {
          "expression": "runScript(\"BlueRidge.Common.Util.convertWrapperObjectToJson\", 0, {view.custom.state.editDraft}) != runScript(\"BlueRidge.Common.Util.convertWrapperObjectToJson\", 0, {view.custom.state.selected})"
        },
        "type": "expr"
      },
      "onChange": {
        "enabled": true,
        "script": "\tsystem.perspective.sendMessage(\"sectionDirtyChanged\", payload={\"section\": \"identity\", \"isDirty\": bool(currentValue.value)}, scope=\"page\")"
      }
    },
    "custom.uomOptions": {
      "binding": {
        "config": {
          "expression": "runScript(\"BlueRidge.Parts.Uom.getForDropdown\", 0)"
        },
        "type": "expr"
      }
    },
    "custom.uomOptionsWithBlank": {
      "binding": {
        "config": {
          "expression": "runScript(\"BlueRidge.Parts.Uom.getForDropdown\", 0, true)"
        },
        "type": "expr"
      }
    },
    "params.value": {
      "onChange": {
        "enabled": true,
        "script": "\tself.rootContainer.load()"
      },
      "paramDirection": "input"
    }
  },
