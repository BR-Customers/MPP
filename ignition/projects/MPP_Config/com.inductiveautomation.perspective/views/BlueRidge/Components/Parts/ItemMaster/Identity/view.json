    "scripts": {
      "customMethods": [
        {
          "name": "load",
          "params": [],
          "script": "\titemId \u003d self.view.params.value\n\trow \u003d BlueRidge.Parts.Item.getOneOrEmpty(itemId)\n\tdef _s(v):\n\t\treturn \"\" if v is None else (v if isinstance(v, basestring) else unicode(v))\n\tloaded \u003d {\n\t\t\"Id\":               row.get(\"Id\"),\n\t\t\"PartNumber\":       _s(row.get(\"PartNumber\")),\n\t\t\"Description\":      _s(row.get(\"Description\")),\n\t\t\"ItemTypeId\":       row.get(\"ItemTypeId\"),\n\t\t\"ItemTypeName\":     _s(row.get(\"ItemTypeName\")),\n\t\t\"UomId\":            row.get(\"UomId\"),\n\t\t\"UomCode\":          _s(row.get(\"UomCode\")),\n\t\t\"WeightUomId\":      row.get(\"WeightUomId\"),\n\t\t\"WeightUomCode\":    _s(row.get(\"WeightUomCode\")),\n\t\t\"MacolaPartNumber\": _s(row.get(\"MacolaPartNumber\")),\n\t\t\"CountryOfOrigin\":  _s(row.get(\"CountryOfOrigin\")),\n\t\t\"UnitWeight\":       _s(row.get(\"UnitWeight\")),\n\t\t\"DefaultSubLotQty\": _s(row.get(\"DefaultSubLotQty\")),\n\t\t\"MaxLotSize\":       _s(row.get(\"MaxLotSize\")),\n\t\t\"MaxParts\":         _s(row.get(\"MaxParts\")),\n\t}\n\t_pid \u003d BlueRidge.Parts.Item.getPlcId(itemId)\n\tloaded[\"PlcId\"] \u003d (_pid.get(\"PlcId\") if _pid else None)\n\tself.view.custom.state \u003d {\"selected\": dict(loaded), \"editDraft\": dict(loaded)}"
        },
        {
          "name": "handleSave",
          "params": [],
          "script": "\tdraft \u003d self.view.custom.state.editDraft or {}\n\titemId \u003d draft.get(\"Id\")\n\tif not itemId:\n\t\tBlueRidge.Common.Notify.toast(\"Nothing to save\", \"Select an item first.\", \"warning\")\n\t\treturn\n\tif not draft.get(\"UomId\"):\n\t\tBlueRidge.Common.Notify.toast(\"UOM required\", \"Pick a UOM before saving.\", \"warning\")\n\t\treturn\n\tdef _toNum(v):\n\t\tif v is None or v \u003d\u003d \"\":\n\t\t\treturn None\n\t\ttry:\n\t\t\treturn int(v)\n\t\texcept (ValueError, TypeError):\n\t\t\ttry:\n\t\t\t\treturn float(v)\n\t\t\texcept (ValueError, TypeError):\n\t\t\t\treturn None\n\tpayload \u003d dict(draft)\n\tpayload[\"DefaultSubLotQty\"] \u003d _toNum(draft.get(\"DefaultSubLotQty\"))\n\tpayload[\"MaxLotSize\"]       \u003d _toNum(draft.get(\"MaxLotSize\"))\n\tpayload[\"UnitWeight\"]       \u003d _toNum(draft.get(\"UnitWeight\"))\n\tpayload[\"MaxParts\"]         \u003d _toNum(draft.get(\"MaxParts\"))\n\tresult \u003d BlueRidge.Parts.Item.update(payload)\n\tBlueRidge.Common.Ui.notifyResult(result, \"Item updated\")\n\tif result and result.get(\"Status\"):\n\t\tBlueRidge.Parts.Item.setPlcId(itemId, _toNum(draft.get(\"PlcId\")))\n\t\tself.load()\n\t\tsystem.perspective.sendMessage(\"itemsRefresh\", scope\u003d\"page\")"
        },
        {
          "name": "handleDiscard",
          "params": [],
          "script": "\tself.view.custom.state.editDraft \u003d dict(self.view.custom.state.selected)"
        },
        {
          "name": "handleDeprecate",
          "params": [],
          "script": "\titemId \u003d (self.view.custom.state.editDraft or {}).get(\"Id\") or (self.view.custom.state.selected or {}).get(\"Id\")\n\tif not itemId:\n\t\treturn\n\tresult \u003d BlueRidge.Parts.Item.deprecate(itemId)\n\tBlueRidge.Common.Ui.notifyResult(result, \"Item deprecated\")\n\tif result and result.get(\"Status\"):\n\t\tsystem.perspective.sendMessage(\"itemsRefresh\", scope\u003d\"page\")\n\t\tsystem.perspective.sendMessage(\"itemDeprecated\", payload\u003d{\"id\": itemId}, scope\u003d\"page\")"
        }
      ],
