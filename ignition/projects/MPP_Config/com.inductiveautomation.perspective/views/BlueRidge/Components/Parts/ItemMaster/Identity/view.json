    "scripts": {
      "customMethods": [
        {
          "name": "load",
          "params": [],
          "script": "\titemId \u003d self.view.params.value\n\trow \u003d BlueRidge.Parts.Item.getOneOrEmpty(itemId)\n\tloaded \u003d {\n\t\t\"Id\":               row.get(\"Id\"),\n\t\t\"PartNumber\":       row.get(\"PartNumber\"),\n\t\t\"Description\":      row.get(\"Description\"),\n\t\t\"ItemTypeId\":       row.get(\"ItemTypeId\"),\n\t\t\"ItemTypeName\":     row.get(\"ItemTypeName\"),\n\t\t\"UomId\":            row.get(\"UomId\"),\n\t\t\"UomCode\":          row.get(\"UomCode\"),\n\t\t\"WeightUomId\":      row.get(\"WeightUomId\"),\n\t\t\"WeightUomCode\":    row.get(\"WeightUomCode\"),\n\t\t\"MacolaPartNumber\": row.get(\"MacolaPartNumber\"),\n\t\t\"CountryOfOrigin\":  row.get(\"CountryOfOrigin\"),\n\t\t\"UnitWeight\":       row.get(\"UnitWeight\"),\n\t\t\"DefaultSubLotQty\": row.get(\"DefaultSubLotQty\"),\n\t\t\"MaxLotSize\":       row.get(\"MaxLotSize\"),\n\t\t\"MaxParts\":         row.get(\"MaxParts\"),\n\t}\n\tself.view.custom.selected  \u003d dict(loaded)\n\tself.view.custom.editDraft \u003d dict(loaded)"
        },
        {
          "name": "handleSave",
          "params": [],
          "script": "\tdraft \u003d self.view.custom.editDraft or {}\n\titemId \u003d draft.get(\"Id\")\n\tif not itemId:\n\t\tBlueRidge.Common.Notify.toast(\"Nothing to save\", \"Select an item first.\", \"warning\")\n\t\treturn\n\tif not draft.get(\"UomId\"):\n\t\tBlueRidge.Common.Notify.toast(\"UOM required\", \"Pick a UOM before saving.\", \"warning\")\n\t\treturn\n\tdef _toNum(v):\n\t\tif v is None or v \u003d\u003d \"\":\n\t\t\treturn None\n\t\ttry:\n\t\t\treturn int(v)\n\t\texcept (ValueError, TypeError):\n\t\t\ttry:\n\t\t\t\treturn float(v)\n\t\t\texcept (ValueError, TypeError):\n\t\t\t\treturn None\n\tpayload \u003d dict(draft)\n\tpayload[\"DefaultSubLotQty\"] \u003d _toNum(draft.get(\"DefaultSubLotQty\"))\n\tpayload[\"MaxLotSize\"]       \u003d _toNum(draft.get(\"MaxLotSize\"))\n\tpayload[\"UnitWeight\"]       \u003d _toNum(draft.get(\"UnitWeight\"))\n\tpayload[\"MaxParts\"]         \u003d _toNum(draft.get(\"MaxParts\"))\n\tresult \u003d BlueRidge.Parts.Item.update(payload)\n\tBlueRidge.Common.Ui.notifyResult(result, \"Item updated\")\n\tif result and result.get(\"Status\"):\n\t\tself.load()\n\t\tsystem.perspective.sendMessage(\"itemsRefresh\", scope\u003d\"page\")"
        },
        {
          "name": "handleDiscard",
          "params": [],
          "script": "\tself.view.custom.editDraft \u003d dict(self.view.custom.selected)"
        },
        {
          "name": "handleDeprecate",
          "params": [],
          "script": "\titemId \u003d (self.view.custom.editDraft or {}).get(\"Id\") or (self.view.custom.selected or {}).get(\"Id\")\n\tif not itemId:\n\t\treturn\n\tresult \u003d BlueRidge.Parts.Item.deprecate(itemId)\n\tBlueRidge.Common.Ui.notifyResult(result, \"Item deprecated\")\n\tif result and result.get(\"Status\"):\n\t\tsystem.perspective.sendMessage(\"itemsRefresh\", scope\u003d\"page\")\n\t\tsystem.perspective.sendMessage(\"itemDeprecated\", payload\u003d{\"id\": itemId}, scope\u003d\"page\")"
        }
      ],
      "extensionFunctions": null,
      "messageHandlers": [
        {
          "messageType": "sectionSaveRequested",
          "pageScope": true,
          "script": "\tif payload and payload.get(\"section\") \u003d\u003d \"identity\":\n\t\tself.handleSave()",
          "sessionScope": false,
          "viewScope": false
        },
        {
          "messageType": "sectionDiscardRequested",
          "pageScope": true,
          "script": "\tif payload and payload.get(\"section\") \u003d\u003d \"identity\":\n\t\tself.handleDiscard()",
