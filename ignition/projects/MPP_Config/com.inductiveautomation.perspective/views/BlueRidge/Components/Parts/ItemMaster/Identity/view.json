          "script": "\titemId = self.view.params.value\n\trow = BlueRidge.Parts.Item.getOneOrEmpty(itemId)\n\tdef _s(v):\n\t\treturn \"\" if v is None else (v if isinstance(v, basestring) else unicode(v))\n\tloaded = {\n\t\t\"Id\":               row.get(\"Id\"),\n\t\t\"PartNumber\":       _s(row.get(\"PartNumber\")),\n\t\t\"Description\":      _s(row.get(\"Description\")),\n\t\t\"ItemTypeId\":       row.get(\"ItemTypeId\"),\n\t\t\"ItemTypeName\":     _s(row.get(\"ItemTypeName\")),\n\t\t\"UomId\":            row.get(\"UomId\"),\n\t\t\"UomCode\":          _s(row.get(\"UomCode\")),\n\t\t\"WeightUomId\":      row.get(\"WeightUomId\"),\n\t\t\"WeightUomCode\":    _s(row.get(\"WeightUomCode\")),\n\t\t\"MacolaPartNumber\": _s(row.get(\"MacolaPartNumber\")),\n\t\t\"CountryOfOrigin\":  _s(row.get(\"CountryOfOrigin\")),\n\t\t\"UnitWeight\":       _s(row.get(\"UnitWeight\")),\n\t\t\"DefaultSubLotQty\": _s(row.get(\"DefaultSubLotQty\")),\n\t\t\"MaxLotSize\":       _s(row.get(\"MaxLotSize\")),\n\t\t\"MaxParts\":         _s(row.get(\"MaxParts\")),\n\t}\n\t_pid = BlueRidge.Parts.Item.getPlcId(itemId)\n\tloaded[\"PlcId\"] = (_pid.get(\"PlcId\") if _pid else None)\n\tself.view.custom.state = {\"selected\": dict(loaded), \"editDraft\": dict(loaded)}"
        },
        {
          "name": "handleSave",
          "params": [],
          "script": "\tdraft = self.view.custom.state.editDraft or {}\n\titemId = draft.get(\"Id\")\n\tif not itemId:\n\t\tBlueRidge.Common.Notify.toast(\"Nothing to save\", \"Select an item first.\", \"warning\")\n\t\treturn\n\tif not draft.get(\"UomId\"):\n\t\tBlueRidge.Common.Notify.toast(\"UOM required\", \"Pick a UOM before saving.\", \"warning\")\n\t\treturn\n\tdef _toNum(v):\n\t\tif v is None or v == \"\":\n\t\t\treturn None\n\t\ttry:\n\t\t\treturn int(v)\n\t\texcept (ValueError, TypeError):\n\t\t\ttry:\n\t\t\t\treturn float(v)\n\t\t\texcept (ValueError, TypeError):\n\t\t\t\treturn None\n\tpayload = dict(draft)\n\tpayload[\"DefaultSubLotQty\"] = _toNum(draft.get(\"DefaultSubLotQty\"))\n\tpayload[\"MaxLotSize\"]       = _toNum(draft.get(\"MaxLotSize\"))\n\tpayload[\"UnitWeight\"]       = _toNum(draft.get(\"UnitWeight\"))\n\tpayload[\"MaxParts\"]         = _toNum(draft.get(\"MaxParts\"))\n\tresult = BlueRidge.Parts.Item.update(payload)\n\tBlueRidge.Common.Ui.notifyResult(result, \"Item updated\")\n\tif result and result.get(\"Status\"):\n\t\tBlueRidge.Parts.Item.setPlcId(itemId, _toNum(draft.get(\"PlcId\")))\n\t\tself.load()\n\t\tsystem.perspective.sendMessage(\"itemsRefresh\", scope=\"page\")"
        },
        {
          "name": "handleDiscard",
          "params": [],
          "script": "\tself.view.custom.state.editDraft = dict(self.view.custom.state.selected)"
        },
        {
          "name": "handleDeprecate",
          "params": [],
          "script": "\titemId = (self.view.custom.state.editDraft or {}).get(\"Id\") or (self.view.custom.state.selected or {}).get(\"Id\")\n\tif not itemId:\n\t\treturn\n\tresult = BlueRidge.Parts.Item.deprecate(itemId)\n\tBlueRidge.Common.Ui.notifyResult(result, \"Item deprecated\")\n\tif result and result.get(\"Status\"):\n\t\tsystem.perspective.sendMessage(\"itemsRefresh\", scope=\"page\")\n\t\tsystem.perspective.sendMessage(\"itemDeprecated\", payload={\"id\": itemId}, scope=\"page\")"
        }
      ],
      "extensionFunctions": null,
      "messageHandlers": [
        {
          "messageType": "sectionSaveRequested",
          "pageScope": true,
          "script": "\tif payload and payload.get(\"section\") == \"identity\":\n\t\tself.handleSave()",
          "sessionScope": false,
          "viewScope": false
        },
        {
          "messageType": "sectionDiscardRequested",
          "pageScope": true,
          "script": "\tif payload and payload.get(\"section\") == \"identity\":\n\t\tself.handleDiscard()",
          "sessionScope": false,
          "viewScope": false
        },
        {
          "messageType": "itemDeprecateConfirmed",
          "pageScope": true,
          "script": "\taction = (payload or {}).get('action')\n\tif action != 'confirm':\n\t\treturn\n\tself.handleDeprecate()",
          "sessionScope": false,
          "viewScope": false
        }
      ]
    },
    "type": "ia.container.flex"
  }
