{
  "custom": {},
  "params": {
    "row": {
      "rowIndex": 0,
      "id": null,
      "dataCollectionFieldId": null,
      "code": "",
      "name": "",
      "isRequired": true
    },
    "fieldOptions": []
  },
  "propConfig": {
    "params.row": { "paramDirection": "input" },
    "params.fieldOptions": { "paramDirection": "input" }
  },
  "props": {
    "defaultSize": { "height": 44, "width": 800 }
  },
  "root": {
    "type": "ia.container.flex",
    "meta": { "name": "root" },
    "props": {
      "direction": "row",
      "alignItems": "center",
      "style": {
        "borderBottom": "1px solid var(--mpp-border-subtle)",
        "padding": "6px 14px",
        "overflow": "hidden",
        "gap": "8px",
        "height": "100%"
      }
    },
    "children": [
      {
        "type": "ia.display.label",
        "meta": { "name": "IndexLabel" },
        "position": { "basis": "32px", "shrink": 0 },
        "propConfig": {
          "props.text": {
            "binding": {
              "type": "expr",
              "config": { "expression": "toStr({view.params.row.rowIndex} + 1)" }
            }
          }
        },
        "props": {
          "style": {
            "color": "var(--mpp-text-secondary)",
            "fontSize": "12px",
            "textAlign": "right"
          }
        }
      },
      {
        "type": "ia.input.dropdown",
        "meta": { "name": "FieldDropdown" },
        "position": { "basis": "0", "grow": 1 },
        "propConfig": {
          "position.display": {
            "binding": {
              "type": "expr",
              "config": { "expression": "isNull({view.params.row.id})" }
            }
          },
          "props.value": {
            "binding": {
              "type": "property",
              "config": { "bidirectional": true, "path": "view.params.row.dataCollectionFieldId" }
            }
          },
          "props.options": {
            "binding": {
              "type": "property",
              "config": { "path": "view.params.fieldOptions" }
            }
          }
        },
        "props": {
          "options": [],
          "noSelectionText": "Select field",
          "style": { "classes": "select", "height": "30px" }
        },
        "events": {
          "component": {
            "onActionPerformed": {
              "type": "script",
              "scope": "G",
              "config": {
                "script": "\tsystem.perspective.sendMessage(\"fieldRowFieldChanged\", payload={\"rowIndex\": self.view.params.row.rowIndex, \"newFieldId\": self.props.value}, scope=\"page\")"
              }
            }
          }
        }
      },
      {
        "type": "ia.display.label",
        "meta": { "name": "CodeLabel" },
        "position": { "basis": "160px", "shrink": 0 },
        "propConfig": {
          "position.display": {
            "binding": {
              "type": "expr",
              "config": { "expression": "!isNull({view.params.row.id})" }
            }
          },
          "props.text": {
            "binding": {
              "type": "property",
              "config": { "path": "view.params.row.code" }
            }
          }
        },
        "props": {
          "text": "",
          "style": {
            "fontFamily": "var(--mpp-font-mono)",
            "fontSize": "12px",
            "fontWeight": "600"
          }
        }
      },
      {
        "type": "ia.display.label",
        "meta": { "name": "NameLabel" },
        "position": { "basis": "0", "grow": 1 },
        "propConfig": {
          "position.display": {
            "binding": {
              "type": "expr",
              "config": { "expression": "!isNull({view.params.row.id})" }
            }
          },
          "props.text": {
            "binding": {
              "type": "property",
              "config": { "path": "view.params.row.name" }
            }
          }
        },
        "props": {
          "text": "",
          "style": {
            "color": "var(--mpp-text-muted)",
            "fontSize": "12px"
          }
        }
      },
      {
        "type": "ia.container.flex",
        "meta": { "name": "RequiredCell" },
        "position": { "basis": "100px", "shrink": 0 },
        "props": {
          "alignItems": "center",
          "justify": "center",
          "style": { "gap": "6px" }
        },
        "children": [
          {
            "type": "ia.input.checkbox",
            "meta": { "name": "RequiredCheckbox" },
            "events": {
              "component": {
                "onActionPerformed": {
                  "type": "script",
                  "scope": "G",
                  "config": {
                    "script": "\tsystem.perspective.sendMessage(\"fieldRowRequiredChanged\", payload={\"rowIndex\": self.view.params.row.rowIndex, \"isRequired\": self.props.selected}, scope=\"page\")"
                  }
                }
              }
            },
            "propConfig": {
              "props.selected": {
                "binding": {
                  "type": "property",
                  "config": { "bidirectional": true, "path": "view.params.row.isRequired" }
                }
              }
            },
            "props": { "text": "" }
          },
          {
            "type": "ia.display.label",
            "meta": { "name": "Label" },
            "propConfig": {
              "props.text": {
                "binding": {
                  "type": "expr",
                  "config": { "expression": "if({view.params.row.isRequired}, 'Required', 'Optional')" }
                }
              }
            },
            "props": {
              "style": {
                "color": "var(--mpp-text-muted)",
                "fontSize": "10px"
              }
            }
          }
        ]
      },
      {
        "type": "ia.input.button",
        "meta": { "name": "RemoveBtn" },
        "position": { "basis": "36px", "shrink": 0 },
        "events": {
          "component": {
            "onActionPerformed": {
              "type": "script",
              "scope": "G",
              "config": {
                "script": "\tsystem.perspective.sendMessage(\"fieldRowRemove\", payload={\"rowIndex\": self.view.params.row.rowIndex}, scope=\"page\")"
              }
            }
          }
        },
        "props": { "text": "×", "style": { "classes": "btn btn-sm btn-danger" } }
      }
    ]
  }
}
