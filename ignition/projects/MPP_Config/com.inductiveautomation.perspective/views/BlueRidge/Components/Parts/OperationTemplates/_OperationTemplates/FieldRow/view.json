{
  "custom": {},
  "params": {
    "field": {}
  },
  "propConfig": {
    "params.field": { "paramDirection": "input" }
  },
  "props": {
    "defaultSize": { "height": 44, "width": 800 }
  },
  "root": {
    "type": "ia.container.flex",
    "meta": { "name": "root" },
    "props": {
      "direction": "row",
      "alignItems": "center",
      "style": {
        "borderBottom": "1px solid var(--mpp-border-subtle)",
        "padding": "8px 14px",
        "overflow": "hidden",
        "gap": "8px"
      }
    },
    "children": [
      {
        "type": "ia.display.label",
        "meta": { "name": "FieldCode" },
        "position": { "basis": "160px", "shrink": 0 },
        "propConfig": {
          "props.text": {
            "binding": {
              "type": "property",
              "config": { "path": "view.params.field.Code" }
            }
          }
        },
        "props": {
          "style": {
            "fontFamily": "var(--mpp-font-mono)",
            "fontSize": "12px",
            "fontWeight": "600"
          }
        }
      },
      {
        "type": "ia.display.label",
        "meta": { "name": "FieldName" },
        "position": { "basis": "0", "grow": 1 },
        "propConfig": {
          "props.text": {
            "binding": {
              "type": "property",
              "config": { "path": "view.params.field.Name" }
            }
          }
        },
        "props": {
          "style": {
            "color": "var(--mpp-text-muted)",
            "fontSize": "12px"
          }
        }
      },
      {
        "type": "ia.container.flex",
        "meta": { "name": "RequiredCell" },
        "position": { "basis": "100px", "shrink": 0 },
        "props": {
          "alignItems": "center",
          "justify": "center",
          "style": { "gap": "6px" }
        },
        "children": [
          {
            "type": "ia.input.checkbox",
            "meta": { "name": "RequiredCheckbox" },
            "events": {
              "component": {
                "onActionPerformed": {
                  "type": "script",
                  "scope": "G",
                  "config": {
                    "script": "\tfield = self.view.params.field or {}\n\tjunctionId = field.get('Id')\n\tif junctionId is None:\n\t\treturn\n\t# event.value carries the NEW selected state in Perspective onActionPerformed.\n\tnewValue = bool(event.value) if 'value' in dir(event) else (not bool(field.get('IsRequired')))\n\tsystem.perspective.sendMessage('templateFieldRequiredToggled', payload={'junctionId': junctionId, 'isRequired': newValue}, scope='page')"
                  }
                }
              }
            },
            "propConfig": {
              "props.selected": {
                "binding": {
                  "type": "property",
                  "config": { "path": "view.params.field.IsRequired" }
                }
              }
            },
            "props": { "text": "" }
          },
          {
            "type": "ia.display.label",
            "meta": { "name": "Label" },
            "propConfig": {
              "props.text": {
                "binding": {
                  "type": "expr",
                  "config": { "expression": "if({view.params.field.IsRequired}, 'Required', 'Optional')" }
                }
              }
            },
            "props": {
              "style": {
                "color": "var(--mpp-text-muted)",
                "fontSize": "10px"
              }
            }
          }
        ]
      },
      {
        "type": "ia.input.button",
        "meta": { "name": "BtnRemove" },
        "position": { "basis": "36px", "shrink": 0 },
        "events": {
          "component": {
            "onActionPerformed": {
              "type": "script",
              "scope": "G",
              "config": {
                "script": "\tfield = self.view.params.field or {}\n\tsystem.perspective.sendMessage('templateFieldRemoveRequest', payload={'junctionId': field.get('Id'), 'name': field.get('Name')}, scope='page')"
              }
            }
          }
        },
        "props": { "text": "✕", "style": { "classes": "btn btn-sm btn-danger" } }
      }
    ]
  }
}
