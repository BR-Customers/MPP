{
  "custom": {
    "data": []
  },
  "params": {
    "value": 0
  },
  "propConfig": {
    "params.value": {
      "paramDirection": "input"
    },
    "custom.data": {
      "binding": {
        "type": "expr",
        "config": {
          "expression": "runScript(\"BlueRidge.Quality.QualitySpec.listForItem\", 0, {view.params.value})"
        }
      }
    }
  },
  "props": {
    "defaultSize": {
      "width": 800,
      "height": 240
    }
  },
  "root": {
    "type": "ia.container.flex",
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "gap": "10px",
        "height": "100%"
      }
    },
    "children": [
      {
        "type": "ia.display.label",
        "meta": {
          "name": "PanelHeader"
        },
        "position": {
          "basis": "auto"
        },
        "props": {
          "text": "Linked Quality Specs",
          "style": {
            "fontSize": "13px",
            "fontWeight": "600"
          }
        }
      },
      {
        "type": "ia.container.flex",
        "meta": {
          "name": "Panel"
        },
        "position": {
          "grow": 1
        },
        "props": {
          "direction": "column",
          "style": {
            "classes": "detail-panel",
            "overflow": "hidden"
          }
        },
        "children": [
          {
            "type": "ia.display.table",
            "meta": {
              "name": "SpecsTable"
            },
            "position": {
              "basis": "auto"
            },
            "propConfig": {
              "props.data": {
                "binding": {
                  "type": "property",
                  "config": {
                    "path": "view.custom.data"
                  }
                }
              }
            },
            "props": {
              "columns": [
                {
                  "field": "specName",
                  "header": "Spec Name"
                },
                {
                  "field": "activeVersion",
                  "header": "Active Version",
                  "width": 120
                },
                {
                  "field": "statusLabel",
                  "header": "Status",
                  "width": 100
                }
              ],
              "rows": {
                "height": 36
              },
              "style": {
                "classes": "data-table"
              }
            }
          }
        ]
      },
      {
        "type": "ia.input.button",
        "meta": {
          "name": "GoToSpecButton"
        },
        "position": {
          "basis": "auto"
        },
        "props": {
          "text": "Go to spec →",
          "style": {
            "alignSelf": "flex-end"
          }
        },
        "events": {
          "component": {
            "onActionPerformed": {
              "config": {
                "script": "\tsel = self.getSibling(\"SpecsTable\").props.selection.selectedRow\n\tif sel is None or sel < 0:\n\t\tBlueRidge.Common.Notify.toast(\"Select a spec\", \"Pick a row in the table first.\", \"info\")\n\t\treturn\n\trows = self.getSibling(\"SpecsTable\").props.data\n\tif sel >= len(rows):\n\t\treturn\n\tspecId = rows[sel][\"id\"]\n\tsystem.perspective.setSessionProps({\"custom.qsIncomingSpecId\": specId})\n\tsystem.perspective.navigate(page=\"/quality-specs\")"
              },
              "scope": "G",
              "type": "script"
            }
          }
        }
      }
    ]
  }
}
