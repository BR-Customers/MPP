{
  "custom": {},
  "params": {
    "createdAt": "",
    "createdBy": "",
    "effectiveFrom": "",
    "state": "",
    "version": ""
  },
  "propConfig": {
    "params.createdAt": {
      "paramDirection": "input"
    },
    "params.createdBy": {
      "paramDirection": "input"
    },
    "params.effectiveFrom": {
      "paramDirection": "input"
    },
    "params.state": {
      "paramDirection": "input"
    },
    "params.version": {
      "paramDirection": "input"
    }
  },
  "props": {
    "defaultSize": {
      "height": 36,
      "width": 600
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "ColVersion"
        },
        "position": {
          "basis": "80px",
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.version"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "fontSize": "12px",
            "fontWeight": "600"
          }
        },
        "type": "ia.display.label"
      },
      {
        "children": [
          {
            "meta": {
              "name": "StateBadge"
            },
            "position": {
              "shrink": 0
            },
            "propConfig": {
              "props.style.classes": {
                "binding": {
                  "config": {
                    "expression": "if({view.params.state} = \"Published\", \"badge badge-published\", if({view.params.state} = \"Draft\", \"badge badge-warn\", if({view.params.state} = \"Deprecated\", \"badge badge-muted\", \"badge badge-purple\")))"
                  },
                  "type": "expr"
                }
              },
              "props.text": {
                "binding": {
                  "config": {
                    "path": "view.params.state"
                  },
                  "type": "property"
                }
              }
            },
            "props": {
              "style": {
                "fontSize": "10px",
                "padding": "1px 5px"
              }
            },
            "type": "ia.display.label"
          }
        ],
        "meta": {
          "name": "ColState"
        },
        "position": {
          "basis": "120px",
          "shrink": 0
        },
        "props": {
          "alignItems": "center",
          "type": "ia.container.flex"
        },
        "type": "ia.container.flex"
      },
      {
        "meta": {
          "name": "ColEffectiveFrom"
        },
        "position": {
          "basis": "160px",
          "grow": 1
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.effectiveFrom"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "color": "var(--mpp-text-secondary)",
            "fontSize": "12px",
            "overflow": "hidden",
            "textOverflow": "ellipsis",
            "whiteSpace": "nowrap"
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "ColCreatedBy"
        },
        "position": {
          "basis": "0",
          "grow": 1
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.createdBy"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "color": "var(--mpp-text-secondary)",
            "fontSize": "12px",
            "overflow": "hidden",
            "textOverflow": "ellipsis",
            "whiteSpace": "nowrap"
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "ColCreatedAt"
        },
        "position": {
          "basis": "160px",
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.createdAt"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "color": "var(--mpp-text-tertiary)",
            "fontSize": "11px",
            "overflow": "hidden",
            "textOverflow": "ellipsis",
            "whiteSpace": "nowrap"
          }
        },
        "type": "ia.display.label"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "alignItems": "center",
      "style": {
        "borderBottom": "1px solid var(--mpp-border-subtle)",
        "gap": "6px",
        "padding": "6px 10px"
      }
    },
    "type": "ia.container.flex"
  }
}
