{
  "custom": {},
  "params": {
    "deprecated": false,
    "name": "",
    "selectedSpecId": 0,
    "specId": 0,
    "state": "",
    "sub": ""
  },
  "propConfig": {
    "params.deprecated": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.name": {
      "paramDirection": "input"
    },
    "params.selectedSpecId": {
      "paramDirection": "input"
    },
    "params.specId": {
      "paramDirection": "input"
    },
    "params.state": {
      "paramDirection": "input"
    },
    "params.sub": {
      "paramDirection": "input"
    }
  },
  "props": {
    "defaultSize": {
      "height": 46,
      "width": 280
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "meta": {
              "name": "LabelName"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "path": "view.params.name"
                  },
                  "type": "property"
                }
              }
            },
            "props": {
              "style": {
                "fontSize": "12px",
                "fontWeight": "600",
                "overflow": "hidden",
                "textOverflow": "ellipsis",
                "whiteSpace": "nowrap"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "LabelSub"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "path": "view.params.sub"
                  },
                  "type": "property"
                }
              }
            },
            "props": {
              "style": {
                "color": "var(--mpp-text-tertiary)",
                "fontSize": "11px",
                "overflow": "hidden",
                "textOverflow": "ellipsis",
                "whiteSpace": "nowrap"
              }
            },
            "type": "ia.display.label"
          }
        ],
        "meta": {
          "name": "RowText"
        },
        "position": {
          "basis": "0",
          "grow": 1
        },
        "props": {
          "direction": "column",
          "style": {
            "gap": "1px",
            "overflow": "hidden"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "meta": {
          "name": "StateBadge"
        },
        "position": {
          "shrink": 0
        },
        "propConfig": {
          "props.style.classes": {
            "binding": {
              "config": {
                "expression": "if({view.params.state} \u003d \"Active\", \"badge badge-published\", if({view.params.state} \u003d \"Draft\", \"badge badge-warn\", \"badge badge-purple\"))"
              },
              "type": "expr"
            }
          },
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.state"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "fontSize": "10px",
            "padding": "1px 5px"
          }
        },
        "type": "ia.display.label"
      }
    ],
    "events": {
      "dom": {
        "onClick": {
          "config": {
            "script": "\tsystem.perspective.sendMessage(\"qsSpecRowClicked\", payload\u003d{\"specId\": self.view.params.specId}, scope\u003d\"page\")"
          },
          "scope": "G",
          "type": "script"
        }
      }
    },
    "meta": {
      "name": "root"
    },
    "propConfig": {
      "props.style.classes": {
        "binding": {
          "config": {
            "expression": "if({view.params.specId} \u003d {view.params.selectedSpecId}, \u0027tree-item tree-item-selected\u0027, \u0027tree-item\u0027)"
          },
          "type": "expr"
        }
      },
      "props.style.opacity": {
        "binding": {
          "config": {
            "expression": "if({view.params.deprecated}, 0.55, 1)"
          },
          "type": "expr"
        }
      }
    },
    "props": {
      "alignItems": "center",
      "justify": "space-between",
      "style": {
        "borderBottom": "1px solid var(--mpp-border-subtle)",
        "cursor": "pointer",
        "gap": "8px",
        "padding": "6px 10px"
      }
    },
    "type": "ia.container.flex"
  }
}