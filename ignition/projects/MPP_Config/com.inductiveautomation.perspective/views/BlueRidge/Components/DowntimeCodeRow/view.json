{
  "custom": {},
  "params": {
    "id": null,
    "code": "",
    "description": "",
    "area": "",
    "type": "",
    "excused": false,
    "deprecated": false,
    "selected": false
  },
  "propConfig": {
    "params.id":          { "paramDirection": "input" },
    "params.code":        { "paramDirection": "input" },
    "params.description": { "paramDirection": "input" },
    "params.area":        { "paramDirection": "input" },
    "params.type":        { "paramDirection": "input" },
    "params.excused":     { "paramDirection": "input" },
    "params.deprecated":  { "paramDirection": "input" },
    "params.selected":    { "paramDirection": "input" }
  },
  "props": {
    "defaultSize": { "width": 800, "height": 44 }
  },
  "root": {
    "type": "ia.container.flex",
    "meta": { "name": "root" },
    "propConfig": {
      "props.style.background": {
        "binding": {
          "type": "expr",
          "config": { "expression": "if({view.params.selected}, 'var(--mpp-accent-20)', 'transparent')" }
        }
      },
      "props.style.color": {
        "binding": {
          "type": "expr",
          "config": { "expression": "if({view.params.selected}, 'var(--mpp-accent-90)', 'var(--mpp-text-primary)')" }
        }
      },
      "props.style.opacity": {
        "binding": {
          "type": "expr",
          "config": { "expression": "if({view.params.deprecated}, 0.55, 1)" }
        }
      }
    },
    "props": {
      "direction": "row",
      "alignItems": "center",
      "style": {
        "padding": "8px 12px",
        "borderBottom": "1px solid var(--mpp-border-subtle)"
      }
    },
    "children": [
      {
        "type": "ia.display.label",
        "meta": { "name": "Code" },
        "position": { "basis": "100px", "shrink": 0 },
        "propConfig": {
          "props.text": { "binding": { "type": "property", "config": { "path": "view.params.code" } } }
        },
        "props": {}
      },
      {
        "type": "ia.display.label",
        "meta": { "name": "Description" },
        "position": { "grow": 1, "basis": "0" },
        "propConfig": {
          "props.text": { "binding": { "type": "property", "config": { "path": "view.params.description" } } }
        },
        "props": {}
      },
      {
        "type": "ia.display.label",
        "meta": { "name": "Area" },
        "position": { "basis": "130px", "shrink": 0 },
        "propConfig": {
          "props.text": { "binding": { "type": "property", "config": { "path": "view.params.area" } } }
        },
        "props": {}
      },
      {
        "type": "ia.display.label",
        "meta": { "name": "Type" },
        "position": { "basis": "130px", "shrink": 0 },
        "propConfig": {
          "props.text": { "binding": { "type": "property", "config": { "path": "view.params.type" } } }
        },
        "props": {}
      },
      {
        "type": "ia.display.icon",
        "meta": { "name": "Excused" },
        "position": { "basis": "80px", "shrink": 0 },
        "propConfig": {
          "props.path": {
            "binding": {
              "type": "expr",
              "config": { "expression": "if({view.params.excused}, 'material/check_box', 'material/check_box_outline_blank')" }
            }
          }
        },
        "props": {
          "path": "material/check_box_outline_blank",
          "style": { "width": "20px", "height": "20px", "color": "var(--mpp-text-secondary)" }
        }
      },
      {
        "type": "ia.input.button",
        "meta": { "name": "EditButton" },
        "position": { "basis": "80px", "shrink": 0 },
        "propConfig": {
          "position.display": {
            "binding": {
              "type": "expr",
              "config": { "expression": "!{view.params.deprecated}" }
            }
          }
        },
        "props": { "text": "Edit", "style": { "classes": "btn btn-sm" } },
        "events": {
          "component": {
            "onActionPerformed": {
              "type": "script",
              "scope": "G",
              "config": {
                "script": "\tsystem.perspective.openPopup(id=\"mpp-downtime-code-editor\", view=\"BlueRidge/Components/Popups/DowntimeCodeEditor\", modal=True, showCloseIcon=False, params={\"mode\": \"update\", \"editId\": self.view.params.id})"
              }
            }
          }
        }
      }
    ]
  }
}
