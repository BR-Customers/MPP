{
  "custom": {},
  "params": {
    "dataType": "",
    "defaultValue": "",
    "definitionId": null,
    "index": 0,
    "name": "",
    "required": false,
    "totalRows": 1,
    "uom": "",
    "value": ""
  },
  "propConfig": {
    "params.dataType": {
      "paramDirection": "input"
    },
    "params.defaultValue": {
      "paramDirection": "input"
    },
    "params.definitionId": {
      "paramDirection": "input"
    },
    "params.index": {
      "paramDirection": "input"
    },
    "params.name": {
      "paramDirection": "input"
    },
    "params.required": {
      "paramDirection": "input"
    },
    "params.totalRows": {
      "paramDirection": "input"
    },
    "params.uom": {
      "paramDirection": "input"
    },
    "params.value": {
      "paramDirection": "input"
    }
  },
  "props": {
    "defaultSize": {
      "height": 48
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "AttrName"
        },
        "position": {
          "basis": "0",
          "grow": 1
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.name"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "fontSize": "12px"
          }
        },
        "type": "ia.display.label"
      },
      {
        "children": [
          {
            "events": {
              "dom": {
                "onBlur": {
                  "config": {
                    "script": "\tsystem.perspective.sendMessage(\"locAttrValueUpdate\", payload\u003d{\"index\": self.view.params.index, \"value\": self.view.params.value}, scope\u003d\"page\")"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "Value"
            },
            "position": {
              "basis": "0",
              "grow": 1
            },
            "propConfig": {
              "position.display": {
                "binding": {
                  "config": {
                    "expression": "{view.params.dataType} !\u003d \"BIT\""
                  },
                  "type": "expr"
                }
              },
              "props.placeholder": {
                "binding": {
                  "config": {
                    "path": "view.params.defaultValue"
                  },
                  "type": "property"
                }
              },
              "props.text": {
                "binding": {
                  "config": {
                    "bidirectional": true,
                    "path": "view.params.value"
                  },
                  "type": "property"
                }
              }
            },
            "props": {
              "style": {
                "boxSizing": "border-box",
                "classes": "search-input",
                "height": "30px"
              }
            },
            "type": "ia.input.text-field"
          },
          {
            "events": {
              "component": {
                "onActionPerformed": {
                  "config": {
                    "script": "\t# Translate the checkbox toggle into the \u00271\u0027/\u00270\u0027 string the proc stores,\n\t# then push back through the page-scoped reply so editDraft.attributes\n\t# stays the single source of truth.\n\tnewVal \u003d \"1\" if self.props.selected else \"0\"\n\tsystem.perspective.sendMessage(\"locAttrValueUpdate\", payload\u003d{\"index\": self.view.params.index, \"value\": newVal}, scope\u003d\"page\")"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "ValueBit"
            },
            "position": {
              "shrink": 0
            },
            "propConfig": {
              "position.display": {
                "binding": {
                  "config": {
                    "expression": "{view.params.dataType} \u003d \"BIT\""
                  },
                  "type": "expr"
                }
              },
              "props.selected": {
                "binding": {
                  "config": {
                    "expression": "{view.params.value} \u003d \"1\" || {view.params.value} \u003d \"true\" || {view.params.value} \u003d \"True\""
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "text": ""
            },
            "type": "ia.input.checkbox"
          }
        ],
        "meta": {
          "name": "ValueCell"
        },
        "position": {
          "basis": "0",
          "grow": 2
        },
        "props": {
          "alignItems": "center",
          "style": {
            "gap": "8px"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "meta": {
          "name": "DataType"
        },
        "position": {
          "basis": "80px",
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.dataType"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "color": "var(--mpp-text-tertiary)",
            "fontSize": "10px",
            "whiteSpace": "nowrap"
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "Uom"
        },
        "position": {
          "basis": "70px",
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.uom"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "color": "var(--mpp-text-secondary)",
            "fontSize": "11px"
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "Required"
        },
        "position": {
          "basis": "60px",
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "expression": "if({view.params.required}, \"★\", \"\")"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "style": {
            "color": "var(--mpp-state-warn-fg)",
            "fontSize": "14px",
            "textAlign": "center"
          }
        },
        "type": "ia.display.label"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "alignItems": "center",
      "style": {
        "borderBottom": "1px solid var(--mpp-border-subtle)",
        "color": "var(--mpp-text-primary)",
        "padding": "6px 12px"
      }
    },
    "type": "ia.container.flex"
  }
}