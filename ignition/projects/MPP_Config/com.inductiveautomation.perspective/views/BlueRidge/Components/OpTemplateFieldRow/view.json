{
  "custom": {},
  "params": {
    "fieldName": "",
    "required": true,
    "isFirst": false,
    "isLast": false
  },
  "propConfig": {
    "params.fieldName": { "paramDirection": "input" },
    "params.required":  { "paramDirection": "input" },
    "params.isFirst":   { "paramDirection": "input" },
    "params.isLast":    { "paramDirection": "input" }
  },
  "props": {
    "defaultSize": { "width": 600, "height": 44 }
  },
  "root": {
    "type": "ia.container.flex",
    "meta": { "name": "root" },
    "props": {
      "direction": "row",
      "alignItems": "center",
      "style": {
        "padding": "8px 12px",
        "borderBottom": "1px solid var(--mpp-border-subtle)",
        "color": "var(--mpp-text-primary)",
        "overflow": "hidden"
      }
    },
    "children": [
      {
        "type": "ia.container.flex",
        "meta": { "name": "Arrows" },
        "position": { "basis": "46px", "shrink": 0 },
        "props": { "direction": "column", "alignItems": "center", "style": { "classes": "arrows", "gap": "1px" } },
        "children": [
          {
            "type": "ia.display.icon",
            "meta": { "name": "Up" },
            "position": { "basis": "auto" },
            "propConfig": {
              "props.style.classes": {
                "binding": { "type": "expr",
                  "config": { "expression": "if({view.params.isFirst}, 'arrow-btn arrow-btn-disabled', 'arrow-btn')" } }
              }
            },
            "props": { "path": "material/arrow_drop_up" }
          },
          {
            "type": "ia.display.icon",
            "meta": { "name": "Down" },
            "position": { "basis": "auto" },
            "propConfig": {
              "props.style.classes": {
                "binding": { "type": "expr",
                  "config": { "expression": "if({view.params.isLast}, 'arrow-btn arrow-btn-disabled', 'arrow-btn')" } }
              }
            },
            "props": { "path": "material/arrow_drop_down" }
          }
        ]
      },
      {
        "type": "ia.display.label",
        "meta": { "name": "FieldName" },
        "position": { "grow": 1, "basis": "0" },
        "propConfig": {
          "props.text": { "binding": { "type": "property", "config": { "path": "view.params.fieldName" } } }
        },
        "props": { "style": { "fontFamily": "'SF Mono','Consolas',monospace", "fontSize": "13px" } }
      },
      {
        "type": "ia.input.checkbox",
        "meta": { "name": "Required" },
        "position": { "basis": "90px", "shrink": 0 },
        "propConfig": {
          "props.selected": { "binding": { "type": "property", "config": { "path": "view.params.required" } } }
        },
        "props": { "text": "", "enabled": false }
      },
      {
        "type": "ia.display.icon",
        "meta": { "name": "Remove" },
        "position": { "basis": "36px", "shrink": 0 },
        "props": {
          "path": "material/close",
          "style": { "color": "var(--mpp-state-bad-fg)", "width": "16px", "height": "16px", "cursor": "pointer" }
        }
      }
    ]
  }
}
