{
  "custom": {},
  "params": {
    "category": "",
    "title": ""
  },
  "propConfig": {
    "params.category": {
      "paramDirection": "input"
    },
    "params.title": {
      "paramDirection": "input"
    }
  },
  "props": {
    "defaultSize": {
      "height": 60,
      "width": 1200
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "children": [
              {
                "meta": {
                  "name": "BreadcrumbCategory"
                },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "config": {
                        "path": "view.params.category"
                      },
                      "type": "property"
                    }
                  }
                },
                "props": {
                  "style": {
                    "classes": "breadcrumb"
                  }
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "BreadcrumbSep"
                },
                "props": {
                  "style": {
                    "classes": "breadcrumb crumb-sep"
                  },
                  "text": "›"
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "BreadcrumbActive"
                },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "config": {
                        "path": "view.params.title"
                      },
                      "type": "property"
                    }
                  }
                },
                "props": {
                  "style": {
                    "classes": "crumb-active"
                  }
                },
                "type": "ia.display.label"
              }
            ],
            "meta": {
              "name": "Breadcrumb"
            },
            "props": {
              "alignItems": "center",
              "style": {
                "classes": "breadcrumb"
              }
            },
            "type": "ia.container.flex"
          },
          {
            "meta": {
              "name": "Title"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "path": "view.params.title"
                  },
                  "type": "property"
                }
              }
            },
            "props": {
              "style": {
                "classes": "title-row-h1"
              }
            },
            "type": "ia.display.label"
          }
        ],
        "meta": {
          "name": "TitleColumn"
        },
        "props": {
          "direction": "column",
          "style": {
            "gap": "2px"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "meta": {
          "name": "TitleRowSpacer"
        },
        "position": {
          "grow": 1
        },
        "props": {
          "style": {
            "classes": "title-row-spacer"
          }
        },
        "type": "ia.display.label"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "alignItems": "center",
      "style": {
        "background": "var(--mpp-surface-raised)",
        "borderBottom": "1px solid var(--mpp-border-subtle)",
        "classes": "title-row",
        "paddingBottom": "8px"
      }
    },
    "type": "ia.container.flex"
  }
}