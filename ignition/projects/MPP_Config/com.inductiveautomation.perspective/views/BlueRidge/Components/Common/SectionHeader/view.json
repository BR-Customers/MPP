{
  "custom": {},
  "params": {
    "title": "Section Title",
    "subtitle": ""
  },
  "propConfig": {},
  "props": {
    "defaultSize": { "height": 52, "width": 400 }
  },
  "root": {
    "children": [
      {
        "meta": { "name": "Title" },
        "position": {},
        "propConfig": {
          "props.text": {
            "binding": { "config": { "paramName": "title" }, "type": "param" }
          }
        },
        "props": {
          "text": "Section Title",
          "style": {
            "color": "#F0F3F8",
            "fontSize": "18px",
            "fontWeight": "600",
            "lineHeight": "1.2"
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": { "name": "Subtitle" },
        "position": {},
        "propConfig": {
          "props.text": {
            "binding": { "config": { "paramName": "subtitle" }, "type": "param" }
          },
          "props.visible": {
            "binding": {
              "config": { "expression": "{view.params.subtitle} != ''" },
              "type": "expr"
            }
          }
        },
        "props": {
          "text": "",
          "style": {
            "color": "#697A98",
            "fontSize": "12px",
            "fontWeight": "400"
          }
        },
        "type": "ia.display.label"
      }
    ],
    "meta": { "name": "root" },
    "propConfig": {},
    "props": {
      "direction": "column",
      "style": {
        "borderBottom": "1px solid #2C3A55",
        "gap": "2px",
        "paddingBottom": "12px"
      }
    },
    "type": "ia.container.flex"
  }
}
