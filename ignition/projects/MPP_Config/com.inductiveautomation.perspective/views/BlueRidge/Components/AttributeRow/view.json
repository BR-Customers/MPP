{
  "custom": {},
  "params": {
    "dataType": "",
    "index": 0,
    "name": "",
    "required": false,
    "totalRows": 1,
    "uom": "",
    "value": ""
  },
  "propConfig": {
    "params.dataType": {
      "paramDirection": "input"
    },
    "params.index": {
      "paramDirection": "input"
    },
    "params.name": {
      "paramDirection": "input"
    },
    "params.required": {
      "paramDirection": "input"
    },
    "params.totalRows": {
      "paramDirection": "input"
    },
    "params.uom": {
      "paramDirection": "input"
    },
    "params.value": {
      "paramDirection": "input"
    }
  },
  "props": {
    "defaultSize": {
      "height": 56
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "events": {
              "dom": {
                "onClick": {
                  "config": {
                    "script": "\tif self.view.params.index \u003e 0:\n\t\tsystem.perspective.sendMessage(\u0027attributeMove\u0027, payload\u003d{\u0027index\u0027: self.view.params.index, \u0027direction\u0027: \u0027up\u0027}, scope\u003d\u0027view\u0027)"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "Up",
              "tooltip": {
                "text": "Move Up"
              }
            },
            "propConfig": {
              "props.style.classes": {
                "binding": {
                  "config": {
                    "expression": "if({view.params.index} \u003d 0, \u0027arrow-btn arrow-btn-disabled\u0027, \u0027arrow-btn\u0027)"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "path": "material/arrow_drop_up"
            },
            "type": "ia.display.icon"
          },
          {
            "events": {
              "dom": {
                "onClick": {
                  "config": {
                    "script": "\tif self.view.params.index \u003c self.view.params.totalRows - 1:\n\t\tsystem.perspective.sendMessage(\u0027attributeMove\u0027, payload\u003d{\u0027index\u0027: self.view.params.index, \u0027direction\u0027: \u0027down\u0027}, scope\u003d\u0027view\u0027)"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "Down",
              "tooltip": {
                "text": "Move Down"
              }
            },
            "propConfig": {
              "props.style.classes": {
                "binding": {
                  "config": {
                    "expression": "if({view.params.index} \u003d {view.params.totalRows} - 1, \u0027arrow-btn arrow-btn-disabled\u0027, \u0027arrow-btn\u0027)"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "path": "material/arrow_drop_down"
            },
            "type": "ia.display.icon"
          }
        ],
        "meta": {
          "name": "Arrows"
        },
        "position": {
          "basis": "46px",
          "shrink": 0
        },
        "props": {
          "alignItems": "center",
          "direction": "column",
          "style": {
            "classes": "arrows",
            "gap": "1px"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "meta": {
          "name": "AttrName"
        },
        "position": {
          "basis": "0",
          "grow": 1
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.name"
              },
              "type": "property"
            }
          }
        },
        "type": "ia.display.label"
      },
      {
        "children": [
          {
            "meta": {
              "name": "Value"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "bidirectional": true,
                    "path": "view.params.value"
                  },
                  "type": "property"
                }
              }
            },
            "props": {
              "style": {
                "boxSizing": "border-box",
                "classes": "search-input",
                "height": "32px",
                "width": "70px"
              }
            },
            "type": "ia.input.text-field"
          },
          {
            "meta": {
              "name": "DataType"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "path": "view.params.dataType"
                  },
                  "type": "property"
                }
              }
            },
            "props": {
              "style": {
                "color": "var(--mpp-text-tertiary)",
                "fontSize": "9px",
                "whiteSpace": "nowrap"
              }
            },
            "type": "ia.display.label"
          }
        ],
        "meta": {
          "name": "ValueCell"
        },
        "position": {
          "basis": "0",
          "grow": 1
        },
        "props": {
          "alignItems": "center",
          "style": {
            "gap": "6px"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "meta": {
          "name": "Uom"
        },
        "position": {
          "basis": "70px",
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.uom"
              },
              "type": "property"
            }
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "Required"
        },
        "position": {
          "basis": "60px",
          "shrink": 0
        },
        "propConfig": {
          "props.selected": {
            "binding": {
              "config": {
                "bidirectional": true,
                "path": "view.params.required"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "text": ""
        },
        "type": "ia.input.checkbox"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "alignItems": "center",
      "style": {
        "borderBottom": "1px solid var(--mpp-border-subtle)",
        "color": "var(--mpp-text-primary)",
        "padding": "8px 12px"
      }
    },
    "type": "ia.container.flex"
  }
}