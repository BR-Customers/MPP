{
  "custom": {},
  "params": {
    "index": 0,
    "totalRows": 1,
    "name": "",
    "value": "",
    "dataType": "",
    "uom": "",
    "required": false
  },
  "propConfig": {
    "params.index":     { "paramDirection": "input" },
    "params.totalRows": { "paramDirection": "input" },
    "params.name":      { "paramDirection": "input" },
    "params.value":     { "paramDirection": "input" },
    "params.dataType":  { "paramDirection": "input" },
    "params.uom":       { "paramDirection": "input" },
    "params.required":  { "paramDirection": "input" }
  },
  "props": {
    "defaultSize": { "width": 800, "height": 44 }
  },
  "root": {
    "type": "ia.container.flex",
    "meta": { "name": "root" },
    "props": {
      "direction": "row",
      "alignItems": "center",
      "style": {
        "padding": "8px 12px",
        "borderBottom": "1px solid var(--mpp-border-subtle)",
        "color": "var(--mpp-text-primary)"
      }
    },
    "children": [
      {
        "type": "ia.container.flex",
        "meta": { "name": "Arrows" },
        "position": { "basis": "46px", "shrink": 0 },
        "props": { "direction": "column", "alignItems": "center", "style": { "classes": "arrows", "gap": "1px" } },
        "children": [
          {
            "type": "ia.display.icon",
            "meta": { "name": "Up", "tooltip": { "text": "Move Up" } },
            "position": { "basis": "auto" },
            "events": {
              "dom": {
                "onClick": {
                  "config": { "script": "\tif self.view.params.index > 0:\n\t\tsystem.perspective.sendMessage('attributeMove', payload={'index': self.view.params.index, 'direction': 'up'}, scope='view')" },
                  "scope": "C",
                  "type": "script"
                }
              }
            },
            "propConfig": {
              "props.style.classes": {
                "binding": {
                  "type": "expr",
                  "config": { "expression": "if({view.params.index} = 0, 'arrow-btn arrow-btn-disabled', 'arrow-btn')" }
                }
              }
            },
            "props": { "path": "material/arrow_drop_up" }
          },
          {
            "type": "ia.display.icon",
            "meta": { "name": "Down", "tooltip": { "text": "Move Down" } },
            "position": { "basis": "auto" },
            "events": {
              "dom": {
                "onClick": {
                  "config": { "script": "\tif self.view.params.index < self.view.params.totalRows - 1:\n\t\tsystem.perspective.sendMessage('attributeMove', payload={'index': self.view.params.index, 'direction': 'down'}, scope='view')" },
                  "scope": "C",
                  "type": "script"
                }
              }
            },
            "propConfig": {
              "props.style.classes": {
                "binding": {
                  "type": "expr",
                  "config": { "expression": "if({view.params.index} = {view.params.totalRows} - 1, 'arrow-btn arrow-btn-disabled', 'arrow-btn')" }
                }
              }
            },
            "props": { "path": "material/arrow_drop_down" }
          }
        ]
      },
      {
        "type": "ia.display.label",
        "meta": { "name": "AttrName" },
        "position": { "grow": 1, "basis": "0" },
        "propConfig": {
          "props.text": { "binding": { "type": "property", "config": { "path": "view.params.name" } } }
        },
        "props": {}
      },
      {
        "type": "ia.container.flex",
        "meta": { "name": "ValueCell" },
        "position": { "grow": 1, "basis": "0" },
        "props": { "direction": "row", "alignItems": "center", "style": { "gap": "6px" } },
        "children": [
          {
            "type": "ia.input.text-field",
            "meta": { "name": "Value" },
            "position": { "basis": "auto" },
            "propConfig": {
              "props.text": { "binding": { "type": "property", "config": { "bidirectional": true, "path": "view.params.value" } } }
            },
            "props": { "style": { "classes": "search-input", "width": "80px" } }
          },
          {
            "type": "ia.display.label",
            "meta": { "name": "DataType" },
            "position": { "basis": "auto" },
            "propConfig": {
              "props.text": { "binding": { "type": "property", "config": { "path": "view.params.dataType" } } }
            },
            "props": { "style": { "fontSize": "9px", "color": "var(--mpp-text-tertiary)", "whiteSpace": "nowrap" } }
          }
        ]
      },
      {
        "type": "ia.display.label",
        "meta": { "name": "Uom" },
        "position": { "basis": "70px", "shrink": 0 },
        "propConfig": {
          "props.text": { "binding": { "type": "property", "config": { "path": "view.params.uom" } } }
        },
        "props": {}
      },
      {
        "type": "ia.input.checkbox",
        "meta": { "name": "Required" },
        "position": { "basis": "60px", "shrink": 0 },
        "propConfig": {
          "props.selected": { "binding": { "type": "property", "config": { "bidirectional": true, "path": "view.params.required" } } }
        },
        "props": { "text": "" }
      }
    ]
  }
}
