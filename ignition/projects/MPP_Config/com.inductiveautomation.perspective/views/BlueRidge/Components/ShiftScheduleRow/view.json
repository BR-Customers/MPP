{
  "custom": {},
  "params": {
    "id": null,
    "name": "",
    "daysLabel": "",
    "startTime": "",
    "endTime": "",
    "effectiveFrom": "",
    "deprecated": false,
    "selected": false
  },
  "propConfig": {
    "params.id": {
      "paramDirection": "input"
    },
    "params.name": {
      "paramDirection": "input"
    },
    "params.daysLabel": {
      "paramDirection": "input"
    },
    "params.startTime": {
      "paramDirection": "input"
    },
    "params.endTime": {
      "paramDirection": "input"
    },
    "params.effectiveFrom": {
      "paramDirection": "input"
    },
    "params.deprecated": {
      "paramDirection": "input"
    },
    "params.selected": {
      "paramDirection": "input"
    }
  },
  "props": {
    "defaultSize": {
      "height": 44
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "Name"
        },
        "position": {
          "basis": "220px",
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.name"
              },
              "type": "property"
            }
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "Days"
        },
        "position": {
          "basis": "0",
          "grow": 1
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.daysLabel"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "color": "var(--mpp-text-secondary)"
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "Start"
        },
        "position": {
          "basis": "90px",
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.startTime"
              },
              "type": "property"
            }
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "End"
        },
        "position": {
          "basis": "90px",
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.endTime"
              },
              "type": "property"
            }
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "EffectiveFrom"
        },
        "position": {
          "basis": "130px",
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.effectiveFrom"
              },
              "type": "property"
            }
          }
        },
        "type": "ia.display.label"
      },
      {
        "events": {
          "component": {
            "onActionPerformed": {
              "config": {
                "script": "\tsystem.perspective.openPopup(id=\"mpp-shift-schedule-editor\", view=\"BlueRidge/Components/Popups/ShiftScheduleEditor\", modal=True, showCloseIcon=False, params={\"mode\": \"update\", \"editId\": self.view.params.id})"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "EditButton"
        },
        "position": {
          "basis": "80px",
          "shrink": 0
        },
        "propConfig": {
          "meta.visible": {
            "binding": {
              "config": {
                "expression": "!{view.params.deprecated}"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "style": {
            "classes": "btn btn-sm"
          },
          "text": "Edit"
        },
        "type": "ia.input.button"
      }
    ],
    "meta": {
      "name": "root"
    },
    "propConfig": {
      "props.style.background": {
        "binding": {
          "config": {
            "expression": "if({view.params.selected}, 'var(--mpp-accent-20)', 'transparent')"
          },
          "type": "expr"
        }
      },
      "props.style.color": {
        "binding": {
          "config": {
            "expression": "if({view.params.selected}, 'var(--mpp-accent-90)', 'var(--mpp-text-primary)')"
          },
          "type": "expr"
        }
      },
      "props.style.opacity": {
        "binding": {
          "config": {
            "expression": "if({view.params.deprecated}, 0.55, 1)"
          },
          "type": "expr"
        }
      }
    },
    "props": {
      "alignItems": "center",
      "style": {
        "borderBottom": "1px solid var(--mpp-border-subtle)",
        "padding": "8px 12px"
      }
    },
    "type": "ia.container.flex"
  }
}
