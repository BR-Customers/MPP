{
  "custom": {},
  "params": {
    "name": "",
    "code": "",
    "versionBadge": "v1",
    "selected": false
  },
  "propConfig": {
    "params.name":         { "paramDirection": "input" },
    "params.code":         { "paramDirection": "input" },
    "params.versionBadge": { "paramDirection": "input" },
    "params.selected":     { "paramDirection": "input" }
  },
  "props": {
    "defaultSize": { "width": 260, "height": 44 }
  },
  "root": {
    "type": "ia.container.flex",
    "meta": { "name": "root" },
    "propConfig": {
      "props.style.classes": {
        "binding": {
          "type": "expr",
          "config": { "expression": "if({view.params.selected}, 'tree-item tree-item-selected', 'tree-item')" }
        }
      }
    },
    "props": {
      "direction": "row",
      "alignItems": "center",
      "justify": "space-between",
      "style": { "paddingLeft": "14px", "gap": "6px" }
    },
    "children": [
      {
        "type": "ia.container.flex",
        "meta": { "name": "NameCol" },
        "position": { "grow": 1, "basis": "0" },
        "props": { "direction": "column", "style": { "gap": "1px", "minWidth": "0" } },
        "children": [
          {
            "type": "ia.display.label",
            "meta": { "name": "Name" },
            "position": { "basis": "auto" },
            "propConfig": {
              "props.text": { "binding": { "type": "property", "config": { "path": "view.params.name" } } }
            },
            "props": { "style": { "fontSize": "13px" } }
          },
          {
            "type": "ia.display.label",
            "meta": { "name": "Code" },
            "position": { "basis": "auto" },
            "propConfig": {
              "props.text": { "binding": { "type": "property", "config": { "path": "view.params.code" } } }
            },
            "props": { "style": { "fontFamily": "'SF Mono','Consolas',monospace", "fontSize": "10px", "color": "var(--mpp-text-tertiary)" } }
          }
        ]
      },
      {
        "type": "ia.display.label",
        "meta": { "name": "VersionBadge" },
        "position": { "basis": "auto" },
        "propConfig": {
          "props.text": { "binding": { "type": "property", "config": { "path": "view.params.versionBadge" } } }
        },
        "props": { "style": { "classes": "badge badge-type", "fontSize": "10px", "padding": "1px 5px" } }
      }
    ]
  }
}
