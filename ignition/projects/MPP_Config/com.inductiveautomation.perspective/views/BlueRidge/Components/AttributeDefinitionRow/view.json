{
  "custom": {},
  "params": {
    "index": 0,
    "totalRows": 1,
    "Id": null,
    "AttributeName": "",
    "DataType": "NVARCHAR",
    "IsRequired": false,
    "DefaultValue": "",
    "Uom": "",
    "Description": ""
  },
  "propConfig": {
    "params.index":         { "paramDirection": "input" },
    "params.totalRows":     { "paramDirection": "input" },
    "params.Id":            { "paramDirection": "input" },
    "params.AttributeName": { "paramDirection": "input" },
    "params.DataType":      { "paramDirection": "input" },
    "params.IsRequired":    { "paramDirection": "input" },
    "params.DefaultValue":  { "paramDirection": "input" },
    "params.Uom":           { "paramDirection": "input" },
    "params.Description":   { "paramDirection": "input" }
  },
  "props": {
    "defaultSize": { "width": 1000, "height": 56 }
  },
  "root": {
    "type": "ia.container.flex",
    "meta": { "name": "root" },
    "props": {
      "direction": "row",
      "alignItems": "center",
      "style": {
        "padding": "8px 12px",
        "borderBottom": "1px solid var(--mpp-border-subtle)",
        "color": "var(--mpp-text-primary)",
        "gap": "8px"
      }
    },
    "children": [
      {
        "type": "ia.container.flex",
        "meta": { "name": "Arrows" },
        "position": { "basis": "46px", "shrink": 0 },
        "props": { "direction": "column", "alignItems": "center", "style": { "classes": "arrows", "gap": "1px" } },
        "children": [
          {
            "type": "ia.display.icon",
            "meta": { "name": "Up", "tooltip": { "text": "Move Up" } },
            "events": {
              "dom": {
                "onClick": {
                  "config": { "script": "\tif self.view.params.index > 0:\n\t\tsystem.perspective.sendMessage(\"attrDraftMove\", payload={\"index\": self.view.params.index, \"direction\": \"up\"}, scope=\"page\")" },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "propConfig": {
              "props.style.classes": {
                "binding": {
                  "type": "expr",
                  "config": { "expression": "if({view.params.index} = 0, 'arrow-btn arrow-btn-disabled', 'arrow-btn')" }
                }
              }
            },
            "props": { "path": "material/arrow_drop_up" }
          },
          {
            "type": "ia.display.icon",
            "meta": { "name": "Down", "tooltip": { "text": "Move Down" } },
            "events": {
              "dom": {
                "onClick": {
                  "config": { "script": "\tif self.view.params.index < self.view.params.totalRows - 1:\n\t\tsystem.perspective.sendMessage(\"attrDraftMove\", payload={\"index\": self.view.params.index, \"direction\": \"down\"}, scope=\"page\")" },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "propConfig": {
              "props.style.classes": {
                "binding": {
                  "type": "expr",
                  "config": { "expression": "if({view.params.index} = {view.params.totalRows} - 1, 'arrow-btn arrow-btn-disabled', 'arrow-btn')" }
                }
              }
            },
            "props": { "path": "material/arrow_drop_down" }
          }
        ]
      },
      {
        "type": "ia.input.text-field",
        "meta": { "name": "AttributeName" },
        "position": { "basis": "0", "grow": 1 },
        "propConfig": {
          "props.text": { "binding": { "type": "property", "config": { "bidirectional": true, "path": "view.params.AttributeName" } } }
        },
        "events": {
          "component": {
            "onActionPerformed": {
              "config": { "script": "\tsystem.perspective.sendMessage(\"attrDraftUpdate\", payload={\"index\": self.view.params.index, \"field\": \"AttributeName\", \"value\": self.view.params.AttributeName}, scope=\"page\")" },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "props": { "style": { "classes": "search-input", "minWidth": "100px", "boxSizing": "border-box" } }
      },
      {
        "type": "ia.input.dropdown",
        "meta": { "name": "DataType" },
        "position": { "basis": "110px", "shrink": 0 },
        "propConfig": {
          "props.value": { "binding": { "type": "property", "config": { "bidirectional": true, "path": "view.params.DataType" } } }
        },
        "events": {
          "component": {
            "onActionPerformed": {
              "config": { "script": "\tsystem.perspective.sendMessage(\"attrDraftUpdate\", payload={\"index\": self.view.params.index, \"field\": \"DataType\", \"value\": self.view.params.DataType}, scope=\"page\")" },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "props": {
          "options": [
            { "label": "NVARCHAR", "value": "NVARCHAR" },
            { "label": "INT",      "value": "INT" },
            { "label": "DECIMAL",  "value": "DECIMAL" },
            { "label": "BIT",      "value": "BIT" },
            { "label": "DATE",     "value": "DATE" }
          ],
          "style": { "classes": "search-input", "boxSizing": "border-box" }
        }
      },
      {
        "type": "ia.input.checkbox",
        "meta": { "name": "IsRequired" },
        "position": { "basis": "60px", "shrink": 0 },
        "propConfig": {
          "props.selected": { "binding": { "type": "property", "config": { "bidirectional": true, "path": "view.params.IsRequired" } } }
        },
        "events": {
          "component": {
            "onActionPerformed": {
              "config": { "script": "\tsystem.perspective.sendMessage(\"attrDraftUpdate\", payload={\"index\": self.view.params.index, \"field\": \"IsRequired\", \"value\": self.view.params.IsRequired}, scope=\"page\")" },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "props": { "text": "" }
      },
      {
        "type": "ia.input.text-field",
        "meta": { "name": "DefaultValue" },
        "position": { "basis": "90px", "shrink": 0 },
        "propConfig": {
          "props.text": { "binding": { "type": "property", "config": { "bidirectional": true, "path": "view.params.DefaultValue" } } }
        },
        "events": {
          "component": {
            "onActionPerformed": {
              "config": { "script": "\tsystem.perspective.sendMessage(\"attrDraftUpdate\", payload={\"index\": self.view.params.index, \"field\": \"DefaultValue\", \"value\": self.view.params.DefaultValue}, scope=\"page\")" },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "props": { "style": { "classes": "search-input", "boxSizing": "border-box" }, "placeholder": "—" }
      },
      {
        "type": "ia.input.text-field",
        "meta": { "name": "Uom" },
        "position": { "basis": "70px", "shrink": 0 },
        "propConfig": {
          "props.text": { "binding": { "type": "property", "config": { "bidirectional": true, "path": "view.params.Uom" } } }
        },
        "events": {
          "component": {
            "onActionPerformed": {
              "config": { "script": "\tsystem.perspective.sendMessage(\"attrDraftUpdate\", payload={\"index\": self.view.params.index, \"field\": \"Uom\", \"value\": self.view.params.Uom}, scope=\"page\")" },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "props": { "style": { "classes": "search-input", "boxSizing": "border-box" }, "placeholder": "—" }
      },
      {
        "type": "ia.input.text-field",
        "meta": { "name": "Description" },
        "position": { "basis": "0", "grow": 1.5 },
        "propConfig": {
          "props.text": { "binding": { "type": "property", "config": { "bidirectional": true, "path": "view.params.Description" } } }
        },
        "events": {
          "component": {
            "onActionPerformed": {
              "config": { "script": "\tsystem.perspective.sendMessage(\"attrDraftUpdate\", payload={\"index\": self.view.params.index, \"field\": \"Description\", \"value\": self.view.params.Description}, scope=\"page\")" },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "props": { "style": { "classes": "search-input", "minWidth": "140px", "boxSizing": "border-box" }, "placeholder": "Optional" }
      },
      {
        "type": "ia.input.button",
        "meta": { "name": "Remove", "tooltip": { "text": "Remove this attribute" } },
        "position": { "basis": "70px", "shrink": 0 },
        "events": {
          "component": {
            "onActionPerformed": {
              "config": { "script": "\tsystem.perspective.sendMessage(\"attrDraftRemove\", payload={\"index\": self.view.params.index}, scope=\"page\")" },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "props": { "text": "Remove", "style": { "classes": "btn btn-danger btn-sm" } }
      }
    ]
  }
}
