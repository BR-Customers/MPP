                "onClick": {
                  "config": {
                    "script": "\tif self.view.params.index \u003e 0:\n\t\tsystem.perspective.sendMessage(\"attrDraftMove\", payload\u003d{\"index\": self.view.params.index, \"direction\": \"up\"}, scope\u003d\"page\")"
