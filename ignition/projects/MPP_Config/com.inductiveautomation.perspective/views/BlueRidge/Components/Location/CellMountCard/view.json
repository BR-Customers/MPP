{
  "custom": {
    "mountNotes": "",
    "selectedToolId": null
  },
  "params": {
    "cellLocationId": null
  },
  "propConfig": {
    "custom.context": {
      "binding": {
        "config": {
          "expression": "runScript(\"BlueRidge.Parts.Tool.getCellMountContextOrEmpty\", 0, {view.params.cellLocationId})"
        },
        "type": "expr"
      }
    },
    "custom.mountable": {
      "binding": {
        "config": {
          "expression": "runScript(\"BlueRidge.Parts.Tool.getMountableToolsForCell\", 0, {view.params.cellLocationId})"
        },
        "type": "expr"
      }
    },
    "params.cellLocationId": {
      "onChange": {
        "enabled": true,
        "script": "\tself.rootContainer.refresh()"
      },
      "paramDirection": "input"
    }
  },
  "props": {
    "defaultSize": {
      "height": 150,
      "width": 480
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "meta": {
              "name": "Title"
            },
            "props": {
              "style": {
                "classes": "detail-header-h2"
              },
              "text": "Mounted Tool"
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "Spacer"
            },
            "position": {
              "grow": 1
            },
            "type": "ia.display.label"
          },
          {
            "events": {
              "component": {
                "onActionPerformed": {
                  "config": {
                    "page": "/parts/tools"
                  },
                  "scope": "C",
                  "type": "nav"
                }
              }
            },
            "meta": {
              "name": "BtnToolConfig"
            },
            "props": {
              "style": {
                "classes": "btn btn-sm"
              },
              "text": "Tool Config"
            },
            "type": "ia.input.button"
          }
        ],
        "meta": {
          "name": "Header"
        },
        "props": {
          "alignItems": "center",
          "style": {
            "classes": "detail-header",
            "gap": "12px"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "children": [
              {
                "children": [
                  {
                    "meta": {
                      "name": "ToolLabel"
                    },
                    "propConfig": {
                      "props.text": {
                        "binding": {
                          "config": {
                            "expression": "coalesce({view.custom.context.ToolCode}, \"\") + \" — \" + coalesce({view.custom.context.ToolName}, \"\")"
                          },
                          "type": "expr"
                        }
                      }
                    },
                    "props": {
                      "style": {
                        "color": "var(--mpp-state-good-fg)",
                        "fontSize": "14px",
                        "fontWeight": "600"
                      }
                    },
                    "type": "ia.display.label"
                  },
                  {
                    "meta": {
                      "name": "TypeBadge"
                    },
                    "propConfig": {
                      "props.text": {
                        "binding": {
                          "config": {
                            "path": "view.custom.context.ToolTypeCode"
                          },
                          "type": "property"
                        }
                      }
                    },
                    "props": {
                      "style": {
                        "classes": "badge badge-purple"
                      }
                    },
                    "type": "ia.display.label"
                  }
                ],
                "meta": {
                  "name": "ToolLine"
                },
                "props": {
                  "alignItems": "center",
                  "style": {
                    "gap": "8px"
                  }
                },
                "type": "ia.container.flex"
              },
              {
                "meta": {
                  "name": "AssignedLine"
                },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "config": {
                        "expression": "\"Assigned \" + if(isNull({view.custom.context.AssignedAt}), \"-\", toStr({view.custom.context.AssignedAt})) + \" by \" + if(isNull({view.custom.context.AssignedBy}), \"-\", toStr({view.custom.context.AssignedBy}))"
                      },
                      "type": "expr"
                    }
                  }
                },
                "props": {
                  "style": {
                    "color": "var(--mpp-text-muted)",
                    "fontSize": "11px"
                  }
                },
                "type": "ia.display.label"
              }
            ],
            "meta": {
              "name": "MountTextStack"
            },
            "position": {
              "grow": 1
            },
            "props": {
              "direction": "column",
              "style": {
                "gap": "2px"
              }
            },
            "type": "ia.container.flex"
          },
          {
            "events": {
              "component": {
                "onActionPerformed": {
                  "config": {
                    "script": "\tself.view.rootContainer.handleRelease()"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "BtnRelease"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "style": {
                "classes": "btn btn-sm btn-danger"
              },
              "text": "Release"
            },
            "type": "ia.input.button"
          }
        ],
        "meta": {
          "name": "OccupiedState"
        },
        "position": {
          "shrink": 0
        },
        "propConfig": {
          "position.display": {
            "binding": {
              "config": {
                "expression": "!isNull({view.custom.context.ToolId})"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "alignItems": "center",
          "style": {
            "background": "var(--mpp-state-good-bg)",
            "border": "1px solid var(--mpp-state-good-border)",
            "borderRadius": "var(--mpp-radius-sm)",
            "gap": "10px",
            "padding": "10px 12px"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "meta": {
              "name": "EmptyLabel"
            },
            "props": {
              "style": {
                "color": "var(--mpp-text-muted)",
                "fontSize": "12px",
                "fontStyle": "italic"
              },
              "text": "No tool mounted"
            },
            "type": "ia.display.label"
          },
          {
            "children": [
              {
                "children": [
                  {
                    "meta": {
                      "name": "Label"
                    },
                    "props": {
                      "style": {
                        "classes": "field-label"
                      },
                      "text": "Tool"
                    },
                    "type": "ia.display.label"
                  },
                  {
                    "meta": {
                      "name": "ToolDropdown"
                    },
                    "propConfig": {
                      "props.options": {
                        "binding": {
                          "config": {
                            "path": "view.custom.mountable"
                          },
                          "type": "property"
                        }
                      },
                      "props.value": {
                        "binding": {
                          "config": {
                            "bidirectional": true,
                            "path": "view.custom.selectedToolId"
                          },
                          "type": "property"
                        }
                      }
                    },
                    "props": {
                      "placeholder": "Select a tool",
                      "style": {
                        "boxSizing": "border-box",
                        "classes": "select",
                        "width": "100%"
                      }
                    },
                    "type": "ia.input.dropdown"
                  }
                ],
                "meta": {
                  "name": "ToolField"
                },
                "position": {
                  "basis": "0",
                  "grow": 1
                },
                "props": {
                  "direction": "column",
                  "style": {
                    "gap": "4px"
                  }
                },
                "type": "ia.container.flex"
              },
              {
                "children": [
                  {
                    "meta": {
                      "name": "Label"
                    },
                    "props": {
                      "style": {
                        "classes": "field-label"
                      },
                      "text": "Notes"
                    },
                    "type": "ia.display.label"
                  },
                  {
                    "meta": {
                      "name": "NotesInput"
                    },
                    "propConfig": {
                      "props.text": {
                        "binding": {
                          "config": {
                            "bidirectional": true,
                            "path": "view.custom.mountNotes"
                          },
                          "type": "property"
                        }
                      }
                    },
                    "props": {
                      "placeholder": "Optional",
                      "style": {
                        "boxSizing": "border-box",
                        "classes": "search-input",
                        "width": "100%"
                      }
                    },
                    "type": "ia.input.text-field"
                  }
                ],
                "meta": {
                  "name": "NotesField"
                },
                "position": {
                  "basis": "0",
                  "grow": 1
                },
                "props": {
                  "direction": "column",
                  "style": {
                    "gap": "4px"
                  }
                },
                "type": "ia.container.flex"
              },
              {
                "events": {
                  "component": {
                    "onActionPerformed": {
                      "config": {
                        "script": "\tself.view.rootContainer.handleMount()"
                      },
                      "scope": "G",
                      "type": "script"
                    }
                  }
                },
                "meta": {
                  "name": "BtnMount"
                },
                "position": {
                  "shrink": 0
                },
                "propConfig": {
                  "props.enabled": {
                    "binding": {
                      "config": {
                        "expression": "!isNull({view.custom.selectedToolId})"
                      },
                      "type": "expr"
                    }
                  }
                },
                "props": {
                  "style": {
                    "classes": "btn btn-primary btn-sm"
                  },
                  "text": "Mount"
                },
                "type": "ia.input.button"
              }
            ],
            "meta": {
              "name": "MountRow"
            },
            "props": {
              "alignItems": "flex-end",
              "style": {
                "gap": "10px"
              }
            },
            "type": "ia.container.flex"
          }
        ],
        "meta": {
          "name": "EmptyState"
        },
        "position": {
          "shrink": 0
        },
        "propConfig": {
          "position.display": {
            "binding": {
              "config": {
                "expression": "isNull({view.custom.context.ToolId})"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "direction": "column",
          "style": {
            "background": "var(--mpp-surface-card)",
            "border": "1px solid var(--mpp-border-subtle)",
            "borderRadius": "var(--mpp-radius-sm)",
            "gap": "8px",
            "padding": "10px 12px"
          }
        },
        "type": "ia.container.flex"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "gap": "10px",
        "height": "100%"
      }
    },
    "scripts": {
      "customMethods": [
        {
          "name": "refresh",
          "params": [],
          "script": "\tcellId \u003d self.view.params.cellLocationId\n\tself.view.custom.context   \u003d BlueRidge.Parts.Tool.getCellMountContextOrEmpty(cellId)\n\tself.view.custom.mountable \u003d BlueRidge.Parts.Tool.getMountableToolsForCell(cellId)"
        },
        {
          "name": "handleMount",
          "params": [],
          "script": "\tcellId \u003d self.view.params.cellLocationId\n\tif not cellId:\n\t\tBlueRidge.Common.Notify.toast(\"No cell\", \"No cell selected.\", \"warning\")\n\t\treturn\n\ttoolId \u003d self.view.custom.selectedToolId\n\tif toolId is None:\n\t\tBlueRidge.Common.Notify.toast(\"No tool\", \"Pick a tool to mount.\", \"warning\")\n\t\treturn\n\tnotes \u003d self.view.custom.mountNotes\n\tresult \u003d BlueRidge.Parts.Tool.assignToCell(toolId, cellId, notes)\n\tBlueRidge.Common.Ui.notifyResult(result, \"Tool mounted\")\n\tif result and result.get(\"Status\"):\n\t\tself.view.custom.selectedToolId \u003d None\n\t\tself.view.custom.mountNotes \u003d \"\"\n\t\tself.refresh()"
        },
        {
          "name": "handleRelease",
          "params": [],
          "script": "\tcellId \u003d self.view.params.cellLocationId\n\tif not cellId:\n\t\treturn\n\tctx \u003d BlueRidge.Parts.Tool.getCellMountContextOrEmpty(cellId)\n\ttoolId \u003d ctx.get(\"ToolId\")\n\tif toolId is None:\n\t\treturn\n\tresult \u003d BlueRidge.Parts.Tool.releaseAssignment(toolId)\n\tBlueRidge.Common.Ui.notifyResult(result, \"Tool released\")\n\tif result and result.get(\"Status\"):\n\t\tself.refresh()"
        }
      ],
      "extensionFunctions": null,
      "messageHandlers": []
    },
    "type": "ia.container.flex"
  }
}