{
  "custom": {},
  "params": {
    "row": {}
  },
  "propConfig": {
    "params.row": {
      "paramDirection": "input"
    }
  },
  "props": {
    "defaultSize": {
      "height": 30,
      "width": 400
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "RowLabel"
        },
        "position": {
          "basis": "100px",
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.row.label"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "color": "var(--mpp-text-muted)",
            "fontSize": "12px",
            "fontWeight": "600",
            "paddingRight": "10px",
            "textAlign": "right"
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "CellRepeater"
        },
        "position": {
          "grow": 1
        },
        "propConfig": {
          "props.instances": {
            "binding": {
              "config": {
                "path": "view.params.row.cells"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "elementPosition": {
            "basis": "90px",
            "shrink": 0
          },
          "path": "BlueRidge/Components/Popups/_DieRanks/MatrixCell",
          "style": {
            "gap": "5px"
          },
          "useDefaultViewHeight": false,
          "useDefaultViewWidth": false
        },
        "type": "ia.display.flex-repeater"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "alignItems": "center",
      "style": {
        "gap": "5px"
      }
    },
    "type": "ia.container.flex"
  }
}