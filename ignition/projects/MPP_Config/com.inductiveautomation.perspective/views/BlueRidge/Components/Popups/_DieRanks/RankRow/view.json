{
  "custom": {},
  "params": {
    "rank": {}
  },
  "propConfig": {
    "params.rank": {
      "paramDirection": "input"
    }
  },
  "props": {
    "defaultSize": {
      "height": 44,
      "width": 200
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "RankLabel"
        },
        "position": {
          "basis": "0",
          "grow": 1
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "expression": "{view.params.rank.Code} + \u0027 — \u0027 + {view.params.rank.Name}"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "style": {
            "fontSize": "12px"
          }
        },
        "type": "ia.display.label"
      },
      {
        "events": {
          "component": {
            "onActionPerformed": {
              "config": {
                "script": "\tsystem.perspective.openPopup(\n\t\tid\u003d\u0027mpp-edit-rank\u0027,\n\t\tview\u003d\u0027BlueRidge/Components/Popups/EditRank\u0027,\n\t\tmodal\u003dTrue,\n\t\tshowCloseIcon\u003dFalse,\n\t\tdraggable\u003dFalse,\n\t\tparams\u003d{\u0027mode\u0027: \u0027update\u0027, \u0027dieRankId\u0027: self.view.params.rank.get(\u0027Id\u0027)})"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "EditButton"
        },
        "position": {
          "basis": "47px",
          "shrink": 0
        },
        "props": {
          "style": {
            "classes": "btn btn-sm"
          },
          "text": "Edit"
        },
        "type": "ia.input.button"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "alignItems": "center",
      "justify": "space-between",
      "style": {
        "borderBottom": "1px solid var(--mpp-border-subtle)",
        "padding": "6px 12px"
      }
    },
    "type": "ia.container.flex"
  }
}