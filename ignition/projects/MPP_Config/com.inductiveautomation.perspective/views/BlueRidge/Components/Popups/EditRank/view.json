{
  "custom": {
    "editDraft": {
      "meta": {
        "Code": "",
        "Id": null,
        "Name": ""
      }
    },
    "mode": "create",
    "selected": {
      "meta": {
        "Code": "",
        "Id": null,
        "Name": ""
      }
    }
  },
  "params": {
    "dieRankId": null,
    "mode": "create"
  },
  "propConfig": {
    "custom._initFired": {
      "binding": {
        "config": {
          "expression": "true"
        },
        "type": "expr"
      },
      "onChange": {
        "enabled": true,
        "script": "\tself.rootContainer.loadIfUpdateMode()"
      }
    },
    "custom.dirty": {
      "binding": {
        "config": {
          "expression": "{view.custom.editDraft} !\u003d {view.custom.selected}"
        },
        "type": "expr"
      }
    },
    "params.dieRankId": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.mode": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 280,
      "width": 460
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "meta": {
              "name": "TitleLabel"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "expression": "if({view.params.mode} \u003d \u0027create\u0027, \u0027Add Rank\u0027, \u0027Edit Rank\u0027)"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "classes": "modal-title",
                "fontSize": "14px",
                "fontWeight": "600"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "Spacer"
            },
            "position": {
              "grow": 1
            },
            "type": "ia.container.flex"
          },
          {
            "meta": {
              "name": "DirtyIndicator"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "expression": "if({view.custom.dirty}, \u0027● Unsaved changes\u0027, \u0027\u0027)"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "color": "var(--mpp-accent)",
                "fontSize": "11px",
                "fontStyle": "italic"
              }
            },
            "type": "ia.display.label"
          },
          {
            "events": {
              "dom": {
                "onClick": {
                  "config": {
                    "script": "\tself.view.rootContainer.handleClose()"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "CloseIcon",
              "tooltip": {
                "text": "Close"
              }
            },
            "props": {
              "path": "mpp/cancel",
              "style": {
                "classes": "modal-close",
                "cursor": "pointer",
                "height": "18px",
                "width": "18px"
              }
            },
            "type": "ia.display.icon"
          }
        ],
        "meta": {
          "name": "HeaderBar"
        },
        "position": {
          "basis": "50px",
          "shrink": 0
        },
        "props": {
          "alignItems": "center",
          "style": {
            "background": "var(--mpp-surface-raised)",
            "borderBottom": "1px solid var(--mpp-border-subtle)",
            "gap": "12px",
            "overflow": "hidden",
            "padding": "0 16px"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "children": [
              {
                "meta": {
                  "name": "Label"
                },
                "props": {
                  "style": {
                    "classes": "field-label"
                  },
                  "text": "Code"
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "Input"
                },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "config": {
                        "bidirectional": true,
                        "path": "view.custom.editDraft.meta.Code"
                      },
                      "type": "property"
                    }
                  }
                },
                "props": {
                  "placeholder": "e.g. A",
                  "style": {
                    "boxSizing": "border-box",
                    "classes": "search-input",
                    "width": "100%"
                  }
                },
                "type": "ia.input.text-field"
              }
            ],
            "meta": {
              "name": "CodeField"
            },
            "props": {
              "direction": "column",
              "style": {
                "gap": "4px",
                "overflow": "visible"
              }
            },
            "type": "ia.container.flex"
          },
          {
            "children": [
              {
                "meta": {
                  "name": "Label"
                },
                "props": {
                  "style": {
                    "classes": "field-label"
                  },
                  "text": "Name"
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "Input"
                },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "config": {
                        "bidirectional": true,
                        "path": "view.custom.editDraft.meta.Name"
                      },
                      "type": "property"
                    }
                  }
                },
                "props": {
                  "placeholder": "e.g. Premium",
                  "style": {
                    "boxSizing": "border-box",
                    "classes": "search-input",
                    "width": "100%"
                  }
                },
                "type": "ia.input.text-field"
              }
            ],
            "meta": {
              "name": "NameField"
            },
            "props": {
              "direction": "column",
              "style": {
                "gap": "4px",
                "overflow": "visible"
              }
            },
            "type": "ia.container.flex"
          }
        ],
        "meta": {
          "name": "FormBody"
        },
        "position": {
          "grow": 1
        },
        "props": {
          "direction": "column",
          "style": {
            "gap": "12px",
            "overflowY": "auto",
            "padding": "16px"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "events": {
              "component": {
                "onActionPerformed": {
                  "config": {
                    "script": "\tself.view.rootContainer.handleDelete()"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "DeleteButton"
            },
            "position": {
              "shrink": 0
            },
            "propConfig": {
              "position.display": {
                "binding": {
                  "config": {
                    "expression": "{view.params.mode} \u003d \u0027update\u0027"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "classes": "btn btn-danger btn-sm"
              },
              "text": "Remove"
            },
            "type": "ia.input.button"
          },
          {
            "children": [
              {
                "events": {
                  "component": {
                    "onActionPerformed": {
                      "config": {
                        "script": "\tself.view.rootContainer.handleClose()"
                      },
                      "scope": "G",
                      "type": "script"
                    }
                  }
                },
                "meta": {
                  "name": "CancelButton"
                },
                "position": {
                  "basis": "62px",
                  "shrink": 0
                },
                "props": {
                  "style": {
                    "classes": "btn btn-sm"
                  },
                  "text": "Cancel"
                },
                "type": "ia.input.button"
              },
              {
                "events": {
                  "component": {
                    "onActionPerformed": {
                      "config": {
                        "script": "\tself.view.rootContainer.handleSave()"
                      },
                      "scope": "G",
                      "type": "script"
                    }
                  }
                },
                "meta": {
                  "name": "SaveButton"
                },
                "position": {
                  "basis": "91px",
                  "shrink": 0
                },
                "props": {
                  "style": {
                    "classes": "btn btn-primary btn-sm"
                  },
                  "text": "Create Rank"
                },
                "type": "ia.input.button"
              }
            ],
            "meta": {
              "name": "RightCluster"
            },
            "props": {
              "alignItems": "center",
              "style": {
                "gap": "8px",
                "overflow": "visible"
              }
            },
            "type": "ia.container.flex"
          }
        ],
        "meta": {
          "name": "FooterBar"
        },
        "position": {
          "basis": "50px",
          "shrink": 0
        },
        "props": {
          "alignItems": "center",
          "justify": "space-between",
          "style": {
            "background": "var(--mpp-surface-raised)",
            "borderTop": "1px solid var(--mpp-border-subtle)",
            "gap": "8px",
            "overflow": "hidden",
            "padding": "12px 16px"
          }
        },
        "type": "ia.container.flex"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "background": "var(--mpp-surface-canvas)",
        "borderRadius": "var(--mpp-radius-md, 8px)",
        "height": "100%",
        "overflow": "hidden",
        "width": "100%"
      }
    },
    "scripts": {
      "customMethods": [
        {
          "name": "loadIfUpdateMode",
          "params": [],
          "script": "\tmode \u003d self.view.params.mode\n\tself.view.custom.mode \u003d mode\n\tif mode !\u003d \u0027update\u0027:\n\t\temptyMeta \u003d {\u0027Id\u0027: None, \u0027Code\u0027: \u0027\u0027, \u0027Name\u0027: \u0027\u0027}\n\t\tself.view.custom.selected  \u003d {\u0027meta\u0027: dict(emptyMeta)}\n\t\tself.view.custom.editDraft \u003d {\u0027meta\u0027: dict(emptyMeta)}\n\t\treturn\n\trankId \u003d self.view.params.dieRankId\n\trow \u003d BlueRidge.Parts.DieRank.getOne(rankId)\n\tif not row:\n\t\tBlueRidge.Common.Notify.toast(\u0027Not found\u0027, \u0027Die rank \u0027 + str(rankId) + \u0027 could not be loaded.\u0027, \u0027error\u0027)\n\t\tsystem.perspective.closePopup(id\u003d\u0027mpp-edit-rank\u0027)\n\t\treturn\n\tmeta \u003d {\u0027Id\u0027: row.get(\u0027Id\u0027), \u0027Code\u0027: row.get(\u0027Code\u0027) or \u0027\u0027, \u0027Name\u0027: row.get(\u0027Name\u0027) or \u0027\u0027}\n\tself.view.custom.selected  \u003d {\u0027meta\u0027: dict(meta)}\n\tself.view.custom.editDraft \u003d {\u0027meta\u0027: dict(meta)}"
        },
        {
          "name": "handleSave",
          "params": [],
          "script": "\tmode  \u003d self.view.custom.mode\n\tdraft \u003d self.view.custom.editDraft or {}\n\tmeta  \u003d draft.get(\u0027meta\u0027) or {}\n\tif mode \u003d\u003d \u0027create\u0027:\n\t\tresult \u003d BlueRidge.Parts.DieRank.add(meta)\n\t\tsuccess \u003d \u0027Die rank created\u0027\n\telse:\n\t\tresult \u003d BlueRidge.Parts.DieRank.update(meta)\n\t\tsuccess \u003d \u0027Die rank updated\u0027\n\tBlueRidge.Common.Ui.notifyResult(result, success)\n\tif result and result.get(\u0027Status\u0027):\n\t\tself.view.custom.selected \u003d {\u0027meta\u0027: dict(meta)}\n\t\tsystem.perspective.sendMessage(\u0027dieRankRefresh\u0027, scope\u003d\u0027page\u0027)\n\t\tsystem.perspective.closePopup(id\u003d\u0027mpp-edit-rank\u0027)"
        },
        {
          "name": "handleDelete",
          "params": [],
          "script": "\t# Route through ConfirmDestructive instead of deleting directly --\n\t# the editRankDeleteConfirmed messageHandler does the real work\n\t# once the user clicks Remove on the confirm popup.\n\tdraft \u003d self.view.custom.editDraft or {}\n\tmeta  \u003d draft.get(\u0027meta\u0027) or {}\n\trankId \u003d meta.get(\u0027Id\u0027)\n\tif rankId is None:\n\t\treturn\n\tcode \u003d meta.get(\u0027Code\u0027) or \u0027\u0027\n\tname \u003d meta.get(\u0027Name\u0027) or \u0027\u0027\n\tlabel \u003d (code + \u0027 - \u0027 + name) if code and name else (code or name or \u0027this rank\u0027)\n\tsystem.perspective.openPopup(\n\t\tid\u003d\u0027mpp-confirm-destructive\u0027,\n\t\tview\u003d\u0027BlueRidge/Components/Popups/ConfirmDestructive\u0027,\n\t\tmodal\u003dTrue,\n\t\tshowCloseIcon\u003dFalse,\n\t\tparams\u003d{\n\t\t\t\u0027title\u0027:        \u0027Remove Die Rank\u0027,\n\t\t\t\u0027message\u0027:      \u0027Remove die rank \u0027 + label + \u0027? This cannot be undone.\u0027,\n\t\t\t\u0027confirmLabel\u0027: \u0027Remove\u0027,\n\t\t\t\u0027replyMessage\u0027: \u0027editRankDeleteConfirmed\u0027\n\t\t}\n\t)"
        },
        {
          "name": "handleClose",
          "params": [],
          "script": "\tif str(self.view.custom.editDraft) \u003d\u003d str(self.view.custom.selected):\n\t\tsystem.perspective.closePopup(id\u003d\"mpp-edit-rank\")\n\telse:\n\t\tsystem.perspective.openPopup(\n\t\t\tid\u003d\"mpp-confirm-unsaved\",\n\t\t\tview\u003d\"BlueRidge/Components/Popups/ConfirmUnsaved\",\n\t\t\tmodal\u003dTrue,\n\t\t\tshowCloseIcon\u003dFalse,\n\t\t\tparams\u003d{\n\t\t\t\t\"title\": \"Unsaved Changes\",\n\t\t\t\t\"message\": \"You have unsaved changes to this rank. Save before closing?\"\n\t\t\t}\n\t\t)"
        }
      ],
      "extensionFunctions": null,
      "messageHandlers": [
        {
          "messageType": "editRankDeleteConfirmed",
          "pageScope": true,
          "script": "\taction \u003d payload.get(\u0027action\u0027) if payload else None\n\tif action !\u003d \u0027confirm\u0027:\n\t\treturn\n\tdraft \u003d self.view.custom.editDraft or {}\n\tmeta  \u003d draft.get(\u0027meta\u0027) or {}\n\trankId \u003d meta.get(\u0027Id\u0027)\n\tif rankId is None:\n\t\treturn\n\tresult \u003d BlueRidge.Parts.DieRank.deprecate(rankId)\n\tBlueRidge.Common.Ui.notifyResult(result, \u0027Die rank removed\u0027)\n\tif result and result.get(\u0027Status\u0027):\n\t\tsystem.perspective.sendMessage(\u0027dieRankRefresh\u0027, scope\u003d\u0027page\u0027)\n\t\tsystem.perspective.closePopup(id\u003d\u0027mpp-edit-rank\u0027)",
          "sessionScope": false,
          "viewScope": false
        },
        {
          "messageType": "confirmUnsavedResult",
          "pageScope": true,
          "script": "\taction \u003d payload.get(\"action\") if payload else None\n\tif action \u003d\u003d \"save\":\n\t\tself.view.rootContainer.handleSave()\n\telif action \u003d\u003d \"discard\":\n\t\tsystem.perspective.closePopup(id\u003d\"mpp-edit-rank\")",
          "sessionScope": false,
          "viewScope": false
        }
      ]
    },
    "type": "ia.container.flex"
  }
}