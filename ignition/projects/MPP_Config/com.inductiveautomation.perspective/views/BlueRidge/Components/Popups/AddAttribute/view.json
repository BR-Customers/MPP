{
  "custom": {
    "editDraft": {
      "DefId": null,
      "Value": ""
    },
    "definitionOptions": []
  },
  "params": {
    "toolId": 0,
    "toolTypeId": 0
  },
  "propConfig": {
    "params.toolId":     { "paramDirection": "input" },
    "params.toolTypeId": { "paramDirection": "input" },
    "custom.definitionOptions": {
      "binding": {
        "type": "expr",
        "config": {
          "expression": "runScript(\"BlueRidge.Parts.Tool.getAttributeDefinitionsForToolType\", 0, {view.params.toolTypeId})"
        }
      }
    }
  },
  "props": {
    "defaultSize": {
      "width": 440,
      "height": 280
    }
  },
  "root": {
    "type": "ia.container.flex",
    "meta": { "name": "root" },
    "props": {
      "direction": "column",
      "style": {
        "background": "var(--mpp-surface-canvas)",
        "borderRadius": "var(--mpp-radius-md, 8px)",
        "height": "100%",
        "overflow": "hidden",
        "width": "100%"
      }
    },
    "children": [
      {
        "type": "ia.container.flex",
        "meta": { "name": "HeaderBar" },
        "position": { "basis": "50px", "shrink": 0 },
        "props": {
          "alignItems": "center",
          "style": {
            "background": "var(--mpp-surface-raised)",
            "borderBottom": "1px solid var(--mpp-border-subtle)",
            "gap": "12px",
            "padding": "0 16px", "overflow": "hidden"
          }
        },
        "children": [
          {
            "type": "ia.display.label",
            "meta": { "name": "TitleLabel" },
            "props": {
              "text": "Add Attribute",
              "style": { "classes": "modal-title", "fontSize": "14px", "fontWeight": "600" }
            }
          },
          {
            "type": "ia.container.flex",
            "meta": { "name": "Spacer" },
            "position": { "grow": 1 }
          },
          {
            "type": "ia.display.icon",
            "meta": { "name": "CloseIcon", "tooltip": { "text": "Close" } },
            "events": {
              "dom": {
                "onClick": {
                  "type": "script",
                  "scope": "G",
                  "config": { "script": "\tsystem.perspective.closePopup(id='mpp-add-attribute')" }
                }
              }
            },
            "props": {
              "path": "mpp/cancel",
              "style": { "classes": "modal-close", "cursor": "pointer", "height": "18px", "width": "18px" }
            }
          }
        ]
      },
      {
        "type": "ia.container.flex",
        "meta": { "name": "FormBody" },
        "position": { "grow": 1 },
        "props": {
          "direction": "column",
          "style": { "gap": "12px", "overflowY": "auto", "padding": "16px" }
        },
        "children": [
          {
            "type": "ia.container.flex",
            "meta": { "name": "AttributeField" },
            "props": { "direction": "column", "style": { "gap": "4px" } },
            "children": [
              {
                "type": "ia.display.label",
                "meta": { "name": "Label" },
                "props": { "text": "Attribute", "style": { "classes": "field-label" } }
              },
              {
                "type": "ia.container.flex",
                "meta": { "name": "DropdownRow" },
                "props": {
                  "direction": "row",
                  "alignItems": "center",
                  "style": { "gap": "8px" }
                },
                "children": [
                  {
                    "type": "ia.input.dropdown",
                    "meta": { "name": "Input" },
                    "position": { "basis": "0", "grow": 1 },
                    "propConfig": {
                      "props.options": {
                        "binding": {
                          "type": "property",
                          "config": { "path": "view.custom.definitionOptions" }
                        }
                      },
                      "props.value": {
                        "binding": {
                          "type": "property",
                          "config": { "bidirectional": true, "path": "view.custom.editDraft.DefId" }
                        }
                      }
                    },
                    "props": {
                      "style": { "boxSizing": "border-box", "classes": "select", "width": "100%" }
                    }
                  },
                  {
                    "type": "ia.input.button",
                    "meta": { "name": "BtnNewDef" },
                    "position": { "shrink": 0 },
                    "events": {
                      "component": {
                        "onActionPerformed": {
                          "type": "script",
                          "scope": "G",
                          "config": {
                            "script": "\ttoolTypeId = self.view.params.toolTypeId\n\tif not toolTypeId:\n\t\tBlueRidge.Common.Notify.toast('No tool type', 'Pick a tool first.', 'warning')\n\t\treturn\n\tsystem.perspective.openPopup(\n\t\tid='mpp-add-attr-def',\n\t\tview='BlueRidge/Components/Popups/AddAttributeDefinition',\n\t\tmodal=True,\n\t\tshowCloseIcon=False,\n\t\tparams={'toolTypeId': toolTypeId}\n\t)"
                          }
                        }
                      }
                    },
                    "props": { "text": "+ New", "style": { "classes": "btn btn-sm" } }
                  }
                ]
              }
            ]
          },
          {
            "type": "ia.container.flex",
            "meta": { "name": "ValueField" },
            "props": { "direction": "column", "style": { "gap": "4px" } },
            "children": [
              {
                "type": "ia.display.label",
                "meta": { "name": "Label" },
                "props": { "text": "Value", "style": { "classes": "field-label" } }
              },
              {
                "type": "ia.input.text-field",
                "meta": { "name": "Input" },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "type": "property",
                      "config": { "bidirectional": true, "path": "view.custom.editDraft.Value" }
                    }
                  }
                },
                "props": {
                  "placeholder": "",
                  "style": { "boxSizing": "border-box", "classes": "search-input", "width": "100%" }
                }
              }
            ]
          }
        ]
      },
      {
        "type": "ia.container.flex",
        "meta": { "name": "FooterBar" },
        "position": { "basis": "50px", "shrink": 0 },
        "props": {
          "alignItems": "center",
          "justify": "flex-end",
          "style": {
            "background": "var(--mpp-surface-raised)",
            "borderTop": "1px solid var(--mpp-border-subtle)",
            "gap": "8px",
            "padding": "12px 16px", "overflow": "hidden"
          }
        },
        "children": [
          {
            "type": "ia.input.button",
            "meta": { "name": "CancelButton" },
            "position": { "shrink": 0 },
            "events": {
              "component": {
                "onActionPerformed": {
                  "type": "script",
                  "scope": "G",
                  "config": { "script": "\tsystem.perspective.closePopup(id='mpp-add-attribute')" }
                }
              }
            },
            "props": { "text": "Cancel", "style": { "classes": "btn btn-sm" } }
          },
          {
            "type": "ia.input.button",
            "meta": { "name": "CreateButton" },
            "position": { "shrink": 0 },
            "events": {
              "component": {
                "onActionPerformed": {
                  "type": "script",
                  "scope": "G",
                  "config": { "script": "\tself.view.rootContainer.handleCreate()" }
                }
              }
            },
            "props": { "text": "Add", "style": { "classes": "btn btn-primary btn-sm" } }
          }
        ]
      }
    ],
    "scripts": {
      "customMethods": [
        {
          "name": "handleCreate",
          "params": [],
          "script": "\ttoolId = self.view.params.toolId\n\tif not toolId:\n\t\tBlueRidge.Common.Notify.toast('No tool selected', 'Pick a tool first.', 'warning')\n\t\treturn\n\tdraft = self.view.custom.editDraft or {}\n\tdefId = draft.get('DefId')\n\tif defId is None:\n\t\tBlueRidge.Common.Notify.toast('Attribute required', 'Pick an attribute from the dropdown.', 'warning')\n\t\treturn\n\tresult = BlueRidge.Parts.Tool.upsertAttribute(toolId, defId, draft.get('Value'))\n\tBlueRidge.Common.Ui.notifyResult(result, 'Attribute saved')\n\tif result and result.get('Status'):\n\t\tsystem.perspective.sendMessage('toolDataChanged', payload={'section': 'attributes'}, scope='page')\n\t\tsystem.perspective.closePopup(id='mpp-add-attribute')"
        },
        {
          "name": "refreshOptions",
          "params": [],
          "script": "\tself.view.custom.definitionOptions = BlueRidge.Parts.Tool.getAttributeDefinitionsForToolType(self.view.params.toolTypeId)"
        }
      ],
      "extensionFunctions": null,
      "messageHandlers": [
        {
          "messageType": "attributeDefinitionsChanged",
          "pageScope": true,
          "sessionScope": false,
          "viewScope": false,
          "script": "\tself.view.rootContainer.refreshOptions()\n\tnewId = (payload or {}).get('newId')\n\tif newId is not None:\n\t\tself.view.custom.editDraft.DefId = newId"
        }
      ]
    }
  }
}
