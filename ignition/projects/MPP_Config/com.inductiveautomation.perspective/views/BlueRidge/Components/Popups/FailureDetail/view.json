{
  "custom": {},
  "params": {
    "attemptedAt": null,
    "attemptedParameters": "",
    "entityId": null,
    "failureReason": "",
    "id": null,
    "logEntityTypeName": "",
    "logEventTypeCode": "",
    "popupId": "mpp-failure-detail",
    "procedureName": "",
    "userDisplayName": ""
  },
  "propConfig": {
    "params.attemptedAt": {
      "paramDirection": "input"
    },
    "params.attemptedParameters": {
      "paramDirection": "input"
    },
    "params.entityId": {
      "paramDirection": "input"
    },
    "params.failureReason": {
      "paramDirection": "input"
    },
    "params.id": {
      "paramDirection": "input"
    },
    "params.logEntityTypeName": {
      "paramDirection": "input"
    },
    "params.logEventTypeCode": {
      "paramDirection": "input"
    },
    "params.popupId": {
      "paramDirection": "input"
    },
    "params.procedureName": {
      "paramDirection": "input"
    },
    "params.userDisplayName": {
      "paramDirection": "input"
    }
  },
  "props": {
    "defaultSize": {
      "height": 560,
      "width": 720
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "meta": {
              "name": "Title"
            },
            "position": {
              "grow": 1
            },
            "props": {
              "style": {
                "classes": "modal-title",
                "color": "var(--mpp-text-primary)",
                "fontSize": "14px",
                "fontWeight": "600"
              },
              "text": "Rejection Detail"
            },
            "type": "ia.display.label"
          },
          {
            "events": {
              "dom": {
                "onClick": {
                  "config": {
                    "script": "\tsystem.perspective.closePopup(id\u003dself.view.params.popupId)"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "CloseIcon"
            },
            "position": {
              "basis": "24px",
              "shrink": 0
            },
            "props": {
              "color": "var(--mpp-text-secondary)",
              "path": "material/close",
              "style": {
                "cursor": "pointer",
                "height": "20px",
                "width": "20px"
              }
            },
            "type": "ia.display.icon"
          }
        ],
        "meta": {
          "name": "Header"
        },
        "position": {
          "basis": "48px",
          "shrink": 0
        },
        "props": {
          "alignItems": "center",
          "style": {
            "background": "var(--mpp-surface-raised)",
            "borderBottom": "1px solid var(--mpp-border-subtle)",
            "overflow": "hidden",
            "padding": "0 16px"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "meta": {
              "name": "MetaLine"
            },
            "position": {
              "shrink": 0
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "expression": "\"Attempted at:  \" + dateFormat({view.params.attemptedAt}, \"yyyy-MM-dd HH:mm:ss\") + \"   |   User:  \" + coalesce({view.params.userDisplayName}, \"(unknown)\") + \"   |   Event:  \" + coalesce({view.params.logEventTypeCode}, \"\")"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "color": "var(--mpp-text-secondary)",
                "fontSize": "12px"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "EntityLine"
            },
            "position": {
              "shrink": 0
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "expression": "\"Procedure:  \" + coalesce({view.params.procedureName}, \"\") + \"   |   Entity:  \" + coalesce({view.params.logEntityTypeName}, \"\") + \"  \\u00B7  \" + coalesce({view.params.entityId}, \"(new)\")"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "color": "var(--mpp-text-secondary)",
                "fontSize": "12px"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "ReasonHeader"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "style": {
                "color": "var(--mpp-text-secondary)",
                "fontSize": "11px",
                "fontWeight": "600",
                "letterSpacing": "0.05em",
                "marginTop": "8px",
                "textTransform": "uppercase"
              },
              "text": "Failure Reason"
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "ReasonText"
            },
            "position": {
              "shrink": 0
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "path": "view.params.failureReason"
                  },
                  "type": "property"
                }
              }
            },
            "props": {
              "style": {
                "color": "var(--mpp-text-primary)",
                "fontSize": "13px",
                "lineHeight": "1.4"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "ParamsHeader"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "style": {
                "color": "var(--mpp-text-secondary)",
                "fontSize": "11px",
                "fontWeight": "600",
                "letterSpacing": "0.05em",
                "marginTop": "8px",
                "textTransform": "uppercase"
              },
              "text": "Attempted Parameters"
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "ParamsBlock"
            },
            "position": {
              "basis": "0",
              "grow": 1,
              "shrink": 0
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "expression": "runScript(\"BlueRidge.Common.Util.prettyJson\", 0, {view.params.attemptedParameters})"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "background": "var(--mpp-surface-card)",
                "border": "1px solid var(--mpp-border-subtle)",
                "borderRadius": "6px",
                "color": "var(--mpp-text-primary)",
                "fontFamily": "ui-monospace, Menlo, Consolas, monospace",
                "fontSize": "11px",
                "lineHeight": "1.4",
                "overflow": "auto",
                "padding": "12px",
                "whiteSpace": "pre"
              }
            },
            "type": "ia.display.label"
          }
        ],
        "meta": {
          "name": "Body"
        },
        "position": {
          "basis": "0",
          "grow": 1
        },
        "props": {
          "direction": "column",
          "style": {
            "gap": "10px",
            "padding": "16px"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "meta": {
              "name": "Spacer"
            },
            "position": {
              "grow": 1
            },
            "type": "ia.container.flex"
          },
          {
            "events": {
              "component": {
                "onActionPerformed": {
                  "config": {
                    "script": "\tsystem.perspective.closePopup(id\u003dself.view.params.popupId)"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "CloseButton"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "style": {
                "classes": "btn btn-sm"
              },
              "text": "Close"
            },
            "type": "ia.input.button"
          }
        ],
        "meta": {
          "name": "Footer"
        },
        "position": {
          "basis": "60px",
          "shrink": 0
        },
        "props": {
          "alignItems": "center",
          "style": {
            "background": "var(--mpp-surface-raised)",
            "borderTop": "1px solid var(--mpp-border-subtle)",
            "overflow": "hidden",
            "padding": "12px 16px"
          }
        },
        "type": "ia.container.flex"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "background": "var(--mpp-surface-canvas)",
        "borderRadius": "var(--mpp-radius-md, 8px)",
        "height": "100%",
        "overflow": "hidden",
        "width": "100%"
      }
    },
    "type": "ia.container.flex"
  }
}