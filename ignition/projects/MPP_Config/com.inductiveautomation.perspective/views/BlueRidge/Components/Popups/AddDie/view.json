{
  "custom": {
    "mode": "create",
    "selected": {
      "meta": {
        "Code": "",
        "Name": "",
        "DieRankCode": "B",
        "Description": ""
      }
    },
    "editDraft": {
      "meta": {
        "Code": "",
        "Name": "",
        "DieRankCode": "B",
        "Description": ""
      }
    },
    "rankOptions": []
  },
  "params": {},
  "propConfig": {
    "custom.rankOptions": {
      "binding": {
        "type": "expr",
        "config": {
          "expression": "runScript(\"BlueRidge.Parts.DieRank.getForDropdown\", 0)"
        }
      }
    }
  },
  "props": {
    "defaultSize": {
      "width": 480,
      "height": 380
    }
  },
  "root": {
    "type": "ia.container.flex",
    "meta": { "name": "root" },
    "props": {
      "direction": "column",
      "style": {
        "background": "var(--mpp-surface-canvas)",
        "borderRadius": "var(--mpp-radius-md, 8px)",
        "height": "100%",
        "overflow": "hidden",
        "width": "100%"
      }
    },
    "children": [
      {
        "type": "ia.container.flex",
        "meta": { "name": "HeaderBar" },
        "position": { "basis": "50px", "shrink": 0 },
        "props": {
          "alignItems": "center",
          "style": {
            "background": "var(--mpp-surface-raised)",
            "borderBottom": "1px solid var(--mpp-border-subtle)",
            "gap": "12px",
            "padding": "0 16px"
          }
        },
        "children": [
          {
            "type": "ia.display.label",
            "meta": { "name": "TitleLabel" },
            "props": {
              "text": "Add Die",
              "style": {
                "classes": "modal-title",
                "fontSize": "14px",
                "fontWeight": "600"
              }
            }
          },
          {
            "type": "ia.container.flex",
            "meta": { "name": "Spacer" },
            "position": { "grow": 1 }
          },
          {
            "type": "ia.display.label",
            "meta": { "name": "DirtyIndicator" },
            "propConfig": {
              "props.text": {
                "binding": {
                  "type": "expr",
                  "config": {
                    "expression": "if({view.custom.editDraft} != {view.custom.selected}, '● Unsaved changes', '')"
                  }
                }
              }
            },
            "props": {
              "text": "",
              "style": {
                "color": "var(--mpp-accent)",
                "fontSize": "11px",
                "fontStyle": "italic"
              }
            }
          },
          {
            "type": "ia.display.icon",
            "meta": {
              "name": "CloseIcon",
              "tooltip": { "text": "Close" }
            },
            "events": {
              "dom": {
                "onClick": {
                  "type": "script",
                  "scope": "G",
                  "config": {
                    "script": "\tself.view.rootContainer.handleClose()"
                  }
                }
              }
            },
            "props": {
              "path": "mpp/cancel",
              "style": {
                "classes": "modal-close",
                "cursor": "pointer",
                "height": "18px",
                "width": "18px"
              }
            }
          }
        ]
      },
      {
        "type": "ia.container.flex",
        "meta": { "name": "FormBody" },
        "position": { "grow": 1 },
        "props": {
          "direction": "column",
          "style": {
            "gap": "12px",
            "overflowY": "auto",
            "padding": "16px"
          }
        },
        "children": [
          {
            "type": "ia.container.flex",
            "meta": { "name": "CodeField" },
            "props": {
              "direction": "column",
              "style": { "gap": "4px" }
            },
            "children": [
              {
                "type": "ia.display.label",
                "meta": { "name": "Label" },
                "props": {
                  "text": "Code",
                  "style": { "classes": "field-label" }
                }
              },
              {
                "type": "ia.input.text-field",
                "meta": { "name": "Input" },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "type": "property",
                      "config": {
                        "bidirectional": true,
                        "path": "view.custom.editDraft.meta.Code"
                      }
                    }
                  }
                },
                "props": {
                  "placeholder": "e.g. DC-043",
                  "style": {
                    "boxSizing": "border-box",
                    "classes": "search-input",
                    "width": "100%"
                  }
                }
              }
            ]
          },
          {
            "type": "ia.container.flex",
            "meta": { "name": "NameField" },
            "props": {
              "direction": "column",
              "style": { "gap": "4px" }
            },
            "children": [
              {
                "type": "ia.display.label",
                "meta": { "name": "Label" },
                "props": {
                  "text": "Name",
                  "style": { "classes": "field-label" }
                }
              },
              {
                "type": "ia.input.text-field",
                "meta": { "name": "Input" },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "type": "property",
                      "config": {
                        "bidirectional": true,
                        "path": "view.custom.editDraft.meta.Name"
                      }
                    }
                  }
                },
                "props": {
                  "placeholder": "e.g. Cam Holder Die",
                  "style": {
                    "boxSizing": "border-box",
                    "classes": "search-input",
                    "width": "100%"
                  }
                }
              }
            ]
          },
          {
            "type": "ia.container.flex",
            "meta": { "name": "DieRankField" },
            "props": {
              "direction": "column",
              "style": { "gap": "4px" }
            },
            "children": [
              {
                "type": "ia.display.label",
                "meta": { "name": "Label" },
                "props": {
                  "text": "Die Rank",
                  "style": { "classes": "field-label" }
                }
              },
              {
                "type": "ia.input.dropdown",
                "meta": { "name": "Input" },
                "propConfig": {
                  "props.options": {
                    "binding": {
                      "type": "property",
                      "config": { "path": "view.custom.rankOptions" }
                    }
                  },
                  "props.value": {
                    "binding": {
                      "type": "property",
                      "config": {
                        "bidirectional": true,
                        "path": "view.custom.editDraft.meta.DieRankCode"
                      }
                    }
                  }
                },
                "props": {
                  "style": {
                    "boxSizing": "border-box",
                    "classes": "select",
                    "width": "100%"
                  }
                }
              }
            ]
          },
          {
            "type": "ia.container.flex",
            "meta": { "name": "DescriptionField" },
            "props": {
              "direction": "column",
              "style": { "gap": "4px" }
            },
            "children": [
              {
                "type": "ia.display.label",
                "meta": { "name": "Label" },
                "props": {
                  "text": "Description",
                  "style": { "classes": "field-label" }
                }
              },
              {
                "type": "ia.input.text-field",
                "meta": { "name": "Input" },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "type": "property",
                      "config": {
                        "bidirectional": true,
                        "path": "view.custom.editDraft.meta.Description"
                      }
                    }
                  }
                },
                "props": {
                  "placeholder": "Optional description",
                  "style": {
                    "boxSizing": "border-box",
                    "classes": "search-input",
                    "width": "100%"
                  }
                }
              }
            ]
          }
        ]
      },
      {
        "type": "ia.container.flex",
        "meta": { "name": "FooterBar" },
        "position": { "basis": "50px", "shrink": 0 },
        "props": {
          "alignItems": "center",
          "justify": "flex-end",
          "style": {
            "background": "var(--mpp-surface-raised)",
            "borderTop": "1px solid var(--mpp-border-subtle)",
            "gap": "8px",
            "padding": "12px 16px"
          }
        },
        "children": [
          {
            "type": "ia.input.button",
            "meta": { "name": "CancelButton" },
            "position": { "shrink": 0 },
            "events": {
              "component": {
                "onActionPerformed": {
                  "type": "script",
                  "scope": "G",
                  "config": {
                    "script": "\tself.view.rootContainer.handleClose()"
                  }
                }
              }
            },
            "props": {
              "text": "Cancel",
              "style": { "classes": "btn btn-sm" }
            }
          },
          {
            "type": "ia.input.button",
            "meta": { "name": "CreateButton" },
            "position": { "shrink": 0 },
            "events": {
              "component": {
                "onActionPerformed": {
                  "type": "script",
                  "scope": "G",
                  "config": {
                    "script": "\tself.view.rootContainer.handleCreate()"
                  }
                }
              }
            },
            "props": {
              "text": "Create Die",
              "style": { "classes": "btn btn-primary btn-sm" }
            }
          }
        ]
      }
    ],
    "scripts": {
      "customMethods": [
        {
          "name": "handleCreate",
          "params": [],
          "script": "\tdraft = self.view.custom.editDraft or {}\n\tmeta  = draft.get('meta') or {}\n\tif not (meta.get('Code') or '').strip():\n\t\tBlueRidge.Common.Notify.toast('Code required', 'Enter a code before creating the die.', 'warning')\n\t\treturn\n\tif not (meta.get('Name') or '').strip():\n\t\tBlueRidge.Common.Notify.toast('Name required', 'Enter a name before creating the die.', 'warning')\n\t\treturn\n\tresult = BlueRidge.Parts.Tool.add(meta)\n\tBlueRidge.Common.Ui.notifyResult(result, 'Die created')\n\tif result and result.get('Status') == 'OK':\n\t\tself.view.custom.selected = {'meta': dict(meta)}\n\t\tsystem.perspective.sendMessage('toolRefresh', scope='page')\n\t\tsystem.perspective.closePopup(id='mpp-add-die')"
        },
        {
          "name": "handleClose",
          "params": [],
          "script": "\t# Reset the draft so the next open lands on a clean form.\n\tself.view.custom.editDraft = {'meta': dict(self.view.custom.selected['meta'])}\n\tsystem.perspective.closePopup(id='mpp-add-die')"
        }
      ],
      "extensionFunctions": null,
      "messageHandlers": []
    }
  }
}
