    "scripts": {
      "customMethods": [
        {
          "name": "handleToggle",
          "params": [
            "fromCode",
            "toCode"
          ],
          "script": "\t# Flip the (fromCode, toCode) cell and its mirror (toCode, fromCode)\n\t# directly in the bodyRows custom prop. Assign a new top-level list\n\t# so Perspective re-renders the BodyRepeater + each affected cell.\n\tnewBodyRows \u003d []\n\tfor rowInst in (self.view.custom.bodyRows or []):\n\t\trowDict \u003d dict((rowInst or {}).get(\u0027row\u0027) or {})\n\t\tnewCells \u003d []\n\t\tfor cellInst in (rowDict.get(\u0027cells\u0027) or []):\n\t\t\tc \u003d dict((cellInst or {}).get(\u0027cell\u0027) or {})\n\t\t\tcfrom \u003d c.get(\u0027fromCode\u0027)\n\t\t\tcto   \u003d c.get(\u0027toCode\u0027)\n\t\t\tif (cfrom \u003d\u003d fromCode and cto \u003d\u003d toCode) or (cfrom \u003d\u003d toCode and cto \u003d\u003d fromCode):\n\t\t\t\tc[\u0027compatible\u0027] \u003d not bool(c.get(\u0027compatible\u0027))\n\t\t\tnewCells.append({\u0027cell\u0027: c})\n\t\trowDict[\u0027cells\u0027] \u003d newCells\n\t\tnewBodyRows.append({\u0027row\u0027: rowDict})\n\tself.view.custom.bodyRows \u003d newBodyRows"
        }
      ],
      "extensionFunctions": null,
      "messageHandlers": [
        {
          "messageType": "matrixCellToggle",
          "pageScope": true,
          "script": "\tif payload is None:\n\t\treturn\n\tfromCode \u003d payload.get(\u0027fromCode\u0027)\n\ttoCode   \u003d payload.get(\u0027toCode\u0027)\n\tif fromCode is None or toCode is None:\n\t\treturn\n\tself.handleToggle(fromCode, toCode)",
          "sessionScope": false,
          "viewScope": false
        },
        {
          "messageType": "dieRankRefresh",
          "pageScope": true,
          "script": "\tself.view.custom.ranks       \u003d BlueRidge.Parts.DieRank.getInstancesForFlexRepeater()\n\tself.view.custom.headerCells \u003d BlueRidge.Parts.DieRank.getMatrixHeaderInstances()\n\tself.view.custom.bodyRows    \u003d BlueRidge.Parts.DieRank.getMatrixRowInstances()",
          "sessionScope": false,
          "viewScope": false
        }
      ]
    },
    "type": "ia.container.flex"
  }
