  "propConfig": {
    "custom.bodyRows": {
      "binding": {
        "config": {
          "expression": "runScript(\"BlueRidge.Parts.DieRank.getMatrixRowInstances\", 0)"
        },
        "type": "expr"
      }
    },
    "custom.compatibilityData": {
      "binding": {
        "config": {
          "path": "view.custom.bodyRows"
        },
        "transforms": [
          {
            "code": "\tinputData \u003d list(value)\n\tsaveData \u003d []\n\t\n\tfor row in inputData:\n\t\tfor cell in row.get(\"row\").get(\"cells\"):\n\t\t\tcurrentCell \u003d cell.get(\"cell\")\n\t\t\t\n\t\t\trankACode \u003d currentCell.get(\"toCode\")\n\t\t\trankA \u003d BlueRidge.Parts.DieRank.getByCode(rankACode)\n\t\t\trankBCode \u003d currentCell.get(\"fromCode\")\n\t\t\trankB \u003d BlueRidge.Parts.DieRank.getByCode(rankBCode)\n\t\t\tif not currentCell.get(\"mirror\"):\n\t\t\t\tsaveData.append({\n\t\t\t\t\t\"RankAId\": rankA.get(\"Id\"),\n\t\t\t\t\t\"RankBId\": rankB.get(\"Id\"),\n\t\t\t\t\t\"CanMix\": currentCell.get(\"compatible\")\n\t\t\t\t})\n\t\t\n\treturn saveData",
            "type": "script"
          }
        ],
        "type": "property"
      },
      "persistent": true
    },
    "custom.headerCells": {
      "binding": {
        "config": {
          "expression": "runScript(\"BlueRidge.Parts.DieRank.getMatrixHeaderInstances\", 0)"
        },
        "type": "expr"
      }
    },
    "custom.ranks": {
      "binding": {
        "config": {
          "expression": "runScript(\"BlueRidge.Parts.DieRank.getInstancesForFlexRepeater\", 0)"
        },
        "type": "expr"
      }
    }
  },
