{
  "custom": {
    "ranks": [],
    "headerCells": [],
    "bodyRows": []
  },
  "params": {},
  "propConfig": {
    "custom.ranks": {
      "binding": {
        "type": "expr",
        "config": {
          "expression": "runScript(\"BlueRidge.Parts.DieRank.getInstancesForFlexRepeater\", 0)"
        }
      }
    },
    "custom.headerCells": {
      "binding": {
        "type": "expr",
        "config": {
          "expression": "runScript(\"BlueRidge.Parts.DieRank.getMatrixHeaderInstances\", 0)"
        }
      }
    },
    "custom.bodyRows": {
      "binding": {
        "type": "expr",
        "config": {
          "expression": "runScript(\"BlueRidge.Parts.DieRank.getMatrixRowInstances\", 0)"
        }
      }
    }
  },
  "props": {
    "defaultSize": {
      "width": 1000,
      "height": 640
    }
  },
  "root": {
    "type": "ia.container.flex",
    "meta": { "name": "root" },
    "props": {
      "direction": "column",
      "style": {
        "background": "var(--mpp-surface-canvas)",
        "borderRadius": "var(--mpp-radius-md, 8px)",
        "height": "100%",
        "overflow": "hidden",
        "width": "100%"
      }
    },
    "scripts": {
      "customMethods": [
        {
          "name": "handleToggle",
          "params": ["fromCode", "toCode"],
          "script": "\t# Flip the (fromCode, toCode) cell and its mirror (toCode, fromCode)\n\t# directly in the bodyRows custom prop. Assign a new top-level list\n\t# so Perspective re-renders the BodyRepeater + each affected cell.\n\tnewBodyRows = []\n\tfor rowInst in (self.view.custom.bodyRows or []):\n\t\trowDict = dict((rowInst or {}).get('row') or {})\n\t\tnewCells = []\n\t\tfor cellInst in (rowDict.get('cells') or []):\n\t\t\tc = dict((cellInst or {}).get('cell') or {})\n\t\t\tcfrom = c.get('fromCode')\n\t\t\tcto   = c.get('toCode')\n\t\t\tif (cfrom == fromCode and cto == toCode) or (cfrom == toCode and cto == fromCode):\n\t\t\t\tc['compatible'] = not bool(c.get('compatible'))\n\t\t\tnewCells.append({'cell': c})\n\t\trowDict['cells'] = newCells\n\t\tnewBodyRows.append({'row': rowDict})\n\tself.view.custom.bodyRows = newBodyRows"
        }
      ],
      "extensionFunctions": null,
      "messageHandlers": [
        {
          "messageType": "matrixCellToggle",
          "pageScope": true,
          "sessionScope": false,
          "viewScope": false,
          "script": "\tif payload is None:\n\t\treturn\n\tfromCode = payload.get('fromCode')\n\ttoCode   = payload.get('toCode')\n\tif fromCode is None or toCode is None:\n\t\treturn\n\tself.handleToggle(fromCode, toCode)"
        },
        {
          "messageType": "dieRankRefresh",
          "pageScope": true,
          "sessionScope": false,
          "viewScope": false,
          "script": "\tself.view.custom.ranks       = BlueRidge.Parts.DieRank.getInstancesForFlexRepeater()\n\tself.view.custom.headerCells = BlueRidge.Parts.DieRank.getMatrixHeaderInstances()\n\tself.view.custom.bodyRows    = BlueRidge.Parts.DieRank.getMatrixRowInstances()"
        }
      ]
    },
    "children": [
      {
        "type": "ia.container.flex",
        "meta": { "name": "HeaderBar" },
        "position": { "basis": "50px", "shrink": 0 },
        "props": {
          "alignItems": "center",
          "style": {
            "background": "var(--mpp-surface-raised)",
            "borderBottom": "1px solid var(--mpp-border-subtle)",
            "gap": "12px",
            "padding": "0 16px"
          }
        },
        "children": [
          {
            "type": "ia.display.label",
            "meta": { "name": "TitleLabel" },
            "props": {
              "text": "Die Ranks",
              "style": {
                "classes": "modal-title",
                "fontSize": "14px",
                "fontWeight": "600"
              }
            }
          },
          {
            "type": "ia.container.flex",
            "meta": { "name": "Spacer" },
            "position": { "grow": 1 }
          },
          {
            "type": "ia.display.icon",
            "meta": {
              "name": "CloseIcon",
              "tooltip": { "text": "Close" }
            },
            "events": {
              "dom": {
                "onClick": {
                  "type": "script",
                  "scope": "G",
                  "config": {
                    "script": "\tsystem.perspective.closePopup(id='mpp-die-ranks')"
                  }
                }
              }
            },
            "props": {
              "path": "mpp/cancel",
              "style": {
                "classes": "modal-close",
                "cursor": "pointer",
                "height": "18px",
                "width": "18px"
              }
            }
          }
        ]
      },
      {
        "type": "ia.container.flex",
        "meta": { "name": "Body" },
        "position": { "grow": 1 },
        "props": {
          "direction": "row",
          "style": {
            "overflow": "hidden"
          }
        },
        "children": [
          {
            "type": "ia.container.flex",
            "meta": { "name": "RankListPanel" },
            "position": { "basis": "200px", "shrink": 0 },
            "props": {
              "direction": "column",
              "style": {
                "background": "var(--mpp-surface-nav)",
                "borderRight": "1px solid var(--mpp-border-subtle)"
              }
            },
            "children": [
              {
                "type": "ia.display.label",
                "meta": { "name": "RankListHeader" },
                "position": { "basis": "auto", "shrink": 0 },
                "props": {
                  "text": "RANKS",
                  "style": {
                    "borderBottom": "1px solid var(--mpp-border-subtle)",
                    "color": "var(--mpp-text-muted)",
                    "fontSize": "11px",
                    "fontWeight": "600",
                    "letterSpacing": "0.04em",
                    "padding": "10px 12px 8px",
                    "textTransform": "uppercase"
                  }
                }
              },
              {
                "type": "ia.display.flex-repeater",
                "meta": { "name": "RankList" },
                "position": { "basis": "0", "grow": 1 },
                "propConfig": {
                  "props.instances": {
                    "binding": {
                      "type": "property",
                      "config": { "path": "view.custom.ranks" }
                    }
                  }
                },
                "props": {
                  "direction": "column",
                  "elementPosition": { "basis": "auto" },
                  "path": "BlueRidge/Components/Popups/_DieRanks/RankRow",
                  "style": {
                    "overflowY": "auto"
                  },
                  "useDefaultViewHeight": false,
                  "useDefaultViewWidth": false
                }
              },
              {
                "type": "ia.container.flex",
                "meta": { "name": "AddRankWrapper" },
                "position": { "basis": "auto", "shrink": 0 },
                "props": {
                  "style": {
                    "borderTop": "1px solid var(--mpp-border-subtle)",
                    "padding": "8px 12px"
                  }
                },
                "children": [
                  {
                    "type": "ia.input.button",
                    "meta": { "name": "BtnAddRank" },
                    "events": {
                      "component": {
                        "onActionPerformed": {
                          "type": "popup",
                          "scope": "C",
                          "config": {
                            "type": "open",
                            "id": "mpp-edit-rank",
                            "viewPath": "BlueRidge/Components/Popups/EditRank",
                            "modal": true,
                            "overlayDismiss": false,
                            "showCloseIcon": false,
                            "viewportBound": true,
                            "viewParams": {
                              "mode": "create",
                              "dieRankId": null
                            }
                          }
                        }
                      }
                    },
                    "props": {
                      "text": "+ Add Rank",
                      "style": {
                        "classes": "btn btn-primary",
                        "width": "100%"
                      }
                    }
                  }
                ]
              }
            ]
          },
          {
            "type": "ia.container.flex",
            "meta": { "name": "MatrixPanel" },
            "position": { "basis": "0", "grow": 1 },
            "props": {
              "direction": "column",
              "style": {
                "padding": "16px",
                "gap": "12px"
              }
            },
            "children": [
              {
                "type": "ia.container.flex",
                "meta": { "name": "IntroBlock" },
                "position": { "basis": "auto" },
                "props": {
                  "direction": "column",
                  "style": { "gap": "3px" }
                },
                "children": [
                  {
                    "type": "ia.display.label",
                    "meta": { "name": "MatrixTitle" },
                    "props": {
                      "text": "Merge Compatibility",
                      "style": {
                        "fontSize": "13px",
                        "fontWeight": "600"
                      }
                    }
                  },
                  {
                    "type": "ia.display.label",
                    "meta": { "name": "MatrixSubtitle" },
                    "props": {
                      "text": "Click a cell to toggle. Green = can merge. Red = blocked. Lower triangle mirrors the upper.",
                      "style": {
                        "color": "var(--mpp-text-muted)",
                        "fontSize": "11px"
                      }
                    }
                  }
                ]
              },
              {
                "type": "ia.container.flex",
                "meta": { "name": "MatrixGrid" },
                "position": { "basis": "auto" },
                "props": {
                  "direction": "column",
                  "style": { "gap": "5px" }
                },
                "children": [
                  {
                    "type": "ia.container.flex",
                    "meta": { "name": "HeaderRow" },
                    "props": {
                      "direction": "row",
                      "style": { "gap": "5px" }
                    },
                    "children": [
                      {
                        "type": "ia.container.flex",
                        "meta": { "name": "CornerCell" },
                        "position": { "basis": "100px", "shrink": 0 }
                      },
                      {
                        "type": "ia.display.flex-repeater",
                        "meta": { "name": "HeaderRepeater" },
                        "position": { "grow": 1 },
                        "propConfig": {
                          "props.instances": {
                            "binding": {
                              "type": "property",
                              "config": { "path": "view.custom.headerCells" }
                            }
                          }
                        },
                        "props": {
                          "direction": "row",
                          "elementPosition": { "basis": "90px", "shrink": 0 },
                          "path": "BlueRidge/Components/Popups/_DieRanks/MatrixHeaderCell",
                          "style": { "gap": "5px" },
                          "useDefaultViewHeight": false,
                          "useDefaultViewWidth": false
                        }
                      }
                    ]
                  },
                  {
                    "type": "ia.display.flex-repeater",
                    "meta": { "name": "BodyRepeater" },
                    "position": { "basis": "auto" },
                    "propConfig": {
                      "props.instances": {
                        "binding": {
                          "type": "property",
                          "config": { "path": "view.custom.bodyRows" }
                        }
                      }
                    },
                    "props": {
                      "direction": "column",
                      "elementPosition": { "basis": "auto" },
                      "path": "BlueRidge/Components/Popups/_DieRanks/MatrixRow",
                      "style": { "gap": "5px" },
                      "useDefaultViewHeight": false,
                      "useDefaultViewWidth": false
                    }
                  }
                ]
              },
              {
                "type": "ia.container.flex",
                "meta": { "name": "Legend" },
                "position": { "basis": "auto" },
                "props": {
                  "direction": "row",
                  "alignItems": "center",
                  "style": {
                    "color": "var(--mpp-text-muted)",
                    "fontSize": "11px",
                    "gap": "16px",
                    "paddingTop": "4px"
                  }
                },
                "children": [
                  {
                    "type": "ia.container.flex",
                    "meta": { "name": "LegendYes" },
                    "props": { "direction": "row", "alignItems": "center", "style": { "gap": "4px" } },
                    "children": [
                      { "type": "ia.container.flex", "meta": { "name": "Swatch" }, "position": { "basis": "14px", "shrink": 0 }, "props": { "style": { "background": "var(--mpp-state-good-bg)", "border": "1px solid var(--mpp-state-good-border)", "borderRadius": "3px", "height": "14px" } } },
                      { "type": "ia.display.label",  "meta": { "name": "Label" },  "props": { "text": "Can merge" } }
                    ]
                  },
                  {
                    "type": "ia.container.flex",
                    "meta": { "name": "LegendNo" },
                    "props": { "direction": "row", "alignItems": "center", "style": { "gap": "4px" } },
                    "children": [
                      { "type": "ia.container.flex", "meta": { "name": "Swatch" }, "position": { "basis": "14px", "shrink": 0 }, "props": { "style": { "background": "var(--mpp-state-bad-bg)", "border": "1px solid var(--mpp-state-bad-border)", "borderRadius": "3px", "height": "14px" } } },
                      { "type": "ia.display.label",  "meta": { "name": "Label" },  "props": { "text": "Blocked" } }
                    ]
                  },
                  {
                    "type": "ia.container.flex",
                    "meta": { "name": "LegendMirror" },
                    "props": { "direction": "row", "alignItems": "center", "style": { "gap": "4px" } },
                    "children": [
                      { "type": "ia.container.flex", "meta": { "name": "Swatch" }, "position": { "basis": "14px", "shrink": 0 }, "props": { "style": { "background": "var(--mpp-surface-card)", "border": "1px solid var(--mpp-border-subtle)", "borderRadius": "3px", "height": "14px" } } },
                      { "type": "ia.display.label",  "meta": { "name": "Label" },  "props": { "text": "Mirror" } }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "ia.container.flex",
        "meta": { "name": "FooterBar" },
        "position": { "basis": "50px", "shrink": 0 },
        "props": {
          "alignItems": "center",
          "justify": "flex-end",
          "style": {
            "background": "var(--mpp-surface-raised)",
            "borderTop": "1px solid var(--mpp-border-subtle)",
            "gap": "8px",
            "padding": "12px 16px"
          }
        },
        "children": [
          {
            "type": "ia.input.button",
            "meta": { "name": "CloseButton" },
            "position": { "shrink": 0 },
            "events": {
              "component": {
                "onActionPerformed": {
                  "type": "script",
                  "scope": "G",
                  "config": { "script": "\tsystem.perspective.closePopup(id='mpp-die-ranks')" }
                }
              }
            },
            "props": {
              "text": "Close",
              "style": { "classes": "btn btn-sm" }
            }
          },
          {
            "type": "ia.input.button",
            "meta": { "name": "SaveButton" },
            "position": { "shrink": 0 },
            "events": {
              "component": {
                "onActionPerformed": {
                  "type": "script",
                  "scope": "C",
                  "config": { "script": "\tBlueRidge.Common.Notify.toast('Saved (stub)', 'Die rank save lands in populate pass.', 'success', 4)\n\tsystem.perspective.closePopup(id='mpp-die-ranks')" }
                }
              }
            },
            "props": {
              "text": "Save",
              "style": { "classes": "btn btn-primary btn-sm" }
            }
          }
        ]
      }
    ]
  }
}
