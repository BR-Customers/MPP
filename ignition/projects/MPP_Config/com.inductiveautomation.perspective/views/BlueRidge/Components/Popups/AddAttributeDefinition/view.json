{
  "custom": {
    "editDraft": {
      "Code": "",
      "DataType": "String",
      "IsRequired": false,
      "Name": ""
    },
    "selected": {
      "Code": "",
      "DataType": "String",
      "IsRequired": false,
      "Name": ""
    }
  },
  "params": {
    "toolTypeId": 0
  },
  "propConfig": {
    "custom.selected": {
      "persistent": true
    },
    "params.toolTypeId": {
      "paramDirection": "input"
    }
  },
  "props": {
    "defaultSize": {
      "height": 380,
      "width": 480
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "meta": {
              "name": "TitleLabel"
            },
            "props": {
              "style": {
                "classes": "modal-title",
                "fontSize": "14px",
                "fontWeight": "600"
              },
              "text": "New Attribute Definition"
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "Spacer"
            },
            "position": {
              "grow": 1
            },
            "type": "ia.container.flex"
          },
          {
            "meta": {
              "name": "DirtyIndicator"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "expression": "if({view.custom.editDraft} !\u003d {view.custom.selected}, \"● Unsaved changes\", \"\")"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "color": "var(--mpp-accent)",
                "fontSize": "11px",
                "fontStyle": "italic"
              }
            },
            "type": "ia.display.label"
          },
          {
            "events": {
              "dom": {
                "onClick": {
                  "config": {
                    "script": "\tself.view.rootContainer.handleClose()"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "CloseIcon",
              "tooltip": {
                "text": "Close"
              }
            },
            "props": {
              "path": "mpp/cancel",
              "style": {
                "classes": "modal-close",
                "cursor": "pointer",
                "height": "18px",
                "width": "18px"
              }
            },
            "type": "ia.display.icon"
          }
        ],
        "meta": {
          "name": "HeaderBar"
        },
        "position": {
          "basis": "50px",
          "shrink": 0
        },
        "props": {
          "alignItems": "center",
          "style": {
            "background": "var(--mpp-surface-raised)",
            "borderBottom": "1px solid var(--mpp-border-subtle)",
            "gap": "12px",
            "overflow": "hidden",
            "padding": "0 16px"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "children": [
              {
                "meta": {
                  "name": "Label"
                },
                "props": {
                  "style": {
                    "classes": "field-label"
                  },
                  "text": "Code"
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "Input"
                },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "config": {
                        "bidirectional": true,
                        "path": "view.custom.editDraft.Code"
                      },
                      "type": "property"
                    }
                  }
                },
                "props": {
                  "placeholder": "e.g. CYCLE_TIME",
                  "style": {
                    "boxSizing": "border-box",
                    "classes": "search-input",
                    "width": "100%"
                  }
                },
                "type": "ia.input.text-field"
              }
            ],
            "meta": {
              "name": "CodeField"
            },
            "props": {
              "direction": "column",
              "style": {
                "gap": "4px",
                "overflow": "visible"
              }
            },
            "type": "ia.container.flex"
          },
          {
            "children": [
              {
                "meta": {
                  "name": "Label"
                },
                "props": {
                  "style": {
                    "classes": "field-label"
                  },
                  "text": "Name"
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "Input"
                },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "config": {
                        "bidirectional": true,
                        "path": "view.custom.editDraft.Name"
                      },
                      "type": "property"
                    }
                  }
                },
                "props": {
                  "placeholder": "e.g. Cycle Time",
                  "style": {
                    "boxSizing": "border-box",
                    "classes": "search-input",
                    "width": "100%"
                  }
                },
                "type": "ia.input.text-field"
              }
            ],
            "meta": {
              "name": "NameField"
            },
            "props": {
              "direction": "column",
              "style": {
                "gap": "4px",
                "overflow": "visible"
              }
            },
            "type": "ia.container.flex"
          },
          {
            "children": [
              {
                "meta": {
                  "name": "Label"
                },
                "props": {
                  "style": {
                    "classes": "field-label"
                  },
                  "text": "Data Type"
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "Input"
                },
                "propConfig": {
                  "props.value": {
                    "binding": {
                      "config": {
                        "bidirectional": true,
                        "path": "view.custom.editDraft.DataType"
                      },
                      "type": "property"
                    }
                  }
                },
                "props": {
                  "options": [
                    {
                      "label": "String",
                      "value": "String"
                    },
                    {
                      "label": "Integer",
                      "value": "Integer"
                    },
                    {
                      "label": "Decimal",
                      "value": "Decimal"
                    },
                    {
                      "label": "Boolean",
                      "value": "Boolean"
                    },
                    {
                      "label": "Date",
                      "value": "Date"
                    }
                  ],
                  "style": {
                    "boxSizing": "border-box",
                    "classes": "select",
                    "width": "100%"
                  }
                },
                "type": "ia.input.dropdown"
              }
            ],
            "meta": {
              "name": "DataTypeField"
            },
            "props": {
              "direction": "column",
              "style": {
                "gap": "4px",
                "overflow": "visible"
              }
            },
            "type": "ia.container.flex"
          },
          {
            "children": [
              {
                "meta": {
                  "name": "Input"
                },
                "propConfig": {
                  "props.selected": {
                    "binding": {
                      "config": {
                        "bidirectional": true,
                        "path": "view.custom.editDraft.IsRequired"
                      },
                      "type": "property"
                    }
                  }
                },
                "type": "ia.input.checkbox"
              },
              {
                "meta": {
                  "name": "Label"
                },
                "props": {
                  "style": {
                    "classes": "field-label"
                  },
                  "text": "Required"
                },
                "type": "ia.display.label"
              }
            ],
            "meta": {
              "name": "RequiredField"
            },
            "props": {
              "alignItems": "center",
              "style": {
                "gap": "8px"
              }
            },
            "type": "ia.container.flex"
          }
        ],
        "meta": {
          "name": "FormBody"
        },
        "position": {
          "grow": 1
        },
        "props": {
          "direction": "column",
          "style": {
            "gap": "12px",
            "overflowY": "auto",
            "padding": "16px"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "events": {
              "component": {
                "onActionPerformed": {
                  "config": {
                    "script": "\tself.view.rootContainer.handleClose()"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "CancelButton"
            },
            "position": {
              "basis": "62px",
              "shrink": 0
            },
            "props": {
              "style": {
                "classes": "btn btn-sm"
              },
              "text": "Cancel"
            },
            "type": "ia.input.button"
          },
          {
            "events": {
              "component": {
                "onActionPerformed": {
                  "config": {
                    "script": "\tself.view.rootContainer.handleCreate()"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "CreateButton"
            },
            "position": {
              "basis": "115px",
              "shrink": 0
            },
            "props": {
              "style": {
                "classes": "btn btn-primary btn-sm"
              },
              "text": "Create Definition"
            },
            "type": "ia.input.button"
          }
        ],
        "meta": {
          "name": "FooterBar"
        },
        "position": {
          "basis": "50px",
          "shrink": 0
        },
        "props": {
          "alignItems": "center",
          "justify": "flex-end",
          "style": {
            "background": "var(--mpp-surface-raised)",
            "borderTop": "1px solid var(--mpp-border-subtle)",
            "gap": "8px",
            "overflow": "hidden",
            "padding": "12px 16px"
          }
        },
        "type": "ia.container.flex"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "background": "var(--mpp-surface-canvas)",
        "borderRadius": "var(--mpp-radius-md, 8px)",
        "height": "100%",
        "overflow": "hidden",
        "width": "100%"
      }
    },
    "scripts": {
      "customMethods": [
        {
          "name": "handleCreate",
          "params": [],
          "script": "\ttoolTypeId \u003d self.view.params.toolTypeId\n\tif not toolTypeId:\n\t\tBlueRidge.Common.Notify.toast(\u0027Tool type required\u0027, \u0027Pick a tool first so the definition can be scoped.\u0027, \u0027warning\u0027)\n\t\treturn\n\tdraft \u003d self.view.custom.editDraft or {}\n\tresult \u003d BlueRidge.Parts.Tool.addAttributeDefinition(\n\t\ttoolTypeId,\n\t\tdraft.get(\u0027Code\u0027),\n\t\tdraft.get(\u0027Name\u0027),\n\t\tdraft.get(\u0027DataType\u0027),\n\t\tdraft.get(\u0027IsRequired\u0027),\n\t)\n\tBlueRidge.Common.Ui.notifyResult(result, \u0027Attribute definition created\u0027)\n\tif result and result.get(\u0027Status\u0027):\n\t\t#system.perspective.sendMessage(\u0027attributeDefinitionsChanged\u0027, payload\u003d{\u0027newId\u0027: result.get(\u0027NewId\u0027)}, scope\u003d\u0027page\u0027)\n\t\tsystem.perspective.sendMessage(\u0027refreshAttrOptions\u0027)\n\t\tsystem.perspective.closePopup(id\u003d\u0027mpp-add-attr-def\u0027)"
        },
        {
          "name": "handleClose",
          "params": [],
          "script": "\tif str(self.view.custom.editDraft) \u003d\u003d str(self.view.custom.selected):\n\t\tsystem.perspective.closePopup(id\u003d\"mpp-add-attr-def\")\n\telse:\n\t\tsystem.perspective.openPopup(\n\t\t\tid\u003d\"mpp-confirm-unsaved\",\n\t\t\tview\u003d\"BlueRidge/Components/Popups/ConfirmUnsaved\",\n\t\t\tmodal\u003dTrue,\n\t\t\tshowCloseIcon\u003dFalse,\n\t\t\tparams\u003d{\n\t\t\t\t\"title\": \"Unsaved Changes\",\n\t\t\t\t\"message\": \"You have unsaved changes to this Attribute Definition. Save before closing?\"\n\t\t\t}\n\t\t)"
        }
      ],
      "extensionFunctions": null,
      "messageHandlers": [
        {
          "messageType": "confirmUnsavedResult",
          "pageScope": true,
          "script": "\taction \u003d payload.get(\"action\") if payload else None\n\tif action \u003d\u003d \"save\":\n\t\tself.handleCreate()\n\telif action \u003d\u003d \"discard\":\n\t\tsystem.perspective.closePopup(id\u003d\"mpp-add-attr-def\")",
          "sessionScope": false,
          "viewScope": false
        }
      ]
    },
    "type": "ia.container.flex"
  }
}