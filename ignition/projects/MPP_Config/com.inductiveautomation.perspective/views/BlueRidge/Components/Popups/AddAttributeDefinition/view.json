{
  "custom": {
    "editDraft": {
      "Code": "",
      "Name": "",
      "DataType": "String",
      "IsRequired": false
    }
  },
  "params": {
    "toolTypeId": 0
  },
  "propConfig": {
    "params.toolTypeId": { "paramDirection": "input" }
  },
  "props": {
    "defaultSize": {
      "width": 480,
      "height": 380
    }
  },
  "root": {
    "type": "ia.container.flex",
    "meta": { "name": "root" },
    "props": {
      "direction": "column",
      "style": {
        "background": "var(--mpp-surface-canvas)",
        "borderRadius": "var(--mpp-radius-md, 8px)",
        "height": "100%",
        "overflow": "hidden",
        "width": "100%"
      }
    },
    "children": [
      {
        "type": "ia.container.flex",
        "meta": { "name": "HeaderBar" },
        "position": { "basis": "50px", "shrink": 0 },
        "props": {
          "alignItems": "center",
          "style": {
            "background": "var(--mpp-surface-raised)",
            "borderBottom": "1px solid var(--mpp-border-subtle)",
            "gap": "12px",
            "overflow": "hidden",
            "padding": "0 16px"
          }
        },
        "children": [
          {
            "type": "ia.display.label",
            "meta": { "name": "TitleLabel" },
            "props": {
              "text": "New Attribute Definition",
              "style": { "classes": "modal-title", "fontSize": "14px", "fontWeight": "600" }
            }
          },
          {
            "type": "ia.container.flex",
            "meta": { "name": "Spacer" },
            "position": { "grow": 1 }
          },
          {
            "type": "ia.display.icon",
            "meta": { "name": "CloseIcon", "tooltip": { "text": "Close" } },
            "events": {
              "dom": {
                "onClick": {
                  "type": "script",
                  "scope": "G",
                  "config": { "script": "\tsystem.perspective.closePopup(id='mpp-add-attr-def')" }
                }
              }
            },
            "props": {
              "path": "mpp/cancel",
              "style": { "classes": "modal-close", "cursor": "pointer", "height": "18px", "width": "18px" }
            }
          }
        ]
      },
      {
        "type": "ia.container.flex",
        "meta": { "name": "FormBody" },
        "position": { "grow": 1 },
        "props": {
          "direction": "column",
          "style": { "gap": "12px", "overflowY": "auto", "padding": "16px" }
        },
        "children": [
          {
            "type": "ia.container.flex",
            "meta": { "name": "CodeField" },
            "props": { "direction": "column", "style": { "gap": "4px" } },
            "children": [
              {
                "type": "ia.display.label",
                "meta": { "name": "Label" },
                "props": { "text": "Code", "style": { "classes": "field-label" } }
              },
              {
                "type": "ia.input.text-field",
                "meta": { "name": "Input" },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "type": "property",
                      "config": { "bidirectional": true, "path": "view.custom.editDraft.Code" }
                    }
                  }
                },
                "props": {
                  "placeholder": "e.g. CYCLE_TIME",
                  "style": { "boxSizing": "border-box", "classes": "search-input", "width": "100%" }
                }
              }
            ]
          },
          {
            "type": "ia.container.flex",
            "meta": { "name": "NameField" },
            "props": { "direction": "column", "style": { "gap": "4px" } },
            "children": [
              {
                "type": "ia.display.label",
                "meta": { "name": "Label" },
                "props": { "text": "Name", "style": { "classes": "field-label" } }
              },
              {
                "type": "ia.input.text-field",
                "meta": { "name": "Input" },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "type": "property",
                      "config": { "bidirectional": true, "path": "view.custom.editDraft.Name" }
                    }
                  }
                },
                "props": {
                  "placeholder": "e.g. Cycle Time",
                  "style": { "boxSizing": "border-box", "classes": "search-input", "width": "100%" }
                }
              }
            ]
          },
          {
            "type": "ia.container.flex",
            "meta": { "name": "DataTypeField" },
            "props": { "direction": "column", "style": { "gap": "4px" } },
            "children": [
              {
                "type": "ia.display.label",
                "meta": { "name": "Label" },
                "props": { "text": "Data Type", "style": { "classes": "field-label" } }
              },
              {
                "type": "ia.input.dropdown",
                "meta": { "name": "Input" },
                "propConfig": {
                  "props.value": {
                    "binding": {
                      "type": "property",
                      "config": { "bidirectional": true, "path": "view.custom.editDraft.DataType" }
                    }
                  }
                },
                "props": {
                  "options": [
                    { "label": "String",  "value": "String" },
                    { "label": "Integer", "value": "Integer" },
                    { "label": "Decimal", "value": "Decimal" },
                    { "label": "Boolean", "value": "Boolean" },
                    { "label": "Date",    "value": "Date" }
                  ],
                  "style": { "boxSizing": "border-box", "classes": "select", "width": "100%" }
                }
              }
            ]
          },
          {
            "type": "ia.container.flex",
            "meta": { "name": "RequiredField" },
            "props": { "direction": "row", "alignItems": "center", "style": { "gap": "8px" } },
            "children": [
              {
                "type": "ia.input.checkbox",
                "meta": { "name": "Input" },
                "propConfig": {
                  "props.selected": {
                    "binding": {
                      "type": "property",
                      "config": { "bidirectional": true, "path": "view.custom.editDraft.IsRequired" }
                    }
                  }
                },
                "props": {}
              },
              {
                "type": "ia.display.label",
                "meta": { "name": "Label" },
                "props": { "text": "Required", "style": { "classes": "field-label" } }
              }
            ]
          }
        ]
      },
      {
        "type": "ia.container.flex",
        "meta": { "name": "FooterBar" },
        "position": { "basis": "50px", "shrink": 0 },
        "props": {
          "alignItems": "center",
          "justify": "flex-end",
          "style": {
            "background": "var(--mpp-surface-raised)",
            "borderTop": "1px solid var(--mpp-border-subtle)",
            "gap": "8px",
            "overflow": "hidden",
            "padding": "12px 16px"
          }
        },
        "children": [
          {
            "type": "ia.input.button",
            "meta": { "name": "CancelButton" },
            "position": { "shrink": 0 },
            "events": {
              "component": {
                "onActionPerformed": {
                  "type": "script",
                  "scope": "G",
                  "config": { "script": "\tsystem.perspective.closePopup(id='mpp-add-attr-def')" }
                }
              }
            },
            "props": { "text": "Cancel", "style": { "classes": "btn btn-sm" } }
          },
          {
            "type": "ia.input.button",
            "meta": { "name": "CreateButton" },
            "position": { "shrink": 0 },
            "events": {
              "component": {
                "onActionPerformed": {
                  "type": "script",
                  "scope": "G",
                  "config": { "script": "\tself.view.rootContainer.handleCreate()" }
                }
              }
            },
            "props": { "text": "Create", "style": { "classes": "btn btn-primary btn-sm" } }
          }
        ]
      }
    ],
    "scripts": {
      "customMethods": [
        {
          "name": "handleCreate",
          "params": [],
          "script": "\ttoolTypeId = self.view.params.toolTypeId\n\tif not toolTypeId:\n\t\tBlueRidge.Common.Notify.toast('Tool type required', 'Pick a tool first so the definition can be scoped.', 'warning')\n\t\treturn\n\tdraft = self.view.custom.editDraft or {}\n\tresult = BlueRidge.Parts.Tool.addAttributeDefinition(\n\t\ttoolTypeId,\n\t\tdraft.get('Code'),\n\t\tdraft.get('Name'),\n\t\tdraft.get('DataType'),\n\t\tdraft.get('IsRequired'),\n\t)\n\tBlueRidge.Common.Ui.notifyResult(result, 'Attribute definition created')\n\tif result and result.get('Status'):\n\t\tsystem.perspective.sendMessage('attributeDefinitionsChanged', payload={'newId': result.get('NewId')}, scope='page')\n\t\tsystem.perspective.closePopup(id='mpp-add-attr-def')"
        }
      ],
      "extensionFunctions": null,
      "messageHandlers": []
    }
  }
}
