{
  "custom": {},
  "params": {
    "cancelLabel": "Cancel",
    "discardLabel": "Discard \u0026 Close",
    "message": "You have unsaved changes. Do you want to save before closing?",
    "popupId": "mpp-confirm-unsaved",
    "replyMessage": "confirmUnsavedResult",
    "saveLabel": "Save \u0026 Close",
    "title": "Unsaved Changes"
  },
  "propConfig": {
    "params.cancelLabel": {
      "paramDirection": "input"
    },
    "params.discardLabel": {
      "paramDirection": "input"
    },
    "params.message": {
      "paramDirection": "input"
    },
    "params.popupId": {
      "paramDirection": "input"
    },
    "params.replyMessage": {
      "paramDirection": "input"
    },
    "params.saveLabel": {
      "paramDirection": "input"
    },
    "params.title": {
      "paramDirection": "input"
    }
  },
  "props": {
    "defaultSize": {
      "height": 200,
      "width": 520
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "Title"
        },
        "position": {
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.title"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "classes": "modal-title",
            "color": "var(--mpp-text-primary)",
            "fontSize": "14px",
            "fontWeight": "600",
            "padding": "14px 16px 4px 16px"
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "Message"
        },
        "position": {
          "basis": "0",
          "grow": 1
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.message"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "color": "var(--mpp-text-secondary)",
            "fontSize": "12px",
            "lineHeight": "1.5",
            "padding": "8px 16px 16px 16px"
          }
        },
        "type": "ia.display.label"
      },
      {
        "children": [
          {
            "events": {
              "component": {
                "onActionPerformed": {
                  "config": {
                    "script": "\tsystem.perspective.sendMessage(self.view.params.replyMessage, payload\u003d{\"action\": \"cancel\"}, scope\u003d\"page\")\n\tsystem.perspective.closePopup(id\u003dself.view.params.popupId)"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "CancelButton"
            },
            "position": {
              "basis": "62px",
              "shrink": 0
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "path": "view.params.cancelLabel"
                  },
                  "type": "property"
                }
              }
            },
            "props": {
              "style": {
                "classes": "btn btn-sm"
              }
            },
            "type": "ia.input.button"
          },
          {
            "meta": {
              "name": "Spacer"
            },
            "position": {
              "grow": 1
            },
            "type": "ia.container.flex"
          },
          {
            "events": {
              "component": {
                "onActionPerformed": {
                  "config": {
                    "script": "\tsystem.perspective.sendMessage(self.view.params.replyMessage, payload\u003d{\"action\": \"discard\"}, scope\u003d\"page\")\n\tsystem.perspective.closePopup(id\u003dself.view.params.popupId)"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "DiscardButton"
            },
            "position": {
              "basis": "109px",
              "shrink": 0
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "path": "view.params.discardLabel"
                  },
                  "type": "property"
                }
              }
            },
            "props": {
              "style": {
                "classes": "btn btn-danger btn-sm"
              }
            },
            "type": "ia.input.button"
          },
          {
            "events": {
              "component": {
                "onActionPerformed": {
                  "config": {
                    "script": "\tsystem.perspective.sendMessage(self.view.params.replyMessage, payload\u003d{\"action\": \"save\"}, scope\u003d\"page\")\n\tsystem.perspective.closePopup(id\u003dself.view.params.popupId)"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "SaveButton"
            },
            "position": {
              "basis": "94px",
              "shrink": 0
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "path": "view.params.saveLabel"
                  },
                  "type": "property"
                }
              }
            },
            "props": {
              "style": {
                "classes": "btn btn-primary btn-sm"
              }
            },
            "type": "ia.input.button"
          }
        ],
        "meta": {
          "name": "Footer"
        },
        "position": {
          "basis": "60px",
          "shrink": 0
        },
        "props": {
          "alignItems": "center",
          "style": {
            "background": "var(--mpp-surface-raised)",
            "borderTop": "1px solid var(--mpp-border-subtle)",
            "gap": "8px",
            "overflow": "hidden",
            "padding": "12px 16px"
          }
        },
        "type": "ia.container.flex"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "background": "var(--mpp-surface-canvas)",
        "borderRadius": "var(--mpp-radius-md, 8px)",
        "height": "100%",
        "overflow": "hidden",
        "width": "100%"
      }
    },
    "type": "ia.container.flex"
  }
}