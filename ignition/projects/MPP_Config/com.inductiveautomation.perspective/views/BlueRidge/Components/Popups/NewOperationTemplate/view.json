{
  "custom": {
    "editDraft": {
      "Code": "",
      "Name": "",
      "AreaLocationId": null,
      "Description": ""
    },
    "areaOptions": []
  },
  "params": {},
  "propConfig": {
    "custom.areaOptions": {
      "binding": {
        "type": "expr",
        "config": {
          "expression": "runScript(\"BlueRidge.Parts.OperationTemplate.getAreasForDropdown\", 0)"
        }
      }
    }
  },
  "props": {
    "defaultSize": {
      "width": 520,
      "height": 400
    }
  },
  "root": {
    "type": "ia.container.flex",
    "meta": { "name": "root" },
    "props": {
      "direction": "column",
      "style": {
        "background": "var(--mpp-surface-canvas)",
        "borderRadius": "var(--mpp-radius-md, 8px)",
        "height": "100%",
        "overflow": "hidden",
        "width": "100%"
      }
    },
    "children": [
      {
        "type": "ia.container.flex",
        "meta": { "name": "HeaderBar" },
        "position": { "basis": "50px", "shrink": 0 },
        "props": {
          "alignItems": "center",
          "style": {
            "background": "var(--mpp-surface-raised)",
            "borderBottom": "1px solid var(--mpp-border-subtle)",
            "gap": "12px",
            "overflow": "hidden",
            "padding": "0 16px"
          }
        },
        "children": [
          {
            "type": "ia.display.label",
            "meta": { "name": "TitleLabel" },
            "props": {
              "text": "New Operation Template",
              "style": { "classes": "modal-title", "fontSize": "14px", "fontWeight": "600" }
            }
          },
          { "type": "ia.container.flex", "meta": { "name": "Spacer" }, "position": { "grow": 1 } },
          {
            "type": "ia.display.icon",
            "meta": { "name": "CloseIcon", "tooltip": { "text": "Close" } },
            "events": {
              "dom": {
                "onClick": {
                  "type": "script",
                  "scope": "G",
                  "config": { "script": "\tsystem.perspective.closePopup(id='mpp-new-operation-template')" }
                }
              }
            },
            "props": {
              "path": "mpp/cancel",
              "style": { "classes": "modal-close", "cursor": "pointer", "height": "18px", "width": "18px" }
            }
          }
        ]
      },
      {
        "type": "ia.container.flex",
        "meta": { "name": "FormBody" },
        "position": { "grow": 1 },
        "props": {
          "direction": "column",
          "style": { "gap": "12px", "overflowY": "auto", "padding": "16px" }
        },
        "children": [
          {
            "type": "ia.container.flex",
            "meta": { "name": "CodeField" },
            "props": { "direction": "column", "style": { "gap": "4px" } },
            "children": [
              { "type": "ia.display.label", "meta": { "name": "Label" }, "props": { "text": "Code", "style": { "classes": "field-label" } } },
              {
                "type": "ia.input.text-field",
                "meta": { "name": "Input" },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "type": "property",
                      "config": { "bidirectional": true, "path": "view.custom.editDraft.Code" }
                    }
                  }
                },
                "props": {
                  "placeholder": "e.g. DC-5G0",
                  "style": { "boxSizing": "border-box", "classes": "search-input", "width": "100%" }
                }
              }
            ]
          },
          {
            "type": "ia.container.flex",
            "meta": { "name": "NameField" },
            "props": { "direction": "column", "style": { "gap": "4px" } },
            "children": [
              { "type": "ia.display.label", "meta": { "name": "Label" }, "props": { "text": "Name", "style": { "classes": "field-label" } } },
              {
                "type": "ia.input.text-field",
                "meta": { "name": "Input" },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "type": "property",
                      "config": { "bidirectional": true, "path": "view.custom.editDraft.Name" }
                    }
                  }
                },
                "props": {
                  "placeholder": "e.g. Die Cast 5G0 Front Cover",
                  "style": { "boxSizing": "border-box", "classes": "search-input", "width": "100%" }
                }
              }
            ]
          },
          {
            "type": "ia.container.flex",
            "meta": { "name": "AreaField" },
            "props": { "direction": "column", "style": { "gap": "4px" } },
            "children": [
              { "type": "ia.display.label", "meta": { "name": "Label" }, "props": { "text": "Area", "style": { "classes": "field-label" } } },
              {
                "type": "ia.input.dropdown",
                "meta": { "name": "Input" },
                "propConfig": {
                  "props.options": {
                    "binding": {
                      "type": "property",
                      "config": { "path": "view.custom.areaOptions" }
                    }
                  },
                  "props.value": {
                    "binding": {
                      "type": "property",
                      "config": { "bidirectional": true, "path": "view.custom.editDraft.AreaLocationId" }
                    }
                  }
                },
                "props": {
                  "style": { "boxSizing": "border-box", "classes": "select", "width": "100%" }
                }
              }
            ]
          },
          {
            "type": "ia.container.flex",
            "meta": { "name": "DescriptionField" },
            "props": { "direction": "column", "style": { "gap": "4px" } },
            "children": [
              { "type": "ia.display.label", "meta": { "name": "Label" }, "props": { "text": "Description", "style": { "classes": "field-label" } } },
              {
                "type": "ia.input.text-field",
                "meta": { "name": "Input" },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "type": "property",
                      "config": { "bidirectional": true, "path": "view.custom.editDraft.Description" }
                    }
                  }
                },
                "props": {
                  "placeholder": "Optional description",
                  "style": { "boxSizing": "border-box", "classes": "search-input", "width": "100%" }
                }
              }
            ]
          }
        ]
      },
      {
        "type": "ia.container.flex",
        "meta": { "name": "FooterBar" },
        "position": { "basis": "50px", "shrink": 0 },
        "props": {
          "alignItems": "center",
          "justify": "flex-end",
          "style": {
            "background": "var(--mpp-surface-raised)",
            "borderTop": "1px solid var(--mpp-border-subtle)",
            "gap": "8px",
            "overflow": "hidden",
            "padding": "12px 16px"
          }
        },
        "children": [
          {
            "type": "ia.input.button",
            "meta": { "name": "CancelButton" },
            "position": { "shrink": 0 },
            "events": {
              "component": {
                "onActionPerformed": {
                  "type": "script",
                  "scope": "G",
                  "config": { "script": "\tsystem.perspective.closePopup(id='mpp-new-operation-template')" }
                }
              }
            },
            "props": { "text": "Cancel", "style": { "classes": "btn btn-sm" } }
          },
          {
            "type": "ia.input.button",
            "meta": { "name": "CreateButton" },
            "position": { "shrink": 0 },
            "events": {
              "component": {
                "onActionPerformed": {
                  "type": "script",
                  "scope": "G",
                  "config": { "script": "\tself.view.rootContainer.handleCreate()" }
                }
              }
            },
            "props": { "text": "Create Template", "style": { "classes": "btn btn-primary btn-sm" } }
          }
        ]
      }
    ],
    "scripts": {
      "customMethods": [
        {
          "name": "handleCreate",
          "params": [],
          "script": "\tdraft = self.view.custom.editDraft or {}\n\tif not (draft.get('Code') or '').strip():\n\t\tBlueRidge.Common.Notify.toast('Code required', 'Enter a code before creating.', 'warning')\n\t\treturn\n\tif not (draft.get('Name') or '').strip():\n\t\tBlueRidge.Common.Notify.toast('Name required', 'Enter a name before creating.', 'warning')\n\t\treturn\n\tif draft.get('AreaLocationId') is None:\n\t\tBlueRidge.Common.Notify.toast('Area required', 'Pick an area before creating.', 'warning')\n\t\treturn\n\tresult = BlueRidge.Parts.OperationTemplate.add(draft)\n\tBlueRidge.Common.Ui.notifyResult(result, 'Template created')\n\tif result and result.get('Status'):\n\t\tnewId = result.get('NewId')\n\t\tsystem.perspective.sendMessage('templateListRefresh', scope='page')\n\t\tif newId:\n\t\t\tsystem.perspective.sendMessage('templateSelectId', payload={'id': newId}, scope='page')\n\t\tsystem.perspective.closePopup(id='mpp-new-operation-template')"
        }
      ],
      "extensionFunctions": null,
      "messageHandlers": []
    }
  }
}
