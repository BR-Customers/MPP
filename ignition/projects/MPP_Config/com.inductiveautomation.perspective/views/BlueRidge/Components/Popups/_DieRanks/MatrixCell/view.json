{
  "custom": {},
  "params": {
    "cell": {}
  },
  "propConfig": {
    "params.cell": {
      "paramDirection": "input"
    }
  },
  "props": {
    "defaultSize": {
      "height": 30,
      "width": 90
    }
  },
  "root": {
    "events": {
      "dom": {
        "onClick": {
          "config": {
            "script": "\tcell \u003d self.view.params.cell or {}\n\tif cell.get(\u0027mirror\u0027):\n\t\treturn\n\tsystem.perspective.sendMessage(\n\t\t\u0027matrixCellToggle\u0027,\n\t\tpayload\u003d{\u0027fromCode\u0027: cell.get(\u0027fromCode\u0027), \u0027toCode\u0027: cell.get(\u0027toCode\u0027)},\n\t\tscope\u003d\u0027page\u0027)"
          },
          "scope": "G",
          "type": "script"
        }
      }
    },
    "meta": {
      "name": "root"
    },
    "propConfig": {
      "props.style.background": {
        "binding": {
          "config": {
            "expression": "if({view.params.cell.mirror}, \u0027var(--mpp-surface-card)\u0027, if({view.params.cell.compatible}, \u0027var(--mpp-state-good-bg)\u0027, \u0027var(--mpp-state-bad-bg)\u0027))"
          },
          "type": "expr"
        }
      },
      "props.style.border": {
        "binding": {
          "config": {
            "expression": "if({view.params.cell.mirror}, \u00271px solid var(--mpp-border-subtle)\u0027, if({view.params.cell.compatible}, \u00271px solid var(--mpp-state-good-border)\u0027, \u00271px solid var(--mpp-state-bad-border)\u0027))"
          },
          "type": "expr"
        }
      },
      "props.style.cursor": {
        "binding": {
          "config": {
            "expression": "if({view.params.cell.mirror}, \u0027default\u0027, \u0027pointer\u0027)"
          },
          "type": "expr"
        }
      }
    },
    "props": {
      "style": {
        "borderRadius": "3px",
        "height": "30px"
      }
    },
    "type": "ia.container.flex"
  }
}