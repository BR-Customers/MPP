                  "component": {
                    "onActionPerformed": {
                      "config": {
                        "script": "\tif self.view.custom.mode \u003d\u003d \"create\":\n\t\tself.view.custom.selected \u003d {\"meta\": None, \"attributes\": []}\n\t\tself.view.custom.editDraft \u003d {\"meta\": None, \"attributes\": []}\n\t\tself.view.custom.selectedDefId \u003d None\n\t\tself.view.custom.mode \u003d \"view\"\n\telse:\n\t\tsel \u003d self.view.custom.selected or {\"meta\": None, \"attributes\": []}\n\t\tself.view.custom.editDraft \u003d {\n\t\t\t\"meta\":       dict(sel.get(\"meta\")) if sel.get(\"meta\") else None,\n\t\t\t\"attributes\": [dict(a) for a in (sel.get(\"attributes\") or [])]\n\t\t}"
