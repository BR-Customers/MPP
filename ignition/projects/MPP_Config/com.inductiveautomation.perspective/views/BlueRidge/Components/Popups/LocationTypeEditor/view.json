    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "background": "var(--mpp-surface-canvas)",
        "borderRadius": "var(--mpp-radius-md, 8px)",
        "height": "100%",
        "overflow": "hidden",
        "width": "100%"
      }
    },
    "scripts": {
      "customMethods": [],
      "extensionFunctions": null,
      "messageHandlers": [
        {
          "messageType": "definitionClick",
          "pageScope": true,
          "script": "\tdefId \u003d payload.get(\"id\") if payload else None\n\tif defId is None:\n\t\tBlueRidge.Common.Notify.toast(\"Click error\", \"Definition click had no id; payload\u003d\" + str(payload), \"warning\")\n\t\treturn\n\tfor d in (self.view.custom.definitions or []):\n\t\tif d.get(\"Id\") \u003d\u003d defId:\n\t\t\tself.view.custom.selectedDefId \u003d defId\n\t\t\tself.view.custom.meta \u003d BlueRidge.Location.LocationTypeDefinition.metaFromDefinition(d)\n\t\t\tself.view.custom.attributesDraft \u003d BlueRidge.Location.LocationAttributeDefinition.listByDefinition(defId)\n\t\t\tself.view.custom.mode \u003d \"update\"\n\t\t\treturn\n\tBlueRidge.Common.Notify.toast(\"Stale selection\", \"Definition \" + str(defId) + \" not in current list -- selection ignored.\", \"warning\")",
          "sessionScope": false,
          "viewScope": false
        },
        {
          "messageType": "attrDraftUpdate",
          "pageScope": true,
          "script": "\tidx \u003d payload.get(\"index\")\n\tfield \u003d payload.get(\"field\")\n\tvalue \u003d payload.get(\"value\")\n\tdrafts \u003d list(self.view.custom.attributesDraft or [])\n\tif idx is not None and 0 \u003c\u003d idx \u003c len(drafts):\n\t\trow \u003d dict(drafts[idx])\n\t\trow[field] \u003d value\n\t\tdrafts[idx] \u003d row\n\t\tself.view.custom.attributesDraft \u003d drafts",
          "sessionScope": false,
          "viewScope": false
        },
        {
          "messageType": "attrDraftRemove",
          "pageScope": true,
          "script": "\tidx \u003d payload.get(\"index\")\n\tdrafts \u003d list(self.view.custom.attributesDraft or [])\n\tif idx is not None and 0 \u003c\u003d idx \u003c len(drafts):\n\t\tdrafts.pop(idx)\n\t\tself.view.custom.attributesDraft \u003d drafts",
          "sessionScope": false,
          "viewScope": false
        },
        {
          "messageType": "attrDraftMove",
          "pageScope": true,
          "script": "\tidx \u003d payload.get(\"index\")\n\tdirection \u003d payload.get(\"direction\")\n\tdrafts \u003d list(self.view.custom.attributesDraft or [])\n\tif idx is None:\n\t\treturn\n\tif direction \u003d\u003d \"up\" and idx \u003e 0:\n\t\tdrafts[idx-1], drafts[idx] \u003d drafts[idx], drafts[idx-1]\n\telif direction \u003d\u003d \"down\" and idx \u003c len(drafts) - 1:\n\t\tdrafts[idx+1], drafts[idx] \u003d drafts[idx], drafts[idx+1]\n\tself.view.custom.attributesDraft \u003d drafts",
          "sessionScope": false,
          "viewScope": false
        }
      ]
    },
    "type": "ia.container.flex"
  }
