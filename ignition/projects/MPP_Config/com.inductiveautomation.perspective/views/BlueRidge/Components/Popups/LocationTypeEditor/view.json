                "events": {
                  "component": {
                    "onActionPerformed": {
                      "config": {
                        "script": "\tdraft \u003d self.view.custom.editDraft or {\"meta\": None, \"attributes\": []}\n\tresult \u003d BlueRidge.Location.LocationTypeDefinition.handleSaveAll(draft.get(\"meta\"), draft.get(\"attributes\"))\n\tif not result:\n\t\treturn\n\t# Refresh definitions list for the parent flex-repeater\n\tself.view.custom.definitions \u003d result[\"definitions\"]\n\tself.view.custom.selectedDefId \u003d result[\"NewId\"]\n\t# Build the new editDraft (meta + Id, refreshed attributes from server)\n\tnewMeta \u003d dict(draft.get(\"meta\") or {})\n\tnewMeta[\"Id\"] \u003d result[\"NewId\"]\n\tnewAttrs \u003d result[\"attributes\"]\n\tself.view.custom.editDraft \u003d {\"meta\": newMeta, \"attributes\": newAttrs}\n\t# Commit baseline so dirty indicator clears\n\tself.view.custom.selected \u003d {\n\t\t\"meta\":       dict(newMeta),\n\t\t\"attributes\": [dict(a) for a in newAttrs]\n\t}\n\tself.view.custom.mode \u003d \"update\""
                      },
                      "scope": "G",
                      "type": "script"
                    }
                  }
                },
                "meta": {
                  "name": "SaveButton"
                },
                "position": {
                  "shrink": 0
                },
                "props": {
                  "style": {
                    "classes": "btn btn-primary btn-sm"
                  },
                  "text": "Save"
                },
                "type": "ia.input.button"
              },
              {
                "events": {
                  "component": {
                    "onActionPerformed": {
                      "config": {
                        "script": "\tdraft \u003d self.view.custom.editDraft or {}\n\tdefId \u003d (draft.get(\"meta\") or {}).get(\"Id\")\n\tif defId is None:\n\t\treturn\n\tresult \u003d BlueRidge.Location.LocationTypeDefinition.handleDeprecate(defId, self.view.custom.tierId)\n\tif not result:\n\t\treturn\n\tself.view.custom.definitions \u003d result[\"definitions\"]\n\tself.view.custom.selectedDefId \u003d None\n\tself.view.custom.selected \u003d {\"meta\": None, \"attributes\": []}\n\tself.view.custom.editDraft \u003d {\"meta\": None, \"attributes\": []}\n\tself.view.custom.mode \u003d \"view\""
                      },
                      "scope": "G",
                      "type": "script"
                    }
