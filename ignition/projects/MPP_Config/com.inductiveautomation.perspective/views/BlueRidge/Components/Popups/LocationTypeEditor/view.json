    "scripts": {
      "customMethods": [],
      "extensionFunctions": null,
      "messageHandlers": [
        {
          "messageType": "definitionClick",
          "pageScope": true,
          "script": "\tdefId \u003d payload.get(\"id\") if payload else None\n\tif defId is None:\n\t\tBlueRidge.Common.Notify.toast(\"Click error\", \"Definition click had no id; payload\u003d\" + str(payload), \"warning\")\n\t\treturn\n\tfor d in (self.view.custom.definitions or []):\n\t\tif d.get(\"Id\") \u003d\u003d defId:\n\t\t\tself.view.custom.selectedDefId \u003d defId\n\t\t\tmeta \u003d BlueRidge.Location.LocationTypeDefinition.metaFromDefinition(d)\n\t\t\tattrs \u003d BlueRidge.Location.LocationAttributeDefinition.getAll(defId)\n\t\t\tself.view.custom.selected \u003d {\n\t\t\t\t\"meta\":       meta,\n\t\t\t\t\"attributes\": attrs\n\t\t\t}\n\t\t\tself.view.custom.editDraft \u003d {\n\t\t\t\t\"meta\":       dict(meta) if meta else None,\n\t\t\t\t\"attributes\": [dict(a) for a in (attrs or [])]\n\t\t\t}\n\t\t\tself.view.custom.mode \u003d \"update\"\n\t\t\treturn\n\tBlueRidge.Common.Notify.toast(\"Stale selection\", \"Definition \" + str(defId) + \" not in current list -- selection ignored.\", \"warning\")",
          "sessionScope": false,
          "viewScope": false
        },
        {
          "messageType": "attrDraftUpdate",
          "pageScope": true,
          "script": "\tidx \u003d payload.get(\"index\")\n\tfield \u003d payload.get(\"field\")\n\tvalue \u003d payload.get(\"value\")\n\tdraft \u003d self.view.custom.editDraft or {\"meta\": None, \"attributes\": []}\n\tattrs \u003d list(draft.get(\"attributes\") or [])\n\tif idx is not None and 0 \u003c\u003d idx \u003c len(attrs):\n\t\trow \u003d dict(attrs[idx])\n\t\trow[field] \u003d value\n\t\tattrs[idx] \u003d row\n\t\tself.view.custom.editDraft \u003d {\"meta\": draft.get(\"meta\"), \"attributes\": attrs}",
          "sessionScope": false,
          "viewScope": false
        },
        {
          "messageType": "attrDraftRemove",
          "pageScope": true,
          "script": "\tidx \u003d payload.get(\"index\")\n\tdraft \u003d self.view.custom.editDraft or {\"meta\": None, \"attributes\": []}\n\tattrs \u003d list(draft.get(\"attributes\") or [])\n\tif idx is not None and 0 \u003c\u003d idx \u003c len(attrs):\n\t\tattrs.pop(idx)\n\t\tself.view.custom.editDraft \u003d {\"meta\": draft.get(\"meta\"), \"attributes\": attrs}",
          "sessionScope": false,
          "viewScope": false
        },
        {
          "messageType": "attrDraftMove",
          "pageScope": true,
          "script": "\tidx \u003d payload.get(\"index\")\n\tdirection \u003d payload.get(\"direction\")\n\tdraft \u003d self.view.custom.editDraft or {\"meta\": None, \"attributes\": []}\n\tattrs \u003d list(draft.get(\"attributes\") or [])\n\tif idx is None:\n\t\treturn\n\tif direction \u003d\u003d \"up\" and idx \u003e 0:\n\t\tattrs[idx-1], attrs[idx] \u003d attrs[idx], attrs[idx-1]\n\telif direction \u003d\u003d \"down\" and idx \u003c len(attrs) - 1:\n\t\tattrs[idx+1], attrs[idx] \u003d attrs[idx], attrs[idx+1]\n\tself.view.custom.editDraft \u003d {\"meta\": draft.get(\"meta\"), \"attributes\": attrs}",
          "sessionScope": false,
          "viewScope": false
        },
        {
          "messageType": "confirmUnsavedResult",
          "pageScope": true,
          "script": "\taction = payload.get(\"action\") if payload else None\n\tif action == \"save\":\n\t\tdraft = self.view.custom.editDraft or {\"meta\": None, \"attributes\": []}\n\t\tresult = BlueRidge.Location.LocationTypeDefinition.handleSaveAll(draft.get(\"meta\"), draft.get(\"attributes\"))\n\t\tif result and result.get(\"Status\"):\n\t\t\tsystem.perspective.closePopup(id=\"mpp-loc-type-editor\")\n\telif action == \"discard\":\n\t\tsystem.perspective.closePopup(id=\"mpp-loc-type-editor\")",
          "sessionScope": false,
          "viewScope": false
        }
      ]
    },
    "type": "ia.container.flex"
  }
