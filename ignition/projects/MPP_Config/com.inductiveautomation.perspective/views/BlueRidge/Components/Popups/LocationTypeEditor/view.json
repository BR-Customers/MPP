                  "transforms": [
                    {
                      "code": "\trows \u003d value or []\n\tn \u003d len(rows)\n\treturn [\n\t\t{\n\t\t\t\"index\":         i,\n\t\t\t\"totalRows\":     n,\n\t\t\t\"Id\":            r.get(\"Id\"),\n\t\t\t\"AttributeName\": r.get(\"AttributeName\") or \"\",\n\t\t\t\"DataType\":      r.get(\"DataType\") or \"NVARCHAR\",\n\t\t\t\"IsRequired\":    bool(r.get(\"IsRequired\")),\n\t\t\t\"DefaultValue\":  r.get(\"DefaultValue\") or \"\",\n\t\t\t\"Uom\":           r.get(\"Uom\") or \"\",\n\t\t\t\"Description\":   r.get(\"Description\") or \"\"\n\t\t}\n\t\tfor i, r in enumerate(rows)\n\t]",
                      "type": "script"
                    }
                  ],
                  "type": "property"
                }
              }
            },
            "props": {
              "direction": "column",
