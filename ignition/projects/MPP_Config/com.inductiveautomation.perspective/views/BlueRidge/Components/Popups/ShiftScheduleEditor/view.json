{
  "custom": {
    "editDraft": {
      "meta": {
        "id": null,
        "name": "",
        "description": "",
        "days": [],
        "startTime": "",
        "endTime": "",
        "effectiveFrom": "",
        "effectiveFromMillis": null
      }
    },
    "selected": {
      "meta": {
        "id": null,
        "name": "",
        "description": "",
        "days": [],
        "startTime": "",
        "endTime": "",
        "effectiveFrom": "",
        "effectiveFromMillis": null
      }
    }
  },
  "params": {
    "editId": null,
    "mode": "create"
  },
  "propConfig": {
    "params.editId": {
      "onChange": {
        "enabled": true,
        "script": "\tnewId = currentValue.value\n\tif newId is None:\n\t\tmeta = BlueRidge.Oee.ShiftSchedule.emptyMeta()\n\telse:\n\t\tmeta = BlueRidge.Oee.ShiftSchedule.loadMeta(newId)\n\tself.view.custom.selected = {\"meta\": meta}\n\tself.view.custom.editDraft = {\"meta\": dict(meta)}"
      },
      "paramDirection": "input",
      "persistent": true
    },
    "params.mode": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 560,
      "width": 560
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "meta": {
              "name": "TitleLabel"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "expression": "if({view.params.mode} = \"create\", \"Add Shift Schedule\", \"Edit Shift Schedule\")"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "classes": "modal-title",
                "fontSize": "14px",
                "fontWeight": "600"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "Spacer"
            },
            "position": {
              "grow": 1
            },
            "type": "ia.container.flex"
          },
          {
            "meta": {
              "name": "DirtyIndicator"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "expression": "if({view.custom.editDraft} != {view.custom.selected}, \"● Unsaved changes\", \"\")"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "color": "var(--mpp-accent)",
                "fontSize": "11px",
                "fontStyle": "italic"
              }
            },
            "type": "ia.display.label"
          },
          {
            "events": {
              "dom": {
                "onClick": {
                  "config": {
                    "script": "\tself.view.rootContainer.handleClose()"
                  },
