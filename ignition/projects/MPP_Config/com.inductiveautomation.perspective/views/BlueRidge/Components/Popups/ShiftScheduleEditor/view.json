                    "events": {
                      "component": {
                        "onActionPerformed": {
                          "config": {
                            "script": "\tdraft = dict(self.view.custom.editDraft)\n\tmeta = dict(draft.get(\"meta\") or {})\n\tdays = list(meta.get(\"days\") or [])\n\ti = 0\n\tif i in days:\n\t\tdays.remove(i)\n\telse:\n\t\tdays.append(i)\n\t\tdays.sort()\n\tmeta[\"days\"] = days\n\tdraft[\"meta\"] = meta\n\tself.view.custom.editDraft = draft"
                          },
                          "scope": "G",
                          "type": "script"
                        }
