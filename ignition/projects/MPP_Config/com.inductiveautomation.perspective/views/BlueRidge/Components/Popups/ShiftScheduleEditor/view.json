            },
            "meta": {
              "name": "DeprecateButton"
            },
            "position": {
              "shrink": 0
            },
            "propConfig": {
              "position.display": {
                "binding": {
                  "config": {
                    "expression": "{view.params.mode} = \"update\""
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "classes": "btn btn-danger btn-sm"
              },
              "text": "Deprecate"
            },
            "type": "ia.input.button"
          },
          {
            "children": [
              {
                "events": {
                  "component": {
                    "onActionPerformed": {
                      "config": {
                        "script": "\tself.view.rootContainer.handleClose()"
                      },
                      "scope": "G",
                      "type": "script"
                    }
                  }
                },
                "meta": {
                  "name": "CancelButton"
                },
                "position": {
                  "shrink": 0
                },
                "props": {
                  "style": {
                    "classes": "btn btn-sm"
                  },
                  "text": "Cancel"
                },
                "type": "ia.input.button"
              },
              {
                "events": {
                  "component": {
                    "onActionPerformed": {
                      "config": {
                        "script": "\tself.view.rootContainer.doSave()"
                      },
                      "scope": "G",
                      "type": "script"
                    }
                  }
                },
                "meta": {
                  "name": "SaveButton"
                },
                "position": {
                  "shrink": 0
                },
                "props": {
                  "style": {
                    "classes": "btn btn-primary btn-sm"
                  },
                  "text": "Save"
                },
                "type": "ia.input.button"
              }
            ],
            "meta": {
              "name": "RightCluster"
            },
            "props": {
              "alignItems": "center",
              "style": {
                "gap": "8px"
              }
            },
            "type": "ia.container.flex"
          }
        ],
        "meta": {
          "name": "FooterBar"
        },
        "position": {
          "basis": "50px",
          "shrink": 0
        },
        "props": {
          "alignItems": "center",
          "justify": "space-between",
          "style": {
            "background": "var(--mpp-surface-raised)",
            "borderTop": "1px solid var(--mpp-border-subtle)",
            "gap": "8px",
            "overflow": "hidden",
            "padding": "12px 16px"
          }
        },
        "type": "ia.container.flex"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "background": "var(--mpp-surface-canvas)",
        "borderRadius": "var(--mpp-radius-md, 8px)",
        "height": "100%",
        "overflow": "hidden",
        "width": "100%"
      }
    },
    "scripts": {
      "customMethods": [
        {
          "name": "doSave",
          "params": [],
          "script": "\timport re\n\tdraft = self.view.custom.editDraft.get(\"meta\", {}) if self.view.custom.editDraft else {}\n\tname = (draft.get(\"name\") or \"\").strip()\n\tdays = list(draft.get(\"days\") or [])\n\tst = (draft.get(\"startTime\") or \"\").strip()\n\tet = (draft.get(\"endTime\") or \"\").strip()\n\tmillis = draft.get(\"effectiveFromMillis\")\n\tpat = re.compile(\"^([01]?[0-9]|2[0-3]):[0-5][0-9]$\")\n\tif not name or not days or not pat.match(st) or not pat.match(et) or millis is None:\n\t\tBlueRidge.Common.Notify.toast(\"Cannot save\", \"Name, at least one day, valid HH:MM start/end times, and an effective date are required.\", \"warning\")\n\t\treturn\n\teff = system.date.format(system.date.fromMillis(long(millis)), \"yyyy-MM-dd\")\n\tmeta = {\n\t\t\"id\": draft.get(\"id\"),\n\t\t\"name\": name,\n\t\t\"description\": (draft.get(\"description\") or \"\").strip(),\n\t\t\"daysOfWeekBitmask\": BlueRidge.Oee.ShiftSchedule.daysToBitmask(days),\n\t\t\"startTime\": st,\n\t\t\"endTime\": et,\n\t\t\"effectiveFrom\": eff\n\t}\n\tif self.view.params.mode == \"create\":\n\t\tresult = BlueRidge.Oee.ShiftSchedule.add(meta)\n\t\tBlueRidge.Common.Ui.notifyResult(result, \"Shift schedule created\")\n\telse:\n\t\tresult = BlueRidge.Oee.ShiftSchedule.update(meta)\n\t\tBlueRidge.Common.Ui.notifyResult(result, \"Shift schedule updated\")\n\tif result and result.get(\"Status\"):\n\t\tsystem.perspective.sendMessage(\"shiftSchedulesRefresh\", scope=\"page\")\n\t\tsystem.perspective.closePopup(id=\"mpp-shift-schedule-editor\")"
        },
        {
          "name": "handleClose",
          "params": [],
          "script": "\tif str(self.view.custom.editDraft) == str(self.view.custom.selected):\n\t\tsystem.perspective.closePopup(id=\"mpp-shift-schedule-editor\")\n\telse:\n\t\tsystem.perspective.openPopup(\n\t\t\tid=\"mpp-confirm-unsaved\",\n\t\t\tview=\"BlueRidge/Components/Popups/ConfirmUnsaved\",\n\t\t\tmodal=True,\n\t\t\tshowCloseIcon=False,\n\t\t\tparams={\n\t\t\t\t\"title\": \"Unsaved Changes\",\n\t\t\t\t\"message\": \"You have unsaved changes to this shift schedule. Save before closing?\"\n\t\t\t}\n\t\t)"
        }
      ],
      "extensionFunctions": null,
      "messageHandlers": [
        {
          "messageType": "confirmUnsavedResult",
          "pageScope": true,
          "script": "\taction = payload.get(\"action\") if payload else None\n\tif action == \"save\":\n\t\tself.doSave()\n\telif action == \"discard\":\n\t\tsystem.perspective.closePopup(id=\"mpp-shift-schedule-editor\")",
          "sessionScope": false,
          "viewScope": false
        }
      ]
    },
    "type": "ia.container.flex"
  }
}
