{
  "custom": {
    "selected": { "meta": null },
    "editDraft": { "meta": null },
    "mode": "view",
    "filter": {
      "searchText": "",
      "areaLocationId": null,
      "includeDeprecated": false
    },
    "rows": [],
    "versions": [],
    "selectedTemplateCode": "",
    "selectedVersionId": 0,
    "showDeprecatedVersions": false,
    "fieldRows": [],
    "areaOptions": [],
    "fieldOptions": [],
    "selectedFieldDcfId": null,
    "fieldsState": {
      "selected":  { "rows": [] },
      "editDraft": { "rows": [] }
    },
    "fieldsDirty": false,
    "pendingNav": null,
    "dirty": false
  },
  "params": {},
  "propConfig": {
    "custom.filter.searchText":     { "persistent": true },
    "custom.filter.areaLocationId": { "persistent": true },
    "custom.dirty": {
      "binding": {
        "type": "expr",
        "config": {
          "expression": "runScript(\"BlueRidge.Common.Util.convertWrapperObjectToJson\", 0, {view.custom.editDraft}) != runScript(\"BlueRidge.Common.Util.convertWrapperObjectToJson\", 0, {view.custom.selected})"
        }
      }
    },
    "custom.rows": {
      "binding": {
        "type": "expr",
        "config": {
          "expression": "runScript(\"BlueRidge.Parts.OperationTemplate.search\", 0, {view.custom.filter})"
        }
      }
    },
    "custom.versions": {
      "binding": {
        "type": "expr",
        "config": {
          "expression": "runScript(\"BlueRidge.Parts.OperationTemplate.getVersionsForCode\", 0, {view.custom.selectedTemplateCode}, {view.custom.showDeprecatedVersions})"
        }
      }
    },
    "custom.areaOptions": {
      "binding": {
        "type": "expr",
        "config": {
          "expression": "runScript(\"BlueRidge.Parts.OperationTemplate.getAreasForDropdown\", 0)"
        }
      }
    },
    "custom.fieldOptions": {
      "binding": {
        "type": "expr",
        "config": {
          "expression": "runScript(\"BlueRidge.Parts.OperationTemplate.getAvailableDataCollectionFields\", 0, {view.custom.selectedVersionId})"
        }
      }
    },
    "custom.fieldsDirty": {
      "binding": {
        "type": "expr",
        "config": {
          "expression": "runScript(\"BlueRidge.Common.Util.convertWrapperObjectToJson\", 0, {view.custom.fieldsState.editDraft.rows}) != runScript(\"BlueRidge.Common.Util.convertWrapperObjectToJson\", 0, {view.custom.fieldsState.selected.rows})"
        }
      }
    }
  },
  "props": {
    "defaultSize": { "height": 1080, "width": 1920 }
  },
  "root": {
    "type": "ia.container.flex",
    "meta": { "name": "root" },
    "props": {
      "direction": "column",
      "style": { "classes": "canvas" }
    },
    "scripts": {
      "customMethods": [
        {
          "name": "_loadTemplate",
          "params": ["templateId"],
          "script": "\tmeta = BlueRidge.Parts.OperationTemplate.getOne(templateId)\n\tif meta is None:\n\t\tBlueRidge.Common.Notify.toast('Template not found', 'Id ' + str(templateId) + ' no longer exists.', 'warning')\n\t\treturn\n\tself.view.custom.selected   = {'meta': dict(meta)}\n\tself.view.custom.editDraft  = {'meta': dict(meta)}\n\tself.view.custom.mode = 'update'\n\tself.view.custom.selectedTemplateCode = meta.get('Code') or ''\n\tself.view.custom.selectedVersionId    = meta.get('Id') or 0\n\tself.view.custom.selectedFieldDcfId   = None\n\tself.loadFields()"
        },
        {
          "name": "_refreshDetail",
          "params": [],
          "script": "\tmeta = (self.view.custom.selected or {}).get('meta') or {}\n\ttemplateId = meta.get('Id')\n\tif templateId is None:\n\t\treturn\n\tself.loadFields()"
        },
        {
          "name": "loadFields",
          "params": [],
          "script": "\tmeta = (self.view.custom.selected or {}).get('meta') or {}\n\ttemplateId = meta.get('Id')\n\tif templateId is None:\n\t\tempty = {'rows': []}\n\t\tself.view.custom.fieldsState = {'selected': dict(empty), 'editDraft': dict(empty)}\n\t\treturn\n\tinstances = BlueRidge.Parts.OperationTemplate.getFieldsForTemplate(templateId) or []\n\tloaded = []\n\tfor inst in instances:\n\t\tf = (inst or {}).get('field') or {}\n\t\tloaded.append({\n\t\t\t'id':                    f.get('Id'),\n\t\t\t'dataCollectionFieldId': f.get('DataCollectionFieldId'),\n\t\t\t'code':                  f.get('Code') or '',\n\t\t\t'name':                  f.get('Name') or '',\n\t\t\t'isRequired':            bool(f.get('IsRequired')),\n\t\t})\n\tself.view.custom.fieldsState = {'selected': {'rows': loaded}, 'editDraft': {'rows': [dict(r) for r in loaded]}}"
        },
        {
          "name": "handleSaveFields",
          "params": [],
          "script": "\tmeta = (self.view.custom.selected or {}).get('meta') or {}\n\ttemplateId = meta.get('Id')\n\tif templateId is None:\n\t\tBlueRidge.Common.Notify.toast('No template selected', 'Pick a template before saving.', 'warning')\n\t\treturn\n\tdraft = BlueRidge.Common.Util.extractQualifiedValues(self.view.custom.fieldsState.editDraft) or {}\n\trows = draft.get('rows') or []\n\tresult = BlueRidge.Parts.OperationTemplate.saveFieldsAll(templateId, rows)\n\tBlueRidge.Common.Ui.notifyResult(result, 'Fields saved')\n\tif result and result.get('Status'):\n\t\tself.loadFields()"
        },
        {
          "name": "handleDiscardFields",
          "params": [],
          "script": "\tselected = BlueRidge.Common.Util.extractQualifiedValues(self.view.custom.fieldsState.selected) or {'rows': []}\n\tself.view.custom.fieldsState = {'selected': selected, 'editDraft': {'rows': [dict(r) for r in (selected.get('rows') or [])]}}"
        },
        {
          "name": "addFieldRow",
          "params": [],
          "script": "\tdraft = dict(BlueRidge.Common.Util.extractQualifiedValues(self.view.custom.fieldsState.editDraft) or {'rows': []})\n\trows = list(draft.get('rows') or [])\n\trows.append({\n\t\t'id':                    None,\n\t\t'dataCollectionFieldId': None,\n\t\t'code':                  '',\n\t\t'name':                  '',\n\t\t'isRequired':            True,\n\t})\n\tdraft['rows'] = rows\n\tselected = BlueRidge.Common.Util.extractQualifiedValues(self.view.custom.fieldsState.selected) or {'rows': []}\n\tself.view.custom.fieldsState = {'selected': selected, 'editDraft': draft}"
        },
        {
          "name": "_applyFieldChange",
          "params": ["idx", "newFieldId"],
          "script": "\tdraft = dict(BlueRidge.Common.Util.extractQualifiedValues(self.view.custom.fieldsState.editDraft) or {'rows': []})\n\trows = list(draft.get('rows') or [])\n\tif idx < 0 or idx >= len(rows):\n\t\treturn\n\trow = dict(rows[idx])\n\trow['dataCollectionFieldId'] = newFieldId\n\t# Derive code/name from the matching option label ('CODE - Name') when present.\n\topts = BlueRidge.Common.Util.extractQualifiedValues(self.view.custom.fieldOptions) or []\n\tlabel = None\n\tfor o in opts:\n\t\tif o.get('value') == newFieldId:\n\t\t\tlabel = o.get('label')\n\t\t\tbreak\n\tif label and ' - ' in label:\n\t\tparts = label.split(' - ', 1)\n\t\trow['code'] = parts[0]\n\t\trow['name'] = parts[1]\n\telse:\n\t\trow['code'] = ''\n\t\trow['name'] = ''\n\trows[idx] = row\n\tdraft['rows'] = rows\n\tselected = BlueRidge.Common.Util.extractQualifiedValues(self.view.custom.fieldsState.selected) or {'rows': []}\n\tself.view.custom.fieldsState = {'selected': selected, 'editDraft': draft}"
        },
        {
          "name": "_applyFieldRequiredChange",
          "params": ["idx", "isRequired"],
          "script": "\tdraft = dict(BlueRidge.Common.Util.extractQualifiedValues(self.view.custom.fieldsState.editDraft) or {'rows': []})\n\trows = list(draft.get('rows') or [])\n\tif idx < 0 or idx >= len(rows):\n\t\treturn\n\trow = dict(rows[idx])\n\trow['isRequired'] = bool(isRequired)\n\trows[idx] = row\n\tdraft['rows'] = rows\n\tselected = BlueRidge.Common.Util.extractQualifiedValues(self.view.custom.fieldsState.selected) or {'rows': []}\n\tself.view.custom.fieldsState = {'selected': selected, 'editDraft': draft}"
        },
        {
          "name": "_removeFieldRow",
          "params": ["idx"],
          "script": "\tdraft = dict(BlueRidge.Common.Util.extractQualifiedValues(self.view.custom.fieldsState.editDraft) or {'rows': []})\n\trows = list(draft.get('rows') or [])\n\tif idx < 0 or idx >= len(rows):\n\t\treturn\n\tdel rows[idx]\n\tdraft['rows'] = rows\n\tselected = BlueRidge.Common.Util.extractQualifiedValues(self.view.custom.fieldsState.selected) or {'rows': []}\n\tself.view.custom.fieldsState = {'selected': selected, 'editDraft': draft}"
        }
      ],
      "extensionFunctions": null,
      "messageHandlers": [
        {
          "messageType": "templateRowClicked",
          "pageScope": true,
          "sessionScope": false,
          "viewScope": false,
          "script": "\tclickedId = (payload or {}).get('id')\n\tif clickedId is None:\n\t\treturn\n\tif self.view.custom.dirty or self.view.custom.fieldsDirty:\n\t\tself.view.custom.pendingNav = clickedId\n\t\tsystem.perspective.openPopup(\n\t\t\tid='mpp-confirm-unsaved',\n\t\t\tview='BlueRidge/Components/Popups/ConfirmUnsaved',\n\t\t\tmodal=True,\n\t\t\tshowCloseIcon=False,\n\t\t\tparams={\n\t\t\t\t'title':   'Unsaved changes',\n\t\t\t\t'message': 'Save changes before switching templates?'\n\t\t\t}\n\t\t)\n\t\treturn\n\tself._loadTemplate(clickedId)"
        },
        {
          "messageType": "templateListRefresh",
          "pageScope": true,
          "sessionScope": false,
          "viewScope": false,
          "script": "\tself.view.custom.rows = BlueRidge.Parts.OperationTemplate.search(self.view.custom.filter)\n\tself._refreshDetail()"
        },
        {
          "messageType": "templateSelectId",
          "pageScope": true,
          "sessionScope": false,
          "viewScope": false,
          "script": "\ttemplateId = (payload or {}).get('id')\n\tif templateId is None:\n\t\treturn\n\tself._loadTemplate(templateId)"
        },
        {
          "messageType": "confirmUnsavedResult",
          "pageScope": true,
          "sessionScope": false,
          "viewScope": false,
          "script": "\taction = (payload or {}).get('action')\n\tpendingId = self.view.custom.pendingNav\n\tself.view.custom.pendingNav = None\n\tif pendingId is None:\n\t\treturn\n\tif action == 'cancel':\n\t\t# Revert the version dropdown to the currently-selected template.\n\t\tcurrentId = ((self.view.custom.selected or {}).get('meta') or {}).get('Id') or 0\n\t\tself.view.custom.selectedVersionId = currentId\n\t\treturn\n\tif action == 'save':\n\t\tdraft = self.view.custom.editDraft or {}\n\t\tmeta  = draft.get('meta') or {}\n\t\tif meta.get('Id') is not None:\n\t\t\tresult = BlueRidge.Parts.OperationTemplate.update(meta)\n\t\t\tBlueRidge.Common.Ui.notifyResult(result, 'Template saved')\n\t\tif self.view.custom.fieldsDirty:\n\t\t\tself.handleSaveFields()\n\tself._loadTemplate(pendingId)"
        },
        {
          "messageType": "templateDeprecateConfirmed",
          "pageScope": true,
          "sessionScope": false,
          "viewScope": false,
          "script": "\taction = (payload or {}).get('action')\n\tif action != 'confirm':\n\t\treturn\n\tmeta = (self.view.custom.selected or {}).get('meta') or {}\n\ttemplateId = meta.get('Id')\n\tif templateId is None:\n\t\treturn\n\tresult = BlueRidge.Parts.OperationTemplate.deprecate(templateId)\n\tBlueRidge.Common.Ui.notifyResult(result, 'Template deprecated')\n\tif result and result.get('Status'):\n\t\tself.view.custom.selected  = {'meta': None}\n\t\tself.view.custom.editDraft = {'meta': None}\n\t\tself.view.custom.mode = 'view'\n\t\tself.view.custom.selectedTemplateCode = ''\n\t\tself.view.custom.selectedVersionId    = 0\n\t\tself.view.custom.fieldsState = {\"selected\": {\"rows\": []}, \"editDraft\": {\"rows\": []}}\n\t\tsystem.perspective.sendMessage('templateListRefresh', scope='page')"
        },
        {
          "messageType": "templateVersionClicked",
          "pageScope": true,
          "sessionScope": false,
          "viewScope": false,
          "script": "\tclickedId = (payload or {}).get('id')\n\tif clickedId is None:\n\t\treturn\n\tif self.view.custom.dirty or self.view.custom.fieldsDirty:\n\t\tself.view.custom.pendingNav = clickedId\n\t\tsystem.perspective.openPopup(\n\t\t\tid='mpp-confirm-unsaved',\n\t\t\tview='BlueRidge/Components/Popups/ConfirmUnsaved',\n\t\t\tmodal=True,\n\t\t\tshowCloseIcon=False,\n\t\t\tparams={\n\t\t\t\t'title':   'Unsaved changes',\n\t\t\t\t'message': 'Save changes before switching versions?'\n\t\t\t}\n\t\t)\n\t\treturn\n\tself._loadTemplate(clickedId)"
        },
        {
          "messageType": "fieldRowFieldChanged",
          "pageScope": true,
          "sessionScope": false,
          "viewScope": false,
          "script": "\tif not payload:\n\t\treturn\n\tidx = int(payload.get('rowIndex', -1))\n\tself._applyFieldChange(idx, payload.get('newFieldId'))"
        },
        {
          "messageType": "fieldRowRequiredChanged",
          "pageScope": true,
          "sessionScope": false,
          "viewScope": false,
          "script": "\tif not payload:\n\t\treturn\n\tidx = int(payload.get('rowIndex', -1))\n\tself._applyFieldRequiredChange(idx, payload.get('isRequired'))"
        },
        {
          "messageType": "fieldRowRemove",
          "pageScope": true,
          "sessionScope": false,
          "viewScope": false,
          "script": "\tif not payload:\n\t\treturn\n\tidx = int(payload.get('rowIndex', -1))\n\tself._removeFieldRow(idx)"
        }
      ]
    },
    "children": [
      {
        "type": "ia.container.flex",
        "meta": { "name": "TitleBar" },
        "position": { "shrink": 0 },
        "props": {
          "alignItems": "center",
          "style": {
            "background": "var(--mpp-surface-card)",
            "borderBottom": "1px solid var(--mpp-border-subtle)",
            "gap": "12px",
            "padding": "8px 16px"
          }
        },
        "children": [
          {
            "type": "ia.container.flex",
            "meta": { "name": "TitleColumn" },
            "position": { "basis": "auto" },
            "props": { "direction": "column", "style": { "gap": "2px" } },
            "children": [
              {
                "type": "ia.container.flex",
                "meta": { "name": "Breadcrumb" },
                "position": { "basis": "auto" },
                "props": {
                  "direction": "row",
                  "alignItems": "center",
                  "style": { "classes": "breadcrumb" }
                },
                "children": [
                  { "type": "ia.display.label", "meta": { "name": "BreadcrumbCategory" }, "position": { "basis": "auto" }, "props": { "text": "Parts", "style": { "classes": "breadcrumb" } } },
                  { "type": "ia.display.label", "meta": { "name": "BreadcrumbSep" },     "position": { "basis": "auto" }, "props": { "text": "›",     "style": { "classes": "breadcrumb crumb-sep" } } },
                  { "type": "ia.display.label", "meta": { "name": "BreadcrumbActive" },  "position": { "basis": "auto" }, "props": { "text": "Operation Templates", "style": { "classes": "crumb-active" } } }
                ]
              },
              {
                "type": "ia.display.label",
                "meta": { "name": "LabelTitle" },
                "position": { "basis": "auto" },
                "props": { "text": "Operation Templates", "style": { "classes": "title-row-h1" } }
              }
            ]
          },
          {
            "type": "ia.display.label",
            "meta": { "name": "LabelDirty" },
            "propConfig": {
              "props.text": {
                "binding": {
                  "type": "expr",
                  "config": { "expression": "if({view.custom.dirty} || {view.custom.fieldsDirty}, '● Unsaved changes', '')" }
                }
              }
            },
            "props": {
              "text": "",
              "style": {
                "color": "var(--mpp-state-warn-fg)",
                "fontSize": "12px",
                "fontStyle": "italic"
              }
            }
          },
          { "type": "ia.container.flex", "meta": { "name": "TitleSpacer" }, "position": { "grow": 1 } },
          {
            "type": "ia.input.button",
            "meta": { "name": "BtnNewTemplate" },
            "events": {
              "component": {
                "onActionPerformed": {
                  "type": "script",
                  "scope": "G",
                  "config": {
                    "script": "\tsystem.perspective.openPopup(\n\t\tid='mpp-new-operation-template',\n\t\tview='BlueRidge/Components/Popups/NewOperationTemplate',\n\t\tmodal=True,\n\t\tshowCloseIcon=False\n\t)"
                  }
                }
              }
            },
            "props": {
              "text": "+ New Template",
              "style": { "classes": "btn btn-primary" }
            }
          }
        ]
      },
      {
        "type": "ia.container.flex",
        "meta": { "name": "Main" },
        "position": { "basis": "0", "grow": 1 },
        "props": {
          "style": {
            "borderTop": "1px solid var(--mpp-border-subtle)",
            "overflow": "hidden"
          }
        },
        "children": [
          {
            "type": "ia.container.flex",
            "meta": { "name": "LeftPanel" },
            "position": { "basis": "240px", "shrink": 0 },
            "props": {
              "direction": "column",
              "style": {
                "background": "var(--mpp-surface-nav)",
                "borderRight": "1px solid var(--mpp-border-subtle)"
              }
            },
            "children": [
              {
                "type": "ia.container.flex",
                "meta": { "name": "FilterBar" },
                "position": { "shrink": 0 },
                "props": {
                  "direction": "column",
                  "style": {
                    "borderBottom": "1px solid var(--mpp-border-subtle)",
                    "gap": "6px",
                    "padding": "8px 10px"
                  }
                },
                "children": [
                  {
                    "type": "ia.input.dropdown",
                    "meta": { "name": "DropdownArea" },
                    "propConfig": {
                      "props.value": {
                        "binding": {
                          "type": "property",
                          "config": { "bidirectional": true, "path": "view.custom.filter.areaLocationId" }
                        }
                      },
                      "props.options": {
                        "binding": {
                          "type": "property",
                          "config": { "path": "view.custom.areaOptions" }
                        }
                      }
                    },
                    "props": {
                      "options": [],
                      "noSelectionText": "All Areas",
                      "style": { "classes": "select" }
                    }
                  },
                  {
                    "type": "ia.input.text-field",
                    "meta": { "name": "InputSearch" },
                    "propConfig": {
                      "props.text": {
                        "binding": {
                          "type": "property",
                          "config": { "bidirectional": true, "path": "view.custom.filter.searchText" }
                        }
                      }
                    },
                    "props": {
                      "placeholder": "🔍 Search templates…",
                      "style": { "classes": "search-input" }
                    }
                  }
                ]
              },
              {
                "type": "ia.display.flex-repeater",
                "meta": { "name": "TemplateList" },
                "position": { "basis": "0", "grow": 1 },
                "propConfig": {
                  "props.instances": {
                    "binding": {
                      "type": "property",
                      "config": { "path": "view.custom.rows" }
                    }
                  }
                },
                "props": {
                  "direction": "column",
                  "elementPosition": { "basis": "44px", "shrink": 0 },
                  "path": "BlueRidge/Components/Parts/OperationTemplates/_OperationTemplates/TemplateRow",
                  "style": { "overflowY": "auto", "padding": "4px 0" },
                  "useDefaultViewHeight": true,
                  "useDefaultViewWidth": false
                }
              }
            ]
          },
          {
            "type": "ia.container.flex",
            "meta": { "name": "DetailArea" },
            "position": { "basis": "0", "grow": 1 },
            "propConfig": {
              "position.display": {
                "binding": {
                  "type": "expr",
                  "config": { "expression": "{view.custom.mode} != \"view\"" }
                }
              }
            },
            "props": {
              "direction": "column",
              "style": { "overflow": "hidden", "gap": "10px", "padding": "12px 14px" }
            },
            "children": [
              {
                "type": "ia.container.flex",
                "meta": { "name": "DetailsPanel" },
                "position": { "basis": "auto", "shrink": 0 },
                "props": {
                  "direction": "column",
                  "style": {
                    "classes": "detail-panel",
                    "overflow": "hidden",
                    "padding": "10px 14px",
                    "gap": "10px"
                  }
                },
                "children": [
                  {
                    "type": "ia.container.flex",
                    "meta": { "name": "SummaryRow" },
                    "props": {
                      "alignItems": "center",
                      "style": { "gap": "8px" }
                    },
                    "children": [
                      {
                        "type": "ia.display.label",
                        "meta": { "name": "SummaryText" },
                        "propConfig": {
                          "props.text": {
                            "binding": {
                              "type": "expr",
                              "config": {
                                "expression": "if(isNull({view.custom.editDraft.meta.Code}), '', {view.custom.editDraft.meta.Code} + ' — ' + {view.custom.editDraft.meta.Name})"
                              }
                            }
                          }
                        },
                        "props": { "style": { "fontSize": "13px", "fontWeight": "600" } }
                      },
                      {
                        "type": "ia.display.label",
                        "meta": { "name": "SummaryBadgeVersion" },
                        "propConfig": {
                          "props.text": {
                            "binding": {
                              "type": "expr",
                              "config": { "expression": "'v' + {view.custom.editDraft.meta.VersionNumber}" }
                            }
                          }
                        },
                        "props": { "style": { "classes": "badge badge-type" } }
                      },
                      {
                        "type": "ia.display.label",
                        "meta": { "name": "SummaryBadgeDeprecated" },
                        "propConfig": {
                          "position.display": {
                            "binding": {
                              "type": "expr",
                              "config": { "expression": "{view.custom.editDraft.meta.DeprecatedAt} != null" }
                            }
                          }
                        },
                        "props": { "text": "Deprecated", "style": { "classes": "badge badge-deprecated" } }
                      },
                      { "type": "ia.container.flex", "meta": { "name": "SummarySpacer" }, "position": { "grow": 1 } },
                      {
                        "type": "ia.input.button",
                        "meta": { "name": "BtnSave" },
                        "events": {
                          "component": {
                            "onActionPerformed": {
                              "type": "script",
                              "scope": "G",
                              "config": {
                                "script": "\tdraft = self.view.custom.editDraft or {}\n\tmeta  = draft.get('meta') or {}\n\tif meta.get('Id') is None:\n\t\tBlueRidge.Common.Notify.toast('No template selected', 'Pick one from the list first.', 'warning')\n\t\treturn\n\tresult = BlueRidge.Parts.OperationTemplate.update(meta)\n\tBlueRidge.Common.Ui.notifyResult(result, 'Template saved')\n\tif result and result.get('Status'):\n\t\trefreshed = BlueRidge.Parts.OperationTemplate.getOne(meta.get('Id'))\n\t\tif refreshed is not None:\n\t\t\tself.view.custom.selected  = {'meta': dict(refreshed)}\n\t\t\tself.view.custom.editDraft = {'meta': dict(refreshed)}\n\t\tsystem.perspective.sendMessage('templateListRefresh', scope='page')"
                              }
                            }
                          }
                        },
                        "props": { "text": "Save", "style": { "classes": "btn btn-primary btn-sm" } }
                      },
                      {
                        "type": "ia.input.button",
                        "meta": { "name": "BtnNewVersion" },
                        "events": {
                          "component": {
                            "onActionPerformed": {
                              "type": "script",
                              "scope": "G",
                              "config": {
                                "script": "\tmeta = (self.view.custom.selected or {}).get('meta') or {}\n\ttemplateId = meta.get('Id')\n\tif templateId is None:\n\t\treturn\n\tresult = BlueRidge.Parts.OperationTemplate.createNewVersion(templateId)\n\tBlueRidge.Common.Ui.notifyResult(result, 'New version created')\n\tif result and result.get('Status'):\n\t\tnewId = result.get('NewId')\n\t\tsystem.perspective.sendMessage('templateListRefresh', scope='page')\n\t\tif newId:\n\t\t\tsystem.perspective.sendMessage('templateSelectId', payload={'id': newId}, scope='page')"
                              }
                            }
                          }
                        },
                        "props": { "text": "New Version", "style": { "classes": "btn btn-sm" } }
