                      { "type": "ia.display.label", "meta": { "name": "ColField" },    "position": { "grow": 1, "basis": "0" },     "props": { "text": "Field" } },
                      { "type": "ia.display.label", "meta": { "name": "ColRequired" }, "position": { "basis": "90px", "shrink": 0 }, "props": { "text": "Required" } },
                      { "type": "ia.display.label", "meta": { "name": "ColRemove" },   "position": { "basis": "36px", "shrink": 0 }, "props": { "text": "" } }
