                    "propConfig": {
                      "props.options": {
                        "binding": {
                          "type": "property",
                          "config": { "path": "view.custom.versions" },
                          "transforms": [
                            {
                              "type": "script",
                              "code": "\tout = []\n\tfor v in (value or []):\n\t\tvnum = v.get('VersionNumber', 0)\n\t\tname = v.get('Name') or ''\n\t\tstate = 'Deprecated' if v.get('Deprecated') else 'Active'\n\t\tlabel = 'v' + str(vnum) + ' -- ' + name + ' (' + state + ')'\n\t\tout.append({'label': label, 'value': v.get('Id')})\n\treturn out"
                            }
                          ]
                        }
                      },
                      "props.value": {
                        "binding": {
                          "type": "property",
                          "config": {
                            "bidirectional": true,
                            "path": "view.custom.selectedVersionId"
                          }
                        }
