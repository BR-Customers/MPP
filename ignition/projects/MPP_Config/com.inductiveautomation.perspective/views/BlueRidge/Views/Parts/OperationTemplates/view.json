                        "onActionPerformed": {
                          "type": "script",
                          "scope": "G",
                          "config": {
                            "script": "\tnewId = event.value\n\tcurrentId = ((self.view.custom.selected or {}).get('meta') or {}).get('Id') or 0\n\tif newId is None or newId == currentId:\n\t\treturn\n\tsystem.perspective.sendMessage('templateVersionClicked', payload={'id': newId}, scope='page')"
                          }
                        }
                      }
