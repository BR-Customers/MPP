                              "config": {
                                "script": "\tmeta = (self.view.custom.selected or {}).get('meta') or {}\n\ttemplateId = meta.get('Id')\n\tif templateId is None:\n\t\treturn\n\tlabel = (meta.get('Code') or '') + ' v' + str(meta.get('VersionNumber') or '')\n\tsystem.perspective.openPopup(\n\t\tid='mpp-confirm-destructive',\n\t\tview='BlueRidge/Components/Popups/ConfirmDestructive',\n\t\tmodal=True,\n\t\tshowCloseIcon=False,\n\t\tparams={\n\t\t\t'title':        'Deprecate Template',\n\t\t\t'message':      'Deprecate ' + label + '? This retires the version from production.',\n\t\t\t'confirmLabel': 'Deprecate',\n\t\t\t'replyMessage': 'templateDeprecateConfirmed'\n\t\t}\n\t)"
                              }
                            }
                          }
                        },
                        "props": { "text": "Deprecate", "style": { "classes": "btn btn-danger btn-sm" } }
                      }
