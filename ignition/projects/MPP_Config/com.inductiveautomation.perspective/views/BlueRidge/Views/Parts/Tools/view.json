    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "classes": "canvas"
      }
    },
    "scripts": {
      "customMethods": [
        {
          "name": "_loadTool",
          "params": [
            "toolId"
          ],
          "script": "\ttoolMeta \u003d BlueRidge.Parts.Tool.getOne(toolId)\n\tif toolMeta is None:\n\t\tBlueRidge.Common.Notify.toast(\u0027Tool not found\u0027, \u0027Tool id \u0027 + str(toolId) + \u0027 no longer exists.\u0027, \u0027warning\u0027)\n\t\treturn\n\tself.view.custom.selected  \u003d {\u0027meta\u0027: dict(toolMeta)}\n\tself.view.custom.editDraft \u003d {\u0027meta\u0027: dict(toolMeta)}\n\tself.view.custom.mode \u003d \u0027update\u0027"
        },
        {
          "name": "_anyDirty",
          "params": [],
          "script": "\t# True when the meta header has unsaved edits OR any draft section is dirty.\n\tif self.view.custom.dirty:\n\t\treturn True\n\tsectionMap \u003d self.view.custom.sectionDirty or {}\n\treturn any(sectionMap.values())"
        },
        {
          "name": "openConfirmUnsaved",
          "params": [],
          "script": "\tsystem.perspective.openPopup(\n\t\tid\u003d\u0027mpp-confirm-unsaved\u0027,\n\t\tview\u003d\u0027BlueRidge/Components/Popups/ConfirmUnsaved\u0027,\n\t\tmodal\u003dTrue,\n\t\tshowCloseIcon\u003dFalse,\n\t\tparams\u003d{\n\t\t\t\u0027title\u0027:   \u0027Unsaved changes\u0027,\n\t\t\t\u0027message\u0027: \u0027You have unsaved changes to this tool. Save before switching?\u0027\n\t\t}\n\t)"
        },
        {
          "name": "completeSwitch",
          "params": [],
          "script": "\tpending \u003d self.view.custom.pendingSwitch or {}\n\tkind   \u003d pending.get(\u0027kind\u0027)\n\ttarget \u003d pending.get(\u0027to\u0027)\n\tself.view.custom.pendingSwitch \u003d None\n\tif kind \u003d\u003d \u0027tab\u0027:\n\t\tsectionKeys \u003d [\u0027attributes\u0027, \u0027cavities\u0027, \u0027assignments\u0027]\n\t\tself.view.custom.activeTabIndex \u003d target\n\t\tif target is not None and 0 \u003c\u003d target \u003c len(sectionKeys):\n\t\t\tself.view.custom.activeTab \u003d sectionKeys[target]\n\telif kind \u003d\u003d \u0027tool\u0027:\n\t\tself._loadTool(target)"
        },
        {
          "name": "cancelSwitch",
          "params": [],
          "script": "\tself.view.custom.pendingSwitch \u003d None"
        }
      ],
      "extensionFunctions": null,
      "messageHandlers": [
        {
          "messageType": "toolRowClicked",
          "pageScope": true,
          "script": "\tclickedId \u003d payload.get(\u0027id\u0027) if payload else None\n\tif clickedId is None:\n\t\treturn\n\tcurrentId \u003d (self.view.custom.selected.meta or {}).get(\u0027Id\u0027) if self.view.custom.selected else None\n\tif clickedId \u003d\u003d currentId:\n\t\treturn\n\t# Gate on meta-header dirty OR any draft section dirty (Attributes /\n\t# Cavities). Assignments is non-draft and never reports dirty, so it\n\t# is naturally excluded.\n\tif self._anyDirty():\n\t\tself.view.custom.pendingSwitch \u003d {\u0027kind\u0027: \u0027tool\u0027, \u0027to\u0027: clickedId}\n\t\tself.openConfirmUnsaved()\n\t\treturn\n\tself._loadTool(clickedId)",
          "sessionScope": false,
          "viewScope": false
        },
        {
          "messageType": "toolRefresh",
          "pageScope": true,
          "script": "\tself.view.custom.tools \u003d BlueRidge.Parts.Tool.getInstancesForFlexRepeater(self.view.custom.filter.searchText, self.view.custom.filter.statusCode, (self.view.custom.selected.meta or {}).get(\u0027Id\u0027, 0))",
          "sessionScope": false,
          "viewScope": false
        },
        {
          "messageType": "toolSelectId",
          "pageScope": true,
          "script": "\ttoolId \u003d (payload or {}).get(\u0027id\u0027)\n\tif toolId is None:\n\t\treturn\n\tself._loadTool(toolId)",
          "sessionScope": false,
          "viewScope": false
        },
        {
          "messageType": "sectionDirtyChanged",
          "pageScope": true,
          "script": "\tsection \u003d payload.get(\u0027section\u0027) if payload else None\n\tisDirty \u003d bool(payload.get(\u0027isDirty\u0027)) if payload else False\n\tif not section:\n\t\treturn\n\tnextMap \u003d dict(self.view.custom.sectionDirty or {})\n\tnextMap[section] \u003d isDirty\n\tself.view.custom.sectionDirty \u003d nextMap\n\t# Deferred completion: once a staged switch\u0027s sections have all gone\n\t# clean (and the meta header is clean too), finish the switch.\n\tpending \u003d self.view.custom.pendingSwitch\n\tif pending and not any(nextMap.values()) and not self.view.custom.dirty:\n\t\tself.completeSwitch()",
          "sessionScope": false,
          "viewScope": false
        },
        {
          "messageType": "confirmUnsavedResult",
          "pageScope": true,
          "script": "\taction \u003d payload.get(\u0027action\u0027) if payload else None\n\tpending \u003d self.view.custom.pendingSwitch\n\tif not pending:\n\t\treturn\n\tif action \u003d\u003d \u0027cancel\u0027:\n\t\tself.cancelSwitch()\n\t\treturn\n\tsectionMap \u003d dict(self.view.custom.sectionDirty or {})\n\tdirtySections \u003d [k for k, v in sectionMap.items() if v]\n\tmetaDirty \u003d bool(self.view.custom.dirty)\n\tif action \u003d\u003d \u0027save\u0027:\n\t\tif metaDirty:\n\t\t\tdraft \u003d self.view.custom.editDraft or {}\n\t\t\tmeta  \u003d draft.get(\u0027meta\u0027) or {}\n\t\t\tif meta.get(\u0027Id\u0027) is not None:\n\t\t\t\tresult \u003d BlueRidge.Parts.Tool.update(meta)\n\t\t\t\tBlueRidge.Common.Ui.notifyResult(result, \u0027Tool saved\u0027)\n\t\t\t\tif result and result.get(\u0027Status\u0027):\n\t\t\t\t\trefreshed \u003d BlueRidge.Parts.Tool.getOne(meta.get(\u0027Id\u0027))\n\t\t\t\t\tif refreshed is not None:\n\t\t\t\t\t\tself.view.custom.selected  \u003d {\u0027meta\u0027: dict(refreshed)}\n\t\t\t\t\t\tself.view.custom.editDraft \u003d {\u0027meta\u0027: dict(refreshed)}\n\t\t\t\tsystem.perspective.sendMessage(\u0027toolRefresh\u0027, scope\u003d\u0027page\u0027)\n\t\tfor sec in dirtySections:\n\t\t\tsystem.perspective.sendMessage(\u0027sectionSaveRequested\u0027, payload\u003d{\u0027section\u0027: sec}, scope\u003d\u0027page\u0027)\n\telif action \u003d\u003d \u0027discard\u0027:\n\t\tif metaDirty:\n\t\t\tself.view.custom.editDraft \u003d {\u0027meta\u0027: dict((self.view.custom.selected or {}).get(\u0027meta\u0027) or {})}\n\t\tfor sec in dirtySections:\n\t\t\tsystem.perspective.sendMessage(\u0027sectionDiscardRequested\u0027, payload\u003d{\u0027section\u0027: sec}, scope\u003d\u0027page\u0027)\n\t# If no draft sections were dirty, the section-clean callback never\n\t# fires -- complete the switch now that the meta leg is resolved.\n\tif not dirtySections:\n\t\tself.completeSwitch()",
          "sessionScope": false,
          "viewScope": false
        },
        {
          "messageType": "toolRetireConfirmed",
          "pageScope": true,
          "script": "\taction \u003d payload.get(\u0027action\u0027) if payload else None\n\tif action !\u003d \u0027confirm\u0027:\n\t\treturn\n\tmeta \u003d (self.view.custom.selected or {}).get(\u0027meta\u0027) or {}\n\ttoolId \u003d meta.get(\u0027Id\u0027)\n\tif toolId is None:\n\t\treturn\n\tresult \u003d BlueRidge.Parts.Tool.deprecate(toolId)\n\tBlueRidge.Common.Ui.notifyResult(result, \u0027Tool retired\u0027)\n\tif result and result.get(\u0027Status\u0027):\n\t\tself.view.custom.selected  \u003d {\u0027meta\u0027: None}\n\t\tself.view.custom.editDraft \u003d {\u0027meta\u0027: None}\n\t\tself.view.custom.mode \u003d \u0027view\u0027\n\t\tsystem.perspective.sendMessage(\u0027toolRefresh\u0027, scope\u003d\u0027page\u0027)",
          "sessionScope": false,
          "viewScope": false
        }
      ]
    },
    "type": "ia.container.flex"
  }
}