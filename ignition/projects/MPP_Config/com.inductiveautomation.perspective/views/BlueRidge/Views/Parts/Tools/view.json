{
  "custom": {
    "selected": {
      "meta": null
    },
    "editDraft": {
      "meta": null
    },
    "mode": "view",
    "filter": {
      "searchText": "",
      "statusCode": "All"
    },
    "dirtySections": {},
    "tools": [],
    "pendingNav": null,
    "dirty": false,
    "rankOptions": [],
    "statusOptions": []
  },
  "params": {},
  "propConfig": {
    "custom.filter.searchText": {
      "persistent": true
    },
    "custom.filter.statusCode": {
      "persistent": true
    },
    "custom.dirty": {
      "binding": {
        "type": "expr",
        "config": {
          "expression": "runScript(\"BlueRidge.Common.Util.convertWrapperObjectToJson\", 0, {view.custom.editDraft}) != runScript(\"BlueRidge.Common.Util.convertWrapperObjectToJson\", 0, {view.custom.selected})"
        }
      }
    },
    "custom.tools": {
      "binding": {
        "type": "expr",
        "config": {
          "expression": "runScript(\"BlueRidge.Parts.Tool.getInstancesForFlexRepeater\", 0, {view.custom.filter.searchText}, {view.custom.filter.statusCode}, {view.custom.selected.meta.Id})"
        }
      }
    },
    "custom.rankOptions": {
      "binding": {
        "type": "expr",
        "config": {
          "expression": "runScript(\"BlueRidge.Parts.DieRank.getForDropdown\", 0)"
        }
      }
    },
    "custom.statusOptions": {
      "binding": {
        "type": "expr",
        "config": {
          "expression": "runScript(\"BlueRidge.Parts.Tool.getStatusCodesForDropdown\", 0)"
        }
      }
    }
  },
  "props": {
    "defaultSize": {
      "height": 1080,
      "width": 1920
    }
  },
  "root": {
    "type": "ia.container.flex",
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "classes": "canvas"
      }
    },
    "scripts": {
      "customMethods": [
        {
          "name": "_loadTool",
          "params": ["toolId"],
          "script": "\ttoolMeta = BlueRidge.Parts.Tool.getOne(toolId)\n\tif toolMeta is None:\n\t\tBlueRidge.Common.Notify.toast('Tool not found', 'Tool id ' + str(toolId) + ' no longer exists.', 'warning')\n\t\treturn\n\tself.view.custom.selected  = {'meta': dict(toolMeta)}\n\tself.view.custom.editDraft = {'meta': dict(toolMeta)}\n\tself.view.custom.mode = 'update'"
        }
      ],
      "extensionFunctions": null,
      "messageHandlers": [
        {
          "messageType": "toolRowClicked",
          "pageScope": true,
          "sessionScope": false,
          "viewScope": false,
          "script": "\tclickedId = payload.get('id') if payload else None\n\tif clickedId is None:\n\t\treturn\n\t# Single source of truth: view.custom.dirty is bound to the same\n\t# expression that drives the title-bar 'Unsaved changes' notice, so\n\t# popup and notice always agree.\n\tif self.view.custom.dirty:\n\t\tself.view.custom.pendingNav = clickedId\n\t\tsystem.perspective.openPopup(\n\t\t\tid='mpp-confirm-unsaved',\n\t\t\tview='BlueRidge/Components/Popups/ConfirmUnsaved',\n\t\t\tmodal=True,\n\t\t\tshowCloseIcon=False,\n\t\t\tparams={\n\t\t\t\t'title':   'Unsaved changes',\n\t\t\t\t'message': 'You have unsaved changes to this tool. Save before switching?'\n\t\t\t}\n\t\t)\n\t\treturn\n\tself._loadTool(clickedId)"
        },
        {
          "messageType": "toolRefresh",
          "pageScope": true,
          "sessionScope": false,
          "viewScope": false,
          "script": "\tself.view.custom.tools = BlueRidge.Parts.Tool.getInstancesForFlexRepeater(self.view.custom.filter.searchText, self.view.custom.filter.statusCode, (self.view.custom.selected.meta or {}).get('Id', 0))"
        },
        {
          "messageType": "toolSelectId",
          "pageScope": true,
          "sessionScope": false,
          "viewScope": false,
          "script": "\ttoolId = (payload or {}).get('id')\n\tif toolId is None:\n\t\treturn\n\tself._loadTool(toolId)"
        },
        {
          "messageType": "confirmUnsavedResult",
          "pageScope": true,
          "sessionScope": false,
          "viewScope": false,
          "script": "\taction = payload.get('action') if payload else None\n\tpendingId = self.view.custom.pendingNav\n\tself.view.custom.pendingNav = None\n\tif pendingId is None or action == 'cancel':\n\t\treturn\n\tif action == 'save':\n\t\tdraft = self.view.custom.editDraft or {}\n\t\tmeta  = draft.get('meta') or {}\n\t\tif meta.get('Id') is not None:\n\t\t\tresult = BlueRidge.Parts.Tool.update(meta)\n\t\t\tBlueRidge.Common.Ui.notifyResult(result, 'Tool saved')\n\tself._loadTool(pendingId)"
        },
        {
          "messageType": "toolRetireConfirmed",
          "pageScope": true,
          "sessionScope": false,
          "viewScope": false,
          "script": "\taction = payload.get('action') if payload else None\n\tif action != 'confirm':\n\t\treturn\n\tmeta = (self.view.custom.selected or {}).get('meta') or {}\n\ttoolId = meta.get('Id')\n\tif toolId is None:\n\t\treturn\n\tresult = BlueRidge.Parts.Tool.deprecate(toolId)\n\tBlueRidge.Common.Ui.notifyResult(result, 'Tool retired')\n\tif result and result.get('Status'):\n\t\tself.view.custom.selected  = {'meta': None}\n\t\tself.view.custom.editDraft = {'meta': None}\n\t\tself.view.custom.mode = 'view'\n\t\tsystem.perspective.sendMessage('toolRefresh', scope='page')"
        }
      ]
    },
    "children": [
      {
        "type": "ia.container.flex",
        "meta": {
          "name": "TitleBar"
        },
        "position": {
          "shrink": 0
        },
        "props": {
          "alignItems": "center",
          "style": {
            "background": "var(--mpp-surface-card)",
            "borderBottom": "1px solid var(--mpp-border-subtle)",
            "gap": "12px",
            "padding": "8px 16px"
          }
        },
        "children": [
          {
            "type": "ia.container.flex",
            "meta": {
              "name": "TitleColumn"
            },
            "position": {
              "basis": "auto"
            },
            "props": {
              "direction": "column",
              "style": {
                "gap": "2px"
              }
            },
            "children": [
              {
                "type": "ia.container.flex",
                "meta": {
                  "name": "Breadcrumb"
                },
                "position": {
                  "basis": "auto"
                },
                "props": {
                  "direction": "row",
                  "alignItems": "center",
                  "style": {
                    "classes": "breadcrumb"
                  }
                },
                "children": [
                  {
                    "type": "ia.display.label",
                    "meta": {
                      "name": "BreadcrumbCategory"
                    },
                    "position": {
                      "basis": "auto"
                    },
                    "props": {
                      "text": "Parts",
                      "style": {
                        "classes": "breadcrumb"
                      }
                    }
                  },
                  {
                    "type": "ia.display.label",
                    "meta": {
                      "name": "BreadcrumbSep"
                    },
                    "position": {
                      "basis": "auto"
                    },
                    "props": {
                      "text": "›",
                      "style": {
                        "classes": "breadcrumb crumb-sep"
                      }
                    }
                  },
                  {
                    "type": "ia.display.label",
                    "meta": {
                      "name": "BreadcrumbActive"
                    },
                    "position": {
                      "basis": "auto"
                    },
                    "props": {
                      "text": "Tools",
                      "style": {
                        "classes": "crumb-active"
                      }
                    }
                  }
                ]
              },
              {
                "type": "ia.display.label",
