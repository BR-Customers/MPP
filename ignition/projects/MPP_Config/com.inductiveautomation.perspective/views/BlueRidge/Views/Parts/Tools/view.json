{
  "custom": {
    "activeTab": "attributes",
    "activeTabIndex": 0,
    "editDraft": {
      "meta": null
    },
    "filter": {
      "searchText": "",
      "statusCode": "All"
    },
    "mode": "view",
    "pendingSwitch": null,
    "sectionDirty": {
      "attributes": false,
      "cavities": false
    },
    "selected": {
      "meta": null
    }
  },
  "params": {},
  "propConfig": {
    "custom.activeTabIndex": {
      "onChange": {
        "enabled": true,
        "script": "\tcurr \u003d currentValue.value if currentValue is not None else None\n\tsectionKeys \u003d [\"attributes\", \"cavities\", \"assignments\"]\n\tif curr is not None and 0 \u003c\u003d curr \u003c len(sectionKeys):\n\t\tself.custom.activeTab \u003d sectionKeys[curr]"
      }
    },
    "custom.dirty": {
      "binding": {
        "config": {
          "expression": "runScript(\"BlueRidge.Common.Util.convertWrapperObjectToJson\", 0, {view.custom.editDraft}) !\u003d runScript(\"BlueRidge.Common.Util.convertWrapperObjectToJson\", 0, {view.custom.selected})"
        },
        "type": "expr"
      }
    },
    "custom.filter.searchText": {
      "persistent": true
    },
    "custom.filter.statusCode": {
      "persistent": true
    },
    "custom.rankOptions": {
      "binding": {
        "config": {
          "expression": "runScript(\"BlueRidge.Parts.DieRank.getForDropdown\", 0)"
        },
        "type": "expr"
      }
    },
    "custom.statusOptions": {
      "binding": {
        "config": {
          "expression": "runScript(\"BlueRidge.Parts.Tool.getStatusCodesForDropdown\", 0)"
        },
        "type": "expr"
      }
    },
    "custom.tools": {
      "binding": {
        "config": {
          "expression": "runScript(\"BlueRidge.Parts.Tool.getInstancesForFlexRepeater\", 0, {view.custom.filter.searchText}, {view.custom.filter.statusCode}, {view.custom.selected.meta.Id})"
        },
        "type": "expr"
      }
    }
  },
  "props": {
    "defaultSize": {
      "height": 1080,
      "width": 1920
    }
  },
