                      }
                    }
                  },
                  {
                    "type": "ia.input.dropdown",
                    "meta": {
                      "name": "DropdownStatus"
                    },
                    "propConfig": {
                      "props.value": {
                        "binding": {
                          "type": "property",
                          "config": {
                            "bidirectional": true,
                            "path": "view.custom.filter.statusCode"
                          }
                        }
                      }
                    },
                    "props": {
                      "options": [
                        { "label": "All Statuses",   "value": "All" },
                        { "label": "Active",         "value": "Active" },
                        { "label": "Under Repair",   "value": "UnderRepair" },
                        { "label": "Retired",        "value": "Retired" }
                      ],
                      "style": {
                        "classes": "select"
                      }
                    }
                  }
                ]
              },
              {
                "type": "ia.display.flex-repeater",
                "meta": {
                  "name": "ToolList"
                },
                "position": {
                  "basis": "0",
                  "grow": 1
                },
                "propConfig": {
                  "props.instances": {
                    "binding": {
                      "type": "property",
                      "config": {
                        "path": "view.custom.tools"
                      }
                    }
                  }
                },
                "props": {
                  "direction": "column",
                  "elementPosition": {
                    "basis": "44px",
                    "shrink": 0
                  },
                  "path": "BlueRidge/Components/Parts/Tools/ToolRow",
                  "style": {
                    "overflowY": "auto",
                    "padding": "4px 0"
                  },
                  "useDefaultViewHeight": true,
                  "useDefaultViewWidth": false
                }
              }
            ]
          },
          {
            "type": "ia.container.flex",
            "meta": {
              "name": "DetailArea"
            },
            "position": {
              "basis": "0",
              "grow": 1
            },
            "propConfig": {
              "position.display": {
                "binding": {
                  "type": "expr",
                  "config": {
                    "expression": "{view.custom.mode} != \"view\""
                  }
                }
              }
            },
            "props": {
              "direction": "column",
              "style": {
                "overflow": "hidden"
              }
            },
            "children": [
              {
                "type": "ia.container.flex",
                "meta": {
                  "name": "DetailsHeader"
                },
                "position": {
                  "shrink": 0
                },
                "props": {
                  "direction": "column",
                  "style": {
                    "background": "var(--mpp-surface-card)",
                    "borderBottom": "1px solid var(--mpp-border-subtle)",
                    "gap": "8px",
                    "padding": "10px 14px"
                  }
                },
                "children": [
                  {
                    "type": "ia.container.flex",
                    "meta": {
                      "name": "SummaryRow"
                    },
                    "props": {
                      "alignItems": "center",
                      "style": {
                        "gap": "8px"
                      }
                    },
                    "children": [
                      {
                        "type": "ia.display.label",
                        "meta": {
                          "name": "SummaryText"
                        },
                        "propConfig": {
                          "props.text": {
                            "binding": {
                              "type": "expr",
                              "config": {
                                "expression": "if(isNull({view.custom.editDraft.meta.Code}), '', {view.custom.editDraft.meta.Code} + ' — ' + {view.custom.editDraft.meta.Name})"
                              }
                            }
                          }
                        },
                        "props": {
                          "style": {
                            "fontSize": "13px",
                            "fontWeight": "600"
                          }
                        }
                      },
                      {
                        "type": "ia.display.label",
                        "meta": {
                          "name": "SummaryBadgeStatus"
                        },
                        "propConfig": {
                          "props.text": {
                            "binding": {
                              "type": "property",
                              "config": {
                                "path": "view.custom.editDraft.meta.StatusCode"
                              }
                            }
                          }
                        },
                        "props": {
                          "style": {
                            "classes": "badge badge-published"
                          }
                        }
                      },
                      {
                        "type": "ia.display.label",
                        "meta": {
                          "name": "SummaryBadgeType"
                        },
                        "propConfig": {
                          "props.text": {
                            "binding": {
                              "type": "property",
                              "config": {
                                "path": "view.custom.editDraft.meta.ToolTypeName"
                              }
                            }
                          }
                        },
                        "props": {
                          "style": {
                            "classes": "badge badge-purple"
                          }
                        }
                      },
                      {
                        "type": "ia.display.label",
                        "meta": {
                          "name": "SummaryBadgeRank"
                        },
                        "propConfig": {
                          "position.display": {
                            "binding": {
                              "type": "expr",
                              "config": {
                                "expression": "!isNull({view.custom.editDraft.meta.DieRankName})"
                              }
                            }
                          },
                          "props.text": {
                            "binding": {
                              "type": "property",
                              "config": {
                                "path": "view.custom.editDraft.meta.DieRankName"
                              }
                            }
                          }
                        },
                        "props": {
                          "style": {
                            "classes": "badge badge-muted"
                          }
                        }
                      },
                      {
                        "type": "ia.container.flex",
                        "meta": {
                          "name": "SummarySpacer"
                        },
                        "position": {
                          "grow": 1
                        }
                      },
                      {
                        "type": "ia.input.button",
                        "meta": {
                          "name": "BtnSave"
                        },
                        "events": {
                          "component": {
                            "onActionPerformed": {
                              "type": "script",
                              "scope": "G",
                              "config": {
                                "script": "\tdraft = self.view.custom.editDraft or {}\n\tmeta  = draft.get('meta') or {}\n\tif meta.get('Id') is None:\n\t\tBlueRidge.Common.Notify.toast('No tool selected', 'Pick a tool from the list first.', 'warning')\n\t\treturn\n\tresult = BlueRidge.Parts.Tool.update(meta)\n\tBlueRidge.Common.Ui.notifyResult(result, 'Tool saved')\n\tif result and result.get('Status'):\n\t\trefreshed = BlueRidge.Parts.Tool.getOne(meta.get('Id'))\n\t\tif refreshed is not None:\n\t\t\tself.view.custom.selected  = {'meta': dict(refreshed)}\n\t\t\tself.view.custom.editDraft = {'meta': dict(refreshed)}\n\t\tsystem.perspective.sendMessage('toolRefresh', scope='page')"
                              }
                            }
                          }
                        },
                        "props": {
                          "text": "Save",
                          "style": {
                            "classes": "btn btn-primary btn-sm"
                          }
                        }
                      },
                      {
                        "type": "ia.input.button",
                        "meta": {
                          "name": "BtnRetire"
                        },
                        "events": {
                          "component": {
                            "onActionPerformed": {
                              "type": "script",
                              "scope": "G",
                              "config": {
                                "script": "\tmeta = (self.view.custom.selected or {}).get('meta') or {}\n\ttoolId = meta.get('Id')\n\tif toolId is None:\n\t\treturn\n\tcode = meta.get('Code') or ''\n\tname = meta.get('Name') or ''\n\tlabel = (code + ' - ' + name) if code and name else (code or name or 'this tool')\n\tsystem.perspective.openPopup(\n\t\tid='mpp-confirm-destructive',\n\t\tview='BlueRidge/Components/Popups/ConfirmDestructive',\n\t\tmodal=True,\n\t\tshowCloseIcon=False,\n\t\tparams={\n\t\t\t'title':        'Retire Tool',\n\t\t\t'message':      'Retire ' + label + '? This will mark the tool as deprecated.',\n\t\t\t'confirmLabel': 'Retire',\n\t\t\t'replyMessage': 'toolRetireConfirmed'\n\t\t}\n\t)"
                              }
                            }
                          }
                        },
                        "props": {
                          "text": "Retire",
                          "style": {
                            "classes": "btn btn-danger btn-sm"
                          }
                        }
