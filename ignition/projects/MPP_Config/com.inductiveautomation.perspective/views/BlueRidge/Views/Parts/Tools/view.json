                    "padding": "8px 10px"
                  }
                },
                "children": [
                  {
                    "type": "ia.input.text-field",
                    "meta": {
                      "name": "InputSearch"
                    },
                    "propConfig": {
                      "props.text": {
                        "binding": {
                          "type": "property",
                          "config": {
                            "bidirectional": true,
                            "path": "view.custom.filter.searchText"
                          }
                        }
                      }
                    },
                    "props": {
                      "placeholder": "🔍 Search dies…",
                      "style": {
