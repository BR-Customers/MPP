                                "classes": "search-input",
                                "width": "100%"
                              }
                            }
                          }
                        ]
                      },
                      {
                        "type": "ia.container.flex",
                        "meta": {
                          "name": "FieldToolType"
                        },
                        "position": {
                          "basis": "120px",
                          "grow": 1
                        },
                        "props": {
                          "direction": "column",
                          "style": {
                            "classes": "field",
                            "gap": "2px"
                          }
                        },
                        "children": [
                          {
                            "type": "ia.display.label",
                            "meta": {
                              "name": "LabelToolType"
                            },
                            "props": {
                              "text": "Tool Type",
                              "style": {
                                "classes": "field-label"
                              }
                            }
                          },
                          {
                            "type": "ia.input.text-field",
                            "meta": {
                              "name": "InputToolType"
                            },
                            "propConfig": {
                              "props.text": {
                                "binding": {
                                  "type": "property",
                                  "config": {
                                    "bidirectional": true,
                                    "path": "view.custom.editDraft.meta.ToolTypeName"
                                  }
                                }
                              }
                            },
                            "props": {
                              "enabled": false,
                              "style": {
