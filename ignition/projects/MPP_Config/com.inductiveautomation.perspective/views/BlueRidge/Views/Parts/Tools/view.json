                            "onActionPerformed": {
                              "config": {
                                "script": "\tmeta \u003d (self.view.custom.selected or {}).get(\u0027meta\u0027) or {}\n\ttoolId \u003d meta.get(\u0027Id\u0027)\n\tif toolId is None:\n\t\treturn\n\tcode \u003d meta.get(\u0027Code\u0027) or \u0027\u0027\n\tname \u003d meta.get(\u0027Name\u0027) or \u0027\u0027\n\tlabel \u003d (code + \u0027 - \u0027 + name) if code and name else (code or name or \u0027this tool\u0027)\n\tsystem.perspective.openPopup(\n\t\tid\u003d\u0027mpp-confirm-destructive\u0027,\n\t\tview\u003d\u0027BlueRidge/Components/Popups/ConfirmDestructive\u0027,\n\t\tmodal\u003dTrue,\n\t\tshowCloseIcon\u003dFalse,\n\t\tparams\u003d{\n\t\t\t\u0027title\u0027:        \u0027Retire Tool\u0027,\n\t\t\t\u0027message\u0027:      \u0027Retire \u0027 + label + \u0027? This will mark the tool as deprecated.\u0027,\n\t\t\t\u0027confirmLabel\u0027: \u0027Retire\u0027,\n\t\t\t\u0027replyMessage\u0027: \u0027toolRetireConfirmed\u0027\n\t\t}\n\t)"
                              },
                              "scope": "G",
                              "type": "script"
                            }
                          }
