                          },
                          "type": "property"
                        }
                      }
                    },
                    "props": {
                      "params": {
                        "value": 0
                      },
                      "path": "BlueRidge/Components/Parts/ItemMaster/Eligibility",
                      "useDefaultViewHeight": false,
                      "useDefaultViewWidth": false
                    },
                    "type": "ia.display.view"
                  }
                ],
                "meta": {
                  "name": "TabContainer_0"
                },
                "position": {
