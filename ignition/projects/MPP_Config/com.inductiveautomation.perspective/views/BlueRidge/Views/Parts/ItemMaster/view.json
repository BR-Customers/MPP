              }
            ],
            "meta": {
              "name": "EmptyState"
            },
            "position": {
              "basis": "0",
              "grow": 1
            },
            "propConfig": {
              "position.display": {
                "binding": {
                  "config": {
                    "expression": "{view.custom.selectedItemId} \u003d null"
                  },
                  "type": "expr"
                }
              }
