{
  "custom": {
    "activeTab": "containerConfig",
    "activeTabIndex": 0,
    "itemTypes": [
      "Raw Material",
      "Component",
      "Sub-Assembly",
      "Finished Good",
      "Pass-Through"
    ],
    "pendingSwitch": null,
    "search": "",
    "sectionDirty": {
      "boms": false,
      "containerConfig": false,
      "eligibility": false,
      "identity": false,
      "qualitySpecs": false,
      "routes": false
    },
    "selectedItemId": null,
    "typeFilter": "All Types",
    "uoms": [
      "EA",
      "LB",
      "KG"
    ]
  },
  "params": {},
  "propConfig": {
    "custom.activeTabIndex": {
      "onChange": {
        "enabled": true,
        "script": "\tprev = previousValue.value if previousValue is not None else None\n\tcurr = currentValue.value if currentValue is not None else None\n\tsectionKeys = [\"containerConfig\", \"routes\", \"boms\", \"qualitySpecs\", \"eligibility\"]\n\tif prev is None or curr is None or prev == curr:\n\t\treturn\n\tif curr < 0 or curr >= len(sectionKeys):\n\t\tif 0 <= prev < len(sectionKeys):\n\t\t\tself.custom.activeTabIndex = prev\n\t\treturn\n\tif prev < 0 or prev >= len(sectionKeys):\n\t\tself.custom.activeTab = sectionKeys[curr]\n\t\treturn\n\tcurrentSection = sectionKeys[prev]\n\tdirtyMap = self.custom.sectionDirty or {}\n\tif dirtyMap.get(currentSection, False):\n\t\tself.custom.pendingSwitch = {\"kind\": \"tab\", \"to\": curr}\n\t\tself.custom.activeTabIndex = prev\n\t\tself.rootContainer.openConfirmUnsaved(currentSection)\n\telse:\n\t\tself.custom.activeTab = sectionKeys[curr]"
      }
    },
    "custom.items": {
      "binding": {
        "config": {
          "expression": "runScript(\"BlueRidge.Parts.Item.getAllForList\", 0, {view.custom.search}, {view.custom.typeFilter})"
        },
        "type": "expr"
      }
    }
  },
  "props": {
    "defaultSize": {
      "height": 720,
      "width": 1280
    }
  },
  "root": {
    "children": [
      {
        "children": [
