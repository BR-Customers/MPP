{
  "custom": {},
  "params": {},
  "propConfig": {
    "custom.userName": {
      "binding": {
        "config": {
          "path": "session.props.auth.user.userName"
        },
        "transforms": [
          {
            "expression": "if({value} \u003d null || len({value}) \u003d 0, \u0027Operator\u0027, {value})",
            "type": "expression"
          }
        ],
        "type": "property"
      }
    }
  },
  "props": {
    "defaultSize": {
      "height": 720,
      "width": 1280
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "meta": {
              "name": "LabelEyebrow"
            },
            "props": {
              "style": {
                "classes": "label-eyebrow"
              },
              "text": "MPP MES"
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "LabelTitle"
            },
            "props": {
              "style": {
                "classes": "heading-lg",
                "marginTop": "8px"
              },
              "text": "Configuration Tool"
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "LabelWelcomeUser"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "expression": "\u0027Welcome, \u0027 + {view.custom.userName}"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "fontSize": "16px",
                "marginTop": "24px"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "LabelStatusBadge"
            },
            "props": {
              "style": {
                "classes": "badge badge-info",
                "marginTop": "16px"
              },
              "text": "Phase 0 — Foundation"
            },
            "type": "ia.display.label"
          }
        ],
        "meta": {
          "name": "WelcomeCard"
        },
        "props": {
          "alignItems": "flex-start",
          "direction": "column",
          "style": {
            "classes": "surface-card",
            "minWidth": "480px",
            "padding": "32px"
          }
        },
        "type": "ia.container.flex"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "alignItems": "center",
      "direction": "column",
      "justify": "center",
      "style": {
        "classes": "canvas"
      }
    },
    "type": "ia.container.flex"
  }
}