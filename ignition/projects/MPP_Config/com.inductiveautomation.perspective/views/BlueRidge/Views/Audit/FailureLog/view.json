          "params": {
            "category": "System",
            "title": "Failure Log"
          }
        }
      },
      {
        "type": "ia.container.flex",
        "meta": {
          "name": "MainSplit"
        },
        "position": {
          "grow": 1
        },
        "props": {
          "direction": "row",
          "style": {
            "overflow": "hidden",
            "borderTop": "1px solid var(--mpp-border-subtle)"
