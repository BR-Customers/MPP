    "scripts": {
      "customMethods": [
        {
          "name": "applySearch",
          "params": [],
          "script": "\tresult \u003d BlueRidge.Audit.FailureLog.search(self.view.custom.filter)\n\tself.view.custom.rows       \u003d result[\"rows\"]\n\tself.view.custom.totalCount \u003d result[\"totalCount\"]\n\tself.view.custom.topReasons \u003d result[\"topReasons\"]\n\tself.view.custom.topProcs   \u003d result[\"topProcs\"]"
        },
        {
          "name": "resetFilter",
          "params": [],
          "script": "\timport system\n\tnow \u003d system.date.now()\n\tself.view.custom.filter \u003d {\n\t\t\"startDate\":      system.date.addDays(now, -7),\n\t\t\"endDate\":        now,\n\t\t\"entityTypeCode\": None,\n\t\t\"procedureName\":  None,\n\t\t\"appUserId\":      None,\n\t\t\"searchText\":     \"\"\n\t}\n\tself.applySearch()"
        }
      ],
      "extensionFunctions": null,
      "messageHandlers": [
        {
          "messageType": "applyFilterFromTile",
          "pageScope": true,
          "script": "\tfield \u003d payload.get(\"field\") if payload else None\n\tvalue \u003d payload.get(\"value\") if payload else None\n\tif not field:\n\t\treturn\n\tf \u003d dict(self.view.custom.filter or {})\n\tif field \u003d\u003d \"failureReasonText\":\n\t\tf[\"searchText\"] \u003d value or \"\"\n\telif field \u003d\u003d \"procedureName\":\n\t\tf[\"procedureName\"] \u003d value\n\tself.view.custom.filter \u003d f\n\tself.applySearch()",
          "sessionScope": false,
          "viewScope": false
        }
      ]
    },
    "type": "ia.container.flex"
  }
}