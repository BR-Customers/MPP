                                "script": "\tsel \u003d event.get(\"selectedRow\") if event else None\n\tif sel is None:\n\t\treturn\n\tidx \u003d sel\n\trows \u003d BlueRidge.Common.Util.extractQualifiedValues(self.props.data) or []\n\tif idx \u003c 0 or idx \u003e\u003d len(rows):\n\t\treturn\n\tdata \u003d rows[idx] or {}\n\tsystem.perspective.openPopup(\n\t\tid\u003d\"mpp-config-change-detail\",\n\t\tview\u003d\"BlueRidge/Components/Popups/ConfigChangeDetail\",\n\t\tmodal\u003dTrue,\n\t\tdraggable\u003dFalse,\n\t\tshowCloseIcon\u003dFalse,\n\t\tparams\u003d{\n\t\t\t\"id\":                data.get(\"Id\"),\n\t\t\t\"loggedAt\":          data.get(\"LoggedAt\"),\n\t\t\t\"userDisplayName\":   data.get(\"UserDisplayName\"),\n\t\t\t\"logEntityTypeName\": data.get(\"LogEntityTypeName\"),\n\t\t\t\"entityId\":          data.get(\"EntityId\"),\n\t\t\t\"logEventTypeCode\":  data.get(\"LogEventTypeCode\"),\n\t\t\t\"logSeverityCode\":   data.get(\"LogSeverityCode\"),\n\t\t\t\"description\":       data.get(\"Description\"),\n\t\t\t\"oldValue\":          data.get(\"OldValue\"),\n\t\t\t\"newValue\":          data.get(\"NewValue\"),\n\t\t\t\"popupId\":           \"mpp-config-change-detail\"\n\t\t}\n\t)"
                              },
                              "scope": "G",
                              "type": "script"
                            }
                          }
                        },
