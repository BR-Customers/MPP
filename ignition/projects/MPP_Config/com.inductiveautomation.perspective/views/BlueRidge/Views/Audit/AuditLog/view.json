          "params": [],
          "script": "\toldSelection \u003d self.getChild(\"MainSplit\").getChild(\"ContentArea\").getChild(\"AuditPanelWrapper\").getChild(\"AuditPanel\").getChild(\"AuditTable\").props.selection.selectedRow\n\tresult \u003d BlueRidge.Audit.ConfigLog.search(self.view.custom.filter)\n\tself.view.custom.rows       \u003d result[\"rows\"]\n\tself.view.custom.totalCount \u003d result[\"totalCount\"]\n\t\n\tnewSelection \u003d self.getChild(\"MainSplit\").getChild(\"ContentArea\").getChild(\"AuditPanelWrapper\").getChild(\"AuditPanel\").getChild(\"AuditTable\").props.selection.selectedRow\n\t#if oldSelection !\u003d newSelection:\n\t#self.view.custom.sortingApplied \u003d True"
        },
        {
          "name": "resetFilter",
          "params": [],
          "script": "\timport system\n\tnow \u003d system.date.now()\n\tself.view.custom.filter \u003d {\n\t\t\"startDate\":      system.date.addDays(now, -7),\n\t\t\"endDate\":        now,\n\t\t\"entityTypeCode\": None,\n\t\t\"logSeverityCode\": None,\n\t\t\"appUserId\":      None,\n\t\t\"searchText\":     \"\"\n\t}\n\tself.applySearch()"
