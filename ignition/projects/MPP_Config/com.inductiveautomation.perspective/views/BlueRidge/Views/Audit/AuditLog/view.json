{
  "custom": {
    "filter": {
      "startDate": null,
      "endDate": null,
      "entityTypeCode": null,
      "logSeverityCode": null,
      "appUserId": null,
      "searchText": ""
    },
    "rows": [],
    "totalCount": 0,
    "_initFired": false
  },
  "params": {},
  "propConfig": {
    "custom.filter.startDate": {
      "persistent": true
    },
    "custom.filter.endDate": {
      "persistent": true
    },
    "custom.filter.entityTypeCode": {
      "persistent": true
    },
    "custom.filter.logSeverityCode": {
      "persistent": true
    },
    "custom.filter.appUserId": {
      "persistent": true
    },
    "custom.filter.searchText": {
      "persistent": true
    },
    "custom._initFired": {
      "binding": {
        "type": "expr",
        "config": {
          "expression": "now(0) != null"
        }
      },
      "onChange": {
        "enabled": true,
        "script": "\t# Fires once on view-load (now(0) is single-eval -> binding evaluates true).\n\t# Calls resetFilter which seeds dates + runs Apply.\n\tif previousValue and previousValue.value != currentValue.value:\n\t\tself.view.resetFilter()"
      }
    }
  },
  "props": {
    "defaultSize": {
      "width": 1280,
      "height": 720
    }
  },
  "root": {
    "type": "ia.container.flex",
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "classes": "screen-active"
      }
    },
    "children": [
      {
        "type": "ia.display.view",
        "meta": {
          "name": "TitleBar"
        },
        "position": {
          "basis": "auto",
          "shrink": 0
        },
        "props": {
          "path": "BlueRidge/Components/Common/TitleBar",
          "params": {
            "category": "System",
            "title": "Audit Log"
          }
        }
      },
      {
        "type": "ia.container.flex",
        "meta": {
          "name": "MainSplit"
        },
        "position": {
          "grow": 1
        },
        "props": {
          "direction": "row",
          "style": {
            "overflow": "hidden",
            "borderTop": "1px solid var(--mpp-border-subtle)"
          }
        },
        "children": [
          {
            "type": "ia.container.flex",
            "meta": {
              "name": "FilterSidebar"
            },
            "position": {
              "basis": "220px",
              "shrink": 0
            },
            "props": {
              "direction": "column",
              "style": {
                "classes": "filter-sidebar"
              }
            },
            "children": [
              {
                "type": "ia.container.flex",
                "meta": {
                  "name": "FilterPanel"
                },
                "position": {
                  "basis": "auto"
                },
                "props": {
                  "direction": "column",
                  "style": {
                    "classes": "filter-panel"
                  }
                },
                "children": [
                  {
                    "type": "ia.container.flex",
                    "meta": {
                      "name": "StartDateField"
                    },
                    "position": {
                      "basis": "auto"
                    },
                    "props": {
                      "direction": "column",
                      "style": {
                        "gap": "4px"
                      }
                    },
                    "children": [
                      {
                        "type": "ia.display.label",
                        "meta": {
                          "name": "StartDateLabel"
                        },
                        "position": {
                          "basis": "auto"
                        },
                        "props": {
                          "text": "Start Date",
                          "style": {
                            "classes": "label-eyebrow"
                          }
                        }
                      },
                      {
                        "type": "ia.input.date-time-input",
                        "meta": {
                          "name": "StartDateInput"
                        },
                        "position": {
                          "basis": "auto"
                        },
                        "propConfig": {
                          "props.value": {
                            "binding": {
                              "type": "property",
                              "config": {
                                "bidirectional": true,
                                "path": "view.custom.filter.startDate"
                              }
                            }
                          }
                        },
                        "props": {
                          "format": "YYYY-MM-DD",
                          "pickerType": "date"
                        }
                      }
                    ]
                  },
                  {
                    "type": "ia.container.flex",
                    "meta": {
                      "name": "EndDateField"
                    },
                    "position": {
                      "basis": "auto"
                    },
                    "props": {
                      "direction": "column",
                      "style": {
                        "gap": "4px"
                      }
                    },
                    "children": [
                      {
                        "type": "ia.display.label",
                        "meta": {
                          "name": "EndDateLabel"
                        },
                        "position": {
                          "basis": "auto"
                        },
                        "props": {
                          "text": "End Date",
                          "style": {
                            "classes": "label-eyebrow"
                          }
                        }
                      },
                      {
                        "type": "ia.input.date-time-input",
                        "meta": {
                          "name": "EndDateInput"
                        },
                        "position": {
                          "basis": "auto"
                        },
                        "propConfig": {
                          "props.value": {
                            "binding": {
                              "type": "property",
                              "config": {
                                "bidirectional": true,
                                "path": "view.custom.filter.endDate"
                              }
                            }
                          }
                        },
                        "props": {
                          "format": "YYYY-MM-DD",
                          "pickerType": "date"
                        }
                      }
                    ]
                  },
                  {
                    "type": "ia.container.flex",
                    "meta": {
                      "name": "EntityTypeField"
                    },
                    "position": {
                      "basis": "auto"
                    },
                    "props": {
                      "direction": "column",
                      "style": {
                        "gap": "4px"
                      }
                    },
                    "children": [
                      {
                        "type": "ia.display.label",
                        "meta": {
                          "name": "EntityTypeLabel"
                        },
                        "position": {
                          "basis": "auto"
                        },
                        "props": {
                          "text": "Entity Type",
                          "style": {
                            "classes": "label-eyebrow"
                          }
                        }
                      },
                      {
                        "type": "ia.input.dropdown",
                        "meta": {
                          "name": "EntityTypeDropdown"
                        },
                        "position": {
                          "basis": "auto"
                        },
                        "propConfig": {
                          "props.options": {
                            "binding": {
                              "type": "expr",
                              "config": {
                                "expression": "runScript(\"BlueRidge.Audit.LogEntityType.list\", 0)"
                              },
                              "transforms": [
                                {
                                  "type": "script",
                                  "code": "\treturn [{\"label\": \"(All)\", \"value\": None}] + [{\"label\": t.get(\"Name\"), \"value\": t.get(\"Code\")} for t in (value or [])]"
                                }
                              ]
                            }
                          },
                          "props.value": {
                            "binding": {
                              "type": "property",
                              "config": {
                                "bidirectional": true,
                                "path": "view.custom.filter.entityTypeCode"
                              }
                            }
                          }
                        },
                        "props": {
                          "style": {
                            "classes": "select"
                          }
                        }
                      }
                    ]
                  },
                  {
                    "type": "ia.container.flex",
                    "meta": {
                      "name": "SeverityField"
                    },
                    "position": {
                      "basis": "auto"
                    },
                    "props": {
                      "direction": "column",
                      "style": {
                        "gap": "4px"
                      }
                    },
                    "children": [
                      {
                        "type": "ia.display.label",
                        "meta": {
                          "name": "SeverityLabel"
                        },
                        "position": {
                          "basis": "auto"
                        },
                        "props": {
                          "text": "Severity",
                          "style": {
                            "classes": "label-eyebrow"
                          }
                        }
                      },
                      {
                        "type": "ia.input.dropdown",
                        "meta": {
                          "name": "SeverityDropdown"
                        },
                        "position": {
                          "basis": "auto"
                        },
                        "propConfig": {
                          "props.options": {
                            "binding": {
                              "type": "expr",
                              "config": {
                                "expression": "runScript(\"BlueRidge.Audit.LogSeverity.list\", 0)"
                              },
                              "transforms": [
                                {
                                  "type": "script",
                                  "code": "\treturn [{\"label\": \"(All)\", \"value\": None}] + [{\"label\": s.get(\"Name\"), \"value\": s.get(\"Code\")} for s in (value or [])]"
                                }
                              ]
                            }
                          },
                          "props.value": {
                            "binding": {
                              "type": "property",
                              "config": {
                                "bidirectional": true,
                                "path": "view.custom.filter.logSeverityCode"
                              }
                            }
                          }
                        },
                        "props": {
                          "style": {
                            "classes": "select"
                          }
                        }
                      }
                    ]
                  },
                  {
                    "type": "ia.container.flex",
                    "meta": {
                      "name": "SearchField"
                    },
                    "position": {
                      "basis": "auto"
                    },
                    "props": {
                      "direction": "column",
                      "style": {
                        "gap": "4px"
                      }
                    },
                    "children": [
                      {
                        "type": "ia.display.label",
                        "meta": {
                          "name": "SearchLabel"
                        },
                        "position": {
                          "basis": "auto"
                        },
                        "props": {
                          "text": "Search",
                          "style": {
                            "classes": "label-eyebrow"
                          }
                        }
                      },
                      {
                        "type": "ia.input.text-field",
                        "meta": {
                          "name": "SearchInput"
                        },
                        "position": {
                          "basis": "auto"
                        },
                        "propConfig": {
                          "props.text": {
                            "binding": {
                              "type": "property",
                              "config": {
                                "bidirectional": true,
                                "path": "view.custom.filter.searchText"
                              }
                            }
                          }
                        },
                        "props": {
                          "placeholder": "Search…",
                          "style": {
                            "classes": "search-input"
                          }
                        }
                      }
                    ]
                  },
                  {
                    "type": "ia.container.flex",
                    "meta": {
                      "name": "FilterFooter"
                    },
                    "position": {
                      "basis": "auto",
                      "shrink": 0
                    },
                    "props": {
                      "alignItems": "center",
                      "style": {
                        "gap": "8px",
                        "padding": "12px 0 0 0"
                      }
                    },
                    "children": [
                      {
                        "type": "ia.input.button",
                        "meta": {
                          "name": "ResetButton"
                        },
                        "position": {
                          "basis": "0",
                          "grow": 1
                        },
                        "props": {
                          "text": "Reset",
                          "style": {
                            "classes": "btn btn-sm"
                          }
                        },
                        "events": {
                          "component": {
                            "onActionPerformed": {
                              "type": "script",
                              "scope": "G",
                              "config": {
                                "script": "\tself.view.resetFilter()"
                              }
                            }
                          }
                        }
                      },
                      {
                        "type": "ia.input.button",
                        "meta": {
                          "name": "ApplyButton"
                        },
                        "position": {
                          "basis": "0",
                          "grow": 1
                        },
                        "props": {
                          "text": "Apply",
                          "style": {
                            "classes": "btn btn-primary btn-sm"
                          }
                        },
                        "events": {
                          "component": {
                            "onActionPerformed": {
                              "type": "script",
                              "scope": "G",
                              "config": {
                                "script": "\tself.view.applySearch()"
                              }
                            }
                          }
                        }
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "ia.container.flex",
            "meta": {
              "name": "ContentArea"
            },
            "position": {
              "grow": 1
            },
            "props": {
              "direction": "column",
              "style": {
                "classes": "detail-area",
                "padding": "0",
                "overflowY": "auto"
              }
            },
            "children": [
              {
                "type": "ia.container.flex",
                "meta": {
                  "name": "AuditPanelWrapper"
                },
                "position": {
                  "grow": 1
                },
                "props": {
                  "direction": "column",
                  "style": {
                    "padding": "0 12px 12px 12px"
                  }
                },
                "children": [
                  {
                    "type": "ia.container.flex",
                    "meta": {
                      "name": "AuditPanel"
                    },
                    "position": {
                      "grow": 1
                    },
                    "props": {
                      "direction": "column",
                      "style": {
                        "classes": "detail-panel"
                      }
                    },
                    "children": [
                      {
                        "type": "ia.display.label",
                        "meta": {
                          "name": "ResultBanner"
                        },
                        "position": {
                          "basis": "auto",
                          "shrink": 0
                        },
                        "propConfig": {
                          "props.text": {
                            "binding": {
                              "type": "expr",
                              "config": {
                                "expression": "if({view.custom.totalCount} < 1000, \"Showing \" + {view.custom.totalCount} + \" rows\", \"Showing first 1000 of \" + {view.custom.totalCount} + \" — narrow your filter\")"
                              }
                            }
                          }
                        },
                        "props": {
                          "style": {
                            "color": "var(--mpp-text-secondary)",
                            "fontSize": "11px",
                            "padding": "4px 12px"
                          }
                        }
                      },
                      {
                        "type": "ia.display.table",
                        "meta": {
                          "name": "AuditTable"
                        },
                        "position": {
                          "grow": 1
                        },
                        "propConfig": {
                          "props.data": {
                            "binding": {
                              "type": "property",
                              "config": {
                                "path": "view.custom.rows"
                              }
                            }
                          }
                        },
                        "props": {
                          "columns": [
                            {
                              "field": "LoggedAt",
                              "header": {
                                "title": "Timestamp"
                              },
                              "visible": true,
                              "sort": "desc"
                            },
                            {
                              "field": "UserDisplayName",
                              "header": {
                                "title": "User"
                              },
                              "visible": true
                            },
                            {
                              "field": "LogEntityTypeName",
                              "header": {
                                "title": "Entity Type"
                              },
                              "visible": true
                            },
                            {
                              "field": "EntityId",
                              "header": {
                                "title": "Entity ID"
                              },
                              "visible": true
                            },
                            {
                              "field": "LogEventTypeCode",
                              "header": {
                                "title": "Event"
                              },
                              "visible": true
                            },
                            {
                              "field": "LogSeverityCode",
                              "header": {
                                "title": "Severity"
                              },
                              "visible": true
                            },
                            {
                              "field": "Description",
                              "header": {
                                "title": "Description"
                              },
                              "visible": true
                            }
                          ],
                          "filter": {
                            "enabled": false
                          },
                          "rows": {
                            "selection": {
                              "enabled": true,
                              "selectionMode": "single"
                            }
                          },
                          "style": {
                            "classes": "data-table"
                          }
                        },
                        "events": {
                          "component": {
                            "onRowClick": {
                              "type": "script",
                              "scope": "G",
                              "config": {
                                "script": "\trow = event.row if hasattr(event, \"row\") else None\n\tdata = row.data if row and hasattr(row, \"data\") else None\n\tif data is None:\n\t\treturn\n\tsystem.perspective.openPopup(\n\t\tid=\"mpp-config-change-detail\",\n\t\tview=\"BlueRidge/Components/Popups/ConfigChangeDetail\",\n\t\tmodal=True,\n\t\tdraggable=False,\n\t\tshowCloseIcon=False,\n\t\tparams={\n\t\t\t\"id\":                data.get(\"Id\"),\n\t\t\t\"loggedAt\":          data.get(\"LoggedAt\"),\n\t\t\t\"userDisplayName\":   data.get(\"UserDisplayName\"),\n\t\t\t\"logEntityTypeName\": data.get(\"LogEntityTypeName\"),\n\t\t\t\"entityId\":          data.get(\"EntityId\"),\n\t\t\t\"logEventTypeCode\":  data.get(\"LogEventTypeCode\"),\n\t\t\t\"logSeverityCode\":   data.get(\"LogSeverityCode\"),\n\t\t\t\"description\":       data.get(\"Description\"),\n\t\t\t\"oldValue\":          data.get(\"OldValue\"),\n\t\t\t\"newValue\":          data.get(\"NewValue\"),\n\t\t\t\"popupId\":           \"mpp-config-change-detail\"\n\t\t}\n\t)"
                              }
                            }
                          }
                        }
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    ],
    "scripts": {
      "customMethods": [
        {
          "name": "applySearch",
          "params": [
            "self"
          ],
          "script": "\tresult = BlueRidge.Audit.ConfigLog.search(self.view.custom.filter)\n\tself.view.custom.rows       = result[\"rows\"]\n\tself.view.custom.totalCount = result[\"totalCount\"]"
        },
        {
          "name": "resetFilter",
          "params": [
            "self"
          ],
          "script": "\timport system\n\tnow = system.date.now()\n\tself.view.custom.filter = {\n\t\t\"startDate\":      system.date.addDays(now, -7),\n\t\t\"endDate\":        now,\n\t\t\"entityTypeCode\": None,\n\t\t\"logSeverityCode\": None,\n\t\t\"appUserId\":      None,\n\t\t\"searchText\":     \"\"\n\t}\n\tself.applySearch()"
        }
      ],
      "extensionFunctions": null
    }
  }
}