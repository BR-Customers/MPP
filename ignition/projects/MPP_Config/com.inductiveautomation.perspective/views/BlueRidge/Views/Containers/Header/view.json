{
  "custom": {},
  "params": {},
  "props": {
    "defaultSize": {
      "height": 42,
      "width": 1280
    }
  },
  "root": {
    "children": [
      {
        "events": {
          "dom": {
            "onClick": {
              "config": {
                "page": "/"
              },
              "scope": "C",
              "type": "nav"
            }
          }
        },
        "meta": {
          "name": "HeaderLogo"
        },
        "props": {
          "style": {
            "classes": "header-logo",
            "cursor": "pointer"
          },
          "text": "MPP"
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "HeaderDivider"
        },
        "props": {
          "style": {
            "classes": "header-divider"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "meta": {
          "name": "HeaderTitle"
        },
        "props": {
          "style": {
            "classes": "header-title"
          },
          "text": "Configuration Tool"
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "HeaderSpacer"
        },
        "position": {
          "grow": 1
        },
        "props": {
          "style": {
            "classes": "header-spacer"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "meta": {
              "name": "ThemeToggle"
            },
            "props": {
              "path": "material/wb_sunny",
              "style": {
                "classes": "theme-toggle",
                "cursor": "pointer"
              }
            },
            "type": "ia.display.icon"
          },
          {
            "meta": {
              "name": "UserAvatar"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "expression": "if({session.props.auth.user.userName} \u003d null || len({session.props.auth.user.userName}) \u003d 0, \u0027??\u0027, upper(left({session.props.auth.user.userName}, 1) + substring({session.props.auth.user.userName}, indexOf({session.props.auth.user.userName}, \u0027 \u0027)+1, 1)))"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "classes": "user-avatar"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "UserInfo"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "path": "session.props.auth.user.userName"
                  },
                  "transforms": [
                    {
                      "expression": "if({value} \u003d null || len({value}) \u003d 0, \u0027Sign In\u0027, {value})",
                      "type": "expression"
                    }
                  ],
                  "type": "property"
                }
              }
            },
            "props": {
              "style": {
                "classes": "user-info"
              }
            },
            "type": "ia.display.label"
          }
        ],
        "meta": {
          "name": "HeaderRight"
        },
        "props": {
          "alignItems": "center",
          "style": {
            "classes": "header-right"
          }
        },
        "type": "ia.container.flex"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "alignItems": "center",
      "style": {
        "classes": "header"
      }
    },
    "scripts": {
      "customMethods": [],
      "extensionFunctions": null,
      "messageHandlers": [
        {
          "messageType": "mpp-toast",
          "pageScope": false,
          "script": "\t# implement your handler here\n\tBlueRidge.Common.Notify._handle(self, payload)",
          "sessionScope": true,
          "viewScope": false
        }
      ]
    },
    "type": "ia.container.flex"
  }
}