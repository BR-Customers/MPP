{
  "custom": {
    "filter": {
      "areaLocationId":    null,
      "searchText":        "",
      "includeDeprecated": false
    },
    "areaOptions": [],
    "allRows":     []
  },
  "params": {},
  "propConfig": {
    "custom.filter.areaLocationId":   { "persistent": true },
    "custom.filter.searchText":       { "persistent": true },
    "custom.filter.includeDeprecated":{ "persistent": true },
    "custom.areaOptions": {
      "binding": {
        "type": "expr",
        "config": { "expression": "runScript(\"BlueRidge.Location.Location.getAllAreas\", 0, true)" }
      }
    },
    "custom.allRows": {
      "binding": {
        "type": "query",
        "config": {
          "queryPath":     "quality/DefectCode_List",
          "fallbackDelay": 2.5,
          "parameters": {
            "includeDeprecated": "{view.custom.filter.includeDeprecated}",
            "areaLocationId":    "{view.custom.filter.areaLocationId}"
          }
        },
        "transforms": [
          {
            "type": "script",
            "code": "\theaders = list(value.getColumnNames()) if value is not None else []\n\treturn [dict(zip(headers, row)) for row in (value or [])]"
          }
        ]
      }
    }
  },
  "props": {
    "defaultSize": { "width": 1280, "height": 720 }
  },
  "root": {
    "type": "ia.container.flex",
    "meta": { "name": "root" },
    "scripts": {
      "messageHandlers": [
        {
          "messageType": "defectCodeRefresh",
          "pageScope": true,
          "sessionScope": false,
          "viewScope": false,
          "script": "\tf = self.view.custom.filter or {}\n\tself.view.custom.allRows = BlueRidge.Quality.DefectCode.getAll(\n\t\tf.get(\"includeDeprecated\", False),\n\t\tf.get(\"areaLocationId\"))"
        }
      ]
    },
    "props": {
      "direction": "column",
      "style": { "classes": "screen-active" }
    },
    "children": [
      {
        "type": "ia.container.flex",
        "meta": { "name": "TitleRow" },
        "position": { "basis": "auto", "shrink": 0 },
        "props": {
          "direction": "row",
          "alignItems": "center",
          "style": {
            "classes": "title-row",
            "paddingBottom": "8px",
            "borderBottom": "1px solid var(--mpp-border-subtle)",
            "background": "var(--mpp-surface-raised)"
          }
        },
        "children": [
          {
            "type": "ia.container.flex",
            "meta": { "name": "TitleColumn" },
            "position": { "basis": "auto" },
            "props": { "direction": "column", "style": { "gap": "2px" } },
            "children": [
              {
                "type": "ia.container.flex",
                "meta": { "name": "Breadcrumb" },
                "position": { "basis": "auto" },
                "props": { "direction": "row", "alignItems": "center", "style": { "classes": "breadcrumb" } },
                "children": [
                  { "type": "ia.display.label", "meta": { "name": "BreadcrumbCategory" }, "position": { "basis": "auto" }, "props": { "text": "Quality", "style": { "classes": "breadcrumb" } } },
                  { "type": "ia.display.label", "meta": { "name": "BreadcrumbSep" },      "position": { "basis": "auto" }, "props": { "text": "›", "style": { "classes": "breadcrumb crumb-sep" } } },
                  { "type": "ia.display.label", "meta": { "name": "BreadcrumbActive" },   "position": { "basis": "auto" }, "props": { "text": "Defect Codes", "style": { "classes": "crumb-active" } } }
                ]
              },
              { "type": "ia.display.label", "meta": { "name": "Title" }, "position": { "basis": "auto" }, "props": { "text": "Defect Codes", "style": { "classes": "title-row-h1" } } }
            ]
          },
          { "type": "ia.display.label", "meta": { "name": "TitleRowSpacer" }, "position": { "grow": 1 }, "props": { "text": "", "style": { "classes": "title-row-spacer" } } },
          {
            "type": "ia.input.button",
            "meta": { "name": "AddCodeButton" },
            "position": { "basis": "auto" },
            "props": { "text": "+ Add Code", "style": { "classes": "btn btn-primary", "marginRight": "12px" } },
            "events": {
              "component": {
                "onActionPerformed": {
                  "type": "script", "scope": "G",
                  "config": {
                    "script": "\tsystem.perspective.openPopup(\n\t\tid=\"mpp-defect-code-editor\",\n\t\tview=\"BlueRidge/Components/Popups/DefectCodeEditor\",\n\t\tmodal=True,\n\t\tshowCloseIcon=False,\n\t\tparams={\"mode\": \"create\", \"defectCodeId\": None})"
                  }
                }
              }
            }
          }
        ]
      },
      {
        "type": "ia.container.flex",
        "meta": { "name": "MainSplit" },
        "position": { "grow": 1 },
        "props": {
          "direction": "row",
          "style": { "overflow": "hidden", "borderTop": "1px solid var(--mpp-border-subtle)" }
        },
        "children": [
          {
            "type": "ia.container.flex",
            "meta": { "name": "FilterSidebar" },
            "position": { "basis": "220px", "shrink": 0 },
            "props": {
              "direction": "column",
              "style": { "classes": "filter-sidebar" }
            },
            "children": [
              {
                "type": "ia.container.flex",
                "meta": { "name": "FilterPanel" },
                "position": { "basis": "auto" },
                "props": {
                  "direction": "column",
                  "style": { "classes": "filter-panel" }
                },
                "children": [
                  {
                    "type": "ia.container.flex",
                    "meta": { "name": "AreaField" },
                    "position": { "basis": "auto" },
                    "props": { "direction": "column", "style": { "gap": "4px" } },
                    "children": [
                      { "type": "ia.display.label", "meta": { "name": "AreaLabel" }, "position": { "basis": "auto" }, "props": { "text": "Area", "style": { "classes": "label-eyebrow" } } },
                      {
                        "type": "ia.input.dropdown",
                        "meta": { "name": "AreaDropdown" },
                        "position": { "basis": "auto" },
                        "propConfig": {
                          "props.options": { "binding": { "type": "property", "config": { "path": "view.custom.areaOptions" } } },
                          "props.value":   { "binding": { "type": "property", "config": { "bidirectional": true, "path": "view.custom.filter.areaLocationId" } } }
                        },
                        "props": { "style": { "classes": "select" } }
                      }
                    ]
                  },
                  {
                    "type": "ia.container.flex",
                    "meta": { "name": "SearchField" },
                    "position": { "basis": "auto" },
                    "props": { "direction": "column", "style": { "gap": "4px" } },
                    "children": [
                      { "type": "ia.display.label", "meta": { "name": "SearchLabel" }, "position": { "basis": "auto" }, "props": { "text": "Search", "style": { "classes": "label-eyebrow" } } },
                      {
                        "type": "ia.input.text-field",
                        "meta": { "name": "SearchInput" },
                        "position": { "basis": "auto" },
                        "propConfig": {
                          "props.text": { "binding": { "type": "property", "config": { "bidirectional": true, "path": "view.custom.filter.searchText" } } }
                        },
                        "props": { "placeholder": "Search…", "style": { "classes": "search-input" } }
                      }
                    ]
                  },
                  {
                    "type": "ia.input.checkbox",
                    "meta": { "name": "IncludeDeprecated" },
                    "position": { "basis": "auto" },
                    "propConfig": {
                      "props.selected": { "binding": { "type": "property", "config": { "bidirectional": true, "path": "view.custom.filter.includeDeprecated" } } }
                    },
                    "props": { "text": "Include deprecated", "style": { "classes": "checkbox", "color": "var(--mpp-text-secondary)", "fontSize": "12px" } }
                  }
                ]
              }
            ]
          },
          {
            "type": "ia.container.flex",
            "meta": { "name": "ContentArea" },
            "position": { "grow": 1 },
            "props": {
              "direction": "column",
              "style": {
                "padding": "12px",
                "background": "var(--mpp-surface-canvas)",
                "overflowY": "auto"
              }
            },
            "children": [
              {
                "type": "ia.container.flex",
                "meta": { "name": "DataPanel" },
                "position": { "grow": 1 },
                "props": {
                  "direction": "column",
                  "style": { "classes": "detail-panel", "padding": "0", "overflowX": "auto" }
                },
                "children": [
                  {
                    "type": "ia.container.flex",
                    "meta": { "name": "TableHeader" },
                    "position": { "basis": "auto" },
                    "props": {
                      "direction": "row",
                      "alignItems": "center",
                      "style": {
                        "background": "var(--mpp-surface-card)",
                        "color": "var(--mpp-text-secondary)",
                        "fontSize": "11px",
                        "fontWeight": "600",
                        "textTransform": "uppercase",
                        "letterSpacing": "0.05em",
                        "borderBottom": "1px solid var(--mpp-border-subtle)",
                        "padding": "8px 12px"
                      }
                    },
                    "children": [
                      { "type": "ia.display.label", "meta": { "name": "ColCode" },        "position": { "basis": "100px", "shrink": 0 }, "props": { "text": "Code" } },
                      { "type": "ia.display.label", "meta": { "name": "ColDescription" }, "position": { "grow": 1, "basis": "0" },     "props": { "text": "Description" } },
                      { "type": "ia.display.label", "meta": { "name": "ColArea" },        "position": { "basis": "140px", "shrink": 0 }, "props": { "text": "Area" } },
                      { "type": "ia.display.label", "meta": { "name": "ColExcused" },     "position": { "basis": "80px", "shrink": 0 },  "props": { "text": "Excused" } },
                      { "type": "ia.display.label", "meta": { "name": "ColEdit" },        "position": { "basis": "80px", "shrink": 0 },  "props": { "text": "" } }
                    ]
                  },
                  {
                    "type": "ia.display.flex-repeater",
                    "meta": { "name": "Rows" },
                    "position": { "basis": "auto" },
                    "propConfig": {
                      "props.instances": {
                        "binding": {
                          "type": "expr",
                          "config": {
                            "expression": "runScript(\"BlueRidge.Quality.DefectCode.filterAndMapRows\", 0, {view.custom.allRows}, {view.custom.filter.searchText})"
                          }
                        }
                      }
                    },
                    "props": {
                      "path": "BlueRidge/Components/DefectCodeRow",
                      "direction": "column",
                      "useDefaultViewWidth": false,
                      "useDefaultViewHeight": false,
                      "elementPosition": { "basis": "48px", "shrink": 0 }
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
