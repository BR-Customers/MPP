{
  "custom": {
    "filter": {
      "areaLocationId": null,
      "downtimeReasonTypeId": null,
      "searchText": "",
      "includeDeprecated": false
    },
    "areaOptions": [],
    "reasonTypeOptions": [],
    "rows": []
  },
  "params": {},
  "propConfig": {
    "custom.filter.areaLocationId":       { "persistent": true },
    "custom.filter.downtimeReasonTypeId": { "persistent": true },
    "custom.filter.searchText":           { "persistent": true },
    "custom.filter.includeDeprecated":    { "persistent": true },
    "custom.areaOptions": {
      "binding": {
        "type": "expr",
        "config": { "expression": "runScript(\"BlueRidge.Location.Location.getAllAreas\", 0, true)" }
      }
    },
    "custom.reasonTypeOptions": {
      "binding": {
        "type": "expr",
        "config": { "expression": "runScript(\"BlueRidge.Oee.DowntimeReasonType.getForDropdown\", 0, true, true)" }
      }
    },
    "custom.rows": {
      "binding": {
        "type": "expr",
        "config": { "expression": "runScript(\"BlueRidge.Oee.DowntimeReasonCode.search\", 0, {view.custom.filter})" }
      }
    }
  },
  "props": {
    "defaultSize": { "width": 1280, "height": 720 }
  },
  "root": {
    "type": "ia.container.flex",
    "meta": { "name": "root" },
    "props": {
      "direction": "column",
      "style": { "classes": "screen-active" }
    },
    "scripts": {
      "customMethods": [],
      "extensionFunctions": null,
      "messageHandlers": [
        {
          "messageType": "downtimeCodesRefresh",
          "pageScope": true,
          "sessionScope": false,
          "viewScope": false,
          "script": "\tself.view.custom.filter = dict(self.view.custom.filter)"
        }
      ]
    },
    "children": [
      {
        "type": "ia.container.flex",
        "meta": { "name": "TitleRow" },
        "position": { "basis": "auto", "shrink": 0 },
        "props": {
          "direction": "row",
          "alignItems": "center",
          "style": {
            "classes": "title-row",
            "paddingBottom": "8px",
            "borderBottom": "1px solid var(--mpp-border-subtle)",
            "background": "var(--mpp-surface-raised)"
          }
        },
        "children": [
          {
            "type": "ia.container.flex",
            "meta": { "name": "TitleColumn" },
            "position": { "basis": "auto" },
            "props": { "direction": "column", "style": { "gap": "2px" } },
            "children": [
              {
                "type": "ia.container.flex",
                "meta": { "name": "Breadcrumb" },
                "position": { "basis": "auto" },
                "props": { "direction": "row", "alignItems": "center", "style": { "classes": "breadcrumb" } },
                "children": [
                  { "type": "ia.display.label", "meta": { "name": "BreadcrumbCategory" }, "position": { "basis": "auto" }, "props": { "text": "Operations", "style": { "classes": "breadcrumb" } } },
                  { "type": "ia.display.label", "meta": { "name": "BreadcrumbSep" },      "position": { "basis": "auto" }, "props": { "text": "›", "style": { "classes": "breadcrumb crumb-sep" } } },
                  { "type": "ia.display.label", "meta": { "name": "BreadcrumbActive" },   "position": { "basis": "auto" }, "props": { "text": "Downtime Codes", "style": { "classes": "crumb-active" } } }
                ]
              },
              { "type": "ia.display.label", "meta": { "name": "Title" }, "position": { "basis": "auto" }, "props": { "text": "Downtime Codes", "style": { "classes": "title-row-h1" } } }
            ]
          },
          { "type": "ia.display.label", "meta": { "name": "TitleRowSpacer" }, "position": { "grow": 1 }, "props": { "text": "", "style": { "classes": "title-row-spacer" } } },
          {
            "type": "ia.input.button",
            "meta": { "name": "AddCodeButton" },
            "position": { "basis": "auto" },
            "props": { "text": "+ Add Code", "style": { "classes": "btn btn-primary", "marginRight": "12px" } },
            "events": {
              "component": {
                "onActionPerformed": {
                  "type": "script",
                  "scope": "G",
                  "config": {
                    "script": "\tsystem.perspective.openPopup(id=\"mpp-downtime-code-editor\", view=\"BlueRidge/Components/Popups/DowntimeCodeEditor\", modal=True, showCloseIcon=False, params={\"mode\": \"create\", \"editId\": None})"
                  }
                }
              }
            }
          }
        ]
      },
      {
        "type": "ia.container.flex",
        "meta": { "name": "MainSplit" },
        "position": { "grow": 1 },
        "props": {
          "direction": "row",
          "style": { "overflow": "hidden", "borderTop": "1px solid var(--mpp-border-subtle)" }
        },
        "children": [
          {
            "type": "ia.container.flex",
            "meta": { "name": "FilterSidebar" },
            "position": { "basis": "220px", "shrink": 0 },
            "props": {
              "direction": "column",
              "style": { "classes": "filter-sidebar" }
            },
            "children": [
              {
                "type": "ia.container.flex",
                "meta": { "name": "FilterPanel" },
                "position": { "basis": "auto" },
                "props": {
                  "direction": "column",
                  "style": { "classes": "filter-panel" }
                },
                "children": [
                  {
                    "type": "ia.container.flex",
                    "meta": { "name": "AreaField" },
                    "position": { "basis": "auto" },
                    "props": { "direction": "column", "style": { "gap": "4px" } },
                    "children": [
                      { "type": "ia.display.label", "meta": { "name": "AreaLabel" }, "position": { "basis": "auto" }, "props": { "text": "Area", "style": { "classes": "label-eyebrow" } } },
                      {
                        "type": "ia.input.dropdown",
                        "meta": { "name": "AreaDropdown" },
                        "position": { "basis": "auto" },
                        "propConfig": {
                          "props.options": { "binding": { "type": "property", "config": { "path": "view.custom.areaOptions" } } },
                          "props.value":   { "binding": { "type": "property", "config": { "bidirectional": true, "path": "view.custom.filter.areaLocationId" } } }
                        },
                        "props": { "style": { "classes": "select" } }
                      }
                    ]
                  },
                  {
                    "type": "ia.container.flex",
                    "meta": { "name": "ReasonTypeField" },
                    "position": { "basis": "auto" },
                    "props": { "direction": "column", "style": { "gap": "4px" } },
                    "children": [
                      { "type": "ia.display.label", "meta": { "name": "ReasonTypeLabel" }, "position": { "basis": "auto" }, "props": { "text": "Reason Type", "style": { "classes": "label-eyebrow" } } },
                      {
                        "type": "ia.input.dropdown",
                        "meta": { "name": "ReasonTypeDropdown" },
                        "position": { "basis": "auto" },
                        "propConfig": {
                          "props.options": { "binding": { "type": "property", "config": { "path": "view.custom.reasonTypeOptions" } } },
                          "props.value":   { "binding": { "type": "property", "config": { "bidirectional": true, "path": "view.custom.filter.downtimeReasonTypeId" } } }
                        },
                        "props": { "style": { "classes": "select" } }
                      }
                    ]
                  },
                  {
                    "type": "ia.container.flex",
                    "meta": { "name": "SearchField" },
                    "position": { "basis": "auto" },
                    "props": { "direction": "column", "style": { "gap": "4px" } },
                    "children": [
                      { "type": "ia.display.label", "meta": { "name": "SearchLabel" }, "position": { "basis": "auto" }, "props": { "text": "Search", "style": { "classes": "label-eyebrow" } } },
                      {
                        "type": "ia.input.text-field",
                        "meta": { "name": "SearchInput" },
                        "position": { "basis": "auto" },
                        "propConfig": {
                          "props.text": { "binding": { "type": "property", "config": { "bidirectional": true, "path": "view.custom.filter.searchText" } } }
                        },
                        "props": { "placeholder": "Search…", "style": { "classes": "search-input" } }
                      }
                    ]
                  },
                  {
                    "type": "ia.container.flex",
                    "meta": { "name": "IncludeDeprecatedField" },
                    "position": { "basis": "auto" },
                    "props": {
                      "direction": "row",
                      "alignItems": "center",
                      "style": { "gap": "8px", "paddingTop": "4px" }
                    },
                    "children": [
                      {
                        "type": "ia.input.checkbox",
                        "meta": { "name": "IncludeDeprecated" },
                        "position": { "basis": "auto", "shrink": 0 },
                        "propConfig": {
                          "props.selected": { "binding": { "type": "property", "config": { "bidirectional": true, "path": "view.custom.filter.includeDeprecated" } } }
                        }
                      },
                      {
                        "type": "ia.display.label",
                        "meta": { "name": "IncludeDeprecatedLabel" },
                        "position": { "basis": "auto" },
                        "props": {
                          "text": "Include deprecated",
                          "style": { "color": "var(--mpp-text-secondary)", "fontSize": "12px", "whiteSpace": "nowrap" }
                        }
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "ia.container.flex",
            "meta": { "name": "ContentArea" },
            "position": { "grow": 1 },
            "props": {
              "direction": "column",
              "style": {
                "padding": "12px",
                "background": "var(--mpp-surface-canvas)",
                "overflowY": "auto"
              }
            },
            "children": [
              {
                "type": "ia.container.flex",
                "meta": { "name": "DataPanel" },
                "position": { "grow": 1 },
                "props": {
                  "direction": "column",
                  "style": { "classes": "detail-panel", "padding": "0", "overflowX": "auto" }
                },
                "children": [
                  {
                    "type": "ia.container.flex",
                    "meta": { "name": "TableHeader" },
                    "position": { "basis": "auto" },
                    "props": {
                      "direction": "row",
                      "alignItems": "center",
                      "style": {
                        "background": "var(--mpp-surface-card)",
                        "color": "var(--mpp-text-secondary)",
                        "fontSize": "11px",
                        "fontWeight": "600",
                        "textTransform": "uppercase",
                        "letterSpacing": "0.05em",
                        "borderBottom": "1px solid var(--mpp-border-subtle)",
                        "padding": "8px 12px"
                      }
                    },
                    "children": [
                      { "type": "ia.display.label", "meta": { "name": "ColCode" },        "position": { "basis": "100px", "shrink": 0 }, "props": { "text": "Code" } },
                      { "type": "ia.display.label", "meta": { "name": "ColDescription" }, "position": { "grow": 1, "basis": "0" },     "props": { "text": "Description" } },
                      { "type": "ia.display.label", "meta": { "name": "ColArea" },        "position": { "basis": "130px", "shrink": 0 }, "props": { "text": "Area" } },
                      { "type": "ia.display.label", "meta": { "name": "ColType" },        "position": { "basis": "130px", "shrink": 0 }, "props": { "text": "Type" } },
                      { "type": "ia.display.label", "meta": { "name": "ColExcused" },     "position": { "basis": "80px", "shrink": 0 },  "props": { "text": "Excused" } },
                      { "type": "ia.display.label", "meta": { "name": "ColEdit" },        "position": { "basis": "80px", "shrink": 0 },  "props": { "text": "" } }
                    ]
                  },
                  {
                    "type": "ia.display.flex-repeater",
                    "meta": { "name": "Rows" },
                    "position": { "basis": "auto" },
                    "propConfig": {
                      "props.instances": {
                        "binding": {
                          "type": "property",
                          "config": { "path": "view.custom.rows" },
                          "transforms": [
                            {
                              "type": "script",
                              "code": "\treturn [\n\t\t{\n\t\t\t\"id\":          r.get(\"Id\"),\n\t\t\t\"code\":        r.get(\"Code\"),\n\t\t\t\"description\": r.get(\"Description\"),\n\t\t\t\"area\":        r.get(\"AreaName\"),\n\t\t\t\"type\":        r.get(\"ReasonTypeName\") or \"(Unassigned)\",\n\t\t\t\"excused\":     bool(r.get(\"IsExcused\")),\n\t\t\t\"selected\":    False\n\t\t}\n\t\tfor r in (value or [])\n\t]"
                            }
                          ]
                        }
                      }
                    },
                    "props": {
                      "path": "BlueRidge/Components/DowntimeCodeRow",
                      "direction": "column",
                      "useDefaultViewWidth": false,
                      "useDefaultViewHeight": false,
                      "elementPosition": { "basis": "48px", "shrink": 0 }
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
