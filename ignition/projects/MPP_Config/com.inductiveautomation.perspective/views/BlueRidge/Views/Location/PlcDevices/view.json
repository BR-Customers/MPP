{
  "custom": {
    "editDraft": {
      "deviceCode": "",
      "id": null,
      "plcDeviceTypeId": null,
      "sortOrder": null,
      "udtInstancePath": ""
    },
    "mappings": [],
    "mode": "view",
    "selectedTerminalId": ""
  },
  "params": {},
  "props": {
    "defaultSize": {
      "height": 720,
      "width": 1100
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "meta": {
              "name": "Title"
            },
            "props": {
              "style": {
                "classes": "screen-title"
              },
              "text": "PLC Device Mapping"
            },
            "type": "ia.display.label"
          },
          {
            "children": [
              {
                "meta": {
                  "name": "TerminalLbl"
                },
                "props": {
                  "text": "Terminal:"
                },
                "type": "ia.display.label"
              },
              {
                "events": {
                  "component": {
                    "onActionPerformed": {
                      "config": {
                        "script": "\tself.view.rootContainer.selectTerminal(self.props.value)"
                      },
                      "scope": "G",
                      "type": "script"
                    }
                  }
                },
                "meta": {
                  "name": "TerminalDropdown"
                },
                "propConfig": {
                  "props.options": {
                    "binding": {
                      "config": {
                        "expression": "runScript(\"BlueRidge.Location.TerminalPlcDevice.getTerminalsForDropdown\", 0)"
                      },
                      "type": "expr"
                    }
                  }
                },
                "props": {
                  "placeholder": {
                    "text": "Select a terminal..."
                  }
                },
                "type": "ia.input.dropdown"
              }
            ],
            "meta": {
              "name": "TerminalPick"
            },
            "props": {
              "alignItems": "center",
              "style": {
                "gap": "8px"
              }
            },
            "type": "ia.container.flex"
          }
        ],
        "meta": {
          "name": "Header"
        },
        "position": {
          "shrink": 0
        },
        "props": {
          "alignItems": "center",
          "justify": "space-between",
          "style": {
            "gap": "12px",
            "padding": "8px 4px"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "children": [
              {
                "meta": {
                  "name": "MappingsHdr"
                },
                "props": {
                  "style": {
                    "classes": "screen-subtitle"
                  },
                  "text": "Mappings for the selected terminal"
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "MappingsRepeater"
                },
                "position": {
                  "basis": "0",
                  "grow": 1
                },
                "propConfig": {
                  "props.instances": {
                    "binding": {
                      "config": {
                        "path": "view.custom.mappings"
                      },
                      "type": "property"
                    }
                  }
                },
                "props": {
                  "direction": "column",
                  "elementPosition": {
                    "basis": "auto"
                  },
                  "path": "BlueRidge/Components/PlcDeviceMappingRow",
                  "style": {
                    "gap": "6px",
                    "overflowY": "auto"
                  },
                  "useDefaultViewHeight": false,
                  "useDefaultViewWidth": false
                },
                "type": "ia.display.flex-repeater"
              },
              {
                "events": {
                  "component": {
                    "onActionPerformed": {
                      "config": {
                        "script": "\tself.view.rootContainer.newDraft()"
                      },
                      "scope": "G",
                      "type": "script"
                    }
                  }
                },
                "meta": {
                  "name": "AddMappingBtn"
                },
                "propConfig": {
                  "props.enabled": {
                    "binding": {
                      "config": {
                        "expression": "{view.custom.selectedTerminalId} !\u003d \"\""
                      },
                      "type": "expr"
                    }
                  }
                },
                "props": {
                  "style": {
                    "classes": "btn"
                  },
                  "text": "+ Add mapping"
                },
                "type": "ia.input.button"
              }
            ],
            "meta": {
              "name": "MappingsPanel"
            },
            "position": {
              "basis": "0",
              "grow": 1
            },
            "props": {
              "direction": "column",
              "style": {
                "gap": "8px",
                "padding": "8px"
              }
            },
            "type": "ia.container.flex"
          },
          {
            "children": [
              {
                "meta": {
                  "name": "FormHdr"
                },
                "props": {
                  "style": {
                    "classes": "screen-subtitle"
                  },
                  "text": "Mapping"
                },
                "type": "ia.display.label"
              },
              {
                "children": [
                  {
                    "meta": {
                      "name": "TypeFieldLbl"
                    },
                    "props": {
                      "text": "Device Type"
                    },
                    "type": "ia.display.label"
                  },
                  {
                    "meta": {
                      "name": "TypeDropdown"
                    },
                    "propConfig": {
                      "props.options": {
                        "binding": {
                          "config": {
                            "expression": "runScript(\"BlueRidge.Location.TerminalPlcDevice.getDeviceTypesForDropdown\", 0)"
                          },
                          "type": "expr"
                        }
                      },
                      "props.value": {
                        "binding": {
                          "config": {
                            "bidirectional": true,
                            "path": "view.custom.editDraft.plcDeviceTypeId"
                          },
                          "type": "property"
                        }
                      }
                    },
                    "type": "ia.input.dropdown"
                  }
                ],
                "meta": {
                  "name": "TypeField"
                },
                "props": {
                  "direction": "column",
                  "style": {
                    "gap": "4px"
                  }
                },
                "type": "ia.container.flex"
              },
              {
                "children": [
                  {
                    "meta": {
                      "name": "DeviceCodeFieldLbl"
                    },
                    "props": {
                      "text": "Device Code"
                    },
                    "type": "ia.display.label"
                  },
                  {
                    "meta": {
                      "name": "DeviceCodeInput"
                    },
                    "propConfig": {
                      "props.text": {
                        "binding": {
                          "config": {
                            "bidirectional": true,
                            "path": "view.custom.editDraft.deviceCode"
                          },
                          "type": "property"
                        }
                      }
                    },
                    "type": "ia.input.text-field"
                  }
                ],
                "meta": {
                  "name": "DeviceCodeField"
                },
                "props": {
                  "direction": "column",
                  "style": {
                    "gap": "4px"
                  }
                },
                "type": "ia.container.flex"
              },
              {
                "children": [
                  {
                    "meta": {
                      "name": "InstanceFieldLbl"
                    },
                    "props": {
                      "text": "UDT Instance Path"
                    },
                    "type": "ia.display.label"
                  },
                  {
                    "meta": {
                      "name": "InstanceDropdown"
                    },
                    "propConfig": {
                      "props.options": {
                        "binding": {
                          "config": {
                            "expression": "runScript(\"BlueRidge.Location.TerminalPlcDevice.getInstancePathOptions\", 0)"
                          },
                          "type": "expr"
                        }
                      },
                      "props.value": {
                        "binding": {
                          "config": {
                            "bidirectional": true,
                            "path": "view.custom.editDraft.udtInstancePath"
                          },
                          "type": "property"
                        }
                      }
                    },
                    "type": "ia.input.dropdown"
                  }
                ],
                "meta": {
                  "name": "InstanceField"
                },
                "props": {
                  "direction": "column",
                  "style": {
                    "gap": "4px"
                  }
                },
                "type": "ia.container.flex"
              },
              {
                "children": [
                  {
                    "meta": {
                      "name": "SortFieldLbl"
                    },
                    "props": {
                      "text": "Sort Order"
                    },
                    "type": "ia.display.label"
                  },
                  {
                    "meta": {
                      "name": "SortInput"
                    },
                    "propConfig": {
                      "props.text": {
                        "binding": {
                          "config": {
                            "bidirectional": true,
                            "path": "view.custom.editDraft.sortOrder"
                          },
                          "type": "property"
                        }
                      }
                    },
                    "type": "ia.input.text-field"
                  }
                ],
                "meta": {
                  "name": "SortField"
                },
                "props": {
                  "direction": "column",
                  "style": {
                    "gap": "4px"
                  }
                },
                "type": "ia.container.flex"
              },
              {
                "children": [
                  {
                    "events": {
                      "component": {
                        "onActionPerformed": {
                          "config": {
                            "script": "\tself.view.rootContainer.save()"
                          },
                          "scope": "G",
                          "type": "script"
                        }
                      }
                    },
                    "meta": {
                      "name": "SaveBtn"
                    },
                    "props": {
                      "style": {
                        "classes": "btn btn-primary"
                      },
                      "text": "Save"
                    },
                    "type": "ia.input.button"
                  },
                  {
                    "events": {
                      "component": {
                        "onActionPerformed": {
                          "config": {
                            "script": "\tself.view.rootContainer.cancel()"
                          },
                          "scope": "G",
                          "type": "script"
                        }
                      }
                    },
                    "meta": {
                      "name": "CancelBtn"
                    },
                    "props": {
                      "style": {
                        "classes": "btn"
                      },
                      "text": "Cancel"
                    },
                    "type": "ia.input.button"
                  }
                ],
                "meta": {
                  "name": "FormActions"
                },
                "props": {
                  "style": {
                    "gap": "8px"
                  }
                },
                "type": "ia.container.flex"
              }
            ],
            "meta": {
              "name": "EditForm"
            },
            "position": {
              "basis": "340px",
              "shrink": 0
            },
            "propConfig": {
              "position.display": {
                "binding": {
                  "config": {
                    "expression": "{view.custom.mode} !\u003d \"view\""
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "direction": "column",
              "style": {
                "gap": "10px",
                "padding": "8px"
              }
            },
            "type": "ia.container.flex"
          }
        ],
        "meta": {
          "name": "Body"
        },
        "position": {
          "basis": "0",
          "grow": 1
        },
        "props": {
          "style": {
            "gap": "12px"
          }
        },
        "type": "ia.container.flex"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "gap": "10px",
        "padding": "12px"
      }
    },
    "scripts": {
      "customMethods": [
        {
          "name": "selectTerminal",
          "params": [
            "terminalId"
          ],
          "script": "\tself.view.custom.selectedTerminalId \u003d terminalId\n\tself.view.custom.mappings \u003d BlueRidge.Location.TerminalPlcDevice.getMappingsForTerminal(terminalId)\n\tself.view.custom.mode \u003d \"view\""
        },
        {
          "name": "newDraft",
          "params": [],
          "script": "\tself.view.custom.editDraft \u003d {\"id\": None, \"plcDeviceTypeId\": None, \"deviceCode\": \"\", \"udtInstancePath\": \"\", \"sortOrder\": None}\n\tself.view.custom.mode \u003d \"create\""
        },
        {
          "name": "cancel",
          "params": [],
          "script": "\tself.view.custom.mode \u003d \"view\""
        },
        {
          "name": "save",
          "params": [],
          "script": "\td \u003d BlueRidge.Common.Util.extractQualifiedValues(self.view.custom.editDraft) or {}\n\td[\"terminalLocationId\"] \u003d self.view.custom.selectedTerminalId\n\tresult \u003d BlueRidge.Location.TerminalPlcDevice.save(d)\n\tBlueRidge.Common.Ui.notifyResult(result, successTitle\u003d\"Mapping saved\")\n\tif result and result.get(\"Status\"):\n\t\tself.view.custom.mode \u003d \"view\"\n\t\tself.view.custom.mappings \u003d BlueRidge.Location.TerminalPlcDevice.getMappingsForTerminal(self.view.custom.selectedTerminalId)"
        }
      ],
      "extensionFunctions": null,
      "messageHandlers": [
        {
          "messageType": "plcMappingEdit",
          "pageScope": true,
          "script": "\tp \u003d payload or {}\n\tself.view.custom.editDraft \u003d {\"id\": p.get(\"id\"), \"plcDeviceTypeId\": p.get(\"plcDeviceTypeId\"), \"deviceCode\": p.get(\"deviceCode\"), \"udtInstancePath\": p.get(\"udtInstancePath\"), \"sortOrder\": p.get(\"sortOrder\")}\n\tself.view.custom.mode \u003d \"edit\"",
          "sessionScope": false,
          "viewScope": false
        },
        {
          "messageType": "plcMappingDeprecate",
          "pageScope": true,
          "script": "\tp \u003d payload or {}\n\tresult \u003d BlueRidge.Location.TerminalPlcDevice.deprecate(p.get(\"id\"))\n\tBlueRidge.Common.Ui.notifyResult(result, successTitle\u003d\"Mapping removed\")\n\tif result and result.get(\"Status\"):\n\t\tself.view.custom.mappings \u003d BlueRidge.Location.TerminalPlcDevice.getMappingsForTerminal(self.view.custom.selectedTerminalId)",
          "sessionScope": false,
          "viewScope": false
        }
      ]
    },
    "type": "ia.container.flex"
  }
}