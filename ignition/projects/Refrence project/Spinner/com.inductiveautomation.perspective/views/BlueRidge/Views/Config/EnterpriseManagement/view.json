    "custom.items": {
      "binding": {
        "config": {
          "path": "view.custom.triggerRefresh"
        },
        "transforms": [
          {
            "expression": "runScript(\"BlueRidge.Config.AssetModel.getAll()\",0)",
            "type": "expression"
          }
        ],
        "type": "property"
      },
      "persistent": true
