    "custom.key": {
      "persistent": true
    },
    "custom.pageToShow": {
      "binding": {
        "config": {
          "path": "view.custom.selection"
        },
        "enabled": false,
        "transforms": [
          {
            "expression": "if(len({value})\u003e0,(len({value}) - len(replace({value}, \"/\", \"\"))),\"\")",
            "type": "expression"
          },
          {
            "fallback": "",
            "inputType": "scalar",
            "mappings": [
              {
                "input": 0,
                "output": "Plant"
              },
              {
                "input": 1,
                "output": "Equipment"
              },
              {
                "input": 2,
                "output": "Asset"
              }
            ],
            "outputType": "scalar",
            "type": "map"
          }
        ],
        "type": "property"
      },
      "persistent": true
    },
    "custom.selectedData": {
      "binding": {
        "config": {
          "path": "view.custom.key"
        },
        "transforms": [
          {
            "expression": "runScript(concat(\"BlueRidge.Config.\",{view.custom.pageToShow},\".getOne\"),0,{value})",
            "type": "expression"
          }
        ],
        "type": "property"
      },
      "persistent": true
    },
    "custom.selection": {
      "onChange": {
        "enabled": null,
        "script": "\tvalue \u003d currentValue.value\n\tif value:\n\t\tpageNum \u003d len(value) - len(value.split(\u0027/\u0027))\n\t\tif pageNum \u003d\u003d 0:\n\t\t\tpage \u003d \"Plant\"\n\t\telif pageNum \u003d\u003d 1:\n\t\t\tpage \u003d \"Equipment\"\n\t\telif pageNum \u003d\u003d 2:\n\t\t\tpage \u003d \"Asset\"\n\t\telse:\n\t\t\tpage \u003d \"\"\n\t\tself.custom.pageToShow \u003d page"
      },
      "persistent": true
    },
    "custom.triggerRefresh": {
      "persistent": true
    }
  },
