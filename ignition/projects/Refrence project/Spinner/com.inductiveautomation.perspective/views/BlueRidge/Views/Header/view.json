{
  "custom": {},
  "params": {
    "params": {},
    "size": "medium"
  },
  "propConfig": {
    "params.params": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.size": {
      "paramDirection": "input"
    }
  },
  "props": {
    "defaultSize": {
      "height": 58
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "hasDelegate": true,
          "name": "Spacer Start"
        },
        "position": {
          "basis": "16px",
          "shrink": 0
        },
        "props": {
          "text": " "
        },
        "type": "ia.display.label"
      },
      {
        "events": {
          "dom": {
            "onBlur": {
              "config": {
                "script": "\tsystem.perspective.closeDock(\"menu\")"
              },
              "scope": "G",
              "type": "script"
            },
            "onClick": {
              "config": {
                "id": "menu",
                "type": "toggle"
              },
              "scope": "C",
              "type": "dock"
            }
          }
        },
        "meta": {
          "name": "Menu Dock",
          "tabIndex": 1
        },
        "position": {
          "basis": "24px",
          "shrink": 0
        },
        "propConfig": {
          "position.display": {
            "binding": {
              "config": {
                "expression": "{view.params.size} !\u003d \"large\""
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "color": "#777777",
          "path": "material/menu",
          "style": {
            "classes": "BlueRidge/Header/Icon",
            "marginRight": "10px"
          }
        },
        "type": "ia.display.icon"
      },
      {
        "events": {
          "dom": {
            "onClick": {
              "config": {
                "page": "/"
              },
              "scope": "C",
              "type": "nav"
            }
          }
        },
        "meta": {
          "name": "Image"
        },
        "position": {
          "basis": "100px"
        },
        "props": {
          "fit": {
            "mode": "fill"
          },
          "source": "/system/images/JET/jasperengineslogo100associateownedwhitetext.png",
          "style": {
            "cursor": "pointer",
            "margin": "2px"
          },
          "tint": {
            "enabled": true
          }
        },
        "type": "ia.display.image"
      },
      {
        "meta": {
          "hasDelegate": true,
          "name": "Filler"
        },
        "position": {
          "grow": 1
        },
        "props": {
          "text": " "
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "hasDelegate": true,
          "name": "Spacer 1"
        },
        "position": {
          "basis": "10px"
        },
        "props": {
          "text": " "
        },
        "type": "ia.display.label"
      },
      {
        "events": {
          "dom": {
            "onClick": {
              "config": {
                "script": "\tif self.session.props.auth.authenticated:\n\t\tsystem.perspective.logout()\n\telse:\n\t\tsystem.perspective.login()"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "User"
        },
        "position": {
          "basis": "30px",
          "shrink": 0
        },
        "props": {
          "color": "#777777",
          "path": "material/person",
          "style": {
            "classes": "BlueRidge/Header/Icon"
          }
        },
        "type": "ia.display.icon"
      },
      {
        "events": {
          "dom": {
            "onClick": {
              "config": {
                "script": "\tif self.session.props.auth.authenticated:\n\t\tsystem.perspective.logout()\n\telse:\n\t\tsystem.perspective.login()"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "hasDelegate": true,
          "name": "Sign In"
        },
        "position": {
          "shrink": 0
        },
        "propConfig": {
          "position.display": {
            "binding": {
              "config": {
                "expression": "{view.params.size} !\u003d \"small\""
              },
              "type": "expr"
            }
          },
          "props.text": {
            "binding": {
              "config": {
                "path": "session.props.auth.user.userName"
              },
              "transforms": [
                {
                  "expression": "if({value} \u003d null || len({value}) \u003d 0, \"Sign In\", {value})",
                  "type": "expression"
                }
              ],
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "classes": "BlueRidge/Header/Icon",
            "color": "#777777",
            "cursor": "pointer",
            "marginLeft": "4px"
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "hasDelegate": true,
          "name": "Spacer 2"
        },
        "position": {
          "basis": "10px",
          "shrink": 0
        },
        "props": {
          "text": " "
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "hasDelegate": true,
          "name": "Spacer End"
        },
        "position": {
          "basis": "16px",
          "shrink": 0
        },
        "props": {
          "text": " "
        },
        "type": "ia.display.label"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "style": {
        "backgroundColor": "#F1F1F1",
        "classes": "BlueRidge/Header/Header"
      }
    },
    "type": "ia.container.flex"
  }
}