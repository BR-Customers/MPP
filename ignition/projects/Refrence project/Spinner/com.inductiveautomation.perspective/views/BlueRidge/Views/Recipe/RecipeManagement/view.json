    "custom.currentEquipmentType": {
      "persistent": true
    },
    "custom.currentType": {
      "persistent": true
    },
    "custom.equipmentTypes": {
      "binding": {
        "config": {
          "path": "view.custom.triggerRefresh"
        },
        "transforms": [
          {
            "code": "\treturn BlueRidge.Recipe.Operation.getOperationEquipmentForDropdown()",
            "type": "script"
          }
        ],
        "type": "property"
      },
      "persistent": true
    },
    "custom.filter": {
      "persistent": true
    },
    "custom.instances": {
      "binding": {
        "config": {
          "path": "view.custom.triggerRefresh"
        },
        "transforms": [
          {
            "expression": "runScript(\u0027BlueRidge.Recipe.Operation.getAll\u0027,0,{view.custom.filter})",
            "type": "expression"
          },
          {
            "code": "\teqOperations \u003d []\n\tfor instance in value:\n\t\tif instance[\u0027equipmentType\u0027] \u003d\u003d self.custom.currentEquipmentType:\n\t\t\teqOperations.append(instance)\n\treturn eqOperations",
            "type": "script"
          },
          {
            "code": "\tvalue.sort(key\u003dlambda x: x[\u0027text\u0027])\n\treturn value",
            "type": "script"
          }
        ],
        "type": "property"
      },
      "persistent": true
    },
    "custom.operation": {
      "binding": {
        "config": {
          "path": "view.custom.selectedData"
        },
        "transforms": [
          {
            "expression": "runScript(\"BlueRidge.Recipe.Operation.getOne\",0,{value})",
            "type": "expression"
          }
        ],
        "type": "property"
      },
      "onChange": {
        "enabled": false,
        "script": "\tif origin \u003d\u003d \u0027BindingWriteback\u0027:\n\t\tdata \u003d self.custom.operation\n\t\tdata \u003d BlueRidge.Recipe.Util.convertWrapperObjectToJson(data)\n\t\tdata[\u0027user\u0027]\u003dself.session.props.auth.user.userName\n\t\tdata[\u0027equipmentType\u0027]\u003dself.custom.currentEquipmentType\n\t\tresp \u003d BlueRidge.Recipe.Operation.update(data)\n\t\tif resp \u003d\u003d -1:\n\t\t\tsystem.perspective.sendMessage(\"refreshTrigger\")\n\t\t\tpass"
      },
      "persistent": true
    },
    "custom.pageToShow": {
      "binding": {
        "config": {
          "path": "view.custom.selectedData"
        },
        "transforms": [
          {
            "expression": "if({value} !\u003d 0, case({view.custom.currentEquipmentType},\r\n\u0027engine\u0027, \u0027Operation\u0027,\r\n\u0027head\u0027, \u0027OperationHeads\u0027, \u0027\u0027), \u0027\u0027)",
            "type": "expression"
          }
        ],
        "type": "property"
      },
      "persistent": true
    },
    "custom.selectedData": {
      "binding": {
        "config": {
          "path": "view.custom.triggerRefresh"
        },
        "transforms": [
          {
            "expression": "0",
            "type": "expression"
          }
        ],
        "type": "property"
      },
      "persistent": true
    },
    "custom.triggerRefresh": {
      "persistent": true
    }
  },
