          "pageScope": true,
          "script": "\tselectedData \u003d self.view.custom.selectedData\n\ttrigger \u003d self.view.custom.triggerRefresh\n\tself.view.custom.triggerRefresh \u003d not trigger\n#\tself.view.custom.selectedData \u003d \u0027\u0027\t\n\tif selectedData:\n\t\tsystem.perspective.sendMessage(\u0027OneShotButtonOperation\u0027, selectedData)\n\t\tsystem.perspective.sendMessage(\u0027OperationButton\u0027, {\u0027view\u0027:selectedData})",
          "sessionScope": false,
          "viewScope": false
        },
        {
          "messageType": "OneShotButtonOperation",
          "pageScope": true,
          "script": "\tself.view.custom.selectedData \u003d payload",
          "sessionScope": false,
          "viewScope": false
        },
        {
          "messageType": "filterUpdate",
          "pageScope": true,
          "script": "\tself.view.custom.filter \u003d payload\n\tsystem.perspective.sendMessage(\"refreshTrigger\")",
          "sessionScope": false,
          "viewScope": false
        },
        {
          "messageType": "archiveButton",
          "pageScope": true,
          "script": "\tif type(payload) \u003d\u003d dict:\n\t\tif \u0027type\u0027 in payload.keys():\n\t\t\tremoveKey \u003d payload[\u0027key\u0027]\n\t\t\toperations \u003d self.view.custom.instances\n\t\t\tnew_operations \u003d [d for d in operations if d.get(\u0027key\u0027) !\u003d removeKey]\n\t\t\tself.view.custom.instances \u003d new_operations\n\t\t\tself.view.custom.selectedData \u003d 0",
          "sessionScope": false,
          "viewScope": false
        },
