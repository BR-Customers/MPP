{
  "custom": {},
  "params": {
    "assignedNumber": 0,
    "selected": false
  },
  "propConfig": {
    "params.assignedNumber": {
      "paramDirection": "inout",
      "persistent": true
    },
    "params.selected": {
      "paramDirection": "inout",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 50,
      "width": 50
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "meta": {
              "name": "NumericEntryField"
            },
            "position": {
              "basis": "32px",
              "display": false
            },
            "propConfig": {
              "props.value": {
                "binding": {
                  "config": {
                    "bidirectional": true,
                    "path": "view.params.assignedNumber"
                  },
                  "type": "property"
                }
              }
            },
            "type": "ia.input.numeric-entry-field"
          },
          {
            "meta": {
              "name": "Label"
            },
            "position": {
              "basis": "50px"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "path": "view.params.assignedNumber"
                  },
                  "type": "property"
                }
              }
            },
            "props": {
              "style": {
                "textAlign": "center"
              }
            },
            "type": "ia.display.label"
          }
        ],
        "meta": {
          "name": "FlexContainer"
        },
        "position": {
          "basis": "200px",
          "grow": 1
        },
        "propConfig": {
          "props.style.backgroundColor": {
            "binding": {
              "config": {
                "path": "view.params.selected"
              },
              "transforms": [
                {
                  "fallback": "#AAAAAA",
                  "inputType": "scalar",
                  "mappings": [
                    {
                      "input": true,
                      "output": "--indicator"
                    },
                    {
                      "input": null,
                      "output": "#AAAAAA"
                    }
                  ],
                  "outputType": "scalar",
                  "type": "map"
                }
              ],
              "type": "property"
            }
          }
        },
        "props": {
          "alignItems": "center",
          "justify": "space-around",
          "style": {
            "borderBottomLeftRadius": "50%",
            "borderBottomRightRadius": "50%",
            "borderTopLeftRadius": "50%",
            "borderTopRightRadius": "50%",
            "margin": 2
          }
        },
        "type": "ia.container.flex"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column"
    },
    "type": "ia.container.flex"
  }
}