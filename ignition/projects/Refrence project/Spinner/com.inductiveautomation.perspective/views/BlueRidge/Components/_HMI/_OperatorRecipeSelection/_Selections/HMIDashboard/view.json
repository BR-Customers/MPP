        "config": {
          "path": "view.custom.operationDetails.widgets"
        },
        "transforms": [
          {
            "code": "\tselections \u003d []\n\tfor w in value:\n\t\tselections.append({\u0027widgetUUID\u0027: w[\u0027viewParams\u0027][\u0027buttonIndex\u0027], \u0027selected\u0027:0})\n\treturn selections",
            "type": "script"
          }
        ],
        "type": "property"
      },
      "onChange": {
        "enabled": null,
        "script": "\tselectedButtons \u003d self.session.custom.hMISelections.selectedButtons\n\tfound \u003d False\n\tfor i in range(len(selectedButtons)):\n\t\tif selectedButtons[i][\u0027operationUUID\u0027] \u003d\u003d self.custom.operationDetails.headOperationUUID:\n\t\t\tselectedButtons[i][\u0027selections\u0027] \u003d currentValue.value\n\t\t\tfound \u003d True\n\tif not found:\n\t\tselectedButtons.append({\u0027operationUUID\u0027: self.custom.operationDetails.headOperationUUID, \u0027selections\u0027: currentValue.value})"
      },
      "persistent": true
    },
    "custom.operationDetails": {
      "binding": {
        "config": {
          "path": "view.params.headOperation"
        },
        "transforms": [
          {
            "code": "\treturn BlueRidge.Config.HeadConfig.getHeadOperation(value)[0]",
