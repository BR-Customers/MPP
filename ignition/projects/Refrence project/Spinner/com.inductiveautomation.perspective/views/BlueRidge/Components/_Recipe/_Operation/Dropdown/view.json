  "root": {
    "children": [
      {
        "events": {
          "component": {
            "onActionPerformed": {
              "config": {
                "script": "\tpayload \u003d {\u0027row\u0027:self.view.params.rowIndex, \u0027value\u0027:self.props.value}\n\tsystem.perspective.sendMessage(\u0027UpdateAssignment\u0027, payload)"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "Dropdown"
        },
        "position": {
          "basis": "36px",
          "grow": 1
        },
        "propConfig": {
          "props.options": {
            "binding": {
              "config": {
                "path": "view.custom.options"
              },
              "type": "property"
            }
          },
          "props.value": {
            "binding": {
              "config": {
                "path": "view.custom.value"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "maxMenuHeight": 500
        },
        "type": "ia.input.dropdown"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column"
    },
    "type": "ia.container.flex"
  }
