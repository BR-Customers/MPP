    "custom.selectionsMade": {
      "binding": {
        "config": {
          "path": "view.custom.selectedData"
        },
        "transforms": [
          {
            "code": "#\tsystem.perspective.print(value)\n\tengineKey \u003d value[\"Engine\"]\n\toperationKey \u003d value[\"Operation\"]\n\tcylinderKey \u003d value[\"Cylinder\"]\n\tmillingKey \u003d value[\"Milling\"]\n\n\tboreOperationParams \u003d []\n\textensionTypeUUID \u003d self.session.custom.equipment.extension\n\tOperationParameterLists \u003d BlueRidge.HMI.CNCLoader.ParameterList.getAll(operationKey)\n\tOperationParameterList \u003d next((v for v in OperationParameterLists if v[\u0027extensionTypeUUID\u0027] \u003d\u003d extensionTypeUUID),None)\n\tif OperationParameterList: \n\t\tOperationParameterListUUID \u003d OperationParameterList[\u0027key\u0027]\n\t\tboreOperationParams \u003d BlueRidge.HMI.CNCLoader.EngineParameter.getAll(OperationParameterListUUID)\n\t\n\tmillOperationParams \u003d []\n\tOperationParameterLists \u003d BlueRidge.HMI.CNCLoader.ParameterList.getAll(millingKey)\n\tOperationParameterList \u003d next((v for v in OperationParameterLists if v[\u0027extensionTypeUUID\u0027] \u003d\u003d extensionTypeUUID),None)\n\tif OperationParameterList: \n\t\tOperationParameterListUUID \u003d OperationParameterList[\u0027key\u0027]\n\t\tmillOperationParams \u003d BlueRidge.HMI.CNCLoader.EngineParameter.getAll(OperationParameterListUUID)\n\t\n\tresp \u003d []\n\tengine \u003d BlueRidge.HMI.CNCLoader.Engine.getOne(engineKey)\n\tengineName \u003d engine[\u0027name\u0027]\n\tblockConfig \u003d engine[\u0027blockConfig\u0027]\n\tresp.append({\u0027text\u0027:engineName,\u0027value\u0027:True})\n\toperationName \u003d BlueRidge.HMI.CNCLoader.Operation.getOne(operationKey).get(\u0027name\u0027)\n\t\n\tif not operationName:\n\t\toperationName \u003d \u0027Bore: None\u0027\n\t\tresp.append({\u0027text\u0027:operationName,\u0027value\u0027:False})\n\telse:\n\t\tselectedValue \u003d self.session.custom.selectedBore\n\t\tif selectedValue:\n\t\t\tselectedLabel \u003d next((i[\"Name\"] for i in boreOperationParams if i[\"Assignment\"] \u003d\u003d selectedValue), None)\n\t\t\toperationName \u003d operationName+\u0027 - %s\u0027 % (selectedLabel)\n\t\tresp.append({\u0027text\u0027:operationName,\u0027value\u0027:True})\n\t\n\tif cylinderKey \u003d\u003d 1:\n\t\tresp.append({\u0027text\u0027:\"Cylinders: All\",\u0027value\u0027:True})\n\t\tselectedAssignedNumbers \u003d []\n\telse:\n\t\tselectedCylinders \u003d self.custom.selectedCylinders\n\t\tassignedNumbers \u003d BlueRidge.HMI.CNCLoader.BlockConfig.getOne(blockConfig)[\u0027assignedNumbers\u0027]\n\t\tselectedCylindersFlat \u003d [item for sublist in selectedCylinders for item in sublist]\n\t\tselectedAssignedNumbers\u003d[num for sel, num in zip(selectedCylindersFlat, assignedNumbers) if bool(sel)]\n\t\tresp.append({\u0027text\u0027:\"Cylinders:{}\".format(selectedAssignedNumbers),\u0027value\u0027:False})\n\t\tself.custom.selectedAssignedNumbers \u003d selectedAssignedNumbers\n\t\n\tif millingKey \u003d\u003d 2:\n\t\tresp.append({\u0027text\u0027:\u0027Milling: None\u0027,\u0027value\u0027:False})\n\telse:\n\t\tmillingName \u003d BlueRidge.HMI.CNCLoader.Operation.getOne(millingKey)[\u0027name\u0027]\n\t\tselectedValue \u003d self.session.custom.selectedMill\n\t\tif selectedValue:\n\t\t\tselectedLabel \u003d next((i[\"Name\"] for i in millOperationParams if i[\"Assignment\"] \u003d\u003d selectedValue), None)\n\t\t\tmillingName \u003d millingName+\u0027 - %s\u0027 % (selectedLabel)\n\t\tresp.append({\u0027text\u0027:millingName,\u0027value\u0027:True})\n\treturn resp",
            "type": "script"
          }
        ],
        "type": "property"
      },
      "persistent": true
    },
    "custom.triggerRefresh": {
      "persistent": true
    }
  },
