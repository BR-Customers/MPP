{
  "custom": {},
  "params": {
    "data": "value",
    "script": "value"
  },
  "propConfig": {
    "params.data": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.script": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 300,
      "width": 400
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "meta": {
              "name": "Label_0"
            },
            "position": {
              "basis": "50px",
              "display": false
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "path": "view.params.data"
                  },
                  "transforms": [
                    {
                      "expression": "\"Item to be archived: \"+runScript(\"BlueRidge.Recipe.Util.extractQualifiedValues\",0,{value})",
                      "type": "expression"
                    }
                  ],
                  "type": "property"
                }
              }
            },
            "props": {
              "style": {
                "classes": "BlueRidge/boldTitleSmall"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "Label"
            },
            "position": {
              "basis": "50px",
              "grow": 1
            },
            "props": {
              "text": "Are you sure?",
              "textStyle": {
                "classes": "BlueRidge/boldTitleLarge"
              }
            },
            "type": "ia.display.label"
          }
        ],
        "meta": {
          "name": "Top"
        },
        "position": {
          "basis": "200px",
          "grow": 1
        },
        "props": {
          "direction": "column",
          "justify": "center"
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "events": {
              "component": {
                "onActionPerformed": {
                  "config": {
                    "draggable": true,
                    "id": "DuplicateOperation",
                    "modal": false,
                    "overlayDismiss": false,
                    "resizable": true,
                    "showCloseIcon": true,
                    "type": "close",
                    "viewPath": "BlueRidge/Components/_Recipe/Popups/DuplicateOperation",
                    "viewportBound": false
                  },
                  "scope": "C",
                  "type": "popup"
                }
              }
            },
            "meta": {
              "name": "CancelButton"
            },
            "position": {
              "basis": "100px"
            },
            "props": {
              "style": {
                "classes": "BlueRidge/Components/dangerButtonRound"
              },
              "text": "Cancel"
            },
            "type": "ia.input.button"
          },
          {
            "events": {
              "component": {
                "onActionPerformed": {
                  "config": {
                    "script": "\tsystem.perspective.sendMessage(\u0027duplicateConfirm\u0027)\n\tsystem.perspective.sendMessage(\"refreshTrigger\")\n\tsystem.perspective.closePopup(\u0027DuplicateOperation\u0027)"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "YesButton"
            },
            "position": {
              "basis": "100px"
            },
            "props": {
              "style": {
                "classes": "BlueRidge/Components/actionButtonRound"
              },
              "text": "Yes"
            },
            "type": "ia.input.button"
          }
        ],
        "meta": {
          "name": "Middle"
        },
        "position": {
          "basis": "34px"
        },
        "props": {
          "justify": "space-evenly"
        },
        "type": "ia.container.flex"
      },
      {
        "meta": {
          "name": "Bottom"
        },
        "position": {
          "basis": "100px"
        },
        "type": "ia.container.flex"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column"
    },
    "type": "ia.container.flex"
  }
}