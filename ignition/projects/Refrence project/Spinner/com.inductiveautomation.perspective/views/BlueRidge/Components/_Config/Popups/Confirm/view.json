{
  "custom": {},
  "params": {
    "data": "value",
    "script": "value"
  },
  "propConfig": {
    "params.data": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.script": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 300,
      "width": 400
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "meta": {
              "name": "Label_0"
            },
            "position": {
              "basis": "50px",
              "display": false
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "path": "view.params.data"
                  },
                  "transforms": [
                    {
                      "expression": "\"Item to be archived: \"+{value}",
                      "type": "expression"
                    }
                  ],
                  "type": "property"
                }
              }
            },
            "props": {
              "style": {
                "classes": "BlueRidge/boldTitleSmall"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "Label"
            },
            "position": {
              "basis": "50px",
              "grow": 1
            },
            "props": {
              "text": "Are you sure?",
              "textStyle": {
                "classes": "BlueRidge/boldTitleLarge"
              }
            },
            "type": "ia.display.label"
          }
        ],
        "meta": {
          "name": "Top"
        },
        "position": {
          "basis": "200px",
          "grow": 1
        },
        "props": {
          "direction": "column",
          "justify": "center"
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "events": {
              "component": {
                "onActionPerformed": {
                  "config": {
                    "draggable": true,
                    "id": "confirm",
                    "modal": false,
                    "overlayDismiss": false,
                    "resizable": true,
                    "showCloseIcon": true,
                    "type": "close",
                    "viewPath": "BlueRidge/Components/Popups/Confirm",
                    "viewportBound": false
                  },
                  "scope": "C",
                  "type": "popup"
                }
              }
            },
            "meta": {
              "name": "CancelButton"
            },
            "position": {
              "basis": "100px"
            },
            "props": {
              "style": {
                "classes": "BlueRidge/Components/dangerButtonRound"
              },
              "text": "Cancel"
            },
            "type": "ia.input.button"
          },
          {
            "events": {
              "component": {
                "onActionPerformed": {
                  "config": {
                    "script": "\tscript \u003d self.view.params.script.replace(\u0027/\u0027,\u0027.\u0027)\n\tdata \u003d self.view.params.data\n\tdata \u003d BlueRidge.Config.Util.convertWrapperObjectToJson(data)\n#\tsystem.perspective.print(\u0027data:{}\u0027.format(data))\n#\tsystem.perspective.print(\u0027dataType:{}\u0027.format(type(data)))\n\ttry:\n\t\tkey \u003d data.get(\u0027key\u0027)\n#\t\tsystem.perspective.print(\u0027key:{}\u0027.format(key))\n\t\tdatatype \u003d data.get(\u0027type\u0027)\n\texcept:\n\t\tkey \u003d data\n\t\tdatatype \u003d \u0027\u0027\n\tfunction \u003d \u0027archive\u0027\n\tif datatype in [\u0027Plant\u0027,\u0027Equipment\u0027,\u0027Asset\u0027]:\n\t\tresp \u003d eval(script+\".{0}(\u0027{1}\u0027)\".format(function,data))\n\telse:\n\t\tif key:\n#\t\t\tdata \u003d system.util.jsonEncode(key)\n\t\t\tdata \u003d key\n\t\tresp \u003d eval(script+\".{0}(\u0027{1}\u0027)\".format(function,data))\n\tif resp \u003d\u003d -1:\n\t\tsystem.perspective.sendMessage(\"refreshTrigger\")\n\t\tsystem.perspective.closePopup(\u0027confirm\u0027)"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "YesButton"
            },
            "position": {
              "basis": "100px"
            },
            "props": {
              "style": {
                "classes": "BlueRidge/Components/actionButtonRound"
              },
              "text": "Yes"
            },
            "type": "ia.input.button"
          }
        ],
        "meta": {
          "name": "Middle"
        },
        "position": {
          "basis": "34px"
        },
        "props": {
          "justify": "space-evenly"
        },
        "type": "ia.container.flex"
      },
      {
        "meta": {
          "name": "Bottom"
        },
        "position": {
          "basis": "100px"
        },
        "type": "ia.container.flex"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column"
    },
    "type": "ia.container.flex"
  }
}