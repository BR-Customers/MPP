            },
            "position": {
              "grow": 0.2
            },
            "type": "ia.container.flex"
          },
          {
            "children": [
              {
                "events": {
                  "component": {
                    "onActionPerformed": {
                      "config": {
                        "script": "\tfrom java.lang import String,Byte\n\tlogger \u003d system.util.getLogger(\"SpinnerOPC\")\n\t\n\tcncFile \u003d BlueRidge.HMI.HeadHMI.File.generateCNCFile(self.session.custom.hMISelections)\n\t\n\tconn \u003d \"SpinnerCNC\"\n\t# Use EXACT NodeIds from Ignition OPC UA Browser (including namespace!)\n\tdir_objectId \u003d system.tag.readBlocking([\u0027[default]VARSFileId\u0027])[0].value\n\topenFileId   \u003d \"i\u003d11580\"\n\treadFileId \u003d \"i\u003d11585\"\n\twriteFileId  \u003d \"i\u003d11588\"\n\tcloseFileId  \u003d \"i\u003d11583\"\n\t\n\t# What you want the file to be called on the Heidenhain side:\n\tfile_name \u003d \"VARS.h\"   # or cncFile.get(\"filename\") if you want dynamic naming\n\t\n\tcontent \u003d cncFile.get(\"content\", \"\")\n\tsystem.perspective.print(str(self.session.custom.hMISelections))\n\tsystem.perspective.print(str(content))\n\t\n\tdata_list \u003d String(content).getBytes(\"utf-8\")  # Byte[] (0-255)\n\t\n\tMODE_WRITE \u003d BlueRidge.Config.Util.bitsToBytes([0,1])  # common \"write\" mode; confirm in method signature/docs\n\n\thandle \u003d None\n\t\n\tif dir_objectId \u003d\u003d \u0027MissingFile\u0027:\n\t\ttry:\n\t\t\tncId \u003d system.tag.readBlocking([\u0027[default]NC_ProgId\u0027])[0].value\n\t\t\tcreatedFile \u003d system.opcua.callMethod(conn, ncId, \u0027i\u003d13390\u0027, [file_name, False])\n\t\t\tdir_objectId \u003d createdFile[2][0]\n\t\texcept:\n\t\t\tlogger.info(\u0027Create file failed\u0027)\n\t\n\ttry:\n\t    # Open(fileName:String, mode:Byte) -\u003e handle\n\t    open_result \u003d system.opcua.callMethod(conn, dir_objectId, openFileId, [7])\n\t    logger.info(str(open_result))\n\t    handle \u003d tuple(open_result)[2][0]\n\t\n\t    logger.info(\"Opened %r, handle\u003d%r, result:%s\" % (file_name, handle,str(open_result)))\n\n\t    system.opcua.callMethod(conn, dir_objectId, writeFileId, [handle, data_list])\n\t    logger.info(\"Wrote %s bytes\" % (data_list))\n\t    self.view.custom.status \u003d \u0027File Sent\u0027\n\texcept:\n\t\tself.view.custom.status \u003d \u0027File Send Failed\u0027\n\tfinally:\n\t    if handle is not None:\n\t        try:\n\t            # Close(handle)\n\t            system.opcua.callMethod(conn, dir_objectId, closeFileId, [handle])\n\t            logger.info(\"Closed handle %r\" % handle)\n\t        except Exception as e:\n\t            logger.error(\"Close failed: %s\" % e)"
                      },
                      "scope": "G",
                      "type": "script"
                    }
                  }
