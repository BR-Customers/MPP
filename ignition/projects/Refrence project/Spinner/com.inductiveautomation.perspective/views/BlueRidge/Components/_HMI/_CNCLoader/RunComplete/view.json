  "propConfig": {
    "custom.failureReasons": {
      "binding": {
        "config": {
          "path": "view.custom.selectedData.Engine"
        },
        "transforms": [
          {
            "expression": "runScript(\u0027BlueRidge.HMI.CNCLoader.FailureReason.getAll\u0027,0,{value})",
            "type": "expression"
          }
        ],
        "type": "property"
      },
      "persistent": true
    },
    "custom.instances": {
      "binding": {
        "config": {
          "path": "view.custom.failureReasons"
        },
        "transforms": [
          {
            "code": "\tresp \u003d []\n\tfor reason in value:\n\t\tresp.append({\u0027text\u0027:reason[\u0027Name\u0027],\u0027view\u0027:reason[\u0027key\u0027],\u0027value\u0027:\u0027\u0027, \u0027messageID\u0027:\u0027FailureReason\u0027})\n\treturn resp",
            "type": "script"
          }
        ],
        "type": "property"
      },
      "persistent": true
    },
    "custom.pageToShow": {
      "binding": {
        "config": {
          "path": "view.custom.selection"
        },
        "enabled": false,
        "transforms": [
          {
            "expression": "if(len({value}),(len({value}) - len(replace({value}, \"/\", \"\"))),\"\")",
            "type": "expression"
          },
          {
            "fallback": "",
            "inputType": "scalar",
            "mappings": [
              {
                "input": 0,
                "output": "Plant"
              },
              {
                "input": 1,
                "output": "Equipment"
              },
              {
                "input": 2,
                "output": "Asset"
              }
            ],
            "outputType": "scalar",
            "type": "map"
          }
        ],
        "type": "property"
      },
      "persistent": true
    },
    "custom.rerunMode": {
      "binding": {
        "config": {
          "bidirectional": true,
          "path": "session.custom.rerun"
        },
        "type": "property"
      },
      "persistent": true
    },
    "custom.selectedData": {
