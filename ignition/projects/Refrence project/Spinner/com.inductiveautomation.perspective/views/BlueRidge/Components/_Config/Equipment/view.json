  "propConfig": {
    "custom.HMIs": {
      "persistent": true
    },
    "custom.availableEngines": {
      "binding": {
        "config": {
          "struct": {
            "key": "{view.params.key}",
            "triggerRefresh": "{view.custom.triggerRefresh}"
          },
          "waitOnAll": true
        },
        "transforms": [
          {
            "code": "\tequipmentUUID \u003d value[\u0027key\u0027]\n\tresp \u003d BlueRidge.Config.Util.getAvailableEngines(equipmentUUID)\n\treturn resp",
            "type": "script"
          }
        ],
        "type": "expr-struct"
      },
      "persistent": true
    },
    "custom.filenameValid": {
      "binding": {
        "config": {
          "path": "view.custom.instance.filename"
        },
        "transforms": [
          {
            "code": "\tif value:\n\t\textentionTypeUUID \u003d self.custom.instance.extension\n\t\tformat \u003d BlueRidge.Config.ExtensionType.getOne(extentionTypeUUID).get(\u0027format\u0027)\n\t\t#parce format string and match against value\n\t\tresp \u003d value.split(\u0027.\u0027)[0].isdigit()\n\telse:\n\t\tresp \u003d False\n\treturn resp",
            "type": "script"
          }
        ],
        "type": "property"
      },
      "persistent": true
    },
    "custom.instance": {
      "binding": {
        "config": {
          "expression": "runScript(\u0027BlueRidge.Config.Equipment.getOne\u0027,0,{view.params.key})"
        },
        "type": "expr"
      },
      "onChange": {
        "enabled": false,
        "script": "\tif origin \u003d\u003d \u0027BindingWriteback\u0027:\n\t\tdata \u003d self.custom.instance\n\t\tdata \u003d BlueRidge.Config.Util.convertWrapperObjectToJson(data)\n\t\tdata[\u0027user\u0027]\u003dself.session.props.auth.user.userName\n\t\tresp \u003d BlueRidge.Config.Equipment.update(data)\n\t\tif resp \u003d\u003d -1:\n\t\t\tsystem.perspective.sendMessage(\"refreshTrigger\")"
      },
      "persistent": true
    },
    "custom.instance.filename": {
      "onChange": {
        "enabled": null,
        "script": "\textensionTypeUUID \u003d self.custom.instance.extension\n\textentionType \u003d BlueRidge.Config.ExtensionType.getOne(extensionTypeUUID)\n\textentionTypeExtension \u003d extentionType.get(\u0027extension\u0027)\n\tif extentionTypeExtension not in currentValue.value:\n\t\tself.custom.instance.filename \u003d currentValue.value + extentionTypeExtension"
      }
    },
    "custom.instances": {
      "binding": {
        "config": {
          "struct": {
            "key": "{view.params.key}",
            "triggerRefresh": "{view.custom.triggerRefresh}"
          },
          "waitOnAll": true
        },
        "transforms": [
          {
            "code": "\tif value[\u0027key\u0027] !\u003d 0:\n\t\tresp \u003d BlueRidge.Config.EquipmentEngine.getAll(value[\u0027key\u0027])\n\t\tresp.sort(key\u003dlambda x: x[\u0027text\u0027])\n\telse:\n\t\tresp \u003d \"\"\n\treturn resp",
            "type": "script"
          }
        ],
        "type": "expr-struct"
      },
      "persistent": true
    },
    "custom.selectedData": {
      "persistent": true
    },
    "custom.triggerRefresh": {
      "persistent": true
    },
    "params.key": {
      "paramDirection": "input",
      "persistent": true
    }
  },
