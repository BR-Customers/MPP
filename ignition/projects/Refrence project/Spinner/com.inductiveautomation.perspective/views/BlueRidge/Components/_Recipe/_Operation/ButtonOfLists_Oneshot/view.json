{
  "custom": {},
  "params": {
    "messageType": "",
    "text": "Button",
    "type": "",
    "value": 0,
    "view": "value"
  },
  "propConfig": {
    "params.messageType": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.text": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.type": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.value": {
      "onChange": {
        "enabled": null,
        "script": "\tvalue \u003d currentValue.value\n\tview \u003d self.params.view\n\tmessageType \u003d self.params.messageType\n\tif value \u003d\u003d view:\n#\t\tsystem.perspective.print(\"value:{0},view:{1}\".format(value,view))\n\t\tsystem.perspective.sendMessage(messageType, value)\n\t\t"
      },
      "paramDirection": "inout",
      "persistent": true
    },
    "params.view": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 34,
      "width": 300
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "OneShotButton"
        },
        "position": {
          "basis": "34px"
        },
        "propConfig": {
          "props.readyState.text": {
            "binding": {
              "config": {
                "expression": "if(len({view.params.type})\u003e0,{view.params.text}+\": \"+{view.params.type},{view.params.text})"
              },
              "type": "expr"
            }
          },
          "props.setValue": {
            "binding": {
              "config": {
                "path": "view.params.view"
              },
              "type": "property"
            }
          },
          "props.value": {
            "binding": {
              "config": {
                "bidirectional": true,
                "path": "view.params.value"
              },
              "type": "property"
            }
          },
          "props.writingState.text": {
            "binding": {
              "config": {
                "expression": "if(len({view.params.type})\u003e0,{view.params.text}+\": \"+{view.params.type},{view.params.text})"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "readyState": {
            "icon": {
              "style": {
                "height": "24px",
                "width": "2rem"
              }
            }
          },
          "writingState": {
            "icon": {
              "style": {
                "height": "24px",
                "width": "2rem"
              }
            },
            "style": {
              "backgroundColor": "#28C33B"
            }
          }
        },
        "type": "ia.input.oneshotbutton"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column"
    },
    "scripts": {
      "customMethods": [],
      "extensionFunctions": null,
      "messageHandlers": [
        {
          "messageType": "OneShotButton",
          "pageScope": true,
          "script": "#\tsystem.perspective.print(\"OneShotButton Message Handler: {}\".format(payload))\n\tview \u003d self.view.params.view\n#\tsystem.perspective.print(\"OneShotButton Message Handler: {}\".format(view))\n\tif payload !\u003d view:\n\t\tself.view.params.value \u003d payload\n#\t\tsystem.perspective.print(\"OneShotButton Message Handler: {}\".format(\"Updating value\"))",
          "sessionScope": false,
          "viewScope": false
        }
      ]
    },
    "type": "ia.container.flex"
  }
}