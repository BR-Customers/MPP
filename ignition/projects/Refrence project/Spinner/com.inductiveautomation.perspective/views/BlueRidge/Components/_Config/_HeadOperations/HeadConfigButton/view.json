    },
    "props": {
      "direction": "column"
    },
    "scripts": {
      "customMethods": [],
      "extensionFunctions": null,
      "messageHandlers": [
        {
          "messageType": "HeadConfigButton",
          "pageScope": true,
          "script": "\tif payload[\u0027view\u0027] !\u003d self.view.params.view:\n\t\tself.view.custom.writing \u003d False\n\telse:\n\t\tself.view.custom.writing \u003d True",
