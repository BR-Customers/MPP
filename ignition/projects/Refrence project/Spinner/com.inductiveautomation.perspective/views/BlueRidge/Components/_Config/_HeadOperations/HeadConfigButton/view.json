{
  "custom": {
    "writing": false
  },
  "params": {
    "text": 834510,
    "view": "value"
  },
  "propConfig": {
    "custom.writing": {
      "persistent": true
    },
    "params.text": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.view": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 38,
      "width": 199
    }
  },
  "root": {
    "children": [
      {
        "events": {
          "component": {
            "onActionPerformed": {
