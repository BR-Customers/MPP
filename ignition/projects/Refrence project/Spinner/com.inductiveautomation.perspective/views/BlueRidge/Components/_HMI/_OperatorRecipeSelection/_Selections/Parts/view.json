  "propConfig": {
    "custom.headGroups": {
      "binding": {
        "config": {
          "expression": "runScript(\u0027BlueRidge.Config.HeadConfig.getHeads\u0027,0)"
        },
        "transforms": [
          {
            "code": "\theadGroups \u003d []\n\tfor group in value:\n\t\tname \u003d group[\u0027name\u0027]\n\t\theads \u003d BlueRidge.Config.HeadConfig.getHeadConfigs(group[\u0027headUUID\u0027])\n\t\theadGroups.append({\u0027partType\u0027: name, \u0027options\u0027: heads})\n\treturn headGroups",
            "type": "script"
          }
        ],
        "type": "expr"
      },
      "persistent": true
    },
    "custom.operation": {
      "binding": {
        "config": {
          "parameters": {
            "head": "{session.custom.hMISelections.selectedPart}"
          },
          "queryPath": "recipe/getOperationsByHead",
          "returnFormat": "json"
        },
        "overlayOptOut": true,
        "transforms": [
          {
            "code": "\ttry:\n\t\tif(value[0][\u0027headOperationUUID\u0027] not in self.session.custom.hMISelections.selectedOperation):\n\t\t\tself.session.custom.hMISelections.selectedOperation.append(value[0][\u0027headOperationUUID\u0027])\n\texcept:\n\t\tpass\n\treturn value",
            "type": "script"
          }
        ],
        "type": "query"
      },
      "persistent": true
    },
    "custom.selectedPart": {
      "binding": {
        "config": {
          "path": "session.custom.hMISelections.selectedPart"
        },
        "transforms": [
          {
            "code": "\treturn BlueRidge.Config.HeadConfig.getOneHeadConfig(value)[0][\u0027name\u0027] if value !\u003d \u0027\u0027 else \u0027None\u0027",
            "type": "script"
          }
        ],
        "type": "property"
      },
      "persistent": true
    },
    "params.Parts": {
      "paramDirection": "input",
      "persistent": true
    }
  },
