{
  "custom": {
    "engineFilter": "",
    "typeFilter": ""
  },
  "params": {},
  "propConfig": {
    "custom.engineFilter": {
      "persistent": true
    },
    "custom.typeFilter": {
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 300,
      "width": 400
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "meta": {
              "name": "Label_0"
            },
            "position": {
              "basis": "50px"
            },
            "props": {
              "style": {
                "classes": "BlueRidge/boldTitleSmall"
              },
              "text": "Filter on type or engine: "
            },
            "type": "ia.display.label"
          },
          {
            "children": [
              {
                "meta": {
                  "name": "Label_0"
                },
                "position": {
                  "basis": "50px"
                },
                "props": {
                  "style": {
                    "classes": "BlueRidge/boldTitleSmall"
                  },
                  "text": "Type: "
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "Dropdown"
                },
                "position": {
                  "basis": "200px"
                },
                "propConfig": {
                  "props.options": {
                    "binding": {
                      "config": {
                        "expression": "runScript(\u0027BlueRidge.Recipe.Util.getOperationTypes\u0027,0)"
                      },
                      "type": "expr"
                    }
                  },
                  "props.value": {
                    "binding": {
                      "config": {
                        "bidirectional": true,
                        "path": "view.custom.typeFilter"
                      },
                      "type": "property"
                    }
                  }
                },
                "type": "ia.input.dropdown"
              }
            ],
            "meta": {
              "name": "FlexContainer"
            },
            "position": {
              "basis": "36px"
            },
            "props": {
              "justify": "center"
            },
            "type": "ia.container.flex"
          },
          {
            "children": [
              {
                "meta": {
                  "name": "Label_0"
                },
                "position": {
                  "basis": "50px"
                },
                "props": {
                  "style": {
                    "classes": "BlueRidge/boldTitleSmall"
                  },
                  "text": "Engine: "
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "Dropdown"
                },
                "position": {
                  "basis": "200px"
                },
                "propConfig": {
                  "props.options": {
                    "binding": {
                      "config": {
                        "expression": "runScript(\u0027BlueRidge.Recipe.Util.getOperationEngines\u0027,0)"
                      },
                      "type": "expr"
                    }
                  },
                  "props.value": {
                    "binding": {
                      "config": {
                        "bidirectional": true,
                        "path": "view.custom.engineFilter"
                      },
                      "type": "property"
                    }
                  }
                },
                "type": "ia.input.dropdown"
              }
            ],
            "meta": {
              "name": "FlexContainer_0"
            },
            "position": {
              "basis": "36px"
            },
            "props": {
              "justify": "center",
              "style": {
                "marginTop": 5
              }
            },
            "type": "ia.container.flex"
          },
          {
            "meta": {
              "name": "Label"
            },
            "position": {
              "basis": "50px",
              "grow": 1
            },
            "props": {
              "text": "Are you sure?",
              "textStyle": {
                "classes": "BlueRidge/boldTitleLarge"
              }
            },
            "type": "ia.display.label"
          }
        ],
        "meta": {
          "name": "Top"
        },
        "position": {
          "basis": "200px",
          "grow": 1
        },
        "props": {
          "direction": "column",
          "justify": "center"
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "events": {
              "component": {
                "onActionPerformed": {
                  "config": {
                    "draggable": true,
                    "id": "Filter",
                    "modal": false,
                    "overlayDismiss": false,
                    "resizable": true,
                    "showCloseIcon": true,
                    "type": "close",
                    "viewPath": "BlueRidge/Components/_Recipe/Popups/Filter",
                    "viewportBound": false
                  },
                  "scope": "C",
                  "type": "popup"
                }
              }
            },
            "meta": {
              "name": "CancelButton"
            },
            "position": {
              "basis": "100px"
            },
            "props": {
              "style": {
                "classes": "BlueRidge/Components/dangerButtonRound"
              },
              "text": "Cancel"
            },
            "type": "ia.input.button"
          },
          {
            "events": {
              "component": {
                "onActionPerformed": {
                  "config": {
                    "script": "\ttypeFilter \u003d self.view.custom.typeFilter\n\tengineFilter \u003d self.view.custom.engineFilter\n\tif typeFilter or engineFilter:\n\t\tdata \u003d {\u0027typeFilter\u0027:typeFilter,\u0027engineFilter\u0027:engineFilter}\n\telse:\n\t\tdata \u003d \u0027\u0027\n\tsystem.perspective.sendMessage(\"filterUpdate\",data)\n\t\n\tsystem.perspective.closePopup(\u0027Filter\u0027)\n\t"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "YesButton"
            },
            "position": {
              "basis": "100px"
            },
            "props": {
              "style": {
                "classes": "BlueRidge/Components/actionButtonRound"
              },
              "text": "Yes"
            },
            "type": "ia.input.button"
          }
        ],
        "meta": {
          "name": "Middle"
        },
        "position": {
          "basis": "34px"
        },
        "props": {
          "justify": "space-evenly"
        },
        "type": "ia.container.flex"
      },
      {
        "meta": {
          "name": "Bottom"
        },
        "position": {
          "basis": "100px"
        },
        "type": "ia.container.flex"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column"
    },
    "type": "ia.container.flex"
  }
}