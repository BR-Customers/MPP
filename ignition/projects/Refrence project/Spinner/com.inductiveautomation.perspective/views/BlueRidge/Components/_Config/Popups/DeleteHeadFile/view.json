{
  "custom": {},
  "params": {
    "data": "value",
    "fileInUse": [],
    "script": "value"
  },
  "propConfig": {
    "params.data": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.fileInUse": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.script": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 300,
      "width": 400
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "meta": {
              "name": "Label_0"
            },
            "position": {
              "basis": "50px",
              "display": false
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "path": "view.params.data"
                  },
                  "transforms": [
                    {
                      "expression": "\"Item to be archived: \"+{value}",
                      "type": "expression"
                    }
                  ],
                  "type": "property"
                }
              }
            },
            "props": {
              "style": {
                "classes": "BlueRidge/boldTitleSmall"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "Label"
            },
            "position": {
              "basis": "50px",
              "grow": 1
            },
            "props": {
              "text": "Are you sure?",
              "textStyle": {
                "classes": "BlueRidge/boldTitleLarge"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "Label_1"
            },
            "position": {
              "basis": "30px",
              "display": false,
              "grow": 1
            },
            "propConfig": {
              "position.display": {
                "binding": {
                  "config": {
                    "path": "view.params.fileInUse"
                  },
                  "transforms": [
                    {
                      "code": "\treturn value !\u003d []",
                      "type": "script"
                    }
                  ],
                  "type": "property"
                },
                "persistent": true
              },
              "props.text": {
                "binding": {
                  "config": {
                    "path": "view.params.fileInUse"
                  },
                  "transforms": [
                    {
                      "code": "\toriginalMessage \u003d \"Warning: This file is used in these configurations: \"\n\t\n\tfor item in value:\n\t\toriginalMessage \u003d originalMessage + str(item[\u0027name\u0027]) + \", \"\n\treturn originalMessage[:-2]",
                      "type": "script"
                    }
                  ],
                  "type": "property"
                }
              }
            },
            "props": {
              "alignVertical": "top",
              "textStyle": {
                "classes": "BlueRidge/boldTitleLarge",
                "fontSize": 16
              }
            },
            "type": "ia.display.label"
          }
        ],
        "meta": {
          "name": "Top"
        },
        "position": {
          "basis": "200px",
          "grow": 1
        },
        "props": {
          "direction": "column",
          "justify": "center"
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "events": {
              "component": {
                "onActionPerformed": {
                  "config": {
                    "draggable": true,
                    "id": "deleteHeadFile",
                    "modal": false,
                    "overlayDismiss": false,
                    "resizable": true,
                    "showCloseIcon": true,
                    "type": "close",
                    "viewPath": "BlueRidge/Components/_Config/Popups/DeleteHeadFile",
                    "viewportBound": false
                  },
                  "scope": "C",
                  "type": "popup"
                }
              }
            },
            "meta": {
              "name": "CancelButton"
            },
            "position": {
              "basis": "100px"
            },
            "props": {
              "style": {
                "classes": "BlueRidge/Components/dangerButtonRound"
              },
              "text": "Cancel"
            },
            "type": "ia.input.button"
          },
          {
            "events": {
              "component": {
                "onActionPerformed": {
                  "config": {
                    "script": "\tBlueRidge.Config.HeadConfig.deleteHeadFile(self.view.params.data)\n\tsystem.perspective.sendMessage(\"refreshTrigger\")\n\tsystem.perspective.closePopup(\"deleteHeadFile\", None, self.page.props.pageId)"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "YesButton"
            },
            "position": {
              "basis": "100px"
            },
            "props": {
              "style": {
                "classes": "BlueRidge/Components/actionButtonRound"
              },
              "text": "Yes"
            },
            "type": "ia.input.button"
          }
        ],
        "meta": {
          "name": "Middle"
        },
        "position": {
          "basis": "34px"
        },
        "props": {
          "justify": "space-evenly"
        },
        "type": "ia.container.flex"
      },
      {
        "meta": {
          "name": "Bottom"
        },
        "position": {
          "basis": "100px"
        },
        "type": "ia.container.flex"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column"
    },
    "type": "ia.container.flex"
  }
}