        "type": "property"
      },
      "persistent": true
    },
    "custom.reason": {
      "onChange": {
        "enabled": false,
        "script": "\tif origin \u003d\u003d \u0027BindingWriteback\u0027:\n\t\tdata \u003d self.custom.reason\n\t\tif data:\n\t\t\tdata \u003d BlueRidge.Config.Util.convertWrapperObjectToJson(data)\n#\t\t\tsystem.perspective.print(\u0027Running Change Script1 {}\u0027.format(data))\n\t\t\tdata \u003d data[0]\n#\t\t\tsystem.perspective.print(\u0027Running Change Script2 {}\u0027.format(data))\n\t\t\tdata[\u0027user\u0027]\u003dself.session.props.auth.user.userName\n#\t\t\tsystem.perspective.print(\u0027Running Change Script3 {}\u0027.format(data))\n\t#\t\tsystem.perspective.print(data)\n\t\t\tresp \u003d BlueRidge.Config.FailureReason.update(data)\n\t\t\tif resp \u003d\u003d -1:\n#\t\t\t\tsystem.perspective.sendMessage(\"refreshTrigger\")\n\t\t\t\tpass"
      },
      "persistent": true
    },
