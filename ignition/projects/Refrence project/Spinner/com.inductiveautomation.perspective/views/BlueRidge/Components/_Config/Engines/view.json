      "binding": {
        "config": {
          "path": "view.custom.triggerRefresh"
        },
        "transforms": [
          {
            "expression": "runScript(\u0027BlueRidge.Config.Engine.getAll\u0027,0)",
            "type": "expression"
          },
          {
            "code": "\tvalue.sort(key\u003dlambda x: x[\u0027text\u0027])\n\treturn value",
