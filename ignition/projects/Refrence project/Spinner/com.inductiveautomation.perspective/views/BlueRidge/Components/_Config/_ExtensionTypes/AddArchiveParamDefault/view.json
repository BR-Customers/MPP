{
  "custom": {},
  "params": {
    "data": {
      "extensionTypeUUID": null,
      "operationTypeUUID": null,
      "paramDefault": null
    },
    "script": ""
  },
  "propConfig": {
    "params.data": {
      "binding": {
        "config": {
          "struct": {
            "extensionTypeUUID": "{view.custom.selectedData}",
            "operationTypeUUID": "{view.custom.selectedOperationType.key}",
            "paramDefault": "{view.custom.paramDefault}"
          },
          "waitOnAll": true
        },
        "transforms": [
          {
            "code": "#\tdata \u003d {}\n##\tif len(value[\u0027paramDefault\u0027])\u003e0: #archive\n##\t\tdata \u003d value[\u0027paramDefault\u0027][0]\n###\t\tdata \u003d system.util.jsonEncode(data)\n##\telse: #add\n##\t\tdata[\u0027extensionTypeUUID\u0027]\u003dvalue[\u0027extensionTypeUUID\u0027]\n##\t\tdata[\u0027operationTypeUUID\u0027]\u003dvalue[\u0027operationTypeUUID\u0027]\n#\tdata \u003d value[\u0027paramDefault\u0027][0]\n#\tdata[\u0027extensionTypeUUID\u0027]\u003dvalue[\u0027extensionTypeUUID\u0027]\n#\tdata[\u0027operationTypeUUID\u0027]\u003dvalue[\u0027operationTypeUUID\u0027]\n\treturn value",
            "type": "script"
          }
        ],
        "type": "expr-struct"
      },
      "paramDirection": "input",
      "persistent": true
    },
    "params.script": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 35,
      "width": 300
    }
  },
  "root": {
    "children": [
      {
        "events": {
          "component": {
            "onActionPerformed": [
              {
                "config": {
                  "draggable": true,
                  "id": "AddParameterDefault",
                  "modal": false,
                  "overlayDismiss": false,
                  "resizable": true,
                  "showCloseIcon": true,
                  "type": "open",
                  "viewParams": {
                    "data": "{view.params.data}",
                    "script": "{view.params.script}"
                  },
                  "viewPath": "BlueRidge/Components/_Config/Popups/AddParameterDefault",
                  "viewportBound": false
                },
                "scope": "C",
                "type": "popup"
              },
              {
                "config": {
                  "script": "\tscript \u003d self.view.params.script.replace(\u0027/\u0027,\u0027.\u0027)\n\tdata \u003d self.view.params.data\n\tfunction \u003d \u0027add\u0027\n#\tsystem.perspective.print(script+\u0027.{0}({1})\u0027.format(function,data))\n\teval(script+\".{0}(\u0027{1}\u0027)\".format(function,data))\n\tsystem.perspective.sendMessage(\"refreshTrigger\")"
                },
                "enabled": false,
                "scope": "G",
                "type": "script"
              }
            ]
          }
        },
        "meta": {
          "name": "AddButton"
        },
        "position": {
          "basis": "100px"
        },
        "props": {
          "style": {
            "classes": "BlueRidge/Components/actionButtonRound"
          },
          "text": "Add"
        },
        "type": "ia.input.button"
      },
      {
        "events": {
          "component": {
            "onActionPerformed": [
              {
                "config": {
                  "draggable": true,
                  "id": "DeleteParameterDefault",
                  "modal": false,
                  "overlayDismiss": false,
                  "resizable": true,
                  "showCloseIcon": true,
                  "title": "Archive",
                  "type": "open",
                  "viewParams": {
                    "data": "{view.params.data.paramDefault}",
                    "script": "{view.params.script}"
                  },
                  "viewPath": "BlueRidge/Components/_Config/Popups/DeleteParameterDefault",
                  "viewportBound": false
                },
                "scope": "C",
                "type": "popup"
              },
              {
                "config": {
                  "script": "\tscript \u003d self.view.params.script.replace(\u0027/\u0027,\u0027.\u0027)\n\tdata \u003d self.view.params.data\n\tfunction \u003d \u0027archive\u0027\n#\tsystem.perspective.print(script+\u0027.{0}({1})\u0027.format(function,data))\n\teval(script+\".{0}(\u0027{1}\u0027)\".format(function,data))\n\tsystem.perspective.sendMessage(\"refreshTrigger\")"
                },
                "enabled": false,
                "scope": "G",
                "type": "script"
              }
            ]
          }
        },
        "meta": {
          "name": "ArchiveButton"
        },
        "position": {
          "basis": "100px"
        },
        "props": {
          "style": {
            "classes": "BlueRidge/Components/dangerButtonRound"
          },
          "text": "Archive"
        },
        "type": "ia.input.button"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "alignItems": "center",
      "justify": "space-evenly",
      "style": {
        "paddingLeft": 10,
        "paddingRight": 10
      }
    },
    "type": "ia.container.flex"
  }
}