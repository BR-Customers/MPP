  "propConfig": {
    "custom.dropdownOptions": {
      "binding": {
        "config": {
          "path": "view.params.data"
        },
        "transforms": [
          {
            "code": "\toptions \u003d [{\u0027value\u0027:i[\u0027key\u0027],\u0027label\u0027:i[\u0027text\u0027]} for i in value]\n#\t[{\u0027value\u0027:value,\u0027label\u0027:label}]\n\treturn options",
            "type": "script"
          }
        ],
        "type": "property"
      },
      "persistent": true
    },
    "custom.selectedData": {
      "persistent": true
    },
    "custom.type": {
      "binding": {
        "config": {
          "path": "view.params.script"
        },
        "transforms": [
          {
            "expression": "right({value},len({value}) - max(lastIndexOf({value}, \".\"),lastIndexOf({value}, \"/\")) - 1)",
            "type": "expression"
          }
        ],
        "type": "property"
      },
      "persistent": true
    },
    "params.data": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.script": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 300,
      "width": 400
    }
  },
