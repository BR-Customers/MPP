          "messageType": "handleSelection",
          "pageScope": true,
          "script": "\tselections \u003d self.view.custom.Selections\n\ttry:\n\t\tidx \u003d selections.index(payload[\u0027index\u0027])\n\t\tselections.pop(idx)\n\texcept ValueError:\n\t\tif self.view.params.MultiSelect:\n\t\t\tselections.append(payload[\u0027index\u0027])\n\t\telse:\n\t\t\tself.view.custom.Selections \u003d [payload[\u0027index\u0027]]",
          "sessionScope": false,
          "viewScope": true
        }
      ]
